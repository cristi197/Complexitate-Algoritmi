---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer class="site-footer" id="about" role="contentinfo">
  <div class="footer-inner">

    <div class="footer-brand">
      <strong>💻 InfoLiceu</strong>
      <span class="footer-tagline">Resurse gratuite pentru BAC Informatică România · C++ · M-I</span>
    </div>

    <nav class="footer-links" aria-label="Linkuri footer">
      <a href={`${base}/`}>Acasă</a>
      <a href={`${base}/capitole/introducere`}>Capitole</a>
      <a href={`${base}/exercitii`}>Exerciții</a>
      <a href={`${base}/analiza-bac`}>Analiză BAC AI</a>
      <a href={`${base}/examen-alb`}>Examen Alb</a>
      <a href={`${base}/editor`}>Editor C++</a>
      <a href={`${base}/cheat-sheet`}>Cheat Sheet</a>
      <a
        href="https://github.com/cristi197/Complexitate-Algoritmi"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Cod sursă pe GitHub (se deschide într-o fereastră nouă)"
      >GitHub ↗</a>
    </nav>

    <div class="footer-meta">
      <span>© {year} InfoLiceu</span>
      <span aria-hidden="true">·</span>
      <span>Conținut educațional sub licență <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener noreferrer">MIT</a></span>
      <span aria-hidden="true">·</span>
      <span>Profil Matematică-Informatică · România</span>
    </div>

  </div>
</footer>

<style>
.site-footer {
  margin-top: 4rem;
  border-top: 1px solid var(--border);
  background: var(--surface2);
  padding: 2.5rem 1.5rem 1.5rem;
}
.footer-inner {
  max-width: 900px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  align-items: center;
  text-align: center;
}
.footer-brand {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.footer-brand strong {
  font-size: 1.1rem;
  color: var(--primary);
}
.footer-tagline {
  font-size: 0.82rem;
  color: var(--text-muted);
}
.footer-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem 1rem;
  justify-content: center;
}
.footer-links a {
  font-size: 0.88rem;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.18s;
}
.footer-links a:hover,
.footer-links a:focus-visible {
  color: var(--primary);
  text-decoration: underline;
}
.footer-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
  font-size: 0.78rem;
  color: var(--text-faint);
}
.footer-meta a {
  color: var(--text-faint);
  text-decoration: underline;
}
.footer-meta a:hover { color: var(--text-muted); }
@media (max-width: 600px) {
  .footer-links { gap: 0.5rem; }
}
</style>
