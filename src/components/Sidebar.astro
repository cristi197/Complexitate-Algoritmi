---
interface Props {
  activeChapter?: number;
}

const { activeChapter = -1 } = Astro.props;
const base = import.meta.env.BASE_URL;

// color maps to one of the semantic CSS variables
const chapters = [
  { num: 0, file: 'introducere',    title: 'Introducere în Informatică', icon: '🖥️',  colorVar: 'blue'   },
  { num: 8, file: 'functii',         title: 'Funcții și Subprograme',     icon: '⚙️',  colorVar: 'blue'   },
  { num: 1, file: 'complexitate',   title: 'Eficiența Algoritmilor',     icon: '📊',  colorVar: 'teal'   },
  { num: 2, file: 'recursivitate',  title: 'Recursivitate',              icon: '🔄',  colorVar: 'green'  },
  { num: 3, file: 'backtracking',   title: 'Backtracking',               icon: '🌳',  colorVar: 'purple' },
  { num: 4, file: 'vectori',        title: 'Vectori',                    icon: '📦',  colorVar: 'orange' },
  { num: 5, file: 'matrici',        title: 'Matrici',                    icon: '🔲',  colorVar: 'teal'   },
  { num: 6, file: 'siruri',         title: 'Șiruri de Caractere',        icon: '🔤',  colorVar: 'red'    },
  { num: 7, file: 'fisiere',        title: 'Fișiere',                    icon: '📁',  colorVar: 'pink'   },
];
---
<nav class="sidebar" id="sidebar" aria-label="Navigare capitole">

  <!-- XP Bar -->
  <div class="sidebar-xp">
    <div class="xp-label">
      <span class="xp-label-text">⚡ Progres</span>
      <span class="xp-value-text"><span id="xp-value">0</span> XP</span>
    </div>
    <div class="xp-bar" role="progressbar" aria-label="XP" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
      <div class="xp-fill" id="xp-fill"></div>
    </div>
    <div class="xp-level" id="xp-level">Nivel 1</div>
  </div>

  <!-- Chapter Navigation -->
  <div class="sidebar-nav">
    <div class="sidebar-section-label">Capitole</div>

    {chapters.map(ch => (
      <a
        href={`${base}/capitole/${ch.file}`}
        class:list={['sidebar-link', activeChapter === ch.num && 'active']}
        data-chapter={ch.num}
        aria-current={activeChapter === ch.num ? 'page' : undefined}
      >
        <span class:list={['ch-icon', `ch-icon-${ch.colorVar}`]} aria-hidden="true">
          {ch.icon}
        </span>
        <span class="ch-title">{ch.title}</span>
        <span class="sidebar-progress-dot" id={`dot-${ch.num}`} aria-hidden="true"></span>
      </a>
    ))}

    <div class="sidebar-section-label sidebar-section-label--tools">Instrumente</div>
    <a href={`${base}/analiza-bac`} class="sidebar-link sidebar-link--ai">
      <span class="ch-icon ch-icon--ai" aria-hidden="true">🤖</span>
      <span class="ch-title">Analiză BAC cu AI</span>
      <span class="sidebar-link-badge">AI</span>
    </a>
    <a href={`${base}/exercitii`} class="sidebar-link sidebar-link--exercises">
      <span class="ch-icon ch-icon--exercises" aria-hidden="true">📝</span>
      <span class="ch-title">Exerciții &amp; Filtrare</span>
      <span class="sidebar-link-badge sidebar-link-badge--new">NOU</span>
    </a>
    <a href={`${base}/greseli-bac`} class="sidebar-link sidebar-link--exercises">
      <span class="ch-icon ch-icon--exercises" aria-hidden="true">⚠️</span>
      <span class="ch-title">Greșeli frecvente BAC</span>
    </a>
    <a href={`${base}/cheat-sheet`} class="sidebar-link sidebar-link--exercises">
      <span class="ch-icon ch-icon--exercises" aria-hidden="true">📄</span>
      <span class="ch-title">Cheat Sheet printabil</span>
    </a>
  </div>
</nav>

<script is:inline>
(function() {
  var XP_KEY = 'infoXP';
  var CHAPTER_XP_KEY = 'infoChXP';
  var LEVELS = [0,100,250,500,900,1400,2000,3000,5000];
  var LEVEL_NAMES = ['Începător','Elev','Cunoscător','Avansat','Expert','Master','Campion','Legend','Profesional'];

  function initSidebarXP() {
    var xp = parseInt(localStorage.getItem(XP_KEY) || '0', 10);
    var lvl = 0;
    for (var i = 0; i < LEVELS.length; i++) { if (xp >= LEVELS[i]) lvl = i; }
    var nextXP = LEVELS[lvl+1] || LEVELS[LEVELS.length-1];
    var prevXP = LEVELS[lvl] || 0;
    var pct = Math.min(100, Math.round(((xp - prevXP) / Math.max(1, nextXP - prevXP)) * 100));

    var valEl  = document.getElementById('xp-value');
    var fillEl = document.getElementById('xp-fill');
    var lvlEl  = document.getElementById('xp-level');
    var xpBar  = document.querySelector('.xp-bar');
    if (valEl)  valEl.textContent  = xp;
    if (fillEl) fillEl.style.width = pct + '%';
    if (lvlEl)  lvlEl.textContent  = 'Nivel ' + (lvl+1) + ' — ' + (LEVEL_NAMES[lvl] || 'Pro');
    if (xpBar)  xpBar.setAttribute('aria-valuenow', pct);

    // Chapter dots
    try {
      var chData = JSON.parse(localStorage.getItem(CHAPTER_XP_KEY) || '{}');
      Object.keys(chData).forEach(function(ch) {
        if (chData[ch] > 0) {
          var dot = document.getElementById('dot-' + ch);
          if (dot) dot.classList.add('completed');
        }
      });
    } catch(e) {}
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebarXP);
  } else {
    initSidebarXP();
  }
})();
</script>

<style>
  /* Icon color variants using CSS variables — no inline styles needed */
  .ch-icon-blue   { background: var(--blue3);   color: var(--blue2); }
  .ch-icon-teal   { background: var(--teal2);   color: var(--teal); }
  .ch-icon-green  { background: var(--green2);  color: var(--green); }
  .ch-icon-purple { background: var(--purple2); color: var(--purple); }
  .ch-icon-orange { background: var(--orange2); color: var(--orange); }
  .ch-icon-red    { background: var(--red2);    color: var(--red); }
  .ch-icon-pink   { background: var(--pink2);   color: var(--pink); }
  .ch-icon--ai    { background: var(--primary-dim); color: var(--primary); }

  .sidebar-link--ai {
    color: var(--primary);
    font-weight: 700;
  }

  .ch-icon--exercises { background: rgba(16,185,129,.15); color: #10b981; }
  .sidebar-link--exercises { color: #10b981; font-weight: 700; }
  .sidebar-link-badge--new { background: rgba(16,185,129,.15); color: #10b981; border-color: rgba(16,185,129,.3); }

  .sidebar-section-label--tools { margin-top: 12px; }

  /* XP enhancements */
  .xp-value-text { font-size: 12px; font-weight: 700; color: var(--primary); }
  .xp-label-text { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .xp-level      { font-size: 10px; font-weight: 700; color: var(--text-faint); margin-top: 4px; text-align: right; }

  /* AI badge pill */
  .sidebar-link-badge {
    margin-left: auto;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--primary-dim);
    color: var(--primary);
    border: 1px solid rgba(99,102,241,0.2);
    flex-shrink: 0;
  }
</style>

<script is:inline>
  (function() {
    // Mark completed chapters
    for (var i = 0; i < 8; i++) {
      var done = localStorage.getItem('ch_done_' + i) === '1';
      var dot  = document.getElementById('dot-' + i);
      if (dot && done) dot.classList.add('done');
    }

    // XP system
    var xp     = parseInt(localStorage.getItem('xp') || '0');
    var xpGoal = 800;
    var level  = Math.floor(Math.sqrt(xp / 100)) + 1;
    var xpEl   = document.getElementById('xp-value');
    var xpFill = document.getElementById('xp-fill');
    var xpLvl  = document.getElementById('xp-level');
    var xpBar  = xpFill && xpFill.parentElement;

    if (xpEl)   xpEl.textContent   = xp;
    if (xpFill) xpFill.style.width = Math.min(100, Math.round(xp / xpGoal * 100)) + '%';
    if (xpLvl)  xpLvl.textContent  = 'Nivel ' + level;
    if (xpBar)  xpBar.setAttribute('aria-valuenow', Math.round(xp / xpGoal * 100));
  })();
</script>
