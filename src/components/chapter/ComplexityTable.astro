---
/**
 * ComplexityTable — render a Big-O complexity comparison table.
 * Pass `rows` as a JSON-serializable array.
 *
 * Each row: { name, best?, average, worst, space, notes? }
 */
interface ComplexityRow {
  name: string;
  best?: string;
  average: string;
  worst: string;
  space: string;
  notes?: string;
}

interface Props {
  rows: ComplexityRow[];
  caption?: string;
}

const CELL_CLASSES: Record<string, string> = {
  'O(1)':       'cx-great',
  'O(log n)':   'cx-good',
  'O(n)':       'cx-ok',
  'O(n log n)': 'cx-warn',
  'O(n²)':      'cx-bad',
  'O(2^n)':     'cx-worst',
  'O(n!)':      'cx-worst',
};

const { rows, caption } = Astro.props;

function cx(val?: string) {
  if (!val) return '';
  return CELL_CLASSES[val] ?? '';
}
---

<div class="cx-table-wrap">
  {caption && <p class="cx-caption">{caption}</p>}
  <div class="cx-table-scroll">
    <table class="cx-table" role="table">
      <thead>
        <tr>
          <th>Algoritm</th>
          {rows.some(r => r.best) && <th>Best</th>}
          <th>Average</th>
          <th>Worst</th>
          <th>Spațiu</th>
          {rows.some(r => r.notes) && <th>Note</th>}
        </tr>
      </thead>
      <tbody>
        {rows.map(row => (
          <tr>
            <td class="cx-name">{row.name}</td>
            {rows.some(r => r.best) && <td class={cx(row.best)}>{row.best ?? '—'}</td>}
            <td class={cx(row.average)}>{row.average}</td>
            <td class={cx(row.worst)}>{row.worst}</td>
            <td class={cx(row.space)}>{row.space}</td>
            {rows.some(r => r.notes) && <td class="cx-notes">{row.notes ?? ''}</td>}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <div class="cx-legend">
    <span class="cx-great">O(1)</span>
    <span class="cx-good">O(log n)</span>
    <span class="cx-ok">O(n)</span>
    <span class="cx-warn">O(n log n)</span>
    <span class="cx-bad">O(n²)</span>
    <span class="cx-worst">O(2ⁿ)+</span>
  </div>
</div>

<style>
  .cx-table-wrap { margin: 20px 0; }
  .cx-caption { font-size: 13px; color: var(--text-muted); margin-bottom: 8px; }

  .cx-table-scroll { overflow-x: auto; border-radius: var(--radius); border: 1px solid var(--border); }
  .cx-table {
    width: 100%; border-collapse: collapse;
    font-size: 13.5px; font-family: var(--mono);
  }
  .cx-table thead { background: var(--surface2); }
  .cx-table th {
    padding: 10px 14px; text-align: left;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }
  .cx-table td {
    padding: 9px 14px;
    border-bottom: 1px solid var(--border-faint);
    font-weight: 600;
  }
  .cx-table tbody tr:last-child td { border-bottom: none; }
  .cx-table tbody tr:hover { background: var(--surface2); }

  .cx-name  { color: var(--text); font-family: var(--font); font-size: 13px; }
  .cx-notes { font-family: var(--font); font-size: 12px; color: var(--text-muted); }

  /* Complexity colouring */
  .cx-great  { color: #16a34a; }
  .cx-good   { color: #0891b2; }
  .cx-ok     { color: #ca8a04; }
  .cx-warn   { color: #ea580c; }
  .cx-bad    { color: #dc2626; }
  .cx-worst  { color: #9f1239; font-weight: 800; }

  /* Legend */
  .cx-legend {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 10px 4px 0;
    font-size: 11px; font-weight: 700; font-family: var(--mono);
  }
  .cx-legend span {
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--surface2);
    border: 1px solid var(--border);
  }
</style>
