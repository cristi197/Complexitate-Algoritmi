---
/**
 * Card — glass-morphism container.
 *
 * variant: 'default' | 'glass' | 'neon'
 * padding: 'none' | 'sm' | 'md' | 'lg'
 * hover:   true adds lift-on-hover effect
 */
interface Props {
  variant?: 'default' | 'glass' | 'neon';
  padding?: 'none' | 'sm' | 'md' | 'lg';
  hover?: boolean;
  class?: string;
  as?: string;
}

const {
  variant = 'default',
  padding = 'md',
  hover = false,
  class: cls = '',
  as: Tag = 'div',
} = Astro.props;
---

<Tag class:list={['card', `card-${variant}`, `card-p-${padding}`, hover && 'card-hover', cls]}>
  <slot />
</Tag>

<style>
  .card {
    border-radius: var(--radius);
    border: 1px solid var(--border);
    transition: all var(--transition);
  }

  /* Padding */
  .card-p-none { padding: 0; }
  .card-p-sm   { padding: 12px; }
  .card-p-md   { padding: 20px; }
  .card-p-lg   { padding: 32px; }

  /* Variants */
  .card-default {
    background: var(--surface);
    box-shadow: var(--shadow);
  }
  .card-glass {
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: rgba(255,255,255,0.08);
  }
  .card-neon {
    background: var(--surface);
    border-color: rgba(99,102,241,0.25);
    box-shadow: 0 0 0 1px rgba(99,102,241,0.1), var(--shadow);
  }

  /* Hover effect */
  .card-hover:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow2);
    border-color: var(--primary);
  }
  .card-hover { cursor: pointer; }
</style>
