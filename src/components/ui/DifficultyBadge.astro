---
/**
 * DifficultyBadge — coloured badge for problem difficulty.
 * level: 'usor' | 'mediu' | 'greu'
 */
interface Props {
  level: 'usor' | 'mediu' | 'greu';
  class?: string;
}

const LABELS = { usor: '🟢 Ușor', mediu: '🟡 Mediu', greu: '🔴 Greu' };
const { level, class: cls = '' } = Astro.props;
---
<span class:list={['diff-badge', `diff-${level}`, cls]}>
  {LABELS[level]}
</span>

<style>
  .diff-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.02em;
  }
  .diff-usor  { background: var(--green2);   color: var(--green);  }
  .diff-mediu { background: var(--orange2);  color: var(--orange); }
  .diff-greu  { background: var(--red2);     color: var(--red);    }
</style>
