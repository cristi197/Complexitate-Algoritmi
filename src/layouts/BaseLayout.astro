---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
}

const { title, description = 'Ghid complet de informatică pentru liceu și bacalaureat.', bodyClass = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Dark mode: apply before render to avoid flash -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      var pref   = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', stored || pref);
    })();
  </script>
</head>
<body class={bodyClass}>
  <div id="page-overlay"></div>
  <div id="scroll-progress" aria-hidden="true"></div>
  <slot />

  <script is:inline>
    // Scroll progress bar
    window.addEventListener('scroll', function() {
      var el = document.getElementById('scroll-progress');
      if (!el) return;
      var pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      el.style.transform = 'scaleX(' + Math.min(1, pct) + ')';
    }, { passive: true });
  </script>
</body>
</html>
