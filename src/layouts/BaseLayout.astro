---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
}

const {
  title,
  description = 'Ghid complet de informatică pentru liceu și bacalaureat. Algoritmi, complexitate, recursivitate, backtracking, vectori, matrici, șiruri, fișiere — cu animații interactive și quiz-uri BAC.',
  ogImage,
  bodyClass = '',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteOrigin = 'https://cristi197.github.io';
const siteBase   = `${siteOrigin}/Complexitate-Algoritmi`;
const canonicalURL = `${siteOrigin}${Astro.url.pathname}`;
const ogImageURL   = ogImage || `${siteBase}/og-default.png`;
const fullTitle    = title.includes('InfoLiceu') ? title : `${title} | InfoLiceu`;
---
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="InfoLiceu" />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:image"       content={ogImageURL} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"      content="ro_RO" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageURL} />

  <!-- Misc -->
  <meta name="robots" content="index, follow" />
  <meta name="author" content="InfoLiceu" />
  <meta name="theme-color" content="#6366f1" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Favicon & PWA manifest -->
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="manifest" href={`${base}/manifest.json`} />

  <!-- Dark mode: apply before render to avoid flash -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      var pref   = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', stored || pref);
    })();
  </script>
</head>
<body class={bodyClass}>
  <!-- Skip navigation for keyboard/screen-reader users (WCAG 2.1 SC 2.4.1) -->
  <a class="skip-link" href="#main-content">Sari la conținut</a>

  <div id="page-overlay"></div>
  <div id="scroll-progress" aria-hidden="true"></div>

  <!-- Search Modal (Ctrl+K) -->
  <div id="searchModal" class="search-modal" role="dialog" aria-modal="true" aria-label="Caută capitol">
    <div class="search-backdrop" onclick="closeSearch()"></div>
    <div class="search-dialog">
      <div class="search-header">
        <span class="search-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </span>
        <input id="searchInput" type="search" placeholder="Caută capitol, funcție, concept..." autocomplete="off" spellcheck="false" />
      </div>
      <ul id="searchResults" role="listbox"></ul>
      <div class="search-footer">
        <span>↑↓ navighează</span>
        <span>↵ deschide</span>
        <span>Ctrl+K pentru toggle</span>
        <span>Esc pentru închidere</span>
      </div>
    </div>
  </div>

  <!-- XP toast -->
  <div id="xp-toast" class="xp-toast" aria-live="polite" aria-atomic="true"></div>

  <slot />

  <script is:inline>
    // Expose base URL for search.js
    window.__BASE_URL = {JSON.stringify(base)};
  </script>
  <script is:inline>
    // Scroll progress bar
    window.addEventListener('scroll', function() {
      var el = document.getElementById('scroll-progress');
      if (!el) return;
      var pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      el.style.transform = 'scaleX(' + Math.min(1, pct) + ')';
    }, { passive: true });
  </script>
  <script is:inline src={`${base}/js/search.js`}></script>
  <script is:inline src={`${base}/js/progress.js`}></script>
</body>
</html>
