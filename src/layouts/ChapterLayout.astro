---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

interface Section {
  id: string;
  label: string;
}

interface Props {
  title: string;
  subtitle: string;
  icon: string;
  gradient: string;
  tags?: string[];
  sections?: Section[];
  chapterNum: number;
  description?: string;
}

const {
  title, subtitle, icon, gradient,
  tags = [], sections = [],
  chapterNum,
  description,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const readingTime = 12; // fallback; scripts will update dynamically

// Chapter order for prev/next navigation (sequential numbering)
const CHAPTER_ORDER = [
  { num: 0,  file: 'introducere',        title: 'Introducere în Informatică' },
  { num: 1,  file: 'functii',            title: 'Funcții și Subprograme' },
  { num: 2,  file: 'complexitate',       title: 'Eficiența Algoritmilor' },
  { num: 3,  file: 'recursivitate',      title: 'Recursivitate' },
  { num: 4,  file: 'backtracking',       title: 'Backtracking' },
  { num: 5,  file: 'vectori',            title: 'Vectori (1D)' },
  { num: 6,  file: 'matrici',            title: 'Matrici (2D)' },
  { num: 7,  file: 'siruri',             title: 'Șiruri de Caractere' },
  { num: 8,  file: 'fisiere',            title: 'Fișiere' },
  { num: 9,  file: 'programare-dinamica',title: 'Programare Dinamică' },
  { num: 10, file: 'structuri',          title: 'Structuri (struct)' },
  { num: 11, file: 'pointeri',           title: 'Pointeri & Alocare Dinamică' },
];
const currentIdx = CHAPTER_ORDER.findIndex(c => c.num === chapterNum);
const prevCh = currentIdx > 0 ? CHAPTER_ORDER[currentIdx - 1] : null;
const nextCh = currentIdx < CHAPTER_ORDER.length - 1 ? CHAPTER_ORDER[currentIdx + 1] : null;
---
<BaseLayout title={`${title} — Informatică Liceu`} description={description} bodyClass="has-sidebar">
  <Header />
  <Sidebar activeChapter={chapterNum} />

  <div class="app-shell">
    <div class="app-content">
      <!-- Chapter Hero -->
      <div class="chapter-hero" style={`--hero-gradient: ${gradient};`}>
        <!-- Breadcrumbs -->
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={`${base}/`}>Acasă</a>
          <span class="breadcrumbs-sep" aria-hidden="true">›</span>
          <span aria-current="page">{title}</span>
        </nav>
        <h1>{icon} {title}</h1>
        <p>{subtitle}</p>
        {tags.length > 0 && (
          <div class="chapter-hero-tags">
            {tags.map(t => <span class="chapter-hero-tag">{t}</span>)}
          </div>
        )}
        <div class="reading-badge" id="reading-badge">
          📖 <span id="reading-time">{readingTime}</span> min
        </div>
        <div class="page-stats">
          <button id="like-btn" class="like-btn" title="Îmi place!" aria-label="Like">
            <span class="like-icon">🤍</span>
            <span class="like-count">0</span>
          </button>
          <span class="view-counter" aria-label="Vizualizări">
            <span aria-hidden="true">👁</span>
            <span id="view-num">0</span>
          </span>
        </div>
      </div>

      <!-- Section sticky nav -->
      {sections.length > 0 && (
        <nav class="nav-bar" aria-label="Secțiuni capitol">
          {sections.map(s => (
            <a href={`#${s.id}`}>{s.label}</a>
          ))}
        </nav>
      )}

      <!-- Chapter content (injected by page) -->
      <div class="wrapper" id="main-content">
        <slot />

        <!-- Prev / Next chapter navigation -->
        {(prevCh || nextCh) && (
          <nav class="chapter-nav" aria-label="Capitol anterior / următor">
            {prevCh ? (
              <a href={`${base}/capitole/${prevCh.file}`} class="chapter-nav-btn prev">
                <span class="nav-arrow">←</span>
                <span>
                  <span class="nav-label">Capitol anterior</span>
                  <span class="nav-title">{prevCh.title}</span>
                </span>
              </a>
            ) : <span />}
            {nextCh ? (
              <a href={`${base}/capitole/${nextCh.file}`} class="chapter-nav-btn next">
                <span>
                  <span class="nav-label">Capitolul următor</span>
                  <span class="nav-title">{nextCh.title}</span>
                </span>
                <span class="nav-arrow">→</span>
              </a>
            ) : <span />}
          </nav>
        )}
      </div>
    </div>
  </div>
  <Footer />

  <!-- Scripts -->
  <script is:inline src={`${import.meta.env.BASE_URL}/js/animations.js`}></script>
  <script is:inline src={`${import.meta.env.BASE_URL}/js/quiz.js`}></script>
  <script is:inline src={`${import.meta.env.BASE_URL}/js/platform.js`}></script>
  <script is:inline src={`${import.meta.env.BASE_URL}/js/audiobook.js`}></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      initScrollReveal();
      initBarCharts();
      initTreeReveal();
      initCopyButtons();
      initNavHighlight();
      initSectionXP();
      initSectionReadingTime();
      initGlobalReadingTime();
      if (typeof initScrollProgress === 'function') initScrollProgress();
    });
  </script>
</BaseLayout>
