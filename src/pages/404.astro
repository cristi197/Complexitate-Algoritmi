---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="404 — Pagină negăsită | InfoLiceu">
  <main class="error-page">
    <div class="error-content">
      <div class="error-code gradient-text">404</div>
      <h1 class="error-title">Pagina nu a fost găsită</h1>
      <p class="error-desc">Se pare că această pagină nu există sau a fost mutată. Verifică URL-ul sau întoarce-te la pagina principală.</p>

      <div class="error-code-block">
        <pre><span style="color:#6b7280;">// C++ easter egg 🐞</span>
<span style="color:#c792ea;">int</span> <span style="color:#82aaff;">main</span>() &#123;
    <span style="color:#c792ea;">string</span> pagina = <span style="color:#c3e88d;">"pagina_cautata"</span>;
    <span style="color:#c792ea;">if</span> (pagina.<span style="color:#82aaff;">exists</span>() == <span style="color:#f78c6c;">false</span>) &#123;
        <span style="color:#89ddff;">cout</span> &lt;&lt; <span style="color:#c3e88d;">"Eroare 404: Nu am găsit nimic."</span>;
        <span style="color:#c792ea;">return</span> <span style="color:#f78c6c;">404</span>;
    &#125;
&#125;</pre>
      </div>

      <a href={`${base}/`} class="btn btn-primary" style="display:inline-flex;align-items:center;gap:8px;margin-top:8px;">
        ← Înapoi la pagina principală
      </a>
    </div>
  </main>

  <style>
    .error-page {
      min-height: 70vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .error-content {
      text-align: center;
      max-width: 560px;
    }
    .error-code {
      font-size: clamp(6rem, 20vw, 10rem);
      font-family: var(--font-display, 'Syne', sans-serif);
      font-weight: 800;
      line-height: 1;
      margin-bottom: 1rem;
    }
    .error-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
    }
    .error-desc {
      color: var(--color-muted);
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }
    .error-code-block {
      background: var(--color-surface, #161b22);
      border: 1px solid var(--color-border, rgba(255,255,255,0.08));
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      text-align: left;
      margin-bottom: 1.75rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.875rem;
      line-height: 1.7;
      overflow-x: auto;
    }
    .error-code-block pre {
      margin: 0;
      background: transparent;
      border: none;
      padding: 0;
    }
  </style>
</BaseLayout>
