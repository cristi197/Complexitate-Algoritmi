---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout
  title="Analiză Variantă BAC — InfoLiceu"
  description="Încarcă varianta ta de BAC la informatică și primești explicații detaliate pentru fiecare exercițiu, cu teoria necesară și linkuri spre capitolele relevante."
>
  <style>
    .upload-zone {
      border: 2.5px dashed var(--primary);
      border-radius: var(--radius);
      background: var(--surface-2);
      padding: 48px 32px;
      text-align: center;
      cursor: pointer;
      transition: background var(--transition), border-color var(--transition);
      position: relative;
    }
    .upload-zone:hover, .upload-zone.drag-over {
      background: var(--surface);
      border-color: var(--primary-light);
    }
    .upload-zone input[type="file"] {
      position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
    }
    .upload-icon { font-size: 3rem; margin-bottom: 12px; display: block; }
    .upload-zone h3 { font-size: 1.15rem; font-weight: 700; color: var(--primary); margin-bottom: 6px; }
    .upload-zone p  { color: var(--text-2); font-size: 0.9rem; }
    .upload-zone .file-types { display: inline-flex; gap: 8px; margin-top: 14px; flex-wrap: wrap; justify-content: center; }
    .file-type-badge {
      background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
      padding: 4px 12px; font-size: 0.8rem; font-weight: 600; color: var(--text-2);
    }
    .preview-box {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 16px 20px; display: flex; align-items: center; gap: 14px; margin-top: 16px;
    }
    .preview-icon { font-size: 2rem; flex-shrink: 0; }
    .preview-info { flex: 1; min-width: 0; }
    .preview-name { font-weight: 600; font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .preview-size { font-size: 0.82rem; color: var(--text-2); }
    .btn-remove {
      background: #fee2e2; color: #b91c1c; border: none; border-radius: 8px;
      padding: 6px 12px; font-size: 0.82rem; font-weight: 600; cursor: pointer;
      transition: background var(--transition);
    }
    .btn-remove:hover { background: #fca5a5; }
    .btn-analyze {
      display: block; width: 100%; margin-top: 20px;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
      color: white; border: none; border-radius: var(--radius);
      padding: 16px 24px; font-size: 1.05rem; font-weight: 700;
      cursor: pointer; transition: opacity var(--transition), transform var(--transition);
      text-align: center;
    }
    .btn-analyze:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-analyze:not(:disabled):hover { opacity: 0.9; transform: translateY(-1px); }
    .progress-section {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 32px 28px; text-align: center;
    }
    .progress-spinner {
      width: 52px; height: 52px; border: 5px solid var(--surface-2);
      border-top-color: var(--primary); border-radius: 50%;
      animation: spin 0.85s linear infinite; margin: 0 auto 18px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .progress-steps { list-style: none; text-align: left; max-width: 340px; margin: 20px auto 0; }
    .progress-steps li {
      padding: 7px 0; color: var(--text-2); font-size: 0.9rem;
      display: flex; align-items: center; gap: 10px;
      border-bottom: 1px solid var(--border);
    }
    .progress-steps li:last-child { border: none; }
    .progress-steps li.done   { color: #16a34a; }
    .progress-steps li.active { color: var(--primary); font-weight: 600; }
    .step-dot {
      width: 10px; height: 10px; border-radius: 50%; background: currentColor; flex-shrink: 0;
    }
    .step-dot.spinning {
      animation: spin 0.85s linear infinite; background: none;
      border: 2px solid var(--primary); border-top-color: transparent; border-radius: 50%;
      width: 12px; height: 12px;
    }
    .results-header {
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 12px; margin-bottom: 24px;
    }
    .results-title { font-size: 1.35rem; font-weight: 800; color: var(--text); }
    .results-meta  { font-size: 0.88rem; color: var(--text-2); }
    .btn-print, .btn-new-analysis {
      background: var(--surface-2); border: 1px solid var(--border); color: var(--text-2);
      border-radius: 8px; padding: 8px 16px; font-size: 0.88rem; font-weight: 600;
      cursor: pointer; display: inline-flex; align-items: center; gap: 6px;
      transition: background var(--transition);
    }
    .btn-print:hover, .btn-new-analysis:hover { background: var(--surface); }
    .btn-new-analysis { color: var(--primary); background: color-mix(in srgb, var(--primary) 10%, transparent); }
    .exercise-card {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      margin-bottom: 20px; overflow: hidden;
      box-shadow: var(--shadow); transition: box-shadow var(--transition);
    }
    .exercise-card:hover { box-shadow: var(--shadow-md); }
    .exercise-header {
      display: flex; align-items: center; gap: 12px;
      padding: 16px 20px; cursor: pointer;
      border-bottom: 1px solid transparent;
      transition: border-color var(--transition), background var(--transition);
      user-select: none;
    }
    .exercise-card.open .exercise-header {
      border-bottom-color: var(--border); background: var(--surface-2);
    }
    .exercise-num {
      background: var(--primary); color: white; border-radius: 8px;
      padding: 4px 10px; font-size: 0.8rem; font-weight: 700; flex-shrink: 0;
    }
    .exercise-title { font-weight: 700; font-size: 1rem; color: var(--text); flex: 1; }
    .exercise-diff {
      border-radius: 20px; padding: 3px 10px; font-size: 0.78rem; font-weight: 600; flex-shrink: 0;
    }
    .diff-usor    { background: #dcfce7; color: #16a34a; }
    .diff-mediu   { background: #fff7ed; color: #ea580c; }
    .diff-dificil { background: #fee2e2; color: #b91c1c; }
    .exercise-chevron { color: var(--text-2); transition: transform var(--transition); flex-shrink: 0; }
    .exercise-card.open .exercise-chevron { transform: rotate(180deg); }
    .exercise-body { padding: 20px; display: none; }
    .exercise-card.open .exercise-body { display: block; }
    .ex-section { margin-bottom: 18px; }
    .ex-section:last-child { margin-bottom: 0; }
    .ex-section-title {
      font-size: 0.78rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.07em; color: var(--text-2); margin-bottom: 8px;
    }
    .ex-section-content { font-size: 0.95rem; color: var(--text); line-height: 1.7; }
    .ex-section-content pre {
      background: var(--surface-2); border: 1px solid var(--border); border-radius: 8px;
      padding: 12px 14px; font-family: var(--mono); font-size: 0.88rem;
      overflow-x: auto; margin-top: 8px;
    }
    .chapter-link {
      display: inline-flex; align-items: center; gap: 8px;
      background: color-mix(in srgb, var(--primary) 10%, transparent);
      border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent);
      color: var(--primary); border-radius: 8px; padding: 8px 14px;
      font-size: 0.88rem; font-weight: 600; text-decoration: none; margin-top: 4px;
      transition: background var(--transition);
    }
    .chapter-link:hover { background: color-mix(in srgb, var(--primary) 20%, transparent); }
    .error-banner {
      background: #fee2e2; border: 1px solid #fca5a5; border-radius: var(--radius);
      padding: 16px 20px; color: #b91c1c; font-size: 0.92rem;
      display: flex; gap: 10px; align-items: flex-start;
    }
    .info-box {
      background: #fefce8; border: 1px solid #fde68a; border-radius: var(--radius);
      padding: 14px 18px; font-size: 0.88rem; color: #92400e;
      display: flex; gap: 10px; align-items: flex-start; margin-bottom: 20px;
    }
    [data-theme="dark"] .info-box {
      background: #1c1a08; border-color: #78610a; color: #fde68a;
    }
    [data-theme="dark"] .diff-usor    { background: #14532d33; color: #4ade80; }
    [data-theme="dark"] .diff-mediu   { background: #7c2d1233; color: #fb923c; }
    [data-theme="dark"] .diff-dificil { background: #7f1d1d33; color: #f87171; }
    [data-theme="dark"] .btn-remove   { background: #7f1d1d33; color: #f87171; }
    [data-theme="dark"] .error-banner { background: #7f1d1d33; border-color: #ef444466; color: #fca5a5; }
    .how-steps {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px; margin-top: 8px;
    }
    .how-step {
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 18px 16px; text-align: center;
    }
    .how-step-icon { font-size: 1.8rem; margin-bottom: 8px; }
    .how-step-title { font-weight: 700; font-size: 0.9rem; color: var(--text); margin-bottom: 4px; }
    .how-step-desc  { font-size: 0.82rem; color: var(--text-2); }
    @media print {
      .site-header, .chapter-hero, #go-top-btn, .chapter-footer-nav,
      .btn-print, .btn-new-analysis, .upload-section, #scroll-progress { display: none !important; }
      .exercise-body { display: block !important; }
      .exercise-card { box-shadow: none; border: 1px solid #ccc; page-break-inside: avoid; }
    }
  </style>

  <Header />

  <!-- Hero -->
  <div class="chapter-hero" style="background: linear-gradient(135deg,#0f172a 0%,#1e3a5f 50%,#1d4ed8 100%);">
    <a href={`${base}/`} class="chapter-hero-back">← Înapoi acasă</a>
    <h1>🤖 Analiză Variantă BAC</h1>
    <p>Încarcă varianta ta de BAC la informatică (PDF sau imagine) și primești explicații detaliate pentru fiecare exercițiu — teorie, pași de rezolvare și linkuri spre capitolele relevante.</p>
    <div class="chapter-hero-tags">
      <span class="chapter-hero-tag">📄 PDF digital sau scanat</span>
      <span class="chapter-hero-tag">🖼️ Imagini JPG / PNG</span>
      <span class="chapter-hero-tag">🔒 Fișierul nu se încarcă pe niciun server</span>
      <span class="chapter-hero-tag">✨ Powered by AI</span>
    </div>
  </div>

  <!-- Main -->
  <div class="wrapper" style="max-width:820px;margin:0 auto;padding:40px 20px 80px;">

    <!-- Cum funcționează -->
    <section class="slide" style="margin-bottom:36px;">
      <h2 style="font-size:1.1rem;font-weight:700;color:var(--text);margin-bottom:14px;">Cum funcționează</h2>
      <div class="how-steps">
        <div class="how-step">
          <div class="how-step-icon">📤</div>
          <div class="how-step-title">1. Încarci varianta</div>
          <div class="how-step-desc">PDF (digital sau scanat) sau o poză cu varianta de BAC</div>
        </div>
        <div class="how-step">
          <div class="how-step-icon">🔍</div>
          <div class="how-step-title">2. Se parsează</div>
          <div class="how-step-desc">Textul este extras din fișier și trimis la AI pentru analiză</div>
        </div>
        <div class="how-step">
          <div class="how-step-icon">🧠</div>
          <div class="how-step-title">3. AI analizează</div>
          <div class="how-step-desc">Fiecare exercițiu este identificat și explicat în detaliu</div>
        </div>
        <div class="how-step">
          <div class="how-step-icon">📚</div>
          <div class="how-step-title">4. Înveți</div>
          <div class="how-step-desc">Primești teorie, pași de rezolvare și link spre capitolul relevant</div>
        </div>
      </div>
    </section>

    <!-- Upload section -->
    <section id="upload-section" class="upload-section slide">
      <div class="info-box">
        <span>💡</span>
        <span><strong>Confidențialitate:</strong> fișierul tău <em>nu</em> este salvat pe niciun server al platformei. Este procesat local în browser și transmis direct la API-ul AI.</span>
      </div>
      <div class="upload-zone" id="upload-zone" role="button" tabindex="0" aria-label="Zonă de upload">
        <input type="file" id="file-input" accept=".pdf,.jpg,.jpeg,.png" aria-label="Selectează fișier" />
        <span class="upload-icon">📂</span>
        <h3>Trage fișierul aici sau click pentru a selecta</h3>
        <p>Varianta de BAC la informatică — PDF sau imagine</p>
        <div class="file-types">
          <span class="file-type-badge">PDF digital</span>
          <span class="file-type-badge">PDF scanat</span>
          <span class="file-type-badge">JPG</span>
          <span class="file-type-badge">PNG</span>
        </div>
      </div>
      <div id="file-preview" class="preview-box" style="display:none;" aria-live="polite">
        <div class="preview-icon" id="preview-icon">📄</div>
        <div class="preview-info">
          <div class="preview-name" id="preview-name"></div>
          <div class="preview-size" id="preview-size"></div>
        </div>
        <button class="btn-remove" id="btn-remove" aria-label="Elimină fișierul">✕ Elimină</button>
      </div>
      <button class="btn-analyze" id="btn-analyze" disabled aria-disabled="true">
        🔍 Analizează varianta de BAC
      </button>
    </section>

    <!-- Progress -->
    <section id="progress-section" class="progress-section slide" style="display:none;" aria-live="polite" aria-label="Progres analiză">
      <div class="progress-spinner" role="status" aria-label="Se procesează..."></div>
      <h3 style="font-weight:700;color:var(--text);margin-bottom:6px;">Se analizează varianta...</h3>
      <p style="color:var(--text-2);font-size:0.9rem;">Acest proces durează 15–40 de secunde</p>
      <ul class="progress-steps" id="progress-steps">
        <li id="step-read"><span class="step-dot"></span> Citire fișier</li>
        <li id="step-extract"><span class="step-dot"></span> Extragere text / procesare imagine</li>
        <li id="step-ai"><span class="step-dot"></span> Trimitere la AI pentru analiză</li>
        <li id="step-parse"><span class="step-dot"></span> Structurare rezultate</li>
      </ul>
    </section>

    <!-- Error -->
    <section id="error-section" style="display:none;" aria-live="assertive">
      <div class="error-banner">
        <span style="font-size:1.3rem;flex-shrink:0;">⚠️</span>
        <div>
          <strong id="error-title">A apărut o eroare</strong>
          <span id="error-message"></span>
        </div>
      </div>
      <button class="btn-analyze" id="btn-retry" style="margin-top:14px;width:auto;display:inline-flex;gap:8px;align-items:center;">
        🔄 Încearcă din nou
      </button>
    </section>

    <!-- Results -->
    <section id="results-section" style="display:none;" aria-live="polite" aria-label="Rezultate analiză">
      <div class="results-header">
        <div>
          <div class="results-title">📋 Analiza variantei BAC</div>
          <div class="results-meta" id="results-meta"></div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <button class="btn-new-analysis" id="btn-new">⬆️ Analiză nouă</button>
          <button class="btn-print" onclick="window.print()">🖨️ Printează / Salvează PDF</button>
        </div>
      </div>
      <div id="exercises-container"></div>
    </section>
  </div>

  <!-- PDF.js -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

  <script is:inline define:vars={{ base }}>
  (function () {
    'use strict';

    if (typeof pdfjsLib !== 'undefined') {
      pdfjsLib.GlobalWorkerOptions.workerSrc =
        'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    }

    var zone        = document.getElementById('upload-zone');
    var fileInput   = document.getElementById('file-input');
    var filePreview = document.getElementById('file-preview');
    var previewIcon = document.getElementById('preview-icon');
    var previewName = document.getElementById('preview-name');
    var previewSize = document.getElementById('preview-size');
    var btnRemove   = document.getElementById('btn-remove');
    var btnAnalyze  = document.getElementById('btn-analyze');
    var btnRetry    = document.getElementById('btn-retry');
    var btnNew      = document.getElementById('btn-new');
    var secUpload   = document.getElementById('upload-section');
    var secProgress = document.getElementById('progress-section');
    var secError    = document.getElementById('error-section');
    var secResults  = document.getElementById('results-section');
    var resultsMeta        = document.getElementById('results-meta');
    var exercisesContainer = document.getElementById('exercises-container');
    var currentFile = null;

    var CHAPTERS = [
      { url: base + '/capitole/introducere',  label: '📘 Introducere în Informatică',  keywords: ['introducere','tipuri de date','structuri de control','if','for','while','bac 2026','algoritm'] },
      { url: base + '/capitole/complexitate', label: '⏱ Complexitatea Algoritmilor',   keywords: ['complexitate','big-o','timp','spatiu','eficienta','o(n)','o(log']  },
      { url: base + '/capitole/vectori',      label: '📊 Vectori',                     keywords: ['vector','tablou','array','sortare','cautare binara','suma','maxim','minim','frecventa','inversare'] },
      { url: base + '/capitole/matrici',      label: '🔢 Matrici',                     keywords: ['matrice','matric','bidimensional','tablou 2d','transpusa','spirala','diagonala'] },
      { url: base + '/capitole/siruri',       label: '🔤 Șiruri de Caractere',         keywords: ['sir','string','caracter','palindrom','anagram','litera','cuvant','text'] },
      { url: base + '/capitole/recursivitate',label: '🔁 Recursivitate',               keywords: ['recursiv','recursivitate','divide','impera','memoizare','hanoi','fibonacci','factorial'] },
      { url: base + '/capitole/backtracking', label: '🔀 Backtracking',                keywords: ['backtracking','permutari','combinari','submultime','subset','generare','aranjamente'] },
      { url: base + '/capitole/fisiere',      label: '💾 Fișiere',                     keywords: ['fisier','fstream','ifstream','ofstream','citire','scriere','txt'] }
    ];

    var SYSTEM_PROMPT = 'Ești un profesor expert de informatică pentru liceu din România.\nElevul ți-a trimis o variantă de bacalaureat la informatică (C++).\n\nSarcina ta: identifică TOATE exercițiile/subiectele din varianta de BAC și pentru fiecare generează o explicație completă.\n\nReguli:\n- Răspunde EXCLUSIV cu un JSON valid, fără niciun text în afara JSON-ului.\n- Dacă nu poți identifica exercițiile, returnează {"eroare": "Nu am putut identifica exercițiile"}.\n- Teoria trebuie să fie clară, în română, potrivită pentru un elev de liceu.\n- capitol_cheie: introducere, complexitate, vectori, matrici, siruri, recursivitate, backtracking sau fisiere.\n\nFormat JSON obligatoriu:\n{\n  "varianta": "Varianta XX / identificare",\n  "exercitii": [\n    {\n      "numar": "I.1",\n      "enunt": "Textul exact",\n      "ce_cere": "Explicație simplă",\n      "teorie": "Teoria necesară (2-4 paragrafe)",\n      "pasi_rezolvare": "Abordare pas cu pas cu cod C++",\n      "capitol_cheie": "vectori",\n      "dificultate": "Ușor"\n    }\n  ]\n}';

    function formatBytes(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function setFile(file) {
      if (!file) return;
      if (file.size > 25 * 1024 * 1024) { showError('Fișier prea mare', 'Maxim 25 MB.'); return; }
      var allowed = ['application/pdf','image/jpeg','image/png','image/jpg'];
      if (!allowed.includes(file.type) && !file.name.match(/\.(pdf|jpg|jpeg|png)$/i)) {
        showError('Tip neacceptat', 'Acceptăm doar PDF, JPG sau PNG.'); return;
      }
      currentFile = file;
      previewIcon.textContent = file.type.startsWith('image/') ? '🖼️' : '📄';
      previewName.textContent = file.name;
      previewSize.textContent = formatBytes(file.size) + ' · ' + (file.type.startsWith('image/') ? 'Imagine' : 'PDF');
      filePreview.style.display = 'flex';
      btnAnalyze.disabled = false;
      btnAnalyze.setAttribute('aria-disabled', 'false');
    }

    fileInput.addEventListener('change', function () { if (fileInput.files[0]) setFile(fileInput.files[0]); });
    zone.addEventListener('dragover',  function (e) { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', function ()  { zone.classList.remove('drag-over'); });
    zone.addEventListener('drop',      function (e) { e.preventDefault(); zone.classList.remove('drag-over'); if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]); });
    zone.addEventListener('keydown',   function (e) { if (e.key === 'Enter' || e.key === ' ') fileInput.click(); });
    btnRemove.addEventListener('click', function () {
      currentFile = null; fileInput.value = '';
      filePreview.style.display = 'none';
      btnAnalyze.disabled = true; btnAnalyze.setAttribute('aria-disabled', 'true');
    });

    function showSection(name) {
      secUpload.style.display   = name === 'upload'   ? '' : 'none';
      secProgress.style.display = name === 'progress' ? '' : 'none';
      secError.style.display    = name === 'error'    ? '' : 'none';
      secResults.style.display  = name === 'results'  ? '' : 'none';
    }
    function setStep(id, state) {
      var el = document.getElementById(id); if (!el) return;
      el.className = state;
      var dot = el.querySelector('.step-dot'); if (!dot) return;
      dot.className = state === 'active' ? 'step-dot spinning' : 'step-dot';
    }
    function showError(title, message) {
      document.getElementById('error-title').textContent = title;
      document.getElementById('error-message').textContent = ' ' + message;
      showSection('error');
    }
    btnRetry.addEventListener('click', function () { showSection('upload'); });
    btnNew.addEventListener('click',   function () { showSection('upload'); });

    function readBuf(file) { return new Promise(function (res, rej) { var r = new FileReader(); r.onload = function (e) { res(e.target.result); }; r.onerror = rej; r.readAsArrayBuffer(file); }); }
    function readURL(file) { return new Promise(function (res, rej) { var r = new FileReader(); r.onload = function (e) { res(e.target.result); }; r.onerror = rej; r.readAsDataURL(file); }); }

    async function processPDF(file) {
      var buf = await readBuf(file);
      var pdf = await pdfjsLib.getDocument({ data: buf }).promise;
      var n = pdf.numPages; var text = '';
      for (var i = 1; i <= n; i++) {
        var pg = await pdf.getPage(i);
        var ct = await pg.getTextContent();
        text += ct.items.map(function (x) { return x.str; }).join(' ') + '\n\n';
      }
      if (text.replace(/\s/g, '').length / n >= 50) return { type: 'text', content: text.trim() };
      var imgs = []; var mx = Math.min(n, 6);
      for (var j = 1; j <= mx; j++) {
        var p = await pdf.getPage(j); var vp = p.getViewport({ scale: 1.8 });
        var cv = document.createElement('canvas'); cv.width = vp.width; cv.height = vp.height;
        await p.render({ canvasContext: cv.getContext('2d'), viewport: vp }).promise;
        imgs.push(cv.toDataURL('image/jpeg', 0.82));
      }
      return { type: 'images', content: imgs };
    }

    async function processImage(file) { return { type: 'images', content: [await readURL(file)] }; }

    async function callAI(content) {
      var userContent = content.type === 'text'
        ? [{ type: 'text', text: 'Textul variantei de BAC:\n\n' + content.content }]
        : [{ type: 'text', text: 'Varianta de BAC (imagini). Analizează TOATE exercițiile.' }]
            .concat(content.content.map(function (img) { return { type: 'image_url', image_url: { url: img } }; }));
      var resp = await fetch('https://text.pollinations.ai/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ model: 'openai', messages: [{ role: 'system', content: SYSTEM_PROMPT }, { role: 'user', content: userContent }], private: true, seed: 42 })
      });
      if (!resp.ok) throw new Error('Eroare API: ' + resp.status);
      return await resp.text();
    }

    function parseResponse(raw) {
      var m = raw.match(/\{[\s\S]*\}/); if (!m) throw new Error('JSON invalid în răspuns.');
      var d = JSON.parse(m[0]);
      if (d.eroare) throw new Error(d.eroare);
      if (!d.exercitii || !d.exercitii.length) throw new Error('Nu au fost identificate exerciții.');
      return d;
    }

    function getChapter(key) {
      if (!key) return null;
      var k = key.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      for (var i = 0; i < CHAPTERS.length; i++) {
        if (CHAPTERS[i].url.includes(k)) return CHAPTERS[i];
        for (var j = 0; j < CHAPTERS[i].keywords.length; j++) { if (CHAPTERS[i].keywords[j] === k) return CHAPTERS[i]; }
      }
      return null;
    }

    function dc(d) {
      if (!d) return '';
      var dn = d.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      return dn[0] === 'u' ? 'diff-usor' : dn[0] === 'm' ? 'diff-mediu' : dn[0] === 'd' ? 'diff-dificil' : '';
    }

    function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    function fmt(text) {
      if (!text) return '';
      return String(text).split(/(```[\s\S]*?```)/g).map(function (p) {
        if (p.startsWith('```') && p.endsWith('```')) return '<pre>' + esc(p.slice(3,-3).replace(/^[a-z+]*\n/,'')) + '</pre>';
        return p.split(/\n{2,}/).map(function (x) { return x.trim() ? '<p>' + esc(x.trim()).replace(/\n/g,'<br>') + '</p>' : ''; }).join('');
      }).join('');
    }

    function renderResults(data) {
      exercisesContainer.innerHTML = '';
      resultsMeta.textContent = (data.varianta||'') + ' · ' + data.exercitii.length + ' exerciții';
      data.exercitii.forEach(function (ex, idx) {
        var ch = getChapter(ex.capitol_cheie);
        var chHTML = ch ? '<a class="chapter-link" href="' + ch.url + '" target="_blank" rel="noopener">' + ch.label + ' →</a>' : '';
        var card = document.createElement('div'); card.className = 'exercise-card';
        card.setAttribute('aria-expanded','false');
        card.innerHTML =
          '<div class="exercise-header" role="button" tabindex="0">' +
            '<span class="exercise-num">' + esc(ex.numar||String(idx+1)) + '</span>' +
            '<span class="exercise-title">' + esc(ex.ce_cere||ex.enunt||'Exercițiu') + '</span>' +
            (ex.dificultate ? '<span class="exercise-diff ' + dc(ex.dificultate) + '">' + esc(ex.dificultate) + '</span>' : '') +
            '<svg class="exercise-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>' +
          '</div>' +
          '<div class="exercise-body">' +
            (ex.enunt ? '<div class="ex-section"><div class="ex-section-title">Enunț</div><div class="ex-section-content">' + fmt(ex.enunt) + '</div></div>' : '') +
            (ex.teorie ? '<div class="ex-section"><div class="ex-section-title">Teorie necesară</div><div class="ex-section-content">' + fmt(ex.teorie) + '</div></div>' : '') +
            (ex.pasi_rezolvare ? '<div class="ex-section"><div class="ex-section-title">Pași de rezolvare</div><div class="ex-section-content">' + fmt(ex.pasi_rezolvare) + '</div></div>' : '') +
            (chHTML ? '<div class="ex-section"><div class="ex-section-title">Capitol relevant</div><div class="ex-section-content">' + chHTML + '</div></div>' : '') +
          '</div>';
        var hdr = card.querySelector('.exercise-header');
        function toggle() { var o = card.classList.toggle('open'); card.setAttribute('aria-expanded', o ? 'true':'false'); }
        hdr.addEventListener('click', toggle);
        hdr.addEventListener('keydown', function (e) { if (e.key==='Enter'||e.key===' ') { e.preventDefault(); toggle(); } });
        if (idx === 0) { card.classList.add('open'); card.setAttribute('aria-expanded','true'); }
        exercisesContainer.appendChild(card);
      });
      showSection('results');
      secResults.scrollIntoView({ behavior:'smooth', block:'start' });
    }

    btnAnalyze.addEventListener('click', async function () {
      if (!currentFile) return;
      showSection('progress'); window.scrollTo({ top:0, behavior:'smooth' });
      ['step-read','step-extract','step-ai','step-parse'].forEach(function (id) { setStep(id,''); });
      try {
        setStep('step-read','active');
        var isPDF = currentFile.type === 'application/pdf' || currentFile.name.toLowerCase().endsWith('.pdf');
        if (isPDF && typeof pdfjsLib === 'undefined') throw new Error('PDF.js nu s-a încărcat. Reîncarcă pagina.');
        setStep('step-read','done');
        setStep('step-extract','active');
        var content = isPDF ? await processPDF(currentFile) : await processImage(currentFile);
        setStep('step-extract','done');
        setStep('step-ai','active');
        var raw = await callAI(content);
        setStep('step-ai','done');
        setStep('step-parse','active');
        var data = parseResponse(raw);
        setStep('step-parse','done');
        renderResults(data);
      } catch(err) {
        var msg = err.message || 'Eroare necunoscută.';
        if (msg.includes('Failed to fetch') || msg.includes('NetworkError')) showError('Eroare de rețea', 'Verifică conexiunea la internet.');
        else if (msg.includes('API: 5')) showError('Serviciul AI indisponibil', 'Încearcă din nou peste câteva minute.');
        else showError('Eroare la analiză', msg);
      }
    });
  })();
  </script>
</BaseLayout>
