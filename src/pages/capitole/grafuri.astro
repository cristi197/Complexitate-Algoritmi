            <circle cx="20" cy="20" r="12" fill="var(--surface)" stroke="var(--blue2)" stroke-width="2"/>
            <text x="20" y="24" text-anchor="middle" font-size="10" font-weight="700" fill="var(--text)">1</text>
            <circle cx="100" cy="20" r="12" fill="var(--surface)" stroke="var(--blue2)" stroke-width="2"/>
            <text x="100" y="24" text-anchor="middle" font-size="10" font-weight="700" fill="var(--text)">2</text>
            <circle cx="20" cy="100" r="12" fill="var(--surface)" stroke="var(--blue2)" stroke-width="2"/>
            <text x="20" y="104" text-anchor="middle" font-size="10" font-weight="700" fill="var(--text)">3</text>
            <circle cx="100" cy="100" r="12" fill="var(--surface)" stroke="var(--blue2)" stroke-width="2"/>
            <text x="100" y="104" text-anchor="middle" font-size="10" font-weight="700" fill="var(--text)">4</text>
          </svg>
