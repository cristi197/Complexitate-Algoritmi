  var btnNode = document.getElementById('graph-mode-node');
  var btnEdge = document.getElementById('graph-mode-edge');
  var btnBFS = document.getElementById('graph-run-bfs');
  var btnDFS = document.getElementById('graph-run-dfs');
  var btnClear = document.getElementById('graph-clear');

  function setMode(m) {
    mode = m;
    selectedNode = null;
    btnNode.style.background = m === 'node' ? 'var(--primary)' : '';
    btnNode.style.color = m === 'node' ? 'white' : '';
    btnNode.style.borderColor = m === 'node' ? 'var(--primary)' : '';
    btnEdge.style.background = m === 'edge' ? 'var(--primary)' : '';
    btnEdge.style.color = m === 'edge' ? 'white' : '';
    btnEdge.style.borderColor = m === 'edge' ? 'var(--primary)' : '';
    draw();
  }

  btnNode.addEventListener('click', function() { setMode('node'); });
  btnEdge.addEventListener('click', function() { setMode('edge'); });
  btnClear.addEventListener('click', function() {
    nodes = []; edges = []; selectedNode = null; animating = false; animOrder = [];
    updateStats(); draw();
  });

  function getCanvasCoords(e) {
    var rect = canvas.getBoundingClientRect();
    var scaleX = canvas.width / rect.width;
    var scaleY = canvas.height / rect.height;
    return { x: (e.clientX - rect.left) * scaleX, y: (e.clientY - rect.top) * scaleY };
  }

  function findNode(x, y) {
    for (var i = 0; i < nodes.length; i++) {
      var dx = nodes[i].x - x, dy = nodes[i].y - y;
      if (dx*dx + dy*dy < 400) return i;
    }
    return -1;
  }

  canvas.addEventListener('click', function(e) {
    if (animating) return;
    var pos = getCanvasCoords(e);
    if (mode === 'node') {
      if (findNode(pos.x, pos.y) === -1) {
        nodes.push({ x: pos.x, y: pos.y, color: null });
        updateStats(); draw();
      }
    } else if (mode === 'edge') {
      var idx = findNode(pos.x, pos.y);
      if (idx === -1) return;
      if (selectedNode === null) {
        selectedNode = idx;
        draw();
      } else {
        if (selectedNode !== idx) {
          var exists = edges.some(function(e) {
            return (e[0]===selectedNode && e[1]===idx) || (e[0]===idx && e[1]===selectedNode);
          });
          if (!exists) {
            edges.push([selectedNode, idx]);
          }
        }
        selectedNode = null;
        updateStats(); draw();
      }
    }
  });

  function getAdj() {
    var adj = [];
    for (var i = 0; i < nodes.length; i++) adj.push([]);
    for (var i = 0; i < edges.length; i++) {
      adj[edges[i][0]].push(edges[i][1]);
      adj[edges[i][1]].push(edges[i][0]);
    }
    return adj;
  }

  function countComponents() {
    var visited = new Array(nodes.length).fill(false);
    var count = 0;
    var adj = getAdj();
    for (var i = 0; i < nodes.length; i++) {
      if (!visited[i]) {
        count++;
        var stack = [i];
        while (stack.length) {
          var n = stack.pop();
          if (visited[n]) continue;
          visited[n] = true;
          for (var j = 0; j < adj[n].length; j++) {
            if (!visited[adj[n][j]]) stack.push(adj[n][j]);
          }
        }
      }
    }
    return count;
  }

  function isEulerian() {
    if (nodes.length < 3) return false;
    if (countComponents() > 1) return false;
    var adj = getAdj();
    for (var i = 0; i < nodes.length; i++) {
      if (adj[i].length % 2 !== 0) return false;
      if (adj[i].length === 0) return false;
    }
    return true;
  }

  function updateStats() {
    var n = nodes.length, m = edges.length;
    document.getElementById('gs-nodes').textContent = n;
    document.getElementById('gs-edges').textContent = m;
    var sumDeg = 2 * m;
    document.getElementById('gs-sum-deg').textContent = sumDeg;
    document.getElementById('gs-comp').textContent = n > 0 ? countComponents() : 0;
    document.getElementById('gs-max-edges').textContent = n > 1 ? (n*(n-1)/2) : 0;
    var eulerEl = document.getElementById('gs-euler');
    eulerEl.style.display = isEulerian() ? 'inline' : 'none';
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    // Draw edges
    for (var i = 0; i < edges.length; i++) {
      var a = nodes[edges[i][0]], b = nodes[edges[i][1]];
      ctx.beginPath();
      ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = '#6366f1'; ctx.lineWidth = 2; ctx.globalAlpha = 0.5;
      ctx.stroke(); ctx.globalAlpha = 1;
    }
    // Draw nodes
    for (var i = 0; i < nodes.length; i++) {
      var nd = nodes[i];
      ctx.beginPath();
      ctx.arc(nd.x, nd.y, 18, 0, Math.PI * 2);
      if (nd.color) {
        ctx.fillStyle = nd.color;
      } else if (selectedNode === i) {
        ctx.fillStyle = '#a855f7';
      } else {
        ctx.fillStyle = '#6366f1';
      }
      ctx.fill();
      ctx.strokeStyle = '#fff'; ctx.lineWidth = 2.5; ctx.stroke();
      ctx.fillStyle = '#fff'; ctx.font = 'bold 12px sans-serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(String(i + 1), nd.x, nd.y);
    }
  }

  // BFS animation
  btnBFS.addEventListener('click', function() {
    if (animating || nodes.length === 0) return;
    animating = true; animOrder = []; animIdx = 0;
    var adj = getAdj();
    var visited = new Array(nodes.length).fill(false);
    var queue = [0]; visited[0] = true;
    while (queue.length) {
      var n = queue.shift();
      animOrder.push(n);
      for (var j = 0; j < adj[n].length; j++) {
        if (!visited[adj[n][j]]) { visited[adj[n][j]] = true; queue.push(adj[n][j]); }
      }
    }
    animateTraversal('#22c55e');
  });

  // DFS animation
  btnDFS.addEventListener('click', function() {
    if (animating || nodes.length === 0) return;
    animating = true; animOrder = []; animIdx = 0;
    var adj = getAdj();
    var visited = new Array(nodes.length).fill(false);
    var stack = [0];
    while (stack.length) {
      var n = stack.pop();
      if (visited[n]) continue;
      visited[n] = true;
      animOrder.push(n);
      for (var j = adj[n].length - 1; j >= 0; j--) {
        if (!visited[adj[n][j]]) stack.push(adj[n][j]);
      }
    }
    animateTraversal('#f59e0b');
  });

  function animateTraversal(color) {
    for (var i = 0; i < nodes.length; i++) nodes[i].color = null;
    function step() {
      if (animIdx >= animOrder.length) { animating = false; return; }
      nodes[animOrder[animIdx]].color = color;
      animIdx++;
      draw();
      setTimeout(step, 500);
    }
    step();
  }

  draw();
  updateStats();
})();
</script>

</ChapterLayout>
