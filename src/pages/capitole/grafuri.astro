          <circle cx="180" cy="30" r="16" fill="#0d9488"/><text x="180" y="35" text-anchor="middle" fill="white" font-size="12" font-weight="bold">1</text>
          <circle cx="100" cy="80" r="16" fill="#0d9488"/><text x="100" y="85" text-anchor="middle" fill="white" font-size="12" font-weight="bold">2</text>
          <circle cx="260" cy="80" r="16" fill="#0d9488"/><text x="260" y="85" text-anchor="middle" fill="white" font-size="12" font-weight="bold">3</text>
          <circle cx="60" cy="140" r="16" fill="#0d9488"/><text x="60" y="145" text-anchor="middle" fill="white" font-size="12" font-weight="bold">4</text>
          <circle cx="140" cy="140" r="16" fill="#0d9488"/><text x="140" y="145" text-anchor="middle" fill="white" font-size="12" font-weight="bold">5</text>
          <circle cx="220" cy="140" r="16" fill="#0d9488"/><text x="220" y="145" text-anchor="middle" fill="white" font-size="12" font-weight="bold">6</text>
