            <circle cx="100" cy="90" r="12" fill="var(--surface)" stroke="var(--green)" stroke-width="2"/>
            <text x="100" y="94" text-anchor="middle" font-size="10" font-weight="700" fill="var(--text)">3</text>
          </svg>
          <div style="font-size:11px;font-weight:700;color:var(--text-muted);">K₃ — 3 muchii</div>
        </div>
        <!-- K4 -->
        <div style="text-align:center;">
          <svg viewBox="0 0 120 120" width="120" height="120" aria-label="Graf complet K4">
            <line x1="20" y1="20" x2="100" y2="20" stroke="var(--blue2)" stroke-width="1.5"/>
