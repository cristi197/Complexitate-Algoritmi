      <h3>Implementare C++ (recursiv)</h3>
      <pre>vector&lt;<span class="kw">int</span>&gt; adj[<span class="nu">101</span>];
<span class="kw">bool</span> vizitat[<span class="nu">101</span>];

<span class="ty">void</span> <span class="fn">DFS</span>(<span class="kw">int</span> nod) &#123;
    vizitat[nod] = <span class="kw">true</span>;
    cout &lt;&lt; nod &lt;&lt; <span class="st">" "</span>;

    <span class="kw">for</span> (<span class="kw">int</span> vecin : adj[nod]) &#123;
        <span class="kw">if</span> (!vizitat[vecin]) &#123;
            <span class="fn">DFS</span>(vecin);
        &#125;
    &#125;
&#125;</pre>

      <h3 style="margin-top:20px;">Implementare C++ (iterativ cu stivă)</h3>
      <pre><span class="pp">#include &lt;stack&gt;</span>

<span class="ty">void</span> <span class="fn">DFS_iterativ</span>(<span class="kw">int</span> start) &#123;
    stack&lt;<span class="kw">int</span>&gt; S;
    S.push(start);

    <span class="kw">while</span> (!S.empty()) &#123;
        <span class="kw">int</span> nod = S.top();
        S.pop();

        <span class="kw">if</span> (vizitat[nod]) <span class="kw">continue</span>;
        vizitat[nod] = <span class="kw">true</span>;
        cout &lt;&lt; nod &lt;&lt; <span class="st">" "</span>;

        <span class="kw">for</span> (<span class="kw">int</span> vecin : adj[nod])
            <span class="kw">if</span> (!vizitat[vecin])
                S.push(vecin);
    &#125;
&#125;</pre>

      <h3 style="margin-top:20px;">Componente conexe cu DFS</h3>
      <pre><span class="kw">int</span> nr_comp = <span class="nu">0</span>;

<span class="kw">for</span> (<span class="kw">int</span> i = <span class="nu">1</span>; i <= n; i++) &#123;
    <span class="kw">if</span> (!vizitat[i]) &#123;
        nr_comp++;
        <span class="fn">DFS</span>(i);  <span class="cm">// vizitează toată componenta</span>
    &#125;
&#125;
cout &lt;&lt; <span class="st">"Componente conexe: "</span> &lt;&lt; nr_comp;</pre>

      <div class="callout success">
        <strong>Aplicații DFS:</strong>
        <ul>
          <li><strong>Componente conexe</strong> (neorientat)</li>
          <li><strong>Componente tare conexe</strong> (orientat — Tarjan/Kosaraju)</li>
          <li><strong>Detectare cicluri</strong></li>
          <li><strong>Sortare topologică</strong> (graf orientat aciclic)</li>
          <li><strong>Verificare graf bipartit</strong></li>
        </ul>
      </div>

      <h3 style="margin-top:20px;">BFS vs DFS — Comparație</h3>
      <table class="data-table" style="font-size:13px;">
        <thead><tr><th>Criteriu</th><th>BFS 🌊</th><th>DFS 🏊</th></tr></thead>
        <tbody>
          <tr><td><strong>Structură</strong></td><td>Coadă (queue)</td><td>Stivă (stack) / Recursie</td></tr>
          <tr><td><strong>Strategie</strong></td><td>Nivel cu nivel (lățime)</td><td>Cât mai adânc (adâncime)</td></tr>
          <tr><td><strong>Complexitate</strong></td><td>O(V + E)</td><td>O(V + E)</td></tr>
          <tr><td><strong>Drum minim</strong></td><td>✅ Da (neponderat)</td><td>❌ Nu garantează</td></tr>
          <tr><td><strong>Memorie</strong></td><td>O(V) — poate fi mare</td><td>O(V) — de obicei mai mică</td></tr>
          <tr><td><strong>Când folosim</strong></td><td>Distanțe minime, bipartit</td><td>Cicluri, sortare topo, CTC</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

