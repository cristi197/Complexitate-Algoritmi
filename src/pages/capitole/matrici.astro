        <button class="btn" style="background:#7c3aed;color:white;" data-zone="diag-sec">◆ Diagonala Secundară (i+j==n+1)</button>
        <button class="btn" style="background:#991b1b;color:white;" data-zone="both-diag">★ Ambele Diagonale</button>
        <button class="btn" style="background:#0f766e;color:white;" data-zone="upper">△ Triunghi Superior (j>i)</button>
        <button class="btn" style="background:#b45309;color:white;" data-zone="lower">▽ Triunghi Inferior (j<i)</button>
        <button class="btn" style="background:#be185d;color:white;" data-zone="border">□ Bordură</button>
      </div>
      <div class="matrix-viz-wrap">
        <div class="matrix-viz" style="grid-template-columns:repeat(5,46px)">
          <!-- celulele sunt generate de JavaScript -->
        </div>
      </div>
      <div class="matrix-legend">
