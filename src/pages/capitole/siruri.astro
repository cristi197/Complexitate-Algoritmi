sprintf(buf, <span class="st">"%05d"</span>, <span class="nu">7</span>);         <span class="cm">// buf = "00007"</span>

<span class="cm">// C-style: sir → numar</span>
<span class="kw">int</span>    n = atoi(<span class="st">"123"</span>);           <span class="cm">// 123</span>
<span class="kw">double</span> d = atof(<span class="st">"3.14"</span>);          <span class="cm">// 3.14</span>

<span class="cm">// Manual: cifre din numar → sir</span>
<span class="kw">int</span> nr = <span class="nu">12345</span>;
<span class="kw">char</span> cifre[<span class="nu">20</span>];
<span class="kw">int</span> len = <span class="nu">0</span>;
<span class="kw">while</span> (nr > <span class="nu">0</span>) &#123;
    cifre[len++] = <span class="st">'0'</span> + nr % <span class="nu">10</span>;
    nr /= <span class="nu">10</span>;
&#125;
cifre[len] = <span class="st">'\0'</span>;
<span class="kw">for</span> (<span class="kw">int</span> i=<span class="nu">0</span>; i &lt; len/<span class="nu">2</span>; i++) swap(cifre[i], cifre[len-<span class="nu">1</span>-i]);
<span class="cm">// cifre = "12345"</span>

<span class="cm">// Manual: sir de cifre → numar</span>
<span class="kw">char</span> str[] = <span class="st">"12345"</span>;
<span class="kw">int</span> val = <span class="nu">0</span>;
<span class="kw">for</span> (<span class="kw">int</span> i=<span class="nu">0</span>; str[i] != <span class="st">'\0'</span>; i++)
    val = val * <span class="nu">10</span> + (str[i] - <span class="st">'0'</span>);
<span class="cm">// val = 12345</span></pre>
