<span class="cm">// C-style: numar → sir cu sprintf</span>
<span class="kw">char</span> buf[<span class="nu">50</span>];
sprintf(buf, <span class="st">"%d"</span>, <span class="nu">42</span>);          <span class="cm">// buf = "42"</span>
