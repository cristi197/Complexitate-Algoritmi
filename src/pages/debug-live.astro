        function sumRec(idx, curSum) {
          steps.push({ line: 1, vars: { idx: idx, curSum: curSum }, exp: 'Verificăm valoarea lui index = ' + idx, arr: v.slice(), highlight: idx >= 1 ? [idx - 1] : [] });
          if (idx <= 0) {
