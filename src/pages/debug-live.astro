  { id: 'diagonala-secundara', name: 'Suma Diagonalei Secundare', description: 'Suma elementelor a[i][n-1-i] pentru i=0..n-1. O(n).', category: 'Matrici', vars: ['a', 'n', 'i', 'suma'], steps: [] },
  { id: 'flipping-01', name: 'Flipping 0 ب™i 1', description: 'Interschimbؤƒ 0 â†” 1 أ®n matrice binarؤƒ in-place. O(nأ—m).', category: 'Matrici', vars: ['a', 'n', 'm', 'i', 'j'], steps: [] },
  { id: 'medie-linii', name: 'Medie pe Fiecare Linie', description: 'Calculeazؤƒ media elementelor pe fiecare linie. O(nأ—m).', category: 'Matrici', vars: ['a', 'n', 'm', 'i', 'j', 'suma_linie', 'medie'], steps: [] },
  { id: 'min-max-matrice', name: 'Min ب™i Max أ®n Matrice', description: 'Gؤƒseب™te minim ب™i maxim dintr-o matrice. O(nأ—m).', category: 'Matrici', vars: ['a', 'n', 'm', 'i', 'j', 'min', 'max'], steps: [] },
  { id: 'matrice-triunghiulara', name: 'Verificare Matrice Triunghiularؤƒ', description: 'Verificؤƒ dacؤƒ matrice este superior sau inferior triunghiularؤƒ. O(nآ²).', category: 'Matrici', vars: ['a', 'n', 'i', 'j', 'superior', 'inferior'], steps: [] },
  { id: 'trace-matrice', name: 'Trace Matrice (Urma)', description: 'Suma diagonalei principale a[i][i]. O(n).', category: 'Matrici', vars: ['a', 'n', 'i', 'trace'], steps: [] },

  // BACKTRACKING +8
  { id: 'n-regine', name: 'N-Regine (Backtracking)', description: 'Plaseazؤƒ n regine pe tablؤƒ nأ—n fؤƒrؤƒ atacuri reciproce. O(n!).', category: 'Backtracking', vars: ['pozitii', 'n', 'solutii'], steps: [] },
  { id: 'hamiltonian', name: 'Drum Hamiltonian', description: 'Gؤƒseب™te drum care viziteazؤƒ fiecare vأ¢rf o datؤƒ. O(n!).', category: 'Backtracking', vars: ['path', 'n', 'visited'], steps: [] },
  { id: 'knight-tour', name: 'Knight Tour', description: 'Mutؤƒ calul peste toate pؤƒtratele unei tablei 8أ—8 o singurؤƒ datؤƒ. O(8^64) backtracking.', category: 'Backtracking', vars: ['board', 'x', 'y', 'moves'], steps: [] },
  { id: 'labirint', name: 'Soluب›ie Labirint', description: 'Gؤƒseب™te cale din start la end evitأ¢nd obstacole cu backtracking. O(4^(nأ—m)).', category: 'Backtracking', vars: ['maze', 'x', 'y', 'path'], steps: [] },
  { id: 'combinatii', name: 'Combinaب›ii C(n,k)', description: 'Genereazؤƒ toate submulب›imile de k elemente. O(C(n,k)).', category: 'Backtracking', vars: ['comb', 'n', 'k', 'idx'], steps: [] },
  { id: 'subseturi', name: 'Submulب›imi (Subsets)', description: 'Genereazؤƒ toate 2^n submulب›imi ale unei mulب›imi. O(2^n).', category: 'Backtracking', vars: ['subset', 'n', 'i'], steps: [] },
  { id: 'partitii-suma', name: 'Partiب›ie cu Sumؤƒ Egalؤƒ', description: 'أژmparte array أ®n 2 submulب›imi cu sume egale folosind DP/backtracking. O(nأ—sum/2).', category: 'Backtracking', vars: ['partition', 'suma_total'], steps: [] },
  { id: 'sudoku-solver', name: 'Sudoku Solver', description: 'Rezolvؤƒ puzzle-ul Sudoku cu backtracking ب™i validare. O(9^(n*n)) backtracking.', category: 'Backtracking', vars: ['board', 'row', 'col', 'num'], steps: [] },
