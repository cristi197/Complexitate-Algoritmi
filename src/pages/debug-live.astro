          steps.push({ line: 2, vars: { v: v.slice(), n: n, x: x, i: i }, exp: 'Verificؤƒm elementul de pe poziب›ia: v[' + i + '] == x? adicؤƒ ' + v[i] + ' == ' + x + '? Rؤƒspuns: ' + (v[i] === x ? 'DA' : 'NU'), arr: v.slice(), highlight: [i] });
          if (v[i] === x) {
