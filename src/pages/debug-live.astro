        var b = parseInt(inputs['inp-b']) || 0;
        var steps = [];
        steps.push({ line: 0, vars: { a: a, b: b, xor_val: '?', count: '?' }, exp: 'Calculăm distanța Hamming între ' + a + ' și ' + b });
        var xorVal = a ^ b;
        steps.push({ line: 1, vars: { a: a, b: b, xor_val: xorVal, count: 0 }, exp: 'Calculăm XOR între numere: ' + a + ' ^ ' + b + ' = ' + xorVal + ' (' + xorVal.toString(2) + ' binar)' });
        var count = 0;
        var tempXOR = xorVal;
        while(tempXOR > 0) {
          var bit = tempXOR & 1;
          count += bit;
