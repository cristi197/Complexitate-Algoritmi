            var sub = simulate(k - 1);
            result = k * sub;
            steps.push({ line: 2, vars: { n: k, rez: result, apel: 'factRec(' + k + ')', adancime: callStack.length }, exp: 'â†‘ Revenire أ®n factRec(' + k + '): ' + k + ' أ— factRec(' + (k-1) + ') = ' + k + ' أ— ' + sub + ' = ' + result });
          }
          callStack.pop();
          return result;
        }
        steps.push({ line: 5, vars: { n: n, rez: '?', apel: 'main()', adancime: 0 }, exp: 'main() citeب™te n = ' + n + ' ب™i apeleazؤƒ factRec(' + n + ')' });
