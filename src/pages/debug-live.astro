        var seen = new Set();
        var orig = n;
        var current = n;
        while (current !== 1 && !seen.has(current)) {
          seen.add(current);
          var sum = 0;
          var tmp = current;
          var digits = [];
          while (tmp) {
            var d = tmp % 10;
            sum += d * d;
            digits.push(d + 'آ²');
