    'inversare-recursiv': {
      name: 'Inversare Vector Recursiv',
      fileName: 'inversare_rec.cpp',
      codeLines: [
        'void inv(int v[], int st, int dr) {',
        '  if (st < dr) {',
        '    int aux = v[st];',
        '    v[st] = v[dr];',
        '    v[dr] = aux;',
        '    inv(v, st+1, dr-1);',
        '  }',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector:<input id="inp-v" class="tracer-input" value="1 2 3 4 5"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var steps = [];
        var maxSteps = 100;
        function solve(st, dr) {
          if (steps.length > maxSteps) return;
          steps.push({ line: 1, vars: { v: v.slice(), st: st, dr: dr }, exp: 'Apel recursiv inv(v, ' + st + ', ' + dr + '). Verificăm st < dr: ' + st + ' < ' + dr, arr: v.slice(), highlight: [st, dr] });
          if (st < dr) {
            var aux = v[st];
            steps.push({ line: 2, vars: { v: v.slice(), st: st, dr: dr, aux: aux }, exp: 'aux = v[' + st + '] = ' + aux, arr: v.slice(), highlight: [st] });
            v[st] = v[dr];
            steps.push({ line: 3, vars: { v: v.slice(), st: st, dr: dr, aux: aux }, exp: 'v[' + st + '] devine v[' + dr + '] = ' + v[dr], arr: v.slice(), highlight: [st, dr] });
            v[dr] = aux;
            steps.push({ line: 4, vars: { v: v.slice(), st: st, dr: dr, aux: aux }, exp: 'v[' + dr + '] devine aux = ' + aux, arr: v.slice(), highlight: [st, dr] });
            solve(st + 1, dr - 1);
          } else {
            steps.push({ line: 1, vars: { v: v.slice(), st: st, dr: dr }, exp: 'Recursivitatea se oprește (st >= dr).', arr: v.slice() });
          }
        }
        solve(0, v.length - 1);
        steps.push({ line: 0, vars: { v: v.slice() }, exp: 'Vector inversat complet!', arr: v.slice(), done: true });
        return { steps: steps, result: 'Inversat: [' + v.join(', ') + ']' };
      }
    },
