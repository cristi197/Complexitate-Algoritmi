    'inversare-vector': {
      name: 'Inversare Vector (In-Place)',
      fileName: 'inversare_vector.cpp',
      codeLines: [
        'void inversare(int v[], int n) {',
        '  int st = 0, dr = n - 1;',
        '  while (st < dr) {',
        '    int aux = v[st];',
        '    v[st] = v[dr];',
        '    v[dr] = aux;',
        '    st++;',
        '    dr--;',
        '  }',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vectorul de inversit:<input id="inp-v" type="text" placeholder="ex: 1 2 3 4 5" class="tracer-input" value="1 2 3 4 5"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var st = 0, dr = n - 1;
        var steps = [];
        steps.push({ line: 0, vars: { v: v.slice(), n: n, st: '?', dr: '?', aux: '?' }, exp: 'Inițiem inversarea cu doi indici: st de la stânga, dr de la dreapta.', arr: v.slice() });
        steps.push({ line: 1, vars: { v: v.slice(), n: n, st: st, dr: dr, aux: '?' }, exp: 'st = 0, dr = ' + dr + '. Cei doi indici pornesc de la capete.', arr: v.slice(), highlight: [st, dr] });
        while (st < dr) {
          steps.push({ line: 2, vars: { v: v.slice(), n: n, st: st, dr: dr, aux: '?' }, exp: 'st < dr? adică ' + st + ' < ' + dr + ' (Adevărat — facem schimb).', arr: v.slice(), highlight: [st, dr] });
          var aux = v[st];
          steps.push({ line: 3, vars: { v: v.slice(), n: n, st: st, dr: dr, aux: aux }, exp: 'Salvăm aux = v[' + st + '] = ' + aux, arr: v.slice(), highlight: [st, dr] });
          v[st] = v[dr];
          steps.push({ line: 4, vars: { v: v.slice(), n: n, st: st, dr: dr, aux: aux }, exp: 'v[' + st + '] = v[' + dr + '] = ' + v[st], arr: v.slice(), highlight: [st, dr] });
          v[dr] = aux;
          steps.push({ line: 5, vars: { v: v.slice(), n: n, st: st, dr: dr, aux: aux }, exp: 'v[' + dr + '] = aux = ' + aux + '. Schimb finalizat!', arr: v.slice(), highlight: [st, dr] });
          st++; dr--;
          steps.push({ line: 6, vars: { v: v.slice(), n: n, st: st, dr: dr, aux: aux }, exp: 'Avansăm indicii: st = ' + st + ', dr = ' + dr, arr: v.slice(), highlight: st < dr ? [st, dr] : [] });
        }
        steps.push({ line: 2, vars: { v: v.slice(), n: n, st: st, dr: dr, aux: '?' }, exp: 'st < dr? adică ' + st + ' < ' + dr + ' (Fals — stop). Vectorul a fost inversat!', arr: v.slice(), done: true });
        return { steps: steps, result: 'Vector inversat: [' + v.join(', ') + ']' };
      }
