          }
        }
        var ans = Math.max.apply(null, dp);
        steps.push({ line: 5, vars: { v: v, n: n, dp: dp.slice(), res: ans }, exp: 'Lungimea celui mai lung subșir crescător este: ' + ans, arr: v.slice(), done: true });
