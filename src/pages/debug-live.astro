          for (var j = 0; j < n - 1; j++) {
            v[j] = v[j+1];
            steps.push({ line: 4, vars: { v: v.slice(), k: k, n: n, i: i, j: j, tmp: tmp }, exp: 'v[' + j + '] precăpătat din v[' + (j+1) + '] = ' + v[j], arr: v.slice(), highlight: [j, j+1] });
          }
          v[n-1] = tmp;
          steps.push({ line: 5, vars: { v: v.slice(), k: k, n: n, i: i, j: n-1, tmp: tmp }, exp: 'Mutăm valoarea salvată în tmp la final: v[' + (n-1) + '] = ' + tmp, arr: v.slice(), highlight: [n-1] });
        }
        steps.push({ line: 7, vars: { v: v.slice() }, exp: 'Rotație finalizată cu succes!', arr: v.slice(), done: true });
        return { steps: steps, result: 'Vector rotit: [' + v.join(', ') + ']' };
