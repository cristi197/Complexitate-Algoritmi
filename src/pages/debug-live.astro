        var n = v.length;
        var steps = [];
        var arr = v.slice();
        steps.push({ line: 0, vars: { v: arr.slice(), n: n, exp: '?' }, exp: 'Inițiem Radix Sort.', arr: arr.slice() });
        var maxV = Math.max.apply(null, arr);
        steps.push({ line: 1, vars: { v: arr.slice(), n: n, maxV: maxV }, exp: 'Găsim elementul maxim: ' + maxV, arr: arr.slice() });
        
        for (var exp = 1; Math.floor(maxV / exp) > 0; exp *= 10) {
          steps.push({ line: 2, vars: { v: arr.slice(), n: n, maxV: maxV, exp: exp }, exp: 'Rulăm sortarea prin distribuire pentru cifra unităților de ordinul ' + exp, arr: arr.slice() });
          
          var cnt = new Array(10).fill(0);
          var out = new Array(n).fill(0);
          for (var i = 0; i < n; i++) {
            var digit = Math.floor(arr[i] / exp) % 10;
            cnt[digit]++;
          }
          for (var i = 1; i < 10; i++) cnt[i] += cnt[i-1];
          for (var i = n - 1; i >= 0; i--) {
            var digit = Math.floor(arr[i] / exp) % 10;
            var j = cnt[digit] - 1;
            cnt[digit]--;
            out[j] = arr[i];
          }
          arr = out.slice();
          steps.push({ line: 3, vars: { v: arr.slice(), exp: exp }, exp: 'După sortarea după grupul de cifre ' + exp + ', vectorul devine: [' + arr.join(', ') + ']', arr: arr.slice() });
        }
        steps.push({ line: 4, vars: { v: arr.slice() }, exp: 'Gata! S-au sortat toate cifrele, vectorul este complet sortat.', arr: arr.slice(), done: true });
        return { steps: steps, result: 'Sortat radix: [' + arr.join(', ') + ']' };
      }
    },
