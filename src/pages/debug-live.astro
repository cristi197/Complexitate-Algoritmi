            steps.push({ line: 2, vars: { x: xi, n: ni, rez: result }, exp: 'â†‘ Revenire: ' + xi + ' أ— putere(' + xi + ', ' + (ni-1) + ') = ' + xi + ' أ— ' + sub + ' = ' + result });
          }
          callStack.pop();
          return result;
        }
        steps.push({ line: 5, vars: { x: x, n: n, rez: '?' }, exp: 'Calculؤƒm ' + x + '^' + n });
        var rez = simulate(x, n);
        steps.push({ line: 7, vars: { x: x, n: n, rez: rez }, exp: x + '^' + n + ' = ' + rez, done: true });
        return { steps: steps, result: x + '^' + n + ' = ' + rez };
      }
    },

