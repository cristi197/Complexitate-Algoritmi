    'fusiune-vectori': {
      name: 'Fuziune Doi Vectori Sortați',
      fileName: 'merge.cpp',
      codeLines: [
        'void merge(int a[], int b[], int c[], int n, int m) {',
        '  int i = 0, j = 0, k = 0;',
        '  while (i < n && j < m)',
        '    if (a[i] <= b[j]) c[k++] = a[i++];',
