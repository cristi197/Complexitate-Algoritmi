            steps.push({ line: 4, vars: { v: v.slice(), n: n, x: x, i: i }, exp: 'Gؤƒsit la poziب›ia ' + i + '! Funcب›ia se terminؤƒ.', arr: v.slice(), highlight: [i], done: true });
            return { steps: steps, result: 'Gؤƒsit la poziب›ia ' + i };
