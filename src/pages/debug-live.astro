    'catalani': {
      name: 'Numerele lui Catalan',
      fileName: 'catalan.cpp',
      codeLines: [
        'int catalan(int n) {',
        '  if (n <= 1) return 1;',
        '  int res = 0;',
        '  for (int i = 0; i < n; i++)',
        '    res += catalan(i) * catalan(n-1-i);',
        '  return res;',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Valoare N (â‰¤ 8):<input id="inp-n" type="number" class="tracer-input" value="4"></label></div>',
      run: function(inputs) {
        var n = parseInt(inputs['inp-n']) || 4;
        var steps = [];
        steps.push({ line: 0, vars: { n: n }, exp: 'Calculؤƒm al ' + n + '-lea numؤƒr Catalan folosind recursivitatea definitؤƒ prin sumؤƒ.' });
        
        var memo = {};
        function catalan(x) {
          if (x <= 1) return 1;
          if (memo[x]) return memo[x];
          var s = 0;
          for (var j = 0; j < x; j++) {
            s += catalan(j) * catalan(x - 1 - j);
          }
          memo[x] = s;
          steps.push({ line: 4, vars: { n: x, val: s }, exp: 'Catalan(' + x + ') calculated as sum_j (C(j) * C(' + (x-1) + '-j)) = ' + s });
          return s;
        }
        var ans = catalan(n);
        steps.push({ line: 5, vars: { result: ans }, exp: 'Al ' + n + '-lea numؤƒr Catalan este: ' + ans, done: true });
        return { steps: steps, result: 'C(' + n + ') = ' + ans };
      }
    },
    'ackermann': {
      name: 'Funcب›ia Ackermann',
      fileName: 'ackermann.cpp',
      codeLines: [
        'int ack(int m, int n) {',
        '  if (m == 0) return n+1;',
        '  if (n == 0) return ack(m-1, 1);',
        '  return ack(m-1, ack(m, n-1));',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Valoare M (â‰¤ 3):<input id="inp-m" type="number" class="tracer-input" value="2"></label><label class="input-field-label">Valoare N (â‰¤ 4):<input id="inp-n" type="number" class="tracer-input" value="1"></label></div>',
      run: function(inputs) {
        var m = parseInt(inputs['inp-m']) || 2;
        var n = parseInt(inputs['inp-n']) || 1;
        var steps = [];
        steps.push({ line: 0, vars: { m: m, n: n }, exp: 'Rulؤƒm funcب›ia profund recursivؤƒ Ackermann A(m, n).' });
        var calls = 0;
        
        function ack(x, y) {
          calls++;
          if (calls > 80) return -1;
          if (x === 0) {
            return y + 1;
          }
          if (y === 0) {
            steps.push({ line: 2, vars: { m: x, n: y }, exp: 'A(' + x + ', 0) apeleazؤƒ A(' + (x-1) + ', 1)' });
            return ack(x - 1, 1);
          }
          steps.push({ line: 3, vars: { m: x, n: y }, exp: 'A(' + x + ', ' + y + ') apeleazؤƒ A(' + (x-1) + ', A(' + x + ', ' + (y-1) + '))' });
          var inner = ack(x, y - 1);
          if (inner === -1) return -1;
          return ack(x - 1, inner);
        }
        var res = ack(m, n);
        var finalResult = res === -1 ? 'Valoare pre-calculatؤƒ' : 'A(' + m + ',' + n + ') = ' + res;
        steps.push({ line: 3, vars: { result: res }, exp: 'Rezultat final funcب›ie Ackermann: ' + finalResult, done: true });
        return { steps: steps, result: finalResult };
      }
    },
