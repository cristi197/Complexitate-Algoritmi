      codeLines: [
        'bool isArmstrong(int n) {',
        '  int orig = n, sum = 0, digits = 0;',
        '  int tmp = n;',
        '  while (tmp) { digits++; tmp /= 10; }',
        '  tmp = n;',
        '  while (tmp) { int d = tmp%10; sum += pow(d,digits); tmp /= 10; }',
        '  return sum == orig;',
        '}'
      ],
