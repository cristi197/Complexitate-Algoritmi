            return 0;
          }
          var val = v[idx - 1];
          var partial = sumRec(idx - 1, curSum + val);
          var tot = val + partial;
          steps.push({ line: 2, vars: { idx: idx, term: val, partial: partial, total: tot }, exp: 'Adăugăm v[' + (idx-1) + '] (' + val + ') la suma elementelor anterioare (' + partial + '). Suma = ' + tot, arr: v.slice(), highlight: [idx - 1] });
          return tot;
        }
        var res = sumRec(n, 0);
        steps.push({ line: 2, vars: { result: res }, exp: 'Suma elementelor vectorului calculată recursiv este: ' + res, arr: v.slice(), done: true });
        return { steps: steps, result: 'Suma = ' + res };
      }
