        var n = v.length;
        var steps = [];
        steps.push({ line: 0, vars: { v: v, x: x, n: n }, exp: 'Iniب›iem Jump Search pentru valoarea ' + x, arr: v.slice() });
        var step = Math.floor(Math.sqrt(n));
        var prev = 0;
        steps.push({ line: 1, vars: { v: v, x: x, n: n, step: step, prev: prev }, exp: 'Stabilim lungimea saltului: step = sqrt(' + n + ') = ' + step + '.', arr: v.slice() });
        
        while (v[Math.min(step, n) - 1] < x) {
          steps.push({ line: 2, vars: { v: v, x: x, n: n, step: step, prev: prev }, exp: 'Elementul de la capؤƒtul blocului saltului v[' + (Math.min(step, n) - 1) + '] (' + v[Math.min(step, n) - 1] + ') < ' + x + '. Efectuؤƒm saltul.', arr: v.slice(), highlight: [Math.min(step, n) - 1] });
          prev = step;
          step += Math.floor(Math.sqrt(n));
          if (prev >= n) {
            steps.push({ line: 2, vars: { v: v, x: x, n: n, prev: prev }, exp: 'Aria de cؤƒutare a depؤƒب™it limitele vectorului. Valoarea nu existؤƒ.', arr: v.slice(), done: true });
            return { steps: steps, result: 'Negؤƒsit' };
          }
        }
        
        var limit = Math.min(step, n);
        steps.push({ line: 3, vars: { v: v, x: x, n: n, prev: prev, limit: limit }, exp: 'Valoarea ar trebui sؤƒ aparب›inؤƒ blocului liniar [' + prev + '...' + (limit - 1) + ']. Iniب›iem cؤƒutarea liniarؤƒ.', arr: v.slice(), highlight: [prev, limit-1] });
        var foundIdx = -1;
        for (var i = prev; i < limit; i++) {
          steps.push({ line: 4, vars: { v: v, x: x, n: n, i: i, temp: v[i] }, exp: 'Comparam v[' + i + '] = ' + v[i] + ' cu ' + x, arr: v.slice(), highlight: [i] });
          if (v[i] === x) {
            foundIdx = i;
            break;
          }
        }
        if (foundIdx !== -1) {
          steps.push({ line: 4, vars: { v: v, x: x, n: n, i: foundIdx }, exp: 'Valoarea a fost gؤƒsitؤƒ la indexul ' + foundIdx, arr: v.slice(), highlight: [foundIdx], done: true });
        } else {
          steps.push({ line: 5, vars: { v: v, x: x, n: n }, exp: 'Am cؤƒutat linear pe segment, dar nu am gؤƒsit valoarea.', arr: v.slice(), done: true });
        }
        return { steps: steps, result: foundIdx >= 0 ? 'Gؤƒsit la index ' + foundIdx : 'Negؤƒsit' };
      }
    },
