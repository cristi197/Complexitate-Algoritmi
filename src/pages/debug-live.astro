        function simulate(k) {
          callStack.push('fact(' + k + ')');
          var stackStr = callStack.join(' â†’ ');
          steps.push({ line: 0, vars: { n: k, rez: '?', apel: 'factRec(' + k + ')', adancime: callStack.length }, exp: 'â†“ Apel: factRec(' + k + ')  |  Stivؤƒ: ' + stackStr });
