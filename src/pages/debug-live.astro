        steps.push({ line: 0, vars: { a: a, b: b, c: [], i: '?', j: '?', k: '?' }, exp: 'Inițiem fuziunea celor doi vectori.', arr: a.concat(b) });
        steps.push({ line: 1, vars: { a: a, b: b, c: [], i: 0, j: 0, k: 0 }, exp: 'Inițializăm indicii i = 0, j = 0, k = 0.', arr: a.concat(b), highlight: [0, n] });
        while(i < n && j < m) {
          steps.push({ line: 2, vars: { a: a, b: b, c: c.slice(), i: i, j: j, k: k }, exp: 'Comparam a[' + i + '] (' + a[i] + ') cu b[' + j + '] (' + b[j] + ')', arr: a.concat(b), highlight: [i, n + j] });
          if (a[i] <= b[j]) {
            c[k] = a[i];
            steps.push({ line: 3, vars: { a: a, b: b, c: c.slice(), i: i, j: j, k: k }, exp: 'a[' + i + '] <= b[' + j + '] → Adăugăm a[' + i + '] = ' + a[i] + ' în c. Avansăm i și k.', arr: c.slice() });
            i++; k++;
