      codeLines: [
        'void countSort(int v[], int n) {',
        '  int cnt[10] = {0};',
        '  for (int i = 0; i < n; i++) cnt[v[i]]++;',
        '  for (int i = 1; i < 10; i++) cnt[i] += cnt[i-1];',
        '  for (int i = n-1; i >= 0; i--) {',
        '    int idx = cnt[v[i]]--; out[idx] = v[i];',
        '  }',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector (numere mici, 0-9):<input id="inp-v" class="tracer-input" value="1 4 1 2 7 5"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var steps = [];
        var maxK = 10;
        var cnt = new Array(maxK).fill(0);
        var out = new Array(n).fill(0);
        
        steps.push({ line: 0, vars: { v: v.slice(), n: n, cnt: cnt.slice(), out: out.slice() }, exp: 'Inițiem Counting Sort pentru elemente mici (gama 0..9).', arr: v.slice() });
        steps.push({ line: 1, vars: { v: v.slice(), n: n, cnt: cnt.slice() }, exp: 'Am alocat vectorul de frecvență cnt cu ' + maxK + ' elemente setate pe 0.', arr: v.slice() });
        for (var i = 0; i < n; i++) {
          cnt[v[i]]++;
          steps.push({ line: 2, vars: { v: v.slice(), n: n, i: i, cnt: cnt.slice() }, exp: 'Incrementăm frecvența pentru v[' + i + '] = ' + v[i] + '. cnt[' + v[i] + '] devine ' + cnt[v[i]], arr: v.slice(), highlight: [i] });
        }
        steps.push({ line: 3, vars: { v: v.slice(), n: n, cnt: cnt.slice() }, exp: 'Calculăm sumele prefixate în cnt pentru a afla pozițiile corecte în vectorul rezultat.', arr: v.slice() });
        for (var i = 1; i < maxK; i++) {
          cnt[i] += cnt[i-1];
        }
        steps.push({ line: 3, vars: { v: v.slice(), n: n, cnt: cnt.slice() }, exp: 'Vectorul de poziții/frecvențe cumulate este: cnt = [' + cnt.join(', ') + ']', arr: v.slice() });
        
        for (var i = n - 1; i >= 0; i--) {
          var val = v[i];
          var j = cnt[val] - 1;
          cnt[val]--;
