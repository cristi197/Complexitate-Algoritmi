---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const algorithms = [
  {
    id: 'bubble-sort',
    name: 'Bubble Sort',
    description: 'Sortare prin interschimbare repetată de elemente adiacente. O(n²).',
    category: 'Sortare',
    vars: ['v', 'n', 'i', 'ok', 'aux'],
    steps: [] // generated by JS
  },
  {
    id: 'cautare-liniara',
    name: 'Căutare liniară',
    description: 'Caută un element x în vector. O(n).',
    category: 'Căutare',
    vars: ['v', 'n', 'x', 'i'],
    steps: []
  },
  {
    id: 'cautare-binara',
    name: 'Căutare binară',
    description: 'Caută un element x în vector sortat. O(log n).',
    category: 'Căutare',
    vars: ['v', 'n', 'x', 'st', 'dr', 'mij'],
    steps: []
  },
  {
    id: 'factorial',
    name: 'Factorial iterativ',
    description: 'Calculează n! iterativ. O(n).',
    category: 'Matematic',
    vars: ['n', 'i', 'rez'],
    steps: []
  },
  {
    id: 'max-vector',
    name: 'Maxim din vector',
    description: 'Găsește valoarea maximă dintr-un vector. O(n).',
    category: 'Vectori',
    vars: ['v', 'n', 'i', 'maxim'],
    steps: []
  },
  {
    id: 'suma-cifre',
    name: 'Suma cifrelor',
    description: 'Calculează suma cifrelor unui număr. O(log n).',
    category: 'Numere',
    vars: ['n', 'suma', 'cifra'],
    steps: []
  },
  // ── Vectori ──
  { id: 'minim-vector', name: 'Minim din vector', description: 'Găsește valoarea minimă dintr-un vector. O(n).', category: 'Vectori', vars: ['v', 'n', 'i', 'minim'], steps: [] },
  { id: 'suma-vector', name: 'Suma elementelor vectorului', description: 'Calculează suma tuturor elementelor unui vector. O(n).', category: 'Vectori', vars: ['v', 'n', 'i', 'suma'], steps: [] },
  { id: 'inversare-vector', name: 'Inversare vector (in-place)', description: 'Inversează elementele cu doi indici st/dr care se întâlnesc la mijloc. O(n).', category: 'Vectori', vars: ['v', 'n', 'st', 'dr', 'aux'], steps: [] },
  { id: 'numarare-par', name: 'Numărare elemente pare', description: 'Numără câte elemente pare există într-un vector. O(n).', category: 'Vectori', vars: ['v', 'n', 'i', 'cnt'], steps: [] },
  // ── Sortare ──
  { id: 'selection-sort', name: 'Selection Sort', description: 'Selectează minimul din subvectorul nesortat și îl aduce la loc. O(n²).', category: 'Sortare', vars: ['v', 'n', 'i', 'j', 'pmin', 'aux'], steps: [] },
  { id: 'insertion-sort', name: 'Insertion Sort', description: 'Inserează fiecare element în locul potrivit din prefixul sortat. O(n²).', category: 'Sortare', vars: ['v', 'n', 'i', 'j', 'key'], steps: [] },
  // ── Numere ──
  { id: 'nr-prim', name: 'Verificare număr prim', description: 'Împarte la toți candidații până la √n. O(√n).', category: 'Numere', vars: ['n', 'i', 'prim'], steps: [] },
  { id: 'cmmdc', name: 'CMMDC — Algoritmul lui Euclid', description: 'Cel mai mare divizor comun prin împărțiri repetate. O(log n).', category: 'Numere', vars: ['a', 'b', 'r'], steps: [] },
  { id: 'nr-cifre', name: 'Numărul de cifre', description: 'Numără cifrele unui număr împărțind repetat la 10. O(log n).', category: 'Numere', vars: ['n', 'cnt'], steps: [] },
  { id: 'palindrom-nr', name: 'Palindrom număr', description: 'Construiește inversul numărului și compară cu originalul. O(log n).', category: 'Numere', vars: ['n', 'inv', 'orig'], steps: [] },
  // ── Recursivitate ──
  { id: 'factorial-rec', name: 'Factorial Recursiv', description: 'Calculează n! prin funcție recursivă — urmărește stiva de apeluri! O(n).', category: 'Recursivitate', vars: ['n', 'rez', 'apel', 'adancime'], steps: [] },
  { id: 'fibonacci', name: 'Fibonacci Iterativ', description: 'Calculează al n-lea număr din șirul Fibonacci fără recursivitate. O(n).', category: 'Recursivitate', vars: ['n', 'i', 'a', 'b', 'c'], steps: [] },
  { id: 'putere-rec', name: 'Putere recursivă x^n', description: 'Calculează x la puterea n printr-un apel recursiv. O(n).', category: 'Recursivitate', vars: ['x', 'n', 'rez'], steps: [] },
  // ── Șiruri de caractere ──
  { id: 'lungime-sir', name: 'Lungimea unui șir', description: 'Numără caracterele până la \'\\0\', replicând strlen(). O(n).', category: 'Siruri', vars: ['s', 'i', 'lung'], steps: [] },
  { id: 'palindrom-sir', name: 'Palindrom șir de caractere', description: 'Compară primul cu ultimul caracter și avansează spre centru. O(n).', category: 'Siruri', vars: ['s', 'st', 'dr', 'ok'], steps: [] },
  { id: 'numarare-vocale', name: 'Numărare vocale', description: 'Parcurge fiecare caracter și verifică dacă este vocală. O(n).', category: 'Siruri', vars: ['s', 'i', 'cnt'], steps: [] },
  // ── Matrici ──
  { id: 'suma-matrice', name: 'Suma elementelor matricei', description: 'Parcurge toată matricea cu două bucle for imbricate. O(n×m).', category: 'Matrici', vars: ['a', 'n', 'm', 'i', 'j', 'suma'], steps: [] },
  { id: 'diagonala-principala', name: 'Suma diagonalei principale', description: 'Suma elementelor a[i][i] pentru o matrice pătratică. O(n).', category: 'Matrici', vars: ['a', 'n', 'i', 'suma'], steps: [] },
  // ── Backtracking ──
  { id: 'permutari', name: 'Permutări prin Backtracking', description: 'Generează toate permutările {1,..,n} prin recursie și revenire. O(n!).', category: 'Backtracking', vars: ['p', 'k', 'solutii', 'folosit'], steps: [] },

  // ════════════════════ 75 ALGORITMI NOI ════════════════════

  // VECTORI +12
  { id: 'inversare-recursiv', name: 'Inversare Vector (Recursiv)', description: 'Inversează recursiv un vector cu doi parametri st și dr. O(n).', category: 'Vectori', vars: ['v', 'st', 'dr', 'aux'], steps: [] },
  { id: 'rotatie-vector', name: 'Rotație Vector', description: 'Rotește vectorul la stânga cu k poziții. O(n).', category: 'Vectori', vars: ['v', 'n', 'k', 'i', 'j'], steps: [] },
  { id: 'eliminar-duplicat', name: 'Eliminare Duplicat din Vector Sortat', description: 'Șterge duplicatele din vector sortat și returnează noua lungime. O(n).', category: 'Vectori', vars: ['v', 'n', 'i', 'j', 'len'], steps: [] },
  { id: 'fusiune-vectori', name: 'Fusiune Doi Vectori Sortați', description: 'Combină doi vectori sortați în al treilea vector sortat. O(m+n).', category: 'Vectori', vars: ['a', 'b', 'c', 'i', 'j', 'k'], steps: [] },
  { id: 'subsecventa-suma-max', name: 'Subsecvență cu Suma Maximă (Kadane)', description: 'Găsește subarray cu suma maximă folosind algoritmul lui Kadane. O(n).', category: 'Vectori', vars: ['v', 'n', 'suma_max', 'suma_curenta'], steps: [] },
  { id: 'k-lea-element', name: 'K-lea Element Cel Mai Mare', description: 'Găsește k-lea element cel mai mare dintr-un vector. O(n log k).', category: 'Vectori', vars: ['v', 'n', 'k', 'i'], steps: [] },
  { id: 'element-majoritar', name: 'Element Majoritar (Boyer-Moore)', description: 'Găsește element care apare mai mult de n/2 ori. O(n).', category: 'Vectori', vars: ['v', 'n', 'candidate', 'count'], steps: [] },
  { id: 'vector-ascendent', name: 'Verificare Vector Ascendent', description: 'Verifică dacă vectorul este sortat în ordine strict ascendentă. O(n).', category: 'Vectori', vars: ['v', 'n', 'i', 'ok'], steps: [] },
  { id: 'produsul-altor', name: 'Produsul Celorlalți Elemente', description: 'Pentru fiecare element, calculează produsul celorlalți (fără împărțire). O(n).', category: 'Vectori', vars: ['v', 'n', 'prod', 'i'], steps: [] },
  { id: 'frecventa-maxima', name: 'Element cu Frecvență Maximă', description: 'Găsește elementul care apare cel mai des în vector. O(n).', category: 'Vectori', vars: ['v', 'n', 'i', 'freq_max', 'elem_max'], steps: [] },
  { id: 'separator-culorilor', name: 'Separator 0, 1, 2 (Sortare Olandeză)', description: 'Sortează 0, 1, 2 in-place fără a folosi algoritm de sortare. O(n).', category: 'Vectori', vars: ['v', 'n', 'low', 'mid', 'high'], steps: [] },
  { id: 'subsir-crescator', name: 'Subsir Crescător Maximal', description: 'Găsește lungimea celui mai lung subsir crescător prin DP. O(n²) sau O(n log n).', category: 'Vectori', vars: ['v', 'n', 'i', 'j', 'len_max'], steps: [] },

  // SORTARE +6
  { id: 'merge-sort', name: 'Merge Sort', description: 'Sortare prin fuziune - divide et impera. O(n log n).', category: 'Sortare', vars: ['v', 'n', 'st', 'dr', 'mij'], steps: [] },
  { id: 'quick-sort', name: 'Quick Sort', description: 'Sortare prin partiție - divide et impera randomizat. O(n log n) mediu.', category: 'Sortare', vars: ['v', 'n', 'st', 'dr', 'pivot'], steps: [] },
  { id: 'heap-sort', name: 'Heap Sort', description: 'Sortare prin heap - construiește min/max heap. O(n log n).', category: 'Sortare', vars: ['v', 'n', 'i', 'heap_size'], steps: [] },
  { id: 'count-sort', name: 'Count Sort (numărare)', description: 'Sortare prin numărare - pentru valori în interval cunoscut. O(n+k).', category: 'Sortare', vars: ['v', 'n', 'count', 'i'], steps: [] },
  { id: 'radix-sort', name: 'Radix Sort', description: 'Sortare pe cifre - stabil, non-comparative. O(d×(n+k)).', category: 'Sortare', vars: ['v', 'n', 'd', 'i', 'exp'], steps: [] },
  { id: 'gnome-sort', name: 'Gnome Sort', description: 'Sortare simplă - similară cu Insertion Sort. O(n²).', category: 'Sortare', vars: ['v', 'n', 'i', 'j'], steps: [] },

  // CĂUTARE +5
  { id: 'cautare-ternara', name: 'Căutare Ternară', description: 'Divide-și-impera în 3 părți în loc de 2. O(log₃ n).', category: 'Căutare', vars: ['v', 'n', 'x', 'st', 'dr', 'mid1', 'mid2'], steps: [] },
  { id: 'cautare-exponentiale', name: 'Căutare Exponențială', description: 'Întinde exponențial până găsește interval, apoi căutare binară. O(log n).', category: 'Căutare', vars: ['v', 'n', 'x', 'i', 'st', 'dr'], steps: [] },
  { id: 'cautare-salturi', name: 'Căutare cu Salturi (Jump Search)', description: 'Sare cu √n și apoi face căutare liniară. O(√n).', category: 'Căutare', vars: ['v', 'n', 'x', 'jump', 'prev', 'i'], steps: [] },
  { id: 'cautare-matrice-2d', name: 'Căutare în Matrice Sortată 2D', description: 'Matrică sortată pe linii și coloane - startează din colțul opus. O(m+n).', category: 'Căutare', vars: ['a', 'n', 'm', 'x', 'i', 'j'], steps: [] },
  { id: 'cautare-interpolate', name: 'Căutare Interpolată', description: 'Estimează poziția pe baza valorii în vector uniform distribuit. O(log log n) mediu.', category: 'Căutare', vars: ['v', 'n', 'x', 'st', 'dr', 'pos'], steps: [] },

  // NUMERE +12
  { id: 'patrat-perfect', name: 'Pătrat Perfect', description: 'Verifică dacă n = k² pentru un întreg k. O(√n).', category: 'Numere', vars: ['n', 'sqrt_n', 'ok'], steps: [] },
  { id: 'perfect-square-sum', name: 'Suma Pătratelor', description: 'Calculează 1² + 2² + ... + n². O(1) sau O(n).', category: 'Numere', vars: ['n', 'i', 'suma'], steps: [] },
  { id: 'numarul-fericit', name: 'Număr Fericit', description: 'Suma cifrelor² se repetă până obții 1 (fericit) sau ciclu (triste). O(log n).', category: 'Numere', vars: ['n', 'suma', 'seen'], steps: [] },
  { id: 'armstrong', name: 'Număr Armstrong', description: 'n = sum(cifre^nr_cifre). Ex: 153 = 1³+5³+3³. O(log n).', category: 'Numere', vars: ['n', 'suma', 'cifra', 'nr_cifre'], steps: [] },
  { id: 'factori-primi', name: 'Factori Primi (descompunere)', description: 'Găsește toți factorii primi ai unui număr. O(√n).', category: 'Numere', vars: ['n', 'i', 'factori'], steps: [] },
  { id: 'lcm', name: 'LCM — Cel Mai Mic Multiplu Comun', description: 'CMMMC(a,b) = (a×b)/CMMDC(a,b). O(log min(a,b)).', category: 'Numere', vars: ['a', 'b', 'cmmdc_ab', 'lcm'], steps: [] },
  { id: 'fibonacci-check', name: 'Verificare Fibonacci', description: 'Verifică dacă n este din șirul Fibonacci. O(log n).', category: 'Numere', vars: ['n', 'a', 'b', 'ok'], steps: [] },
  { id: 'sieve-eratostene', name: 'Ciurul lui Eratostene', description: 'Găsește toate numerele prime până la n prin eliminare. O(n log log n).', category: 'Numere', vars: ['n', 'i', 'j', 'ciur'], steps: [] },
  { id: 'cel-mic-factor', name: 'Cel Mai Mic Factor Prim', description: 'Găsește factorul prim minimal al lui n. O(√n).', category: 'Numere', vars: ['n', 'i', 'factor'], steps: [] },
  { id: 'putere-perfecta', name: 'Putere Perfectă', description: 'Verifică dacă n = a^b pentru a,b ≥ 2. O(log² n).', category: 'Numere', vars: ['n', 'a', 'b', 'ok'], steps: [] },
  { id: 'abundent-deficient', name: 'Abundent/Deficient/Perfect', description: 'Clasifică număr după suma divizorilor proprii. O(√n).', category: 'Numere', vars: ['n', 'i', 'suma_div'], steps: [] },
  { id: 'hamming-distance', name: 'Distanța Hamming', description: 'Numără poziții diferite în reprezentarea binară. O(log n).', category: 'Numere', vars: ['a', 'b', 'xor', 'dist'], steps: [] },

  // RECURSIVITATE +8
  { id: 'gcd-recursiv', name: 'GCD Recursiv', description: 'CMMDC prin recursie simplă a lui Euclid. O(log min(a,b)).', category: 'Recursivitate', vars: ['a', 'b', 'rez'], steps: [] },
  { id: 'suma-vector-rec', name: 'Suma Vector Recursiv', description: 'Suma elementelor unui vector prin apel recursiv pe prefixe. O(n).', category: 'Recursivitate', vars: ['v', 'n', 'i', 'suma'], steps: [] },
  { id: 'inversare-sir-rec', name: 'Inversare Șir Recursiv', description: 'Inversează un șir din două capete cu apeluri recursive. O(n).', category: 'Recursivitate', vars: ['s', 'st', 'dr'], steps: [] },
  { id: 'hanoi', name: 'Tornyul din Hanoi', description: 'Mută n discuri între 3 tije urmând reguli. O(2^n-1).', category: 'Recursivitate', vars: ['n', 'from', 'to', 'aux', 'mutari'], steps: [] },
  { id: 'catalani', name: 'Număr Catalan (recursiv)', description: 'C(n) = C(0)×C(n-1) + C(1)×C(n-2) + ... O(n) cu DP.', category: 'Recursivitate', vars: ['n', 'i', 'catalan'], steps: [] },
  { id: 'ackermann', name: 'Funcția Ackermann', description: 'Funcție recursivă rapidă - creștere enormă. A(m,n).', category: 'Recursivitate', vars: ['m', 'n', 'rez'], steps: [] },
  { id: 'compar-subarray', name: 'Comparare Subarray Recursiv', description: 'Compară două subarray-uri cu apeluri recursive. O(n).', category: 'Recursivitate', vars: ['a', 'b', 'i', 'ok'], steps: [] },
  { id: 'produs-numeric-rec', name: 'Produs Numeric Recursiv', description: 'Calculează produsul cifrelor unui număr recursiv. O(log n).', category: 'Recursivitate', vars: ['n', 'produs'], steps: [] },

  // ȘIRURI +12
  { id: 'inversare-sir', name: 'Inversare Șir (Iterativ)', description: 'Inversează un șir in-place cu doi indici. O(n).', category: 'Siruri', vars: ['s', 'st', 'dr'], steps: [] },
  { id: 'anagram', name: 'Verificare Anagram', description: 'Verifică dacă două șiruri sunt anagrame (anagramă checker). O(n).', category: 'Siruri', vars: ['s1', 's2', 'ok'], steps: [] },
  { id: 'eliminar-spatii', name: 'Eliminare Spații', description: 'Șterge toate spațiile dintr-un șir. O(n).', category: 'Siruri', vars: ['s', 'i', 'j'], steps: [] },
  { id: 'case-upper', name: 'Conversie la Majuscule', description: 'Convertește șirul la majuscule. O(n).', category: 'Siruri', vars: ['s', 'i'], steps: [] },
  { id: 'case-lower', name: 'Conversie la Minuscule', description: 'Convertește șirul la minuscule. O(n).', category: 'Siruri', vars: ['s', 'i'], steps: [] },
  { id: 'prefix-comun', name: 'Prefix Comun Maximal', description: 'Găsește cel mai lung prefix comun al mai multor șiruri. O(n×m).', category: 'Siruri', vars: ['s1', 's2', 'i', 'prefix_len'], steps: [] },
  { id: 'potrivire-model-naive', name: 'Potrivire Model (Naiv)', description: 'Caută apariții ale unui model în text. O((n-m+1)×m).', category: 'Siruri', vars: ['text', 'pattern', 'i', 'j'], steps: [] },
  { id: 'kmp-search', name: 'Căutare KMP', description: 'Căutare eficientă a unui model în text cu tabel KMP. O(n+m).', category: 'Siruri', vars: ['text', 'pattern', 'i', 'j'], steps: [] },
  { id: 'rot13', name: 'Rot13 Cipher', description: 'Rotează fiecare literă cu 13 poziții în alfabet. O(n).', category: 'Siruri', vars: ['s', 'i', 'char'], steps: [] },
  { id: 'capitalizare', name: 'Capitalizare Cuvinte', description: 'Convertește prima literă a fiecărui cuvânt la majusculă. O(n).', category: 'Siruri', vars: ['s', 'i', 'capital'], steps: [] },
  { id: 'numara-caractere-unice', name: 'Numără Caractere Unice', description: 'Numără caractere distincte într-un șir. O(n).', category: 'Siruri', vars: ['s', 'i', 'freq', 'unice'], steps: [] },
  { id: 'compressed-string', name: 'String Compression', description: 'Comprimă șirul în format run-length (aaabbc → a3b2c1). O(n).', category: 'Siruri', vars: ['s', 'i', 'j', 'compressed'], steps: [] },

  // MATRICI +12
  { id: 'rotire-matrice', name: 'Rotire Matrice 90°', description: 'Rotește matrice în sens invers acelor de ceasornic 90°. O(n²).', category: 'Matrici', vars: ['a', 'n', 'i', 'j', 'aux'], steps: [] },
  { id: 'transpozare-matrice', name: 'Transpozare Matrice', description: 'Interschimbă linii cu coloane - a[i][j] → a[j][i]. O(n×m).', category: 'Matrici', vars: ['a', 'n', 'm', 'i', 'j', 'tmp'], steps: [] },
  { id: 'spiral-matrice', name: 'Traversare Spirală', description: 'Parcurge matricea în ordine spirală de la exterior la centru. O(n×m).', category: 'Matrici', vars: ['a', 'n', 'm', 'top', 'bottom', 'left', 'right'], steps: [] },
  { id: 'determinant-2x2', name: 'Determinant Matrice 2×2', description: 'Det = a×d - b×c pentru matrice [[a,b],[c,d]]. O(1).', category: 'Matrici', vars: ['a', 'det'], steps: [] },
  { id: 'multiplicare-matrici', name: 'Multiplicare Matrici', description: 'C[i][j] = sum(A[i][k]×B[k][j]). O(n³) sau mai bine.', category: 'Matrici', vars: ['a', 'b', 'c', 'i', 'j', 'k'], steps: [] },
  { id: 'matrice-identitate', name: 'Matrice Identitate', description: 'Generează matrice I unde I[i][i]=1, rest 0. O(n²).', category: 'Matrici', vars: ['I', 'n', 'i', 'j'], steps: [] },
  { id: 'diagonala-secundara', name: 'Suma Diagonalei Secundare', description: 'Suma elementelor a[i][n-1-i] pentru i=0..n-1. O(n).', category: 'Matrici', vars: ['a', 'n', 'i', 'suma'], steps: [] },
  { id: 'flipping-01', name: 'Flipping 0 și 1', description: 'Interschimbă 0 ↔ 1 în matrice binară in-place. O(n×m).', category: 'Matrici', vars: ['a', 'n', 'm', 'i', 'j'], steps: [] },
  { id: 'medie-linii', name: 'Medie pe Fiecare Linie', description: 'Calculează media elementelor pe fiecare linie. O(n×m).', category: 'Matrici', vars: ['a', 'n', 'm', 'i', 'j', 'suma_linie', 'medie'], steps: [] },
  { id: 'min-max-matrice', name: 'Min și Max în Matrice', description: 'Găsește minim și maxim dintr-o matrice. O(n×m).', category: 'Matrici', vars: ['a', 'n', 'm', 'i', 'j', 'min', 'max'], steps: [] },
  { id: 'matrice-triunghiulara', name: 'Verificare Matrice Triunghiulară', description: 'Verifică dacă matrice este superior sau inferior triunghiulară. O(n²).', category: 'Matrici', vars: ['a', 'n', 'i', 'j', 'superior', 'inferior'], steps: [] },
  { id: 'trace-matrice', name: 'Trace Matrice (Urma)', description: 'Suma diagonalei principale a[i][i]. O(n).', category: 'Matrici', vars: ['a', 'n', 'i', 'trace'], steps: [] },

  // BACKTRACKING +8
  { id: 'n-regine', name: 'N-Regine (Backtracking)', description: 'Plasează n regine pe tablă n×n fără atacuri reciproce. O(n!).', category: 'Backtracking', vars: ['pozitii', 'n', 'solutii'], steps: [] },
  { id: 'hamiltonian', name: 'Drum Hamiltonian', description: 'Găsește drum care vizitează fiecare vârf o dată. O(n!).', category: 'Backtracking', vars: ['path', 'n', 'visited'], steps: [] },
  { id: 'knight-tour', name: 'Knight Tour', description: 'Mută calul peste toate pătratele unei tablei 8×8 o singură dată. O(8^64) backtracking.', category: 'Backtracking', vars: ['board', 'x', 'y', 'moves'], steps: [] },
  { id: 'labirint', name: 'Soluție Labirint', description: 'Găsește cale din start la end evitând obstacole cu backtracking. O(4^(n×m)).', category: 'Backtracking', vars: ['maze', 'x', 'y', 'path'], steps: [] },
  { id: 'combinatii', name: 'Combinații C(n,k)', description: 'Generează toate submulțimile de k elemente. O(C(n,k)).', category: 'Backtracking', vars: ['comb', 'n', 'k', 'idx'], steps: [] },
  { id: 'subseturi', name: 'Submulțimi (Subsets)', description: 'Generează toate 2^n submulțimi ale unei mulțimi. O(2^n).', category: 'Backtracking', vars: ['subset', 'n', 'i'], steps: [] },
  { id: 'partitii-suma', name: 'Partiție cu Sumă Egală', description: 'Împarte array în 2 submulțimi cu sume egale folosind DP/backtracking. O(n×sum/2).', category: 'Backtracking', vars: ['partition', 'suma_total'], steps: [] },
  { id: 'sudoku-solver', name: 'Sudoku Solver', description: 'Rezolvă puzzle-ul Sudoku cu backtracking și validare. O(9^(n*n)) backtracking.', category: 'Backtracking', vars: ['board', 'row', 'col', 'num'], steps: [] },
];
---
<BaseLayout
  title="Debug Live — Simulator Trasare Algoritm | InfoLiceu"
  description="Urmărește execuția algoritmilor pas cu pas cu noul simulator interactiv Debug Live. Perfect pentru Subiectul I de la BAC."
  bodyClass="has-sidebar"
>
  <Header />
  <Sidebar />

  <div class="app-shell">
    <div class="app-content" id="main-content">

      <!-- Hero -->
      <div class="chapter-hero" style="--hero-gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);">
        <a href={`${base}/`} class="chapter-hero-back">← Înapoi acasă</a>
        <h1><span aria-hidden="true">💻</span> Debug Live / Simulator Trasare</h1>
        <p>Alege un șablon de algoritm și un set de date prestabilit pentru a porni depanarea pas cu pas. Trasează exact ca la <strong>Subiectul I de la BAC</strong> cu ajutorul tabelului de trasare generat automat.</p>
        <div class="hero-badges" style="margin-top:1rem">
          <span class="hero-badge">📋 100 Algoritmi Completi</span>
          <span class="hero-badge">🚀 Șabloane Date prestabilite</span>
          <span class="hero-badge">📊 Tabel de Trasare Interactiv</span>
        </div>
      </div>

      <div class="wrapper" style="max-width:1100px;">

        <!-- Step 1: Choose Algorithm -->
        <div class="tracer-card">
          <h2 class="tracer-section-title">Step 1: Selectează Algoritmul</h2>

          <div class="algo-filter-bar">
            <input type="text" id="algo-search" placeholder="🔍 Caută algoritm..." class="algo-search-input" autocomplete="off">
            <div class="algo-cats-scroll">
              <div class="algo-cats" id="algo-cats">
                <button class="cat-btn active" data-cat="all">Toți</button>
                <button class="cat-btn" data-cat="Vectori">📦 Vectori</button>
                <button class="cat-btn" data-cat="Sortare">↕ Sortare</button>
                <button class="cat-btn" data-cat="Căutare">🔍 Căutare</button>
                <button class="cat-btn" data-cat="Numere">🔢 Numere</button>
                <button class="cat-btn" data-cat="Recursivitate">🔄 Recursivitate</button>
                <button class="cat-btn" data-cat="Siruri">📝 Șiruri</button>
                <button class="cat-btn" data-cat="Matrici">🔲 Matrici</button>
                <button class="cat-btn" data-cat="Backtracking">🌳 Backtracking</button>
              </div>
            </div>
          </div>

          <div class="algo-grid" id="algo-grid">
            <!-- filled by JS -->
          </div>
        </div>

        <!-- Step 2: Configure & Templates -->
        <div class="tracer-card" id="input-card" style="display:none">
          <h2 class="tracer-section-title">Step 2: Configurare & Șabloane de date</h2>
          
          <div class="templates-section">
            <h3 class="subsection-title">Alege un scenariu / set de date de test:</h3>
            <div class="quick-templates" id="templates-container">
              <!-- templates loaded dynamically by JS -->
            </div>
          </div>

          <div class="input-form">
            <h3 class="subsection-title">Sau personalizează datele manual:</h3>
            <div id="input-area"></div>
            <button class="tracer-btn tracer-btn--primary start-simulation-btn" id="start-btn">
              <span>▶</span> Pornește Depanatorul
            </button>
          </div>
        </div>

        <!-- Step 3: Interactive Debugger Workspace -->
        <div class="tracer-workspace" id="tracer-card" style="display:none">
          
          <!-- Control Bar -->
          <div class="debug-control-bar">
            <div class="control-left">
              <span class="pulse-indicator">● LIVE</span>
              <strong id="active-algo-title">Bubble Sort</strong>
            </div>
            
            <div class="control-center">
              <button class="control-btn" id="prev-btn" title="Pasul anterior" disabled>
                <i>⏮</i> Anterior
              </button>
              <div class="step-badge" id="step-info">Pas 0 / 0</div>
              <button class="control-btn control-btn--primary" id="next-btn" title="Pasul următor">
                Următor <i>⏭</i>
              </button>
            </div>

            <div class="control-right">
              <button class="control-btn control-btn--ghost" id="restart-btn" title="Reia de la început">
                <i>↺</i> Reîncepe
              </button>
              <button class="control-btn control-btn--ghost" id="change-algo-btn" title="Alege alt algoritm">
                <i>⚔</i> Schimbă
              </button>
            </div>
          </div>

          <!-- Debugger Grid layout -->
          <div class="tracer-layout">
            <!-- IDE / Code Editor view -->
            <div class="tracer-code-panel">
              <div class="ide-tab-header">
                <div class="ide-tab active">
                  <span class="ide-tab-icon">📄</span>
                  <span id="ide-filename">algoritm.cpp</span>
                </div>
                <div class="ide-tab-actions">
                  <span class="ide-dot green"></span>
                  <span class="ide-dot yellow"></span>
                  <span class="ide-dot red"></span>
                </div>
              </div>
              <div class="code-editor-scroller">
                <pre class="tracer-code" id="tracer-code"></pre>
              </div>
            </div>

            <!-- Panel side: State and variables -->
            <div class="tracer-side-panels">
              <!-- Variables list -->
              <div class="tracer-vars-panel">
                <div class="panel-header">
                  <span>📊 Valori Variable</span>
                  <small>Pasul curent</small>
                </div>
                <div class="panel-body">
                  <div class="tracer-vars" id="tracer-vars"></div>
                </div>
              </div>

              <!-- Explanation context helper -->
              <div class="tracer-exp-panel">
                <div class="panel-header">
                  <span>💡 Explicație Pas Curent</span>
                </div>
                <div class="panel-body">
                  <div class="tracer-explanation" id="tracer-exp"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Visualizing Arrays if applicable -->
          <div id="array-viz-wrap" style="display:none" class="array-visualizer-card">
            <div class="panel-header">
              <span>📈 Reprezentare Vizuală Vector v</span>
            </div>
            <div class="panel-body">
              <div class="array-viz" id="array-viz"></div>
            </div>
          </div>

          <!-- TRACE TABLE (Tabel de Trasare) -->
          <div class="trace-table-card">
            <div class="panel-header flex-header">
              <span>📋 Tabel de Trasare (Specific Subiectului I BAC)</span>
              <small>Fiecare rând corespunde unui pas de execuție. Apasă pe orice rând pentru a sări direct la acel pas!</small>
            </div>
            <div class="trace-table-scroller">
              <table class="trace-table" id="trace-table">
                <thead>
                  <tr id="trace-table-header">
                    <!-- filled by JS based on vars -->
                  </tr>
                </thead>
                <tbody id="trace-table-body">
                  <!-- filled by JS -->
                </tbody>
              </table>
            </div>
          </div>

        </div>

        <!-- Completion Alert -->
        <div class="tracer-card tracer-done" id="done-card" style="display:none">
          <div class="done-icon" aria-hidden="true">🎉</div>
          <h3>Simulare Finalizată cu Succes!</h3>
          <p id="done-msg"></p>
          <div class="done-actions">
            <button class="tracer-btn tracer-btn--primary" id="new-algo-btn">Alege alt algoritm</button>
            <button class="tracer-btn tracer-btn--secondary" id="replay-btn">Reia execuția pas cu pas</button>
          </div>
        </div>

      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script id="tracer-algos-data" type="application/json" set:html={JSON.stringify(algorithms)}></script>

