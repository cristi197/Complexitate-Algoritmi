            col--;
          } else {
            steps.push({ line: 5, vars: { m: m, n: n, x: x, i: row, j: col, val: val }, exp: 'Deoarece ' + val + ' < ' + x + ', cؤƒutؤƒm pe linia inferioarؤƒ. Incrementؤƒm linia.', arr: flatArr, highlight: [row * n + col] });
            row++;
