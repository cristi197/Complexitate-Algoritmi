  var ALGOS = {
    'bubble-sort': {
      name: 'Bubble Sort (Sortare prin Metoda Bulelor)',
      fileName: 'bubble_sort.cpp',
      codeLines: [
        'void bubbleSort(int v[], int n) {',
        '  bool ok;',
        '  do {',
        '    ok = true;',
        '    for (int i = 0; i < n-1; i++) {',
        '      if (v[i] > v[i+1]) {',
        '        int aux = v[i];',
        '        v[i] = v[i+1];',
        '        v[i+1] = aux;',
        '        ok = false;',
        '      }',
        '    }',
        '  } while (!ok);',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vectorul de numere (separate prin spaب›ii):<input id="inp-v" type="text" placeholder="ex: 5 3 8 1 4" class="tracer-input" value="5 3 8 1 4"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var steps = [];
        var ok;
        steps.push({ line: 0, vars: { v: v.slice(), n: n, ok: '?', i: '?', aux: '?' }, exp: 'Se أ®ncepe parcurgerea algoritmului Bubble Sort.', arr: v.slice() });
        do {
          ok = true;
          steps.push({ line: 3, vars: { v: v.slice(), n: n, ok: true, i: '?', aux: '?' }, exp: 'Setؤƒm presupunerea de sortare ok = true.', arr: v.slice() });
          for (var i = 0; i < n - 1; i++) {
            steps.push({ line: 4, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: '?' }, exp: 'Intrؤƒm أ®n bucla FOR. i = ' + i + ' (comparؤƒm v[' + i + '] cu v[' + (i+1) + ']).', arr: v.slice(), highlight: [i, i+1] });
            steps.push({ line: 5, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: '?' }, exp: 'Verificؤƒm elementele: ' + v[i] + ' > ' + v[i+1] + '? Rؤƒspuns: ' + (v[i] > v[i+1] ? 'DA' : 'NU'), arr: v.slice(), highlight: [i, i+1] });
            if (v[i] > v[i+1]) {
              var aux = v[i];
              steps.push({ line: 6, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'Salvare aux = ' + aux, arr: v.slice(), highlight: [i, i+1] });
              v[i] = v[i+1];
              steps.push({ line: 7, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'Copiem v[' + (i+1) + '] أ®n v[' + i + ']. Vectorul devine: ' + JSON.stringify(v), arr: v.slice(), highlight: [i, i+1] });
              v[i+1] = aux;
              steps.push({ line: 8, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'Restaurؤƒm aux أ®n v[' + (i+1) + ']. Schimb finalizat!', arr: v.slice(), highlight: [i, i+1] });
              ok = false;
              steps.push({ line: 9, vars: { v: v.slice(), n: n, ok: false, i: i, aux: aux }, exp: 'S-a fؤƒcut swap. Setؤƒm ok = false ca sؤƒ mai facem o trecere completؤƒ.', arr: v.slice() });
            }
          }
          steps.push({ line: 12, vars: { v: v.slice(), n: n, ok: ok, i: '?', aux: '?' }, exp: 'Sfأ¢rب™itul unei iteraب›ii complete. ok = ' + ok + '. Verificؤƒm condiب›ia: ' + (!ok ? '!ok este adevؤƒrat, reluؤƒm bucla do-while.' : '!ok este fals, terminؤƒm.'), arr: v.slice() });
        } while (!ok);
        steps.push({ line: 13, vars: { v: v.slice(), n: n, ok: ok, i: '?', aux: '?' }, exp: 'Am obب›inut vectorul sortat final: ' + JSON.stringify(v), arr: v.slice(), done: true });
        return { steps: steps, result: 'Vector sortat: [' + v.join(', ') + ']' };
      }
    },
