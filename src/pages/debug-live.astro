    'nr-prim': {
      name: 'Verificare Număr Prim',
      fileName: 'nr_prim.cpp',
      codeLines: [
        'bool estePrim(int n) {',
        '  if (n < 2) return false;',
        '  for (int i = 2; (long long)i*i <= n; i++) {',
        '    if (n % i == 0)',
        '      return false;',
        '  }',
        '  return true;',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Numărul n:<input id="inp-n" type="number" class="tracer-input" value="17" min="0" style="width:150px"></label></div>',
      run: function(inputs) {
        var n = parseInt(inputs['inp-n']);
        var steps = [];
        steps.push({ line: 0, vars: { n: n, i: '?', prim: '?' }, exp: 'Verificăm dacă n = ' + n + ' este număr prim.' });
        steps.push({ line: 1, vars: { n: n, i: '?', prim: '?' }, exp: 'n < 2? adică ' + n + ' < 2? ' + (n < 2 ? 'DA → returnăm false (nu e prim)' : 'NU → continuăm') });
        if (n < 2) {
          steps.push({ line: 1, vars: { n: n, i: '?', prim: false }, exp: n + ' nu este prim (n < 2).', done: true });
          return { steps: steps, result: n + ' NU este prim' };
        }
