  var ALGOS = {
    'bubble-sort': {
      name: 'Bubble Sort (Sortare prin Metoda Bulelor)',
      fileName: 'bubble_sort.cpp',
      codeLines: [
        'void bubbleSort(int v[], int n) {',
        '  bool ok;',
        '  do {',
        '    ok = true;',
        '    for (int i = 0; i < n-1; i++) {',
        '      if (v[i] > v[i+1]) {',
        '        int aux = v[i];',
        '        v[i] = v[i+1];',
        '        v[i+1] = aux;',
        '        ok = false;',
        '      }',
        '    }',
        '  } while (!ok);',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vectorul de numere (separate prin spații):<input id="inp-v" type="text" placeholder="ex: 5 3 8 1 4" class="tracer-input" value="5 3 8 1 4"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var steps = [];
        var ok;
        steps.push({ line: 0, vars: { v: v.slice(), n: n, ok: '?', i: '?', aux: '?' }, exp: 'Se începe parcurgerea algoritmului Bubble Sort.', arr: v.slice() });
        do {
          ok = true;
          steps.push({ line: 3, vars: { v: v.slice(), n: n, ok: true, i: '?', aux: '?' }, exp: 'Setăm presupunerea de sortare ok = true.', arr: v.slice() });
          for (var i = 0; i < n - 1; i++) {
            steps.push({ line: 4, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: '?' }, exp: 'Intrăm în bucla FOR. i = ' + i + ' (comparăm v[' + i + '] cu v[' + (i+1) + ']).', arr: v.slice(), highlight: [i, i+1] });
            steps.push({ line: 5, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: '?' }, exp: 'Verificăm elementele: ' + v[i] + ' > ' + v[i+1] + '? Răspuns: ' + (v[i] > v[i+1] ? 'DA' : 'NU'), arr: v.slice(), highlight: [i, i+1] });
            if (v[i] > v[i+1]) {
              var aux = v[i];
              steps.push({ line: 6, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'Salvare aux = ' + aux, arr: v.slice(), highlight: [i, i+1] });
              v[i] = v[i+1];
              steps.push({ line: 7, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'Copiem v[' + (i+1) + '] în v[' + i + ']. Vectorul devine: ' + JSON.stringify(v), arr: v.slice(), highlight: [i, i+1] });
              v[i+1] = aux;
              steps.push({ line: 8, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'Restaurăm aux în v[' + (i+1) + ']. Schimb finalizat!', arr: v.slice(), highlight: [i, i+1] });
              ok = false;
              steps.push({ line: 9, vars: { v: v.slice(), n: n, ok: false, i: i, aux: aux }, exp: 'S-a făcut swap. Setăm ok = false ca să mai facem o trecere completă.', arr: v.slice() });
            }
          }
          steps.push({ line: 12, vars: { v: v.slice(), n: n, ok: ok, i: '?', aux: '?' }, exp: 'Sfârșitul unei iterații complete. ok = ' + ok + '. Verificăm condiția: ' + (!ok ? '!ok este adevărat, reluăm bucla do-while.' : '!ok este fals, terminăm.'), arr: v.slice() });
        } while (!ok);
        steps.push({ line: 13, vars: { v: v.slice(), n: n, ok: ok, i: '?', aux: '?' }, exp: 'Am obținut vectorul sortat final: ' + JSON.stringify(v), arr: v.slice(), done: true });
        return { steps: steps, result: 'Vector sortat: [' + v.join(', ') + ']' };
      }
    },
    'cautare-liniara': {
      name: 'Căutare Liniară (Secvențială)',
      fileName: 'cautare_liniara.cpp',
      codeLines: [
        'int cautareLiniara(int v[], int n, int x) {',
        '  for (int i = 0; i < n; i++) {',
        '    if (v[i] == x) {',
        '      return i;  // găsit la poziția i',
        '    }',
        '  }',
        '  return -1;  // negăsit',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector:<input id="inp-v" type="text" placeholder="ex: 5 3 8 1 4" class="tracer-input" value="5 3 8 1 4"></label><label class="input-field-label">Valoarea căutată x:<input id="inp-x" type="number" class="tracer-input" value="8" style="width: auto"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var x = parseInt(inputs['inp-x']);
        var steps = [];
        steps.push({ line: 0, vars: { v: v.slice(), n: n, x: x, i: '?' }, exp: 'Inițiem funcția. Căutăm x = ' + x + ' în vectorul de dimensiune ' + n, arr: v.slice() });
        for (var i = 0; i < n; i++) {
          steps.push({ line: 1, vars: { v: v.slice(), n: n, x: x, i: i }, exp: 'Evaluăm condiția for-ului. Pasul i = ' + i, arr: v.slice(), highlight: [i] });
          steps.push({ line: 2, vars: { v: v.slice(), n: n, x: x, i: i }, exp: 'Verificăm elementul de pe poziția: v[' + i + '] == x? adică ' + v[i] + ' == ' + x + '? Răspuns: ' + (v[i] === x ? 'DA' : 'NU'), arr: v.slice(), highlight: [i] });
          if (v[i] === x) {
            steps.push({ line: 3, vars: { v: v.slice(), n: n, x: x, i: i }, exp: 'Deoarece am găsit valoarea x, returnăm indicele i = ' + i, arr: v.slice(), highlight: [i] });
            steps.push({ line: 4, vars: { v: v.slice(), n: n, x: x, i: i }, exp: 'Găsit la poziția ' + i + '! Funcția se termină.', arr: v.slice(), highlight: [i], done: true });
            return { steps: steps, result: 'Găsit la poziția ' + i };
          }
        }
        steps.push({ line: 6, vars: { v: v.slice(), n: n, x: x, i: n }, exp: 'Am parcurs întreg vectorul fără succes. Returnăm -1.', arr: v.slice() });
        steps.push({ line: 7, vars: { v: v.slice(), n: n, x: x, i: n }, exp: 'Elementul nu a fost găsit în vector.', arr: v.slice(), done: true });
        return { steps: steps, result: 'Negăsit (-1)' };
      }
    },
    'cautare-binara': {
      name: 'Căutare Binară (Divide et Impera)',
      fileName: 'cautare_binara.cpp',
      codeLines: [
        'int cautareBinara(int v[], int n, int x) {',
        '  int st = 0, dr = n - 1;',
        '  while (st <= dr) {',
        '    int mij = (st + dr) / 2;',
        '    if (v[mij] == x) return mij;',
        '    if (v[mij] < x) st = mij + 1;',
        '    else             dr = mij - 1;',
        '  }',
        '  return -1;',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector SORTAT crescător:<input id="inp-v" type="text" placeholder="ex: 1 3 5 8 12 17" class="tracer-input" value="1 3 5 8 12 17"></label><label class="input-field-label">Valoarea căutată x:<input id="inp-x" type="number" class="tracer-input" value="8" style="width: auto"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var x = parseInt(inputs['inp-x']);
        var steps = [];
        var st = 0, dr = n - 1;
        steps.push({ line: 0, vars: { v: v.slice(), n: n, x: x, st: '?', dr: '?', mij: '?' }, exp: 'Lansăm căutarea binară pe vectorul sortat ' + JSON.stringify(v), arr: v.slice() });
        steps.push({ line: 1, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: '?' }, exp: 'Inițializăm limitele stânga st = 0 și dreapta dr = ' + dr + '.', arr: v.slice(), highlight: [st, dr] });
        while (st <= dr) {
          steps.push({ line: 2, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: '?' }, exp: 'Verificăm executarea buclei: st <= dr? adică ' + st + ' <= ' + dr + ' (' + (st <= dr) + ')', arr: v.slice(), highlight: [st, dr] });
          var mij = Math.floor((st + dr) / 2);
          steps.push({ line: 3, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: mij }, exp: 'Calculăm mij = (' + st + ' + ' + dr + ') / 2 = ' + mij + '. Valoarea din mijloc v[' + mij + '] = ' + v[mij], arr: v.slice(), highlight: [mij] });
          
          steps.push({ line: 4, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: mij }, exp: 'Comparam: v[' + mij + '] == x? adică ' + v[mij] + ' == ' + x + '?', arr: v.slice(), highlight: [mij] });
          if (v[mij] === x) {
            steps.push({ line: 4, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: mij }, exp: 'Am găsit elementul exact pe poziția de mijloc: ' + mij, arr: v.slice(), highlight: [mij], done: true });
            return { steps: steps, result: 'Găsit la poziția ' + mij };
          }
          
          steps.push({ line: 5, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: mij }, exp: 'Este v[' + mij + '] < x? adică ' + v[mij] + ' < ' + x + '?', arr: v.slice(), highlight: [mij] });
          if (v[mij] < x) {
            steps.push({ line: 5, vars: { v: v.slice(), n: n, x: x, st: mij + 1, dr: dr, mij: mij }, exp: 'Adevărat. Deoarece v[' + mij + '] < ' + x + ', elementul e în jumătatea dreaptă. Actualizăm st = mij + 1 = ' + (mij + 1), arr: v.slice() });
            st = mij + 1;
          } else {
            steps.push({ line: 6, vars: { v: v.slice(), n: n, x: x, st: st, dr: mij - 1, mij: mij }, exp: 'Fals. Deoarece v[' + mij + '] > ' + x + ', elementul e în jumătatea stângă. Actualizăm dr = mij - 1 = ' + (mij - 1), arr: v.slice() });
            dr = mij - 1;
          }
        }
        steps.push({ line: 8, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: '?' }, exp: 'Condiția st <= dr a devenit falsă. Se returnează -1.', arr: v.slice() });
        steps.push({ line: 9, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: '?' }, exp: 'Elementul nu a fost găsit în vector.', arr: v.slice(), done: true });
        return { steps: steps, result: 'Negăsit (-1)' };
      }
    },
    'factorial': {
      name: 'Factorial Iterativ',
      fileName: 'factorial.cpp',
      codeLines: [
        'long long factorial(int n) {',
        '  long long rez = 1;',
