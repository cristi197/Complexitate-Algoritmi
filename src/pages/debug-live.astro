    'cautare-interpolate': {
      name: 'Interpolation Search',
      fileName: 'interp.cpp',
      codeLines: [
        'int interpSearch(int v[], int n, int x) {',
        '  int st = 0, dr = n-1;',
        '  while (st <= dr && x >= v[st] && x <= v[dr]) {',
        '    int pos = st + ((x-v[st])*(dr-st))/(v[dr]-v[st]);',
        '    if (v[pos] == x) return pos;',
        '    if (v[pos] < x) st = pos+1;',
        '    else dr = pos-1;',
        '  }',
        '  return -1;',
        '}'
      ],
