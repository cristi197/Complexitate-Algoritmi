            arr[k] = rightArr[j++];
            steps.push({ line: 5, vars: { v: arr.slice(), st: st, dr: dr, mij: mij, i: k }, exp: 'Adؤƒugؤƒm elementul rؤƒmas din dreapta: ' + arr[k], arr: arr.slice(), highlight: [k] });
            k++;
          }
        }
        
        function divide(st, dr) {
          if (st < dr) {
            var mij = Math.floor((st + dr) / 2);
            steps.push({ line: 2, vars: { v: arr.slice(), st: st, dr: dr, mij: mij }, exp: 'Dividem intervalul [' + st + '...' + dr + '] la mijlocul mij = ' + mij + ' (valoare: ' + arr[mij] + ')', arr: arr.slice(), highlight: [st, dr] });
            steps.push({ line: 3, vars: { v: arr.slice(), st: st, dr: dr, mij: mij }, exp: 'Intrؤƒm أ®n sub-apelul stأ¢ng [' + st + '...' + mij + ']', arr: arr.slice() });
            divide(st, mij);
            steps.push({ line: 4, vars: { v: arr.slice(), st: st, dr: dr, mij: mij }, exp: 'Intrؤƒm أ®n sub-apelul drept [' + (mij + 1) + '...' + dr + ']', arr: arr.slice() });
            divide(mij + 1, dr);
