        function heapify(size, idx) {
          var largest = idx;
          var l = 2 * idx + 1;
          var r = 2 * idx + 2;
          steps.push({ line: 0, vars: { v: arr.slice(), n: size, i: idx, largest: largest, l: l, r: r }, exp: 'Apelăm heapify pentru nodul ' + idx + ' (valoare: ' + arr[idx] + ') în arborele de dimensiune ' + size, arr: arr.slice(), highlight: [idx] });
          if (l < size && arr[l] > arr[largest]) largest = l;
          steps.push({ line: 2, vars: { v: arr.slice(), n: size, i: idx, largest: largest, l: l, r: r }, exp: 'Verificăm fiul stâng l = ' + l + (l < size ? ' (valoare: ' + arr[l] + '). ' + (largest === l ? 'Fiul stâng devine cel mai mare.' : 'Nodul curent rămâne mai mare.') : ' (inexistent)'), arr: arr.slice(), highlight: [idx, l].filter(function(x) { return x < size; }) });
          if (r < size && arr[r] > arr[largest]) largest = r;
          steps.push({ line: 3, vars: { v: arr.slice(), n: size, i: idx, largest: largest, l: l, r: r }, exp: 'Verificăm fiul drept r = ' + r + (r < size ? ' (valoare: ' + arr[r] + '). ' + (largest === r ? 'Fiul drept este cel mai mare.' : 'Nu schimbăm cel mai mare.') : ' (inexistent)'), arr: arr.slice(), highlight: [idx, r].filter(function(x) { return x < size; }) });
          if (largest !== idx) {
            var tmp = arr[idx]; arr[idx] = arr[largest]; arr[largest] = tmp;
            steps.push({ line: 4, vars: { v: arr.slice(), n: size, i: idx, largest: largest }, exp: 'Largest (' + largest + ') diferă de i (' + idx + '). Interschimbăm v[' + idx + '] cu v[' + largest + '] și reluăm heapify pe sub-arbore.', arr: arr.slice(), highlight: [idx, largest] });
            heapify(size, largest);
          }
        }
        
        steps.push({ line: 0, vars: { v: arr.slice(), n: n }, exp: 'Pasul 1: Construim max-heap-ul pornind de la ultimul părinte de jos.', arr: arr.slice() });
        for (var i = Math.floor(n / 2) - 1; i >= 0; i--) {
          heapify(n, i);
        }
        steps.push({ line: 0, vars: { v: arr.slice(), n: n }, exp: 'Max-heap-ul a fost construit! Începem sortarea prin extragerea repetată a maximului.', arr: arr.slice() });
        for (var i = n - 1; i > 0; i--) {
          var tmp = arr[0]; arr[0] = arr[i]; arr[i] = tmp;
          steps.push({ line: 4, vars: { v: arr.slice(), n: i }, exp: 'Interschimbăm rădăcina/maximul (v[0] = ' + arr[i] + ') cu ultimul element nesortat (v[' + i + '] = ' + arr[0] + '). Re-rulăm heapify pentru rădăcină.', arr: arr.slice(), highlight: [0, i] });
