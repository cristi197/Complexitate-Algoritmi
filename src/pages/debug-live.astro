      fileName: 'hamming.cpp',
      codeLines: [
        'int hammingDist(int a, int b) {',
        '  int xor_val = a ^ b;',
        '  int count = 0;',
        '  while (xor_val) { count += xor_val & 1; xor_val >>= 1; }',
        '  return count;',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Valoare A:<input id="inp-a" type="number" class="tracer-input" value="1"></label><label class="input-field-label">Valoare B:<input id="inp-b" type="number" class="tracer-input" value="4"></label></div>',
      run: function(inputs) {
