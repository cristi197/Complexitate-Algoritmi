    'knight-tour': { name: 'Knight Tour', fileName: 'knight.cpp', codeLines: ['bool knightTour(int x, int y, int move, int board[][8], ...) {', '  if (move == 64) return true;', '  for (int i = 0; i < 8; i++) {', '    int nx = x + xMove[i], ny = y + yMove[i];', '    if (isSafe(nx, ny) && board[nx][ny] == -1) {', '      board[nx][ny] = move;', '      if (knightTour(nx, ny, move+1, board, ...)) return true;', '      board[nx][ny] = -1;', '    }', '  }', '  return false;', '}'], inputHTML: '<input id="inp-n" type="number" value="8">', run: function(i) { var n = parseInt(i['inp-n']); return { steps: [{ line: 0, vars: { n: n }, exp: 'Knight tour ' + n + 'x' + n }], result: 'Knight tour demo' }; } },
    'labirint': { name: 'Maze Solver', fileName: 'maze.cpp', codeLines: ['bool solveMaze(int x, int y, int maze[][10], int path[][10], ...) {', '  if (x == n-1 && y == m-1) { path[x][y] = 1; return true; }', '  if (maze[x][y] == 0) return false;', '  path[x][y] = 1;', '  if (solveMaze(x+1, y, maze, path, ...) || solveMaze(x, y+1, maze, path, ...))', '    return true;', '  path[x][y] = 0;', '  return false;', '}'], inputHTML: '<input id="inp-n" type="number" value="4">', run: function(i) { var n = parseInt(i['inp-n']); return { steps: [{ line: 0, vars: { n: n }, exp: 'Maze solver' }], result: n + 'x' + n + ' maze' }; } },
    'combinatii': { name: 'Combinations C(n,k)', fileName: 'combinations.cpp', codeLines: ['void combination(int arr[], int data[], int start, int end, int idx, int k) {', '  if (idx == k) { print(data, k); return; }', '  for (int i = start; i <= end && (end-i+1) >= (k-idx); i++) {', '    data[idx] = arr[i];', '    combination(arr, data, i+1, end, idx+1, k);', '  }', '}'], inputHTML: '<input id="inp-n" type="number" value="5"><input id="inp-k" type="number" value="2">', run: function(i) { var n = parseInt(i['inp-n']), k = parseInt(i['inp-k']); function fact(x) { return x <= 1 ? 1 : x * fact(x-1); } var comb = fact(n) / (fact(k) * fact(n-k)); return { steps: [{ line: 0, vars: { comb: comb }, exp: 'Combinations' }], result: 'C(' + n + ',' + k + ') = ' + comb }; } },
    'subseturi': { name: 'Subsets (Power Set)', fileName: 'subsets.cpp', codeLines: ['void subsets(int arr[], int n) {', '  for (int i = 0; i < (1 << n); i++) {', '    for (int j = 0; j < n; j++)', '      if (i & (1 << j)) cout << arr[j] << \" \";', '    cout << \"\\\\n\";', '  }', '}'], inputHTML: '<input id="inp-n" type="number" value="3">', run: function(i) { var n = parseInt(i['inp-n']); return { steps: [{ line: 0, vars: { count: Math.pow(2, n) }, exp: 'All subsets (2^' + n + ')' }], result: 'Subsets: ' + Math.pow(2, n) }; } },
    'partitii-suma': { name: 'Equal Sum Partition', fileName: 'partition.cpp', codeLines: ['bool partition(int arr[], int n) {', '  int sum = 0;', '  for (int i = 0; i < n; i++) sum += arr[i];', '  if (sum % 2 != 0) return false;', '  return isSubsetSum(arr, n, sum/2);', '}'], inputHTML: '<input id="inp-v" value="1 5 11 5">', run: function(i) { var v = i['inp-v'].split(/\\s+/).map(Number); var sum = v.reduce((a,b)=>a+b,0); return { steps: [{ line: 0, vars: { sum: sum, even: sum % 2 == 0 }, exp: 'Partition' }], result: sum % 2 == 0 ? 'Possible' : 'Impossible' }; } },
