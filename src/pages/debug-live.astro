    'permutari': {
      name: 'Permutări prin Backtracking',
      fileName: 'permutari.cpp',
      codeLines: [
        'int p[10], n, solutii = 0;',
        'bool folosit[10] = {false};',
        'void back(int k) {',
        '  if (k > n) { solutii++; return; }',
        '  for (int v = 1; v <= n; v++) {',
        '    if (!folosit[v]) {',
        '      p[k] = v;  folosit[v] = true;',
        '      back(k + 1);',
        '      folosit[v] = false;',
        '    }',
        '  }',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">n (2–4):<input id="inp-n" type="number" class="tracer-input" value="3" min="2" max="4" style="width:120px"></label></div>',
      run: function(inputs) {
        var n = Math.min(parseInt(inputs['inp-n']) || 3, 4);
        var steps = [];
        var p = new Array(n + 1).fill(0);
        var folosit = new Array(n + 1).fill(false);
        var solutii = 0;
        var MAX_STEPS = 250;
        function back(k) {
          if (steps.length >= MAX_STEPS) return;
          var pStr = '[' + p.slice(1, k).join(',') + ']';
          var folStr = folosit.slice(1).map(function(f, idx) { return (idx+1) + ':' + (f?'T':'F'); }).join(' ');
          if (k > n) {
            solutii++;
            steps.push({ line: 3, vars: { k: k, p: '[' + p.slice(1, n+1).join(',') + ']', solutii: solutii, folosit: folStr }, exp: '✅ Soluție #' + solutii + ': (' + p.slice(1,n+1).join(', ') + ')' });
            return;
          }
          steps.push({ line: 2, vars: { k: k, p: pStr, solutii: solutii, folosit: folStr }, exp: 'back(' + k + '): trebuie să completăm poziția p[' + k + ']' });
          for (var v = 1; v <= n; v++) {
            if (steps.length >= MAX_STEPS) return;
            steps.push({ line: 5, vars: { k: k, p: pStr, solutii: solutii, folosit: folStr }, exp: 'Încercăm v = ' + v + ' pe poziția ' + k + '. Folosit[' + v + '] = ' + (folosit[v] ? 'true (ocupat)' : 'false → liber!') });
            if (!folosit[v]) {
              p[k] = v; folosit[v] = true;
              var pStr2 = '[' + p.slice(1, k+1).join(',') + ']';
              var folStr2 = folosit.slice(1).map(function(f, idx) { return (idx+1) + ':' + (f?'T':'F'); }).join(' ');
              steps.push({ line: 6, vars: { k: k, p: pStr2, solutii: solutii, folosit: folStr2 }, exp: 'p[' + k + '] = ' + v + ', folosit[' + v + '] = true → apelăm back(' + (k+1) + ')' });
              back(k + 1);
              folosit[v] = false;
              var folStr3 = folosit.slice(1).map(function(f, idx) { return (idx+1) + ':' + (f?'T':'F'); }).join(' ');
              if (steps.length < MAX_STEPS) steps.push({ line: 8, vars: { k: k, p: pStr, solutii: solutii, folosit: folStr3 }, exp: '← Backtrack din back(' + (k+1) + '). Eliberăm folosit[' + v + '] = false. Încercăm alt v.' });
            }
          }
        }
        steps.push({ line: 0, vars: { k: 1, p: '[]', solutii: 0, folosit: new Array(n).fill(0).map(function(_,i){return (i+1)+':F';}).join(' ') }, exp: 'Generăm permutările lui {1..' + n + '} prin backtracking. back(1).' });
        back(1);
        steps.push({ line: 11, vars: { k: '?', p: '?', solutii: solutii, folosit: '—' }, exp: 'Gata! Am generat toate ' + solutii + ' permutările lui {1..' + n + '} (' + n + '! = ' + solutii + ').', done: true });
        return { steps: steps, result: solutii + ' permutări ale {1..' + n + '}' };
      }
    },

