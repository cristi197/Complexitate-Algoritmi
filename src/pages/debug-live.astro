        function qSort(st, dr) {
          if (st < dr) {
            steps.push({ line: 0, vars: { v: arr.slice(), st: st, dr: dr, pivot: '?', i: '?', j: '?' }, exp: 'Apelăm partenerul QuickSort pe segmentul [' + st + '...' + dr + ']', arr: arr.slice() });
            var pivot = arr[dr];
            var i = st - 1;
            steps.push({ line: 1, vars: { v: arr.slice(), st: st, dr: dr, pivot: pivot, i: i }, exp: 'Alegem pivotul ca v[dr] = ' + pivot + '. Inițializăm indexul i = ' + i, arr: arr.slice(), highlight: [dr] });
            for (var j = st; j < dr; j++) {
              var smaller = arr[j] < pivot;
              steps.push({ line: 2, vars: { v: arr.slice(), st: st, dr: dr, pivot: pivot, i: i, j: j }, exp: 'Comparam v[j] (' + arr[j] + ') cu pivotul (' + pivot + ').' + (smaller ? ' Este mai mic! Incrementăm i și interschimbăm.' : ' Nu este mai mic.'), arr: arr.slice(), highlight: [j, dr] });
              if (smaller) {
                i++;
                var tmp = arr[i]; arr[i] = arr[j]; arr[j] = tmp;
                steps.push({ line: 3, vars: { v: arr.slice(), st: st, dr: dr, pivot: pivot, i: i, j: j }, exp: 'Dupa swap: v[' + i + '] (' + arr[i] + ') interschimbat cu v[' + j + '] (' + arr[j] + ').', arr: arr.slice(), highlight: [i, j] });
              }
            }
            var tmp = arr[i+1]; arr[i+1] = arr[dr]; arr[dr] = tmp;
            var pivotIdx = i + 1;
            steps.push({ line: 4, vars: { v: arr.slice(), st: st, dr: dr, pivot: pivot, pi: pivotIdx }, exp: 'Interschimbăm pivotul de la capăt cu v[i+1] (' + arr[pivotIdx] + '). Pivotul ' + pivot + ' este acum fixat la poziția sa finală ' + pivotIdx + '.', arr: arr.slice(), highlight: [pivotIdx, dr] });
            
            qSort(st, pivotIdx - 1);
            qSort(pivotIdx + 1, dr);
          }
        }
        qSort(0, n - 1);
        steps.push({ line: 5, vars: { v: arr.slice() }, exp: 'Vector sortat complet prin Quick Sort!', arr: arr.slice(), done: true });
        return { steps: steps, result: 'Sortat: [' + arr.join(', ') + ']' };
      }
    },
    'heap-sort': {
      name: 'Heap Sort',
      fileName: 'heap_sort.cpp',
      codeLines: [
        'void heapify(int v[], int n, int i) {',
        '  int largest = i, l = 2*i+1, r = 2*i+2;',
        '  if (l < n && v[l] > v[largest]) largest = l;',
        '  if (r < n && v[r] > v[largest]) largest = r;',
