        '  while (n != 1 && !seen.count(n)) {',
        '    seen.insert(n);',
        '    int sum = 0;',
        '    while (n) { int d = n%10; sum += d*d; n /= 10; }',
        '    n = sum;',
        '  }',
        '  return n == 1;',
        '}'
