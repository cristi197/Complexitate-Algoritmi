        function simulate(k) {
          callStack.push('fact(' + k + ')');
          var stackStr = callStack.join(' → ');
          steps.push({ line: 0, vars: { n: k, rez: '?', apel: 'factRec(' + k + ')', adancime: callStack.length }, exp: '↓ Apel: factRec(' + k + ')  |  Stivă: ' + stackStr });
          steps.push({ line: 1, vars: { n: k, rez: '?', apel: 'factRec(' + k + ')', adancime: callStack.length }, exp: k + ' <= 1? ' + (k <= 1 ? 'DA → cazul de bază, returnăm 1' : 'NU → apelăm recursiv factRec(' + (k-1) + ')') });
          var result;
          if (k <= 1) {
            result = 1;
            steps.push({ line: 1, vars: { n: k, rez: 1, apel: 'factRec(' + k + ')', adancime: callStack.length }, exp: '↑ Returnăm 1 din factRec(' + k + ')' });
          } else {
            var sub = simulate(k - 1);
            result = k * sub;
            steps.push({ line: 2, vars: { n: k, rez: result, apel: 'factRec(' + k + ')', adancime: callStack.length }, exp: '↑ Revenire în factRec(' + k + '): ' + k + ' × factRec(' + (k-1) + ') = ' + k + ' × ' + sub + ' = ' + result });
          }
          callStack.pop();
          return result;
        }
        steps.push({ line: 5, vars: { n: n, rez: '?', apel: 'main()', adancime: 0 }, exp: 'main() citește n = ' + n + ' și apelează factRec(' + n + ')' });
        var rez = simulate(n);
        steps.push({ line: 7, vars: { n: n, rez: rez, apel: 'main()', adancime: 0 }, exp: 'cout << factRec(' + n + ') → afișăm ' + rez, done: true });
        return { steps: steps, result: n + '! = ' + rez };
      }
    },

