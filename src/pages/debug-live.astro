          steps.push({ line: 5, vars: { n: current, sum: sum }, exp: 'Calculؤƒm suma pؤƒtratelor cifrelor: ' + digits.reverse().join(' + ') + ' = ' + sum });
          current = sum;
        }
        var ok = (current === 1);
        steps.push({ line: 8, vars: { n: current, ok: ok }, exp: ok ? 'S-a ajuns la 1! Numؤƒrul original ' + orig + ' este fericit!' : 'S-a detectat o buclؤƒ infinitؤƒ la ' + current + '. Numؤƒrul original ' + orig + ' este trist.', done: true });
        return { steps: steps, result: ok ? orig + ' e fericit!' : orig + ' e trist' };
      }
