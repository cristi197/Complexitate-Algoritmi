              len = lps[len - 1];
            } else {
              lps[jLps] = 0;
              jLps++;
            }
          }
        }
        
        steps.push({ line: 0, vars: { text: text, pat: pat, i: '?', j: '?' }, exp: 'Generؤƒm tabelul LPS/Prefix pentru KMP. LPS = [' + lps.join(', ') + ']' });
        steps.push({ line: 2, vars: { text: text, pat: pat, i: 0, j: 0 }, exp: 'Iniب›ializؤƒm i = 0, j = 0' });
        
