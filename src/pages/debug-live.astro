    'merge-sort': {
      name: 'Merge Sort',
      fileName: 'merge_sort.cpp',
      codeLines: [
        'void mergeSort(int v[], int st, int dr) {',
        '  if (st < dr) {',
        '    int mij = (st+dr)/2;',
        '    mergeSort(v, st, mij);',
        '    mergeSort(v, mij+1, dr);',
        '    merge(v, st, mij, dr);',
        '  }',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector:<input id="inp-v" class="tracer-input" value="64 25 12 22 11"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var steps = [];
        var arr = v.slice();
        steps.push({ line: 0, vars: { v: arr.slice(), st: 0, dr: n-1 }, exp: 'Inițiem programul de sortare Merge Sort pe întregul vector.', arr: arr.slice() });
        
        function merge(st, mij, dr) {
          var leftArr = arr.slice(st, mij + 1);
          var rightArr = arr.slice(mij + 1, dr + 1);
          var i = 0, j = 0, k = st;
          while(i < leftArr.length && j < rightArr.length) {
            if (leftArr[i] <= rightArr[j]) {
              arr[k] = leftArr[i++];
            } else {
              arr[k] = rightArr[j++];
            }
            steps.push({ 
              line: 5, 
              vars: { v: arr.slice(), st: st, dr: dr, mij: mij, i: k, val: arr[k] }, 
              exp: 'Fuzionăm elementul ' + arr[k] + ' în poziția ' + k, 
              arr: arr.slice(), 
              highlight: [k] 
            });
            k++;
          }
          while(i < leftArr.length) {
            arr[k] = leftArr[i++];
            steps.push({ line: 5, vars: { v: arr.slice(), st: st, dr: dr, mij: mij, i: k }, exp: 'Adăugăm elementul rămas din stânga: ' + arr[k], arr: arr.slice(), highlight: [k] });
            k++;
          }
          while(j < rightArr.length) {
            arr[k] = rightArr[j++];
            steps.push({ line: 5, vars: { v: arr.slice(), st: st, dr: dr, mij: mij, i: k }, exp: 'Adăugăm elementul rămas din dreapta: ' + arr[k], arr: arr.slice(), highlight: [k] });
            k++;
          }
        }
        
        function divide(st, dr) {
          if (st < dr) {
            var mij = Math.floor((st + dr) / 2);
            steps.push({ line: 2, vars: { v: arr.slice(), st: st, dr: dr, mij: mij }, exp: 'Dividem intervalul [' + st + '...' + dr + '] la mijlocul mij = ' + mij + ' (valoare: ' + arr[mij] + ')', arr: arr.slice(), highlight: [st, dr] });
            steps.push({ line: 3, vars: { v: arr.slice(), st: st, dr: dr, mij: mij }, exp: 'Intrăm în sub-apelul stâng [' + st + '...' + mij + ']', arr: arr.slice() });
            divide(st, mij);
            steps.push({ line: 4, vars: { v: arr.slice(), st: st, dr: dr, mij: mij }, exp: 'Intrăm în sub-apelul drept [' + (mij + 1) + '...' + dr + ']', arr: arr.slice() });
            divide(mij + 1, dr);
            steps.push({ line: 5, vars: { v: arr.slice(), st: st, dr: dr, mij: mij }, exp: 'Fuzionăm intervalele [' + st + '...' + mij + '] și [' + (mij + 1) + '...' + dr + ']', arr: arr.slice() });
            merge(st, mij, dr);
          }
        }
        divide(0, n-1);
        steps.push({ line: 7, vars: { v: arr.slice() }, exp: 'Vector sortat cu succes prin Merge Sort!', arr: arr.slice(), done: true });
        return { steps: steps, result: 'Sortat: [' + arr.join(', ') + ']' };
      }
    },
    'quick-sort': {
