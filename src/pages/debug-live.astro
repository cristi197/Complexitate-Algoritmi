      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Textul de bazؤƒ:<input id="inp-text" class="tracer-input" value="ABABDABAB"></label><label class="input-field-label">Modelul cؤƒutat (pat):<input id="inp-pattern" class="tracer-input" value="ABAB"></label></div>',
      run: function(inputs) {
