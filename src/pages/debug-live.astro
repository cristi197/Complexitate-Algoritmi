    'selection-sort': {
      name: 'Selection Sort (Sortare prin Selecție)',
      fileName: 'selection_sort.cpp',
      codeLines: [
        'void selectionSort(int v[], int n) {',
        '  for (int i = 0; i < n-1; i++) {',
        '    int pmin = i;',
        '    for (int j = i+1; j < n; j++) {',
        '      if (v[j] < v[pmin])',
        '        pmin = j;',
        '    }',
        '    int aux = v[i];',
        '    v[i] = v[pmin];',
        '    v[pmin] = aux;',
        '  }',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vectorul de sortat:<input id="inp-v" type="text" placeholder="ex: 64 25 12 22 11" class="tracer-input" value="64 25 12 22 11"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var steps = [];
        steps.push({ line: 0, vars: { v: v.slice(), n: n, i: '?', j: '?', pmin: '?', aux: '?' }, exp: 'Inițiem Selection Sort. La fiecare pas i se aduce minimul din subvectorul nesortat.', arr: v.slice() });
        for (var i = 0; i < n - 1; i++) {
          var pmin = i;
          steps.push({ line: 1, vars: { v: v.slice(), n: n, i: i, j: '?', pmin: pmin, aux: '?' }, exp: 'Pasul exterior i = ' + i + '. Subvector nesortat: v[' + i + '...' + (n-1) + ']', arr: v.slice(), highlight: [i] });
          steps.push({ line: 2, vars: { v: v.slice(), n: n, i: i, j: '?', pmin: pmin, aux: '?' }, exp: 'Presupunem că minimul e la pmin = ' + pmin + ' (v[' + pmin + '] = ' + v[pmin] + ')', arr: v.slice(), highlight: [pmin] });
          for (var j = i + 1; j < n; j++) {
            steps.push({ line: 3, vars: { v: v.slice(), n: n, i: i, j: j, pmin: pmin, aux: '?' }, exp: 'Verificăm j = ' + j + ': v[' + j + '] = ' + v[j] + ' vs v[pmin] = ' + v[pmin], arr: v.slice(), highlight: [pmin, j] });
            if (v[j] < v[pmin]) {
              pmin = j;
              steps.push({ line: 5, vars: { v: v.slice(), n: n, i: i, j: j, pmin: pmin, aux: '?' }, exp: 'Nou minim găsit! pmin = ' + pmin + ' (v[' + pmin + '] = ' + v[pmin] + ')', arr: v.slice(), highlight: [pmin] });
            }
          }
          var aux = v[i];
          steps.push({ line: 7, vars: { v: v.slice(), n: n, i: i, j: '?', pmin: pmin, aux: aux }, exp: 'Facem schimb: v[' + i + '] ↔ v[' + pmin + '] (' + v[i] + ' ↔ ' + v[pmin] + ')', arr: v.slice(), highlight: [i, pmin] });
          v[i] = v[pmin]; v[pmin] = aux;
          steps.push({ line: 9, vars: { v: v.slice(), n: n, i: i, j: '?', pmin: pmin, aux: aux }, exp: 'v[' + i + '] = ' + v[i] + ' (element sortat). Vector: ' + JSON.stringify(v), arr: v.slice(), highlight: [i] });
        }
        steps.push({ line: 11, vars: { v: v.slice(), n: n, i: n-1, j: '?', pmin: '?', aux: '?' }, exp: 'Sortare completă: ' + JSON.stringify(v), arr: v.slice(), done: true });
        return { steps: steps, result: 'Sortat: [' + v.join(', ') + ']' };
      }
    },

    'insertion-sort': {
      name: 'Insertion Sort (Sortare prin Inserție)',
      fileName: 'insertion_sort.cpp',
      codeLines: [
        'void insertionSort(int v[], int n) {',
        '  for (int i = 1; i < n; i++) {',
        '    int key = v[i];',
        '    int j = i - 1;',
        '    while (j >= 0 && v[j] > key) {',
        '      v[j+1] = v[j];',
        '      j--;',
        '    }',
        '    v[j+1] = key;',
        '  }',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vectorul de sortat:<input id="inp-v" type="text" placeholder="ex: 5 2 4 6 1" class="tracer-input" value="5 2 4 6 1"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var steps = [];
        steps.push({ line: 0, vars: { v: v.slice(), n: n, i: '?', j: '?', key: '?' }, exp: 'Inițiem Insertion Sort. Elementele din stânga sunt mereu sortate.', arr: v.slice() });
        for (var i = 1; i < n; i++) {
          var key = v[i];
          var j = i - 1;
          steps.push({ line: 1, vars: { v: v.slice(), n: n, i: i, j: j, key: '?' }, exp: 'Pasul i = ' + i + '. Prefix sortat: [' + v.slice(0,i).join(',') + ']. Urmează v[' + i + '] = ' + v[i], arr: v.slice(), highlight: [i] });
          steps.push({ line: 2, vars: { v: v.slice(), n: n, i: i, j: j, key: key }, exp: 'key = v[' + i + '] = ' + key + '. Îl vom insera în locul potrivit.', arr: v.slice(), highlight: [i] });
          steps.push({ line: 3, vars: { v: v.slice(), n: n, i: i, j: j, key: key }, exp: 'j = i - 1 = ' + j + '. Vom compara cu elementele din stânga.', arr: v.slice() });
          while (j >= 0 && v[j] > key) {
            steps.push({ line: 4, vars: { v: v.slice(), n: n, i: i, j: j, key: key }, exp: 'j >= 0 && v[' + j + '] > key? adică ' + v[j] + ' > ' + key + ' (DA — mutăm)', arr: v.slice(), highlight: [j] });
            v[j + 1] = v[j];
            steps.push({ line: 5, vars: { v: v.slice(), n: n, i: i, j: j, key: key }, exp: 'Mutăm v[' + j + '] = ' + v[j] + ' la v[' + (j+1) + ']. Vector: ' + JSON.stringify(v), arr: v.slice() });
            j--;
            steps.push({ line: 6, vars: { v: v.slice(), n: n, i: i, j: j, key: key }, exp: 'j-- → j = ' + j, arr: v.slice() });
          }
          steps.push({ line: 4, vars: { v: v.slice(), n: n, i: i, j: j, key: key }, exp: 'Condiția while devine falsă (j = ' + j + '). Locul potrivit găsit la j+1 = ' + (j+1), arr: v.slice() });
          v[j + 1] = key;
          steps.push({ line: 8, vars: { v: v.slice(), n: n, i: i, j: j, key: key }, exp: 'Inserăm key = ' + key + ' la v[' + (j+1) + ']. Prefix sortat: [' + v.slice(0,i+1).join(',') + ']', arr: v.slice(), highlight: [j+1] });
        }
        steps.push({ line: 10, vars: { v: v.slice(), n: n, i: n, j: '?', key: '?' }, exp: 'Sortare completă: ' + JSON.stringify(v), arr: v.slice(), done: true });
        return { steps: steps, result: 'Sortat: [' + v.join(', ') + ']' };
      }
    },

