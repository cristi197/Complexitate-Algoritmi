    'cautare-ternara': {
      name: 'Ternary Search',
      fileName: 'ternary.cpp',
      codeLines: [
        'int ternary(int v[], int st, int dr, int x) {',
        '  if (st > dr) return -1;',
        '  int mid1 = st + (dr-st)/3;',
        '  int mid2 = dr - (dr-st)/3;',
        '  if (v[mid1] == x) return mid1;',
        '  if (v[mid2] == x) return mid2;',
        '  if (x < v[mid1]) return ternary(v, st, mid1-1, x);',
        '  if (x > v[mid2]) return ternary(v, mid2+1, dr, x);',
        '  return ternary(v, mid1+1, mid2-1, x);',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector ordonat:<input id="inp-v" class="tracer-input" value="1 2 5 8 12 15 20 25 30"></label><label class="input-field-label">Valoare X de cؤƒutat:<input id="inp-x" type="number" class="tracer-input" value="8" style="width:100px"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var x = parseInt(inputs['inp-x']) || 0;
        var n = v.length;
        var steps = [];
        steps.push({ line: 0, vars: { v: v, x: x, st: 0, dr: n-1 }, exp: 'Cؤƒutؤƒm valoarea ' + x + ' folosind Ternary Search pe vectorul ordonat.', arr: v.slice() });
        
        function tSearch(st, dr) {
          steps.push({ line: 1, vars: { v: v, x: x, st: st, dr: dr }, exp: 'Apel ternary pentru intervalul [' + st + '...' + dr + ']', arr: v.slice(), highlight: [st, dr] });
          if (st > dr) {
            steps.push({ line: 1, vars: { v: v, x: x, st: st, dr: dr }, exp: 'Intervalul s-a epuizat (st > dr). Valoarea nu se aflؤƒ أ®n vector!', arr: v.slice(), done: true });
            return -1;
          }
          var mid1 = st + Math.floor((dr - st) / 3);
          var mid2 = dr - Math.floor((dr - st) / 3);
          steps.push({ line: 2, vars: { v: v, x: x, st: st, dr: dr, mid1: mid1, mid2: mid2 }, exp: 'Calculؤƒm cele douؤƒ puncte de divizare: mid1 = ' + mid1 + ' (valoare: ' + v[mid1] + ') ب™i mid2 = ' + mid2 + ' (valoare: ' + v[mid2] + ')', arr: v.slice(), highlight: [mid1, mid2] });
          if (v[mid1] === x) {
            steps.push({ line: 4, vars: { v: v, x: x, st: st, dr: dr, mid1: mid1, mid2: mid2 }, exp: 'Gؤƒsit! Valoarea de la mid1 (' + mid1 + ') este egalؤƒ cu x (' + x + ').', arr: v.slice(), highlight: [mid1], done: true });
            return mid1;
          }
          if (v[mid2] === x) {
            steps.push({ line: 5, vars: { v: v, x: x, st: st, dr: dr, mid1: mid1, mid2: mid2 }, exp: 'Gؤƒsit! Valoarea de la mid2 (' + mid2 + ') este egalؤƒ cu x (' + x + ').', arr: v.slice(), highlight: [mid2], done: true });
            return mid2;
          }
          if (x < v[mid1]) {
            steps.push({ line: 6, vars: { v: v, x: x, st: st, dr: dr, mid1: mid1, mid2: mid2 }, exp: 'x < v[mid1] (' + x + ' < ' + v[mid1] + '). Continuؤƒm cؤƒutarea أ®n treimea stأ¢ngؤƒ: [' + st + '...' + (mid1-1) + ']', arr: v.slice() });
            return tSearch(st, mid1 - 1);
          } else if (x > v[mid2]) {
            steps.push({ line: 7, vars: { v: v, x: x, st: st, dr: dr, mid1: mid1, mid2: mid2 }, exp: 'x > v[mid2] (' + x + ' > ' + v[mid2] + '). Continuؤƒm cؤƒutarea أ®n treimea dreaptؤƒ: [' + (mid2+1) + '...' + dr + ']', arr: v.slice() });
            return tSearch(mid2 + 1, dr);
          } else {
            steps.push({ line: 8, vars: { v: v, x: x, st: st, dr: dr, mid1: mid1, mid2: mid2 }, exp: 'v[mid1] < x < v[mid2] (' + v[mid1] + ' < ' + x + ' < ' + v[mid2] + '). Continuؤƒm cؤƒutarea أ®n treimea din mijloc: [' + (mid1+1) + '...' + (mid2-1) + ']', arr: v.slice() });
            return tSearch(mid1 + 1, mid2 - 1);
          }
        }
        var res = tSearch(0, n - 1);
        return { steps: steps, result: res >= 0 ? 'Gؤƒsit la index ' + res : 'Negؤƒsit' };
      }
    },
    'cautare-exponentiale': {
      name: 'Exponential Search',
      fileName: 'exp_search.cpp',
      codeLines: [
        'int expSearch(int v[], int n, int x) {',
        '  if (v[0] == x) return 0;',
        '  int i = 1;',
