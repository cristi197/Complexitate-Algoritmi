          var result;
          if (k <= 1) {
            result = 1;
            steps.push({ line: 1, vars: { n: k, rez: 1, apel: 'factRec(' + k + ')', adancime: callStack.length }, exp: 'â†‘ Returnؤƒm 1 din factRec(' + k + ')' });
