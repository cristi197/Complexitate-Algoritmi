        steps.push({ line: 0, vars: { n: n, rez: '?', i: '?' }, exp: 'Apelăm funcția factorial pentru n = ' + n });
        steps.push({ line: 1, vars: { n: n, rez: rez, i: '?' }, exp: 'Inițializăm rezulatul rez = 1' });
        for (var i = 2; i <= n; i++) {
          steps.push({ line: 2, vars: { n: n, rez: rez, i: i }, exp: 'Verificăm i <= n? adică ' + i + ' <= ' + n + ' (' + (i <= n) + ')' });
          var prev = rez;
          rez = rez * i;
          steps.push({ line: 3, vars: { n: n, rez: rez, i: i }, exp: 'Actualizăm: rez = rez * i = ' + prev + ' * ' + i + ' = ' + rez });
        }
        if (n >= 2) {
          steps.push({ line: 2, vars: { n: n, rez: rez, i: n + 1 }, exp: 'For finalizat, i = ' + (n + 1) + ' depășește n = ' + n });
        }
        steps.push({ line: 5, vars: { n: n, rez: rez, i: '?' }, exp: 'Se returnează valoarea finală rez = ' + rez });
        steps.push({ line: 6, vars: { n: n, rez: rez, i: '?' }, exp: 'Rezultat final: ' + n + '! = ' + rez, done: true });
        return { steps: steps, result: n + '! = ' + rez };
      }
    },
