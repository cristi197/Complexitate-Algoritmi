        var x = parseInt(inputs['inp-x']) || 0;
        
        var flatArr = [];
        for (var i = 0; i < m; i++) {
          flatArr = flatArr.concat(matrix[i]);
        }
        var steps = [];
        steps.push({ line: 0, vars: { a: 'matrix', m: m, n: n, x: x, i: '?', j: '?' }, exp: 'Inițiem căutarea în matricea 2D ordonată pe linii și coloane (Căutare tip Sad-Saddle).', arr: flatArr });
        var row = 0, col = n - 1;
        steps.push({ line: 1, vars: { m: m, n: n, x: x, i: row, j: col }, exp: 'Pornim de la colțul dreapta-sus: linie = ' + row + ', coloană = ' + col + ' (valoare: ' + matrix[row][col] + ')', arr: flatArr, highlight: [row * n + col] });
        
        var found = false;
        while(row < m && col >= 0) {
          var val = matrix[row][col];
          steps.push({ line: 2, vars: { m: m, n: n, x: x, i: row, j: col, val: val }, exp: 'Verificăm poziția curentă v[' + row + '][' + col + '] = ' + val, arr: flatArr, highlight: [row * n + col] });
          if (val === x) {
            steps.push({ line: 3, vars: { m: m, n: n, x: x, i: row, j: col, val: val }, exp: 'Găsit! Valoarea din matrice este egală cu ' + x, arr: flatArr, highlight: [row * n + col], done: true });
            found = true;
            break;
          }
          if (val > x) {
            steps.push({ line: 4, vars: { m: m, n: n, x: x, i: row, j: col, val: val }, exp: 'Deoarece ' + val + ' > ' + x + ', căutăm pe coloana din stânga. Decrementăm coloana.', arr: flatArr, highlight: [row * n + col] });
            col--;
          } else {
            steps.push({ line: 5, vars: { m: m, n: n, x: x, i: row, j: col, val: val }, exp: 'Deoarece ' + val + ' < ' + x + ', căutăm pe linia inferioară. Incrementăm linia.', arr: flatArr, highlight: [row * n + col] });
            row++;
          }
        }
        if (!found) {
          steps.push({ line: 7, vars: { m: m, n: n, x: x }, exp: 'Am ieșit din limitele matricei. Elementul ' + x + ' nu există.', arr: flatArr, done: true });
        }
        return { steps: steps, result: found ? 'Găsit la (' + row + ',' + col + ')' : 'Negăsit' };
      }
    },
    'cautare-interpolate': {
      name: 'Interpolation Search',
      fileName: 'interp.cpp',
      codeLines: [
        'int interpSearch(int v[], int n, int x) {',
        '  int st = 0, dr = n-1;',
        '  while (st <= dr && x >= v[st] && x <= v[dr]) {',
        '    int pos = st + ((x-v[st])*(dr-st))/(v[dr]-v[st]);',
        '    if (v[pos] == x) return pos;',
        '    if (v[pos] < x) st = pos+1;',
        '    else dr = pos-1;',
        '  }',
        '  return -1;',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector ordonat (ideal distribuit uniform):<input id="inp-v" class="tracer-input" value="10 20 30 40 50 60 70 80 90"></label><label class="input-field-label">Valoare X de căutat:<input id="inp-x" type="number" class="tracer-input" value="30" style="width:100px"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var x = parseInt(inputs['inp-x']) || 0;
        var n = v.length;
        var steps = [];
        steps.push({ line: 0, vars: { v: v, x: x, n: n, st: '?', dr: '?' }, exp: 'Inițiem căutarea prin interpolare pentru valoarea ' + x, arr: v.slice() });
        var st = 0, dr = n - 1;
        steps.push({ line: 1, vars: { v: v, x: x, st: st, dr: dr }, exp: 'Inițializăm limitele st = 0, dr = ' + dr, arr: v.slice(), highlight: [st, dr] });
        
        var foundIdx = -1;
        while(st <= dr && x >= v[st] && x <= v[dr]) {
          steps.push({ line: 2, vars: { v: v, x: x, st: st, dr: dr }, exp: 'Verificăm condiția: st <= dr și valoarea se află în interiorul plajei [' + v[st] + '...' + v[dr] + ']', arr: v.slice(), highlight: [st, dr] });
          
          var denom = v[dr] - v[st];
          var pos;
          if (denom === 0) {
            pos = st;
          } else {
            pos = st + Math.floor(((x - v[st]) * (dr - st)) / denom);
          }
          
          steps.push({ line: 3, vars: { v: v, x: x, st: st, dr: dr, pos: pos }, exp: 'Calculăm poziția estimată prin formulă de interpolare lineară: pos = ' + pos + ' (valoare: ' + v[pos] + ')', arr: v.slice(), highlight: [st, pos, dr] });
          
          if (v[pos] === x) {
            foundIdx = pos;
            steps.push({ line: 4, vars: { v: v, x: x, st: st, dr: dr, pos: pos }, exp: 'Găsit! v[pos] este egal cu ' + x, arr: v.slice(), highlight: [pos], done: true });
            break;
          }
          if (v[pos] < x) {
            steps.push({ line: 5, vars: { v: v, x: x, st: st, dr: dr, pos: pos }, exp: 'v[pos] < x (' + v[pos] + ' < ' + x + '). Restrângem căutarea în dreapta: st = ' + (pos + 1), arr: v.slice(), highlight: [pos] });
            st = pos + 1;
          } else {
            steps.push({ line: 6, vars: { v: v, x: x, st: st, dr: dr, pos: pos }, exp: 'v[pos] > x (' + v[pos] + ' > ' + x + '). Restrângem căutarea în stânga: dr = ' + (pos - 1), arr: v.slice(), highlight: [pos] });
            dr = pos - 1;
          }
        }
        if (foundIdx === -1) {
          steps.push({ line: 8, vars: { v: v, x: x, st: st, dr: dr }, exp: 'Am terminat bucla de căutare. Valoarea nu se află în vector.', arr: v.slice(), done: true });
        }
        return { steps: steps, result: foundIdx >= 0 ? 'Găsit la index ' + foundIdx : 'Negăsit' };
      }
    },
