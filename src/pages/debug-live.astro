    'suma-vector-rec': {
      name: 'Suma Elementelor Recursiv',
      fileName: 'sum_rec.cpp',
      codeLines: [
        'int sumRec(int v[], int n) {',
        '  if (n <= 0) return 0;',
        '  return v[n-1] + sumRec(v, n-1);',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector:<input id="inp-v" class="tracer-input" value="1 2 3 4 5"></label></div>',
      run: function(inputs) {
