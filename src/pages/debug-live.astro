        '  vector<int> dp(n, 1);',
        '  for (int i = 1; i < n; i++)',
        '    for (int j = 0; j < i; j++)',
        '      if (v[j] < v[i]) dp[i] = max(dp[i], dp[j]+1);',
        '  return *max_element(dp.begin(), dp.end());',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector:<input id="inp-v" class="tracer-input" value="10 9 2 5 3 7 101"></label></div>',
