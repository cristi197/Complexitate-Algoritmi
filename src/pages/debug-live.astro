    'permutari': {
      name: 'Permutؤƒri prin Backtracking',
      fileName: 'permutari.cpp',
      codeLines: [
        'int p[10], n, solutii = 0;',
        'bool folosit[10] = {false};',
        'void back(int k) {',
        '  if (k > n) { solutii++; return; }',
        '  for (int v = 1; v <= n; v++) {',
        '    if (!folosit[v]) {',
        '      p[k] = v;  folosit[v] = true;',
        '      back(k + 1);',
        '      folosit[v] = false;',
        '    }',
        '  }',
        '}',
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">n (2â€“4):<input id="inp-n" type="number" class="tracer-input" value="3" min="2" max="4" style="width:120px"></label></div>',
      run: function(inputs) {
        var n = Math.min(parseInt(inputs['inp-n']) || 3, 4);
        var steps = [];
        var p = new Array(n + 1).fill(0);
        var folosit = new Array(n + 1).fill(false);
        var solutii = 0;
        var MAX_STEPS = 250;
        function back(k) {
          if (steps.length >= MAX_STEPS) return;
          var pStr = '[' + p.slice(1, k).join(',') + ']';
          var folStr = folosit.slice(1).map(function(f, idx) { return (idx+1) + ':' + (f?'T':'F'); }).join(' ');
          if (k > n) {
            solutii++;
            steps.push({ line: 3, vars: { k: k, p: '[' + p.slice(1, n+1).join(',') + ']', solutii: solutii, folosit: folStr }, exp: 'âœ… Soluب›ie #' + solutii + ': (' + p.slice(1,n+1).join(', ') + ')' });
            return;
          }
          steps.push({ line: 2, vars: { k: k, p: pStr, solutii: solutii, folosit: folStr }, exp: 'back(' + k + '): trebuie sؤƒ completؤƒm poziب›ia p[' + k + ']' });
          for (var v = 1; v <= n; v++) {
            if (steps.length >= MAX_STEPS) return;
            steps.push({ line: 5, vars: { k: k, p: pStr, solutii: solutii, folosit: folStr }, exp: 'أژncercؤƒm v = ' + v + ' pe poziب›ia ' + k + '. Folosit[' + v + '] = ' + (folosit[v] ? 'true (ocupat)' : 'false â†’ liber!') });
            if (!folosit[v]) {
              p[k] = v; folosit[v] = true;
              var pStr2 = '[' + p.slice(1, k+1).join(',') + ']';
              var folStr2 = folosit.slice(1).map(function(f, idx) { return (idx+1) + ':' + (f?'T':'F'); }).join(' ');
              steps.push({ line: 6, vars: { k: k, p: pStr2, solutii: solutii, folosit: folStr2 }, exp: 'p[' + k + '] = ' + v + ', folosit[' + v + '] = true â†’ apelؤƒm back(' + (k+1) + ')' });
              back(k + 1);
              folosit[v] = false;
              var folStr3 = folosit.slice(1).map(function(f, idx) { return (idx+1) + ':' + (f?'T':'F'); }).join(' ');
              if (steps.length < MAX_STEPS) steps.push({ line: 8, vars: { k: k, p: pStr, solutii: solutii, folosit: folStr3 }, exp: 'â†گ Backtrack din back(' + (k+1) + '). Eliberؤƒm folosit[' + v + '] = false. أژncercؤƒm alt v.' });
            }
          }
        }
        steps.push({ line: 0, vars: { k: 1, p: '[]', solutii: 0, folosit: new Array(n).fill(0).map(function(_,i){return (i+1)+':F';}).join(' ') }, exp: 'Generؤƒm permutؤƒrile lui {1..' + n + '} prin backtracking. back(1).' });
        back(1);
        steps.push({ line: 11, vars: { k: '?', p: '?', solutii: solutii, folosit: 'â€”' }, exp: 'Gata! Am generat toate ' + solutii + ' permutؤƒrile lui {1..' + n + '} (' + n + '! = ' + solutii + ').', done: true });
        return { steps: steps, result: solutii + ' permutؤƒri ale {1..' + n + '}' };
      }
    },

    // â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ 75 ALGORITMI NOI - COMPLET INMEMORILE DE SIMULARE â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گ
    'inversare-recursiv': {
      name: 'Inversare Vector Recursiv',
      fileName: 'inversare_rec.cpp',
      codeLines: [
        'void inv(int v[], int st, int dr) {',
        '  if (st < dr) {',
        '    int aux = v[st];',
        '    v[st] = v[dr];',
        '    v[dr] = aux;',
        '    inv(v, st+1, dr-1);',
        '  }',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector:<input id="inp-v" class="tracer-input" value="1 2 3 4 5"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var steps = [];
        var maxSteps = 100;
        function solve(st, dr) {
          if (steps.length > maxSteps) return;
          steps.push({ line: 1, vars: { v: v.slice(), st: st, dr: dr }, exp: 'Apel recursiv inv(v, ' + st + ', ' + dr + '). Verificؤƒm st < dr: ' + st + ' < ' + dr, arr: v.slice(), highlight: [st, dr] });
          if (st < dr) {
            var aux = v[st];
            steps.push({ line: 2, vars: { v: v.slice(), st: st, dr: dr, aux: aux }, exp: 'aux = v[' + st + '] = ' + aux, arr: v.slice(), highlight: [st] });
            v[st] = v[dr];
            steps.push({ line: 3, vars: { v: v.slice(), st: st, dr: dr, aux: aux }, exp: 'v[' + st + '] devine v[' + dr + '] = ' + v[dr], arr: v.slice(), highlight: [st, dr] });
            v[dr] = aux;
            steps.push({ line: 4, vars: { v: v.slice(), st: st, dr: dr, aux: aux }, exp: 'v[' + dr + '] devine aux = ' + aux, arr: v.slice(), highlight: [st, dr] });
            solve(st + 1, dr - 1);
          } else {
            steps.push({ line: 1, vars: { v: v.slice(), st: st, dr: dr }, exp: 'Recursivitatea se opreب™te (st >= dr).', arr: v.slice() });
          }
        }
        solve(0, v.length - 1);
        steps.push({ line: 0, vars: { v: v.slice() }, exp: 'Vector inversat complet!', arr: v.slice(), done: true });
        return { steps: steps, result: 'Inversat: [' + v.join(', ') + ']' };
      }
    },
    'rotatie-vector': {
      name: 'Rotaب›ie Stأ¢nga Vector',
      fileName: 'rotatie.cpp',
      codeLines: [
        'void rotate(int v[], int n, int k) {',
        '  for (int i = 0; i < k; i++) {',
        '    int tmp = v[0];',
        '    for (int j = 0; j < n-1; j++)',
        '      v[j] = v[j+1];',
        '    v[n-1] = tmp;',
        '  }',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Vector:<input id="inp-v" class="tracer-input" value="1 2 3 4 5"></label><label class="input-field-label">Poziب›ii de rotit (k):<input id="inp-k" type="number" class="tracer-input" value="2" style="width:100px"></label></div>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var k = parseInt(inputs['inp-k']) || 1;
        var n = v.length;
        var steps = [];
        steps.push({ line: 0, vars: { v: v.slice(), k: k, n: n, i: '?', j: '?', tmp: '?' }, exp: 'Iniب›iem rotaب›ia vectorului de lungime n = ' + n + ' cu k = ' + k + ' poziب›ii la stأ¢nga.', arr: v.slice() });
        for (var i = 0; i < k; i++) {
          steps.push({ line: 1, vars: { v: v.slice(), k: k, n: n, i: i, j: '?', tmp: '?' }, exp: 'Iteraب›ie i = ' + i + ' pentru rotaب›ie.', arr: v.slice() });
          var tmp = v[0];
          steps.push({ line: 2, vars: { v: v.slice(), k: k, n: n, i: i, j: '?', tmp: tmp }, exp: 'Salvam primul element tmp = v[0] = ' + tmp, arr: v.slice(), highlight: [0] });
          for (var j = 0; j < n - 1; j++) {
            v[j] = v[j+1];
            steps.push({ line: 4, vars: { v: v.slice(), k: k, n: n, i: i, j: j, tmp: tmp }, exp: 'v[' + j + '] precؤƒpؤƒtat din v[' + (j+1) + '] = ' + v[j], arr: v.slice(), highlight: [j, j+1] });
