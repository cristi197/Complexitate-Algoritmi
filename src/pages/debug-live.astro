      codeLines: [
        'int partition(int v[], int st, int dr) {',
        '  int pivot = v[dr], i = st-1;',
        '  for (int j = st; j < dr; j++)',
        '    if (v[j] < pivot) swap(v[++i], v[j]);',
        '  swap(v[i+1], v[dr]); return i+1;',
        '}'
