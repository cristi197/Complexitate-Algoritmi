        var m = pat.length;
        var steps = [];
        var matches = [];
        
        var lps = new Array(m).fill(0);
        var len = 0;
        var jLps = 1;
        while (jLps < m) {
          if (pat[jLps] === pat[len]) {
            len++;
            lps[jLps] = len;
            jLps++;
          } else {
