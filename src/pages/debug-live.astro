        var dp = new Array(n).fill(1);
        steps.push({ line: 0, vars: { v: v, n: n, i: '?', j: '?', dp: '?' }, exp: 'Inițiem algoritmul LIS prin programare dinamică.', arr: v.slice() });
        steps.push({ line: 1, vars: { v: v, n: n, i: '?', j: '?', dp: dp.slice() }, exp: 'Inițializăm vectorul dp unde dp[i] este lungimea LIS care se termină în v[i] (inițial toate 1).', arr: v.slice() });
        for (var i = 1; i < n; i++) {
          for (var j = 0; j < i; j++) {
            var bigger = (v[j] < v[i]);
            var prevDP = dp[i];
            if (bigger) dp[i] = Math.max(dp[i], dp[j] + 1);
