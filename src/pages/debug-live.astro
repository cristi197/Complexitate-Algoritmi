  };

  /* ── State ── */
  var currentAlgo = null;
  var currentSteps = [];
  var currentStep = -1;

  /* ── Elements ── */
  function el(id) { return document.getElementById(id); }
  var algoGrid   = el('algo-grid');
  var inputCard  = el('input-card');
  var inputArea  = el('input-area');
  var tracerCard = el('tracer-card');
  var doneCard   = el('done-card');
  var codeEl     = el('tracer-code');
  var varsEl     = el('tracer-vars');
  var expEl      = el('tracer-exp');
  var stepInfo   = el('step-info');
  var prevBtn    = el('prev-btn');
  var nextBtn    = el('next-btn');
  var arrayViz   = el('array-viz');
  var arrayWrap  = el('array-viz-wrap');
  var templatesContainer = el('templates-container');
  var traceTableBody = el('trace-table-body');
  var traceTableHeader = el('trace-table-header');
  var activeAlgoTitle = el('active-algo-title');
  var ideFilename = el('ide-filename');

  /* ── Build algo grid ── */
  var algosData = JSON.parse(el('tracer-algos-data').textContent);
  var algoButtons = {};
  algosData.forEach(function(algo) {
    var def = ALGOS[algo.id];
    if (!def) return;
    var btn = document.createElement('button');
    btn.className = 'algo-btn-v2';
    btn.dataset.algoId = algo.id;
    btn.dataset.category = algo.category;
    btn.dataset.name = def.name.toLowerCase();
    btn.dataset.desc = algo.description.toLowerCase();
    btn.innerHTML =
      '<div class="algo-btn-card-header">' +
        '<strong>' + def.name + '</strong>' +
        '<span class="algo-cat-pill">' + algo.category + '</span>' +
      '</div>' +
      '<small class="algo-btn-desc">' + algo.description + '</small>' +
      '<span class="algo-btn-vars-label">Variabile: ' + algo.vars.map(function(v) { return '<code>' + v + '</code>'; }).join(', ') + '</span>';
    btn.addEventListener('click', function() {
      selectAlgo(algo.id);
    });
    algoGrid.appendChild(btn);
    algoButtons[algo.id] = btn;
  });

  /* ── Filter & Search Logic ── */
  var searchInput = el('algo-search');
  var algoCatsEl = el('algo-cats');
  var catButtons = algoCatsEl ? algoCatsEl.querySelectorAll('.cat-btn') : [];
  var currentFilter = 'all';
  var currentSearch = '';

  function updateGridDisplay() {
    var allButtons = algoGrid.querySelectorAll('.algo-btn-v2');
    var visibleCount = 0;
    allButtons.forEach(function(btn) {
      var id = btn.dataset.algoId;
      var cat = btn.dataset.category;
      var name = btn.dataset.name;
      var desc = btn.dataset.desc;
      var matchesCategory = (currentFilter === 'all' || cat === currentFilter);
      var matchesSearch = currentSearch === '' || name.includes(currentSearch) || desc.includes(currentSearch);
      var shouldShow = matchesCategory && matchesSearch;
      btn.classList.toggle('hidden', !shouldShow);
      if (shouldShow) visibleCount++;
    });
    if (visibleCount === 0) {
      if (!el('algo-no-results')) {
        var noRes = document.createElement('div');
        noRes.id = 'algo-no-results';
        noRes.style.cssText = 'grid-column:1/-1;text-align:center;padding:2rem;color:var(--text-faint);font-size:0.9rem';
        noRes.textContent = '❌ Niciun algoritm nu se potrivește filtrelor...';
        algoGrid.appendChild(noRes);
      }
    } else {
      var noRes = el('algo-no-results');
      if (noRes) noRes.remove();
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      currentSearch = this.value.toLowerCase().trim();
      updateGridDisplay();
    });
  }

  if (catButtons && catButtons.length > 0) {
    catButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        catButtons.forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        currentFilter = this.dataset.cat || 'all';
        updateGridDisplay();
      });
    });
  }

  function selectAlgo(id) {
    currentAlgo = id;
    var def = ALGOS[id];
    // Highlight selected algorithm button
    algoGrid.querySelectorAll('.algo-btn-v2').forEach(function(b) { b.classList.remove('selected'); });
    if (algoButtons[id]) algoButtons[id].classList.add('selected');

    // Populate Templates
    var tls = TEMPLATES[id] || [];
    templatesContainer.innerHTML = '';
    
    tls.forEach(function(tpl) {
      var tBtn = document.createElement('button');
      tBtn.className = 'template-pill';
      tBtn.innerHTML = '<strong>' + tpl.name + '</strong><span class="tpl-desc">' + tpl.desc + '</span>';
      tBtn.addEventListener('click', function() {
        // apply values to inputs
        Object.keys(tpl.values).forEach(function(inputKey) {
          var inputField = el(inputKey);
          if (inputField) {
            inputField.value = tpl.values[inputKey];
            inputField.classList.add('pulse-highlight');
            setTimeout(function() { inputField.classList.remove('pulse-highlight'); }, 800);
          }
        });
        // Highlight active template pill
        templatesContainer.querySelectorAll('.template-pill').forEach(function(b) { b.classList.remove('active-tpl'); });
        tBtn.classList.add('active-tpl');
      });
      templatesContainer.appendChild(tBtn);
    });

    // Show input cards
    inputArea.innerHTML = def.inputHTML;
    inputCard.style.display = '';
    tracerCard.style.display = 'none';
    doneCard.style.display = 'none';

    // select first template by default to quick fill
    if (tls.length > 0) {
      setTimeout(function() {
        var firstTplBtn = templatesContainer.querySelector('.template-pill');
        if (firstTplBtn) firstTplBtn.click();
      }, 50);
    }
  }

  /* ── Interactive simulation starter ── */
  el('start-btn').addEventListener('click', function() {
    var def = ALGOS[currentAlgo];
    activeAlgoTitle.textContent = def.name;
    ideFilename.textContent = def.fileName || 'algoritm.cpp';

    // Collect inputs
    var inputs = {};
    inputArea.querySelectorAll('input').forEach(function(inp) {
      inputs[inp.id] = inp.value;
    });

    var result = def.run(inputs);
    currentSteps = result.steps;
    currentStep = 0;
    
    // Toggle displays
    tracerCard.style.display = 'block';
    doneCard.style.display = 'none';
    
    // Render IDE code with line numbers
    codeEl.innerHTML = def.codeLines.map(function(line, i) {
      var numStr = (i + 1).toString().padStart(2, '0');
      return '<div class="code-line-tr" id="cl-tr-' + i + '">' +
               '<span class="code-active-arrow" aria-hidden="true">▶</span>' +
               '<span class="line-number-gutter">' + numStr + '</span>' +
               '<span class="code-text-span">' + escapeHtml(line) + '</span>' +
             '</div>';
    }).join('\n');

    // Build the Trace Table (tabel de trasare)
    buildTraceTable();
    
    renderStep();
  });

  function buildTraceTable() {
    // Collect specific keys to display: list variables from algo metadata
    var algoMeta = algosData.find(function(a) { return a.id === currentAlgo; });
    var variableKeys = algoMeta ? algoMeta.vars : [];

    // Table Header
    var headerHTML = '<th>Pas</th><th>Lg. Cod</th>';
    variableKeys.forEach(function(key) {
      headerHTML += '<th>' + key + '</th>';
    });
    traceTableHeader.innerHTML = headerHTML;

    // Table Rows
    var bodyHTML = '';
    currentSteps.forEach(function(step, idx) {
      bodyHTML += '<tr class="trace-table-row" id="t-row-' + idx + '" data-step-id="' + idx + '">';
      bodyHTML += '<td>' + (idx + 1) + '</td>';
      
      var lineNo = (step.line !== undefined) ? (step.line + 1) : '-';
      bodyHTML += '<td>L' + lineNo + '</td>';

      variableKeys.forEach(function(key) {
        var val = step.vars[key];
        if (val === undefined) {
          bodyHTML += '<td>-</td>';
        } else if (Array.isArray(val)) {
          bodyHTML += '<td class="mono-font">[' + val.join(',') + ']</td>';
        } else {
          bodyHTML += '<td class="mono-font font-semibold">' + val + '</td>';
        }
      });
      bodyHTML += '</tr>';
    });
    
    traceTableBody.innerHTML = bodyHTML;

    // Add click listeners to rows so clicking jump-cuts simulation to that point!
    traceTableBody.querySelectorAll('.trace-table-row').forEach(function(row) {
      row.addEventListener('click', function() {
        var sId = parseInt(this.getAttribute('data-step-id'));
        currentStep = sId;
        renderStep();
      });
    });
  }

  el('next-btn').addEventListener('click', function() {
    if (currentStep < currentSteps.length - 1) {
      currentStep++;
      renderStep();
    }
  });

  el('prev-btn').addEventListener('click', function() {
    if (currentStep > 0) {
      currentStep--;
      renderStep();
    }
  });

  el('restart-btn').addEventListener('click', function() {
    currentStep = 0;
    renderStep();
    tracerCard.style.display = 'block';
    doneCard.style.display = 'none';
  });

  el('replay-btn').addEventListener('click', function() {
    currentStep = 0;
    renderStep();
    tracerCard.style.display = 'block';
    doneCard.style.display = 'none';
  });

  function changeToSelection() {
    doneCard.style.display = 'none';
    tracerCard.style.display = 'none';
    inputCard.style.display = 'none';
    algoGrid.querySelectorAll('.algo-btn-v2').forEach(function(b) { b.classList.remove('selected'); });
    currentAlgo = null;
    window.scrollTo({ top: algoGrid.offsetTop - 100, behavior: 'smooth' });
  }

  el('change-algo-btn').addEventListener('click', changeToSelection);
  el('new-algo-btn').addEventListener('click', changeToSelection);

  function renderStep() {
    if (currentStep < 0 || currentStep >= currentSteps.length) return;
    var step = currentSteps[currentStep];
    if (!step) return;
    
    // Highlight code line
    var codeLines = codeEl.querySelectorAll('.code-line-tr');
    codeLines.forEach(function(l) { l.classList.remove('active-line'); });
    if (step.line !== undefined && codeLines[step.line]) {
      codeLines[step.line].classList.add('active-line');
      scrollIntoContainer(codeLines[step.line], codeEl.closest('.code-editor-scroller'));
    }

    // Highlight row in Trace Table
    var rows = traceTableBody.querySelectorAll('.trace-table-row');
    rows.forEach(function(r) { r.classList.remove('active-row'); });
    var activeRow = el('t-row-' + currentStep);
    if (activeRow) {
      activeRow.classList.add('active-row');
      scrollIntoContainer(activeRow, traceTableBody.closest('.trace-table-scroller'));
    }

    // Display variables in sidebar
    varsEl.innerHTML = '';
    var algoMeta = algosData.find(function(a) { return a.id === currentAlgo; });
    var varsToShow = algoMeta ? algoMeta.vars : Object.keys(step.vars);

    varsToShow.forEach(function(key) {
      var val = step.vars[key];
      if (Array.isArray(val)) return; // skip vectors, because we draw them in viz
      if (val === undefined || val === null || val === '') val = '?';
      
      var row = document.createElement('div');
      row.className = 'v2-var-card';
      
      var label = document.createElement('span');
      label.className = 'v2-var-name';
      label.textContent = key;

      var eq = document.createElement('span');
      eq.className = 'v2-var-eq';
      eq.textContent = '=';
      
      var valueSpan = document.createElement('span');
      valueSpan.className = 'v2-var-value';
      valueSpan.textContent = String(val);
      if (val === '?') {
        valueSpan.classList.add('uninitialized');
      }

      row.appendChild(label);
      row.appendChild(eq);
      row.appendChild(valueSpan);
      varsEl.appendChild(row);
    });

    // Explanation explanation update
    expEl.innerHTML = step.exp || '';

    // Array / Vector Visualization
    if (step.arr) {
      arrayWrap.style.display = 'block';
      arrayViz.innerHTML = step.arr.map(function(v, i) {
        var cls = 'v2-arr-cell';
        if (step.highlight && step.highlight.indexOf(i) !== -1) {
          cls += ' v2-arr-cell--active';
        }
        return '<div class="' + cls + '">' +
                 '<span class="v2-arr-val">' + v + '</span>' +
                 '<span class="v2-arr-idx">[' + i + ']</span>' +
               '</div>';
      }).join('');
    } else {
      arrayWrap.style.display = 'none';
    }

    // Step Info indicators
    stepInfo.textContent = 'Pas ' + (currentStep + 1) + ' / ' + currentSteps.length;
    prevBtn.disabled = currentStep === 0;
    nextBtn.disabled = currentStep === currentSteps.length - 1;

    // Show Completion Card if at final step
    if (currentStep === currentSteps.length - 1) {
      el('done-msg').textContent = 'Algoritmul "' + ALGOS[currentAlgo].name + '" s-a încheiat cu rezultatul: ' + currentSteps[currentSteps.length - 1].exp;
      doneCard.style.display = 'block';
    } else {
      doneCard.style.display = 'none';
    }
  }

  function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function scrollIntoContainer(target, container) {
    if (!target || !container) return;
    var tTop = target.offsetTop;
    var tBottom = tTop + target.offsetHeight;
    var cTop = container.scrollTop;
    var cBottom = cTop + container.clientHeight;

    if (tTop < cTop) {
      container.scrollTop = Math.max(tTop - 8, 0);
      return;
    }

    if (tBottom > cBottom) {
      container.scrollTop = tBottom - container.clientHeight + 8;
    }
  }

  // Keyboard Navigation: Arrow Right key advances, Left key goes back
  document.addEventListener('keydown', function(e) {
    if (tracerCard.style.display !== 'block') return;
    if (document.activeElement && ['INPUT', 'TEXTAREA', 'SELECT'].indexOf(document.activeElement.tagName) !== -1) return; // ignore when typing

    if (e.key === 'ArrowRight') {
      nextBtn.click();
    } else if (e.key === 'ArrowLeft') {
      prevBtn.click();
    }
  });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initApp);
  } else {
    initApp();
  }
})();
</script>

