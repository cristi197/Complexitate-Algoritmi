      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var x = parseInt(inputs['inp-x']) || 0;
        var n = v.length;
        var steps = [];
        steps.push({ line: 0, vars: { v: v, x: x, n: n, st: '?', dr: '?' }, exp: 'Iniب›iem cؤƒutarea prin interpolare pentru valoarea ' + x, arr: v.slice() });
        var st = 0, dr = n - 1;
        steps.push({ line: 1, vars: { v: v, x: x, st: st, dr: dr }, exp: 'Iniب›ializؤƒm limitele st = 0, dr = ' + dr, arr: v.slice(), highlight: [st, dr] });
        
        var foundIdx = -1;
        while(st <= dr && x >= v[st] && x <= v[dr]) {
          steps.push({ line: 2, vars: { v: v, x: x, st: st, dr: dr }, exp: 'Verificؤƒm condiب›ia: st <= dr ب™i valoarea se aflؤƒ أ®n interiorul plajei [' + v[st] + '...' + v[dr] + ']', arr: v.slice(), highlight: [st, dr] });
          
          var denom = v[dr] - v[st];
          var pos;
          if (denom === 0) {
            pos = st;
          } else {
            pos = st + Math.floor(((x - v[st]) * (dr - st)) / denom);
          }
          
          steps.push({ line: 3, vars: { v: v, x: x, st: st, dr: dr, pos: pos }, exp: 'Calculؤƒm poziب›ia estimatؤƒ prin formulؤƒ de interpolare linearؤƒ: pos = ' + pos + ' (valoare: ' + v[pos] + ')', arr: v.slice(), highlight: [st, pos, dr] });
          
          if (v[pos] === x) {
            foundIdx = pos;
            steps.push({ line: 4, vars: { v: v, x: x, st: st, dr: dr, pos: pos }, exp: 'Gؤƒsit! v[pos] este egal cu ' + x, arr: v.slice(), highlight: [pos], done: true });
            break;
          }
          if (v[pos] < x) {
            steps.push({ line: 5, vars: { v: v, x: x, st: st, dr: dr, pos: pos }, exp: 'v[pos] < x (' + v[pos] + ' < ' + x + '). Restrأ¢ngem cؤƒutarea أ®n dreapta: st = ' + (pos + 1), arr: v.slice(), highlight: [pos] });
            st = pos + 1;
          } else {
            steps.push({ line: 6, vars: { v: v, x: x, st: st, dr: dr, pos: pos }, exp: 'v[pos] > x (' + v[pos] + ' > ' + x + '). Restrأ¢ngem cؤƒutarea أ®n stأ¢nga: dr = ' + (pos - 1), arr: v.slice(), highlight: [pos] });
            dr = pos - 1;
          }
        }
        if (foundIdx === -1) {
          steps.push({ line: 8, vars: { v: v, x: x, st: st, dr: dr }, exp: 'Am terminat bucla de cؤƒutare. Valoarea nu se aflؤƒ أ®n vector.', arr: v.slice(), done: true });
        }
