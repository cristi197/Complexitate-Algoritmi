        var orig = n;
        var digits = n.toString().length;
        steps.push({ line: 3, vars: { n: n, orig: orig, sum: 0, digits: digits }, exp: 'Numărul de cifre ale lui ' + n + ' este ' + digits });
        var tmp = n;
