          tmp = Math.floor(tmp / 10);
        }
        var ok = (sum === orig);
        steps.push({ line: 6, vars: { n: n, orig: orig, sum: sum, ok: ok }, exp: 'Comparăm suma realizată (' + sum + ') cu numărul original (' + orig + '). ' + (ok ? 'Sunt egale!' : 'Sunt diferite!'), done: true });
        return { steps: steps, result: ok ? orig + ' este Armstrong!' : orig + ' nu este Armstrong' };
      }
    },
