          steps.push({ line: 5, vars: { v: v.slice(), n: n, i: i, cnt: cnt.slice(), out: out.slice() }, exp: 'Plasăm v[' + i + '] (' + val + ') la indexul ' + j + ' pe baza cnt[' + val + '] = ' + (j+1) + '. Decrementăm cnt[' + val + '] la ' + cnt[val], arr: out.slice(), highlight: [j] });
        }
        steps.push({ line: 6, vars: { v: out.slice(), n: n }, exp: 'Gata! Vectorul sortat prin Counting Sort este: [' + out.join(', ') + ']', arr: out.slice(), done: true });
        return { steps: steps, result: 'Sortat count: [' + out.join(', ') + ']' };
      }
    },
    'radix-sort': {
