    'numarul-fericit': {
      name: 'Număr Fericit',
      fileName: 'happy.cpp',
      codeLines: [
        'bool isHappy(int n) {',
        '  set<int> seen;',
        '  while (n != 1 && !seen.count(n)) {',
        '    seen.insert(n);',
        '    int sum = 0;',
        '    while (n) { int d = n%10; sum += d*d; n /= 10; }',
        '    n = sum;',
        '  }',
        '  return n == 1;',
        '}'
      ],
      inputHTML: '<div class="input-form-inner"><label class="input-field-label">Număr de verificat:<input id="inp-n" type="number" class="tracer-input" value="7"></label></div>',
      run: function(inputs) {
        var n = parseInt(inputs['inp-n']) || 0;
        var steps = [];
        steps.push({ line: 0, vars: { n: n }, exp: 'Inițiem verificarea dacă ' + n + ' este un număr fericit.' });
        var seen = new Set();
        var orig = n;
        var current = n;
        while (current !== 1 && !seen.has(current)) {
          seen.add(current);
          var sum = 0;
          var tmp = current;
          var digits = [];
          while (tmp) {
            var d = tmp % 10;
            sum += d * d;
            digits.push(d + '²');
            tmp = Math.floor(tmp / 10);
          }
          steps.push({ line: 2, vars: { n: current, seen: Array.from(seen) }, exp: 'Numărul curent în flux este: ' + current + '.' });
          steps.push({ line: 5, vars: { n: current, sum: sum }, exp: 'Calculăm suma pătratelor cifrelor: ' + digits.reverse().join(' + ') + ' = ' + sum });
          current = sum;
        }
        var ok = (current === 1);
        steps.push({ line: 8, vars: { n: current, ok: ok }, exp: ok ? 'S-a ajuns la 1! Numărul original ' + orig + ' este fericit!' : 'S-a detectat o buclă infinită la ' + current + '. Numărul original ' + orig + ' este trist.', done: true });
        return { steps: steps, result: ok ? orig + ' e fericit!' : orig + ' e trist' };
      }
    },
