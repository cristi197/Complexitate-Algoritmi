        steps.push({ line: 0, vars: { s: s.join(''), st: 0, dr: n-1 }, exp: 'Inversăm șirul recursiv.', arr: s.slice() });
        
        function rRec(st, dr) {
          steps.push({ line: 1, vars: { s: s.join(''), st: st, dr: dr }, exp: 'Apel revRec(st = ' + st + ', dr = ' + dr + ')', arr: s.slice(), highlight: [st, dr] });
