---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Examen în Alb — InfoLiceu">
  <Header />

  <main class="ea-page" id="main-content">

    <!-- ── Hero ──────────────────────────────────────────────── -->
    <div class="ea-hero">
      <div class="ea-hero__inner">
        <div class="ea-hero__badge">🎓 Simulare BAC Informatică</div>
        <h1>Examen în Alb</h1>
        <p>Simulează condiții reale de bacalaureat cu subiecte oficiale. Subiectul I se notează automat. Subiectele II și III au editor de cod cu teste.</p>
      </div>
    </div>

    <!-- ── Selector overlay ──────────────────────────────────── -->
    <div id="selectorOverlay" class="ea-overlay">
      <div class="ea-selector">
        <h2>Alege examenul</h2>
        <div class="ea-filter-row">
          <select id="filterYear" class="ea-select"><option value="">Toți anii</option></select>
          <select id="filterType" class="ea-select">
            <option value="">Toate sesiunile</option>
            <option value="simulare">Simulare</option>
            <option value="model">Modele oficiale</option>
            <option value="iunie">Sesiunea Iunie</option>
            <option value="august">Sesiunea August</option>
            <option value="special">Sesiunea Specială</option>
          </select>
          <button id="btnRandom" class="ea-btn ea-btn--accent">🎲 Aleatoriu</button>
        </div>
        <div id="examList" class="ea-exam-list">
          <div style="display:flex;justify-content:center;padding:40px"><div class="ea-spinner"></div></div>
        </div>
      </div>
    </div>

    <!-- ── Exam interface ────────────────────────────────────── -->
    <div id="examInterface" style="display:none">

      <div class="ea-timer-bar">
        <div class="ea-timer-left">
          <span id="examLabel" class="ea-exam-label"></span>
          <span id="timerDisplay" class="ea-timer-clock">3:00:00</span>
        </div>
        <div class="ea-timer-track"><div id="timerFill" class="ea-timer-fill"></div></div>
        <div class="ea-timer-actions">
          <button id="btnOpenBarem" class="ea-btn ea-btn--sm" style="display:none">📋 Barem</button>
          <button id="btnOpenPdf"   class="ea-btn ea-btn--sm">📄 PDF</button>
        </div>
      </div>

      <div id="examLoading" class="ea-loading">
        <div class="ea-spinner"></div><p>Se încarcă subiectele…</p>
      </div>

      <div id="examContent" class="ea-content" style="display:none">

        <section class="ea-subject" id="secSubI">
          <div class="ea-subject__header ea-subject__header--I">
            <div><span class="ea-subject__num">SUBIECTUL I</span><span class="ea-subject__desc">Grilă — câte un răspuns corect</span></div>
            <span class="ea-subject__pts">20 puncte</span>
          </div>
          <div class="ea-subject__info">Fiecare răspuns corect = <strong>4 puncte</strong>. Se acordă <strong>10 puncte din oficiu</strong>.</div>
          <div id="subI-questions" class="ea-questions"></div>
        </section>

        <section class="ea-subject" id="secSubII">
          <div class="ea-subject__header ea-subject__header--II">
            <div><span class="ea-subject__num">SUBIECTUL al II-lea</span><span class="ea-subject__desc">Pseudocod + algoritmi parțiali</span></div>
            <span class="ea-subject__pts">40 puncte</span>
          </div>
          <div id="subII-problems" class="ea-problems"></div>
        </section>

        <section class="ea-subject" id="secSubIII">
          <div class="ea-subject__header ea-subject__header--III">
            <div><span class="ea-subject__num">SUBIECTUL al III-lea</span><span class="ea-subject__desc">Cod complet C/C++</span></div>
            <span class="ea-subject__pts">30 puncte</span>
          </div>
          <div id="subIII-problems" class="ea-problems"></div>
        </section>

      </div>

      <div class="ea-submit-bar" id="submitBar" style="display:none">
        <div>
          <button id="btnSubmit" class="ea-btn ea-btn--submit">✅ Predă Examenul</button>
          <button id="btnAbort"  class="ea-btn ea-btn--ghost">← Alt examen</button>
        </div>
        <p class="ea-submit-hint">Câmpurile necompletate = 0 puncte. Poți preda oricând.</p>
      </div>
    </div>

    <!-- ── Results ────────────────────────────────────────────── -->
    <div id="resultsSection" style="display:none" class="ea-results-wrap">
      <div class="ea-results-card">
        <h2>📊 Rezultate</h2>
        <div id="resultsBody"></div>
        <div class="ea-results-actions">
          <button id="btnRetry"   class="ea-btn ea-btn--accent">🔄 Reia examenul</button>
          <button id="btnNewExam" class="ea-btn ea-btn--ghost">📋 Alt examen</button>
        </div>
      </div>
    </div>

  </main>

  <style is:global>
  .ea-page { min-height:100vh; padding-bottom:60px; background:var(--color-background,#0f172a); }

  .ea-hero {
    background:linear-gradient(135deg,#1a1a2e 0%,#16213e 30%,#0f3460 60%,#533483 100%);
    padding:56px 24px 40px; text-align:center; color:#fff; position:relative; overflow:hidden;
  }
  .ea-hero::before {
    content:''; position:absolute; inset:0; pointer-events:none;
    background: radial-gradient(ellipse 60% 50% at 50% 0%,rgba(99,102,241,.15) 0%,transparent 60%),
                radial-gradient(ellipse 40% 35% at 80% 80%,rgba(168,85,247,.08) 0%,transparent 50%);
  }
  .ea-hero__inner { position:relative; max-width:680px; margin:0 auto; }
  .ea-hero__badge {
    display:inline-block; background:rgba(255,255,255,.1); backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,.18); border-radius:20px;
    padding:5px 18px; font-size:.82rem; font-weight:600; margin-bottom:18px;
  }
  .ea-hero h1 { font-size:clamp(2rem,5vw,3rem); margin:0 0 14px; font-weight:800; letter-spacing:-1px; }
  .ea-hero p  { opacity:.85; max-width:580px; margin:0 auto; line-height:1.65; }

  .ea-overlay { display:flex; justify-content:center; padding:36px 20px; }
  .ea-selector { max-width:900px; width:100%; }
  .ea-selector h2 { text-align:center; margin-bottom:24px; font-size:1.4rem; font-weight:700; }

  .ea-filter-row { display:flex; gap:12px; margin-bottom:24px; flex-wrap:wrap; align-items:center; }
  .ea-select {
    flex:1; min-width:160px; padding:10px 14px; border-radius:10px;
    background:var(--color-surface,#1e293b); border:1.5px solid var(--color-border,#334155);
    color:var(--color-text,#e2e8f0); font-size:14px; cursor:pointer;
  }
  .ea-exam-list { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:14px; }

  .ea-exam-card {
    background:var(--color-surface,#1e293b); border:1.5px solid var(--color-border,#334155);
    border-radius:14px; padding:18px 20px; cursor:pointer;
    transition:border-color .2s,transform .2s,box-shadow .2s;
  }
  .ea-exam-card:hover { border-color:#3b82f6; transform:translateY(-2px); box-shadow:0 8px 24px rgba(59,130,246,.12); }
  .ea-exam-card__year    { font-size:.75rem; color:#60a5fa; font-weight:700; text-transform:uppercase; letter-spacing:.5px; margin-bottom:4px; }
  .ea-exam-card__session { font-size:15px; font-weight:600; margin-bottom:6px; }
  .ea-exam-card__type    { font-size:12px; color:var(--color-text-muted,#64748b); }

  .ea-loading { display:flex; flex-direction:column; align-items:center; padding:60px; gap:16px; color:var(--color-text-muted,#64748b); }
  .ea-spinner { width:44px; height:44px; border:4px solid #334155; border-top-color:#3b82f6; border-radius:50%; animation:ea-spin .8s linear infinite; }
  @keyframes ea-spin { to { transform:rotate(360deg); } }

  .ea-timer-bar {
    position:sticky; top:0; z-index:100;
    background:rgba(15,23,42,.95); backdrop-filter:blur(10px);
    border-bottom:1px solid var(--color-border,#334155);
    padding:10px 24px; display:flex; align-items:center; gap:16px; flex-wrap:wrap;
  }
  .ea-timer-left  { display:flex; align-items:center; gap:14px; flex-shrink:0; }
  .ea-exam-label  { font-size:13px; color:var(--color-text-muted,#64748b); max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .ea-timer-clock { font-size:1.4rem; font-weight:800; color:#60a5fa; font-variant-numeric:tabular-nums; }
  .ea-timer-track { flex:1; height:6px; background:#1e293b; border-radius:99px; overflow:hidden; min-width:80px; }
  .ea-timer-fill  { height:100%; width:100%; background:linear-gradient(90deg,#22c55e,#16a34a); transition:width 1s linear,background .5s; border-radius:99px; }
  .ea-timer-actions { display:flex; gap:8px; flex-shrink:0; }

  .ea-content { max-width:960px; margin:32px auto 0; padding:0 20px; display:flex; flex-direction:column; gap:32px; }

  .ea-subject { background:var(--color-surface,#1e293b); border:1.5px solid var(--color-border,#334155); border-radius:18px; overflow:hidden; box-shadow:0 4px 20px rgba(0,0,0,.12); }
  .ea-subject__header { padding:18px 24px; display:flex; justify-content:space-between; align-items:center; color:#fff; gap:12px; }
  .ea-subject__header--I   { background:linear-gradient(90deg,#1d4ed8,#2563eb); }
  .ea-subject__header--II  { background:linear-gradient(90deg,#7c3aed,#8b5cf6); }
  .ea-subject__header--III { background:linear-gradient(90deg,#0f766e,#0d9488); }
  .ea-subject__num  { font-weight:800; font-size:1rem; display:block; }
  .ea-subject__desc { font-size:13px; opacity:.8; display:block; margin-top:2px; }
  .ea-subject__pts  { background:rgba(255,255,255,.15); border-radius:8px; padding:4px 12px; font-size:13px; white-space:nowrap; flex-shrink:0; }
  .ea-subject__info { padding:10px 24px; font-size:13px; color:var(--color-text-muted,#64748b); background:rgba(255,255,255,.02); border-bottom:1px solid var(--color-border,#334155); }

  /* MCQ */
  .ea-questions { padding:20px 24px; display:flex; flex-direction:column; gap:20px; }
  .ea-q { border:1.5px solid var(--color-border,#334155); border-radius:14px; padding:20px; background:var(--color-background,#0f172a); transition:border-color .2s; }
  .ea-q.answered { border-color:rgba(34,197,94,.35); }
  .ea-q.correct  { border-color:#22c55e; background:rgba(34,197,94,.04); }
  .ea-q.wrong    { border-color:#ef4444; background:rgba(239,68,68,.04); }
  .ea-q__text { font-weight:600; margin-bottom:14px; line-height:1.6; font-size:15px; }
  .ea-q__num  { color:#60a5fa; font-weight:800; margin-right:8px; }
  .ea-q__code { background:#111827; border:1px solid #334155; border-radius:8px; padding:12px 16px; margin:10px 0; font-family:'Courier New',monospace; font-size:13px; line-height:1.6; overflow-x:auto; white-space:pre; display:block; }
  .ea-options { display:flex; flex-direction:column; gap:8px; }
  .ea-option {
    display:flex; align-items:flex-start; gap:12px; cursor:pointer;
    padding:10px 14px; border-radius:10px; border:1.5px solid transparent;
    transition:background .15s,border-color .15s;
  }
  .ea-option:hover   { background:rgba(59,130,246,.06); border-color:rgba(59,130,246,.2); }
  .ea-option.selected{ background:rgba(59,130,246,.1);  border-color:#3b82f6; }
  .ea-option.correct { background:rgba(34,197,94,.12);  border-color:#22c55e; }
  .ea-option.wrong   { background:rgba(239,68,68,.12);  border-color:#ef4444; }
  .ea-option input[type=radio] { margin-top:3px; accent-color:#3b82f6; width:18px; height:18px; flex-shrink:0; }
  .ea-option span  { font-size:14px; line-height:1.55; }
  .ea-option strong{ color:#93c5fd; }
  .ea-q__feedback { margin-top:12px; padding:12px 16px; border-radius:8px; font-size:13px; display:none; }
  .ea-q__feedback.correct { background:rgba(34,197,94,.1); border:1px solid rgba(34,197,94,.3); color:#4ade80; display:block; }
  .ea-q__feedback.wrong   { background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.3); color:#f87171; display:block; }

  /* Problems */
  .ea-problems { padding:20px 24px; display:flex; flex-direction:column; gap:28px; }
  .ea-problem { border:1.5px solid var(--color-border,#334155); border-radius:14px; background:var(--color-background,#0f172a); overflow:hidden; }
  .ea-problem__header { padding:12px 18px; background:rgba(255,255,255,.03); border-bottom:1px solid var(--color-border,#334155); display:flex; justify-content:space-between; align-items:center; }
  .ea-problem__title { font-weight:700; font-size:14px; }
  .ea-problem__pts   { font-size:12px; color:var(--color-text-muted,#64748b); }
  .ea-problem__body  { padding:18px 20px; display:flex; flex-direction:column; gap:16px; }
  .ea-problem__text  { font-size:14px; line-height:1.75; white-space:pre-wrap; }

  .ea-pseudocode {
    background:#0d1117; border:1px solid #30363d; border-radius:10px;
    padding:16px 18px; font-family:'Courier New',monospace; font-size:13px;
    line-height:1.85; overflow-x:auto; white-space:pre; color:#e6edf3;
    border-left:3px solid #7c3aed;
  }

  .ea-subq { border:1px solid #2d3748; border-radius:10px; padding:14px 16px; display:flex; flex-direction:column; gap:10px; }
  .ea-subq__label { font-weight:700; font-size:13px; color:#a78bfa; }
  .ea-subq__text  { font-size:13px; line-height:1.65; }

  .ea-textarea {
    width:100%; min-height:72px; padding:10px 14px; border-radius:8px;
    background:#111827; border:1.5px solid #334155; color:#e2e8f0;
    font-size:13px; line-height:1.6; resize:vertical; font-family:inherit;
    transition:border-color .2s; box-sizing:border-box;
  }
  .ea-textarea:focus { outline:none; border-color:#3b82f6; }

  .ea-code-editor {
    width:100%; min-height:160px; padding:12px 14px; border-radius:8px;
    background:#0d1117; border:1.5px solid #30363d; color:#e6edf3;
    font-size:13px; line-height:1.7; resize:vertical;
    font-family:'Courier New',Courier,monospace;
    transition:border-color .2s; tab-size:2;
    white-space:pre; overflow-wrap:normal; overflow-x:auto;
    box-sizing:border-box;
  }
  .ea-code-editor:focus { outline:none; border-color:#7c3aed; }
  .ea-code-actions { display:flex; gap:8px; margin-top:8px; flex-wrap:wrap; }

  .ea-testcases { display:flex; flex-direction:column; gap:10px; }
  .ea-testcase  { border:1px solid #2d3748; border-radius:8px; padding:12px 14px; display:flex; flex-direction:column; gap:8px; font-size:13px; transition:border-color .2s; }
  .ea-testcase__label { font-weight:700; font-size:11px; color:#60a5fa; text-transform:uppercase; letter-spacing:.5px; }
  .ea-testcase__io    { display:flex; gap:12px; flex-wrap:wrap; }
  .ea-testcase__slot  { flex:1; min-width:180px; }
  .ea-testcase__slot h5 { font-size:11px; color:var(--color-text-muted,#64748b); margin:0 0 4px; text-transform:uppercase; letter-spacing:.4px; }
  .ea-testcase__val   { background:#0d1117; border:1px solid #30363d; border-radius:6px; padding:6px 10px; font-family:monospace; font-size:12px; white-space:pre-wrap; color:#e6edf3; }
  .ea-testcase__check { display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
  .ea-testcase__check span { font-size:12px; color:var(--color-text-muted,#64748b); }
  .ea-testcase__check label { display:flex; gap:6px; align-items:center; cursor:pointer; font-size:13px; }

  .ea-self-note { padding:10px 16px; border-radius:8px; font-size:12px; line-height:1.55; background:rgba(168,85,247,.08); border:1px solid rgba(168,85,247,.2); color:#c084fc; }

  /* Buttons */
  .ea-btn { padding:10px 22px; border-radius:10px; border:none; cursor:pointer; font-size:14px; font-weight:600; transition:all .2s; display:inline-flex; align-items:center; gap:6px; text-decoration:none; }
  .ea-btn--accent  { background:linear-gradient(135deg,#3b82f6,#6366f1); color:#fff; }
  .ea-btn--accent:hover { transform:translateY(-1px); box-shadow:0 6px 20px rgba(59,130,246,.3); }
  .ea-btn--submit  { background:linear-gradient(135deg,#22c55e,#16a34a); color:#fff; padding:14px 36px; font-size:15px; }
  .ea-btn--submit:hover { transform:translateY(-1px); box-shadow:0 6px 20px rgba(34,197,94,.3); }
  .ea-btn--ghost   { background:transparent; color:var(--color-text-muted,#64748b); border:1.5px solid var(--color-border,#334155); }
  .ea-btn--ghost:hover { background:rgba(255,255,255,.05); color:var(--color-text,#e2e8f0); }
  .ea-btn--sm      { padding:6px 14px; font-size:12px; }
  .ea-btn--copy    { background:rgba(99,102,241,.1); color:#a5b4fc; border:1px solid rgba(99,102,241,.3); padding:6px 12px; font-size:12px; border-radius:8px; }
  .ea-btn--compiler{ background:rgba(234,179,8,.1); color:#fbbf24; border:1px solid rgba(234,179,8,.3); padding:6px 12px; font-size:12px; border-radius:8px; }

  /* Submit bar */
  .ea-submit-bar { display:flex; align-items:center; gap:12px; justify-content:center; padding:28px 20px; flex-wrap:wrap; flex-direction:column; }
  .ea-submit-bar > div { display:flex; gap:12px; flex-wrap:wrap; justify-content:center; }
  .ea-submit-hint { font-size:12px; color:var(--color-text-muted,#64748b); text-align:center; margin:0; }

  /* Results */
  .ea-results-wrap { display:flex; justify-content:center; padding:40px 20px; }
  .ea-results-card { background:var(--color-surface,#1e293b); border:1.5px solid var(--color-border,#334155); border-radius:20px; padding:36px; max-width:720px; width:100%; }
  .ea-results-card h2 { margin:0 0 28px; font-size:1.3rem; font-weight:800; }
  .ea-result-subject { margin-bottom:18px; padding-bottom:18px; border-bottom:1px solid var(--color-border,#334155); }
  .ea-result-subject:last-child { border-bottom:none; margin-bottom:0; padding-bottom:0; }
  .ea-result-subject h4 { margin:0 0 8px; font-size:14px; font-weight:700; }
  .ea-result-bar-bg   { height:8px; background:#1e293b; border-radius:99px; overflow:hidden; border:1px solid #334155; }
  .ea-result-bar-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,#3b82f6,#6366f1); transition:width .6s ease; }
  .ea-score-big { font-size:3rem; font-weight:800; margin:0 0 6px; }
  .ea-score-ok  { color:#22c55e; }
  .ea-score-mid { color:#f59e0b; }
  .ea-score-bad { color:#ef4444; }
  .ea-results-actions { display:flex; gap:12px; margin-top:28px; flex-wrap:wrap; justify-content:center; }

  @media (max-width:640px) {
    .ea-filter-row { flex-direction:column; }
    .ea-select { width:100%; }
    .ea-exam-list { grid-template-columns:1fr; }
    .ea-questions, .ea-problems { padding:14px; }
    .ea-subject__header { flex-direction:column; align-items:flex-start; gap:6px; }
  }
  </style>

  <script define:vars={{ base }}>
  (function() {
    /* ── State ─────────────────────────────────────────────── */
    let currentExam = null;
    let timerInterval = null;
    let secondsLeft   = 3 * 60 * 60;
    const TOTAL_SEC   = 3 * 60 * 60;
    let answers    = {};
    let selfScores = {};
    let examIndex  = [];

    /* ── DOM ────────────────────────────────────────────────── */
    const selectorOverlay = document.getElementById('selectorOverlay');
    const examInterface   = document.getElementById('examInterface');
    const examLoading     = document.getElementById('examLoading');
    const examContent     = document.getElementById('examContent');
    const submitBar       = document.getElementById('submitBar');
    const resultsSection  = document.getElementById('resultsSection');
    const filterYear      = document.getElementById('filterYear');
    const filterType      = document.getElementById('filterType');
    const examList        = document.getElementById('examList');
    const timerDisplay    = document.getElementById('timerDisplay');
    const timerFill       = document.getElementById('timerFill');
    const examLabel       = document.getElementById('examLabel');
    const btnOpenBarem    = document.getElementById('btnOpenBarem');
    const btnOpenPdf      = document.getElementById('btnOpenPdf');

    /* ── URL prefix ─────────────────────────────────────────── */
    function prefix() {
      if (base) return base;
      const parts = window.location.pathname.split('/').filter(Boolean);
      return parts.length > 1 ? '/' + parts[0] : '';
    }

    /* ── Load index ─────────────────────────────────────────── */
    async function loadIndex() {
      const res = await fetch(prefix() + '/data/examen-alb/index.json');
      examIndex = await res.json();
      const years = [...new Set(examIndex.map(e => e.year))].sort((a,b) => b-a);
      years.forEach(y => {
        const o = document.createElement('option');
        o.value = y; o.textContent = y;
        filterYear.appendChild(o);
      });
      renderList();
    }

    function typeLabel(t) {
      return ({simulare:'Simulare',model:'Modele oficiale',iunie:'Sesiunea Iunie',august:'Sesiunea August',special:'Sesiunea Specială','test-mec':'Test MEC',antrenament:'Test antrenament',rezerva:'Subiect de rezervă'})[t] || t;
    }

    function renderList() {
      const yr  = filterYear.value;
      const typ = filterType.value;
      const list = examIndex.filter(e => (!yr || String(e.year)===yr) && (!typ || e.type===typ));
      if (!list.length) {
        examList.innerHTML = '<p style="text-align:center;color:var(--color-text-muted,#64748b);padding:24px">Niciun examen găsit.</p>';
        return;
      }
      examList.innerHTML = list.map(e =>
        `<div class="ea-exam-card" data-id="${e.id}">
           <div class="ea-exam-card__year">${e.year}</div>
           <div class="ea-exam-card__session">${e.session}</div>
           <div class="ea-exam-card__type">${typeLabel(e.type)}</div>
         </div>`).join('');
      examList.querySelectorAll('.ea-exam-card').forEach(c =>
        c.addEventListener('click', () => startExam(c.dataset.id)));
    }

    filterYear.addEventListener('change', renderList);
    filterType.addEventListener('change', renderList);
    document.getElementById('btnRandom').addEventListener('click', () => {
      if (!examIndex.length) return;
      startExam(examIndex[Math.floor(Math.random() * examIndex.length)].id);
    });

    /* ── Start exam ─────────────────────────────────────────── */
    async function startExam(id) {
      selectorOverlay.style.display = 'none';
      examInterface.style.display   = 'block';
      examLoading.style.display     = 'flex';
      examContent.style.display     = 'none';
      submitBar.style.display       = 'none';
      answers = {}; selfScores = {};

      const res = await fetch(prefix() + '/data/examen-alb/' + id + '.json');
      currentExam = await res.json();

      examLabel.textContent = currentExam.year + ' — ' + currentExam.session;

      if (currentExam.pdfUrl) {
        btnOpenPdf.style.display = 'inline-flex';
        btnOpenPdf.onclick = () => window.open(prefix() + currentExam.pdfUrl, '_blank');
      }
      if (currentExam.baremUrl) {
        btnOpenBarem.style.display = 'inline-flex';
        btnOpenBarem.onclick = () => window.open(prefix() + currentExam.baremUrl, '_blank');
      }

      buildExam(currentExam);
      examLoading.style.display = 'none';
      examContent.style.display = 'flex';
      submitBar.style.display   = 'flex';

      secondsLeft = TOTAL_SEC;
      clearInterval(timerInterval);
      updateTimer();
      timerInterval = setInterval(updateTimer, 1000);
    }

    /* ── Timer ──────────────────────────────────────────────── */
    function updateTimer() {
      if (secondsLeft <= 0) { clearInterval(timerInterval); submitExam(true); return; }
      const h = Math.floor(secondsLeft/3600),
            m = Math.floor((secondsLeft%3600)/60),
            s = secondsLeft%60;
      timerDisplay.textContent = `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
      const pct = (secondsLeft/TOTAL_SEC)*100;
      timerFill.style.width = pct + '%';
      timerFill.style.background = pct < 25
        ? 'linear-gradient(90deg,#ef4444,#dc2626)'
        : pct < 50 ? 'linear-gradient(90deg,#f59e0b,#d97706)'
        : 'linear-gradient(90deg,#22c55e,#16a34a)';
      secondsLeft--;
    }

    /* ── Build exam ─────────────────────────────────────────── */
    function buildExam(exam) {
      buildSubiectI(exam.subiectI);
      buildSubiectII(exam.subiectII);
      buildSubiectIII(exam.subiectIII);
    }

    /* ── Helper: escape HTML ────────────────────────────────── */
    function esc(s) {
      return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ── Subject I: MCQ ─────────────────────────────────────── */
    function buildSubiectI(sub) {
      const container = document.getElementById('subI-questions');
      container.innerHTML = '';
      if (!sub?.questions?.length) {
        container.innerHTML = '<p style="color:var(--color-text-muted,#64748b);padding:12px 0">Întrebările nu au putut fi extrase automat. Consultați PDF-ul.</p>';
        return;
      }
      sub.questions.forEach((q, idx) => {
        const div = document.createElement('div');
        div.className = 'ea-q'; div.id = `q-I-${idx}`;
        div.innerHTML = `
          <div class="ea-q__text"><span class="ea-q__num">${q.nr}.</span>${esc(q.text)}</div>
          <div class="ea-options">${Object.entries(q.options||{}).map(([letter,opt])=>`
            <label class="ea-option">
              <input type="radio" name="s1q${idx}" value="${letter}">
              <span><strong>${letter.toUpperCase()})</strong> ${esc(opt)}</span>
            </label>`).join('')}</div>
          <div class="ea-q__feedback"></div>`;
        div.querySelectorAll('input[type=radio]').forEach(inp => {
          inp.addEventListener('change', () => {
            answers['s1q'+idx] = inp.value;
            div.classList.add('answered');
            div.querySelectorAll('.ea-option').forEach(l => l.classList.remove('selected'));
            inp.closest('.ea-option').classList.add('selected');
          });
        });
        container.appendChild(div);
      });
    }

    /* ── Subject II ─────────────────────────────────────────── */
    function buildSubiectII(sub) {
      const container = document.getElementById('subII-problems');
      container.innerHTML = '';
      if (!sub?.problems?.length) {
        container.innerHTML = '<p style="color:var(--color-text-muted,#64748b);padding:12px 0">Problemele nu au putut fi extrase automat. Consultați PDF-ul.</p>';
        return;
      }
      sub.problems.forEach((prob, pi) => {
        const div = document.createElement('div');
        div.className = 'ea-problem';
        if (prob.type === 'pseudocode') {
          const sqs = (prob.subQuestions||[]).map((sq,si) => subQHTML('II',pi,si,sq)).join('');
          div.innerHTML = `
            <div class="ea-problem__header">
              <span class="ea-problem__title">Problema ${prob.nr} — Pseudocod</span>
              <span class="ea-problem__pts">28 puncte</span>
            </div>
            <div class="ea-problem__body">
              <p style="font-size:13px;color:var(--color-text-muted,#64748b);margin:0">Algoritmul de mai jos este reprezentat în pseudocod:</p>
              ${prob.pseudocode
                ? `<pre class="ea-pseudocode">${esc(prob.pseudocode)}</pre>`
                : `<p class="ea-self-note">Pseudocodul nu a putut fi extras automat — consultați subiectul PDF.</p>`}
              <div style="display:flex;flex-direction:column;gap:14px">${sqs}</div>
            </div>`;
        } else {
          div.innerHTML = `
            <div class="ea-problem__header">
              <span class="ea-problem__title">Problema ${prob.nr}</span>
              <span class="ea-problem__pts">${prob.points||6} puncte</span>
            </div>
            <div class="ea-problem__body">
              <div class="ea-problem__text">${esc(prob.text||'')}</div>
              <textarea class="ea-textarea" id="ans-II-${pi}-0" rows="4"
                placeholder="Scrieți răspunsul..."
                oninput="window._saveAns('II-${pi}-0',this.value)"></textarea>
            </div>`;
        }
        container.appendChild(div);
      });
    }

    function subQHTML(subj, pi, si, sq) {
      const key = `${subj}-${pi}-${si}`;
      const pts = sq.points ? `<span style="font-size:12px;color:var(--color-text-muted,#64748b)">${sq.points}p</span>` : '';
      if (sq.type === 'code') {
        return `<div class="ea-subq">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <span class="ea-subq__label">${sq.id ? sq.id+')' : ''}</span>${pts}
          </div>
          <p class="ea-subq__text">${esc(sq.text||'')}</p>
          <textarea class="ea-code-editor" id="ans-${key}" rows="8"
            placeholder="#include &lt;iostream&gt;&#10;using namespace std;&#10;&#10;int main() {&#10;  // codul tău&#10;  return 0;&#10;}"
            oninput="window._saveAns('${key}',this.value)"></textarea>
          <div class="ea-code-actions">
            <button class="ea-btn ea-btn--copy"     onclick="window._copyCode('ans-${key}')">📋 Copiază</button>
            <button class="ea-btn ea-btn--compiler" onclick="window._openCompiler('ans-${key}')">🖥️ Compilator online</button>
          </div></div>`;
      }
      return `<div class="ea-subq">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span class="ea-subq__label">${sq.id ? sq.id+')' : ''}</span>${pts}
        </div>
        <p class="ea-subq__text">${esc(sq.text||'')}</p>
        <textarea class="ea-textarea" id="ans-${key}" rows="3"
          placeholder="Scrieți răspunsul..."
          oninput="window._saveAns('${key}',this.value)"></textarea>
      </div>`;
    }

    /* ── Subject III ────────────────────────────────────────── */
    function buildSubiectIII(sub) {
      const container = document.getElementById('subIII-problems');
      container.innerHTML = '';
      if (!sub?.problems?.length) {
        container.innerHTML = '<p style="color:var(--color-text-muted,#64748b);padding:12px 0">Problemele nu au putut fi extrase automat. Consultați PDF-ul.</p>';
        return;
      }
      sub.problems.forEach((prob, pi) => {
        const key = `III-${pi}`;
        const tcs = extractTestCases(prob.text);
        const tcHTML = tcs.length ? `
          <div>
            <p style="font-size:12px;color:var(--color-text-muted,#64748b);margin:0 0 8px;font-weight:700;text-transform:uppercase;letter-spacing:.4px">Teste de verificare</p>
            <div class="ea-testcases">${tcs.map((tc,ti) => `
              <div class="ea-testcase" id="tc-${key}-${ti}">
                <span class="ea-testcase__label">Test ${ti+1}</span>
                <div class="ea-testcase__io">
                  ${tc.input  ? `<div class="ea-testcase__slot"><h5>Input / date</h5><div class="ea-testcase__val">${esc(tc.input)}</div></div>` : ''}
                  ${tc.output ? `<div class="ea-testcase__slot"><h5>Output așteptat</h5><div class="ea-testcase__val">${esc(tc.output)}</div></div>` : ''}
                </div>
                <div class="ea-testcase__check">
                  <span>Codul meu produce output-ul corect?</span>
                  <label><input type="radio" name="tc-${key}-${ti}" value="ok"   onchange="window._markTest('${key}',${ti},'ok')">  ✅ Da</label>
                  <label><input type="radio" name="tc-${key}-${ti}" value="fail" onchange="window._markTest('${key}',${ti},'fail')"> ❌ Nu</label>
                </div>
              </div>`).join('')}
            </div>
          </div>` : '';

        const div = document.createElement('div');
        div.className = 'ea-problem';
        div.innerHTML = `
          <div class="ea-problem__header">
            <span class="ea-problem__title">Problema ${prob.nr}</span>
            <span class="ea-problem__pts">${prob.points||10} puncte</span>
          </div>
          <div class="ea-problem__body">
            <div class="ea-problem__text">${esc(prob.text||'')}</div>
            <textarea class="ea-code-editor" id="ans-${key}" rows="14"
              placeholder="#include &lt;iostream&gt;&#10;using namespace std;&#10;&#10;// Scrieți definiția completă a subprogramului sau programul complet&#10;&#10;int main() {&#10;  return 0;&#10;}"
              oninput="window._saveAns('${key}',this.value)"></textarea>
            <div class="ea-code-actions">
              <button class="ea-btn ea-btn--copy"     onclick="window._copyCode('ans-${key}')">📋 Copiază</button>
              <button class="ea-btn ea-btn--compiler" onclick="window._openCompiler('ans-${key}')">🖥️ Compilator online</button>
            </div>
            ${tcHTML}
          </div>`;
        container.appendChild(div);
      });
    }

    /* ── Extract test cases from problem text ────────────────── */
    function extractTestCases(text) {
      if (!text) return [];
      const cases = [];
      // Pattern: "dacă X, atunci ... returnează/afișează Y"
      const r1 = /dac[ăa]\s+(.{2,100?}?)\s*,?\s*atunci\s+(?:subprogramul\s+)?(?:returneaz[ăa]|afi[șş]eaz[ăa](?:\s+pe\s+ecran)?)\s+([\S][^\n.;(]{0,80})/gi;
      let m;
      while ((m = r1.exec(text)) !== null && cases.length < 3)
        cases.push({ input: m[1].trim(), output: m[2].trim() });

      // Pattern: "dacă textul citit este X se afișează Y"
      const r2 = /dac[ăa]\s+(?:textul\s+citit\s+este|(?:pentru\s+)?[a-z]+\s+(?:citit[ăa]?\s+este|=))\s+(.{2,80?}?)\s+se\s+afi[șş]eaz[ăa](?:\s+pe\s+ecran)?\s+([\S][^\n.]{0,60})/gi;
      while ((m = r2.exec(text)) !== null && cases.length < 4)
        cases.push({ input: m[1].replace(/[„"""]/g,'').trim(), output: m[2].trim() });

      // If nothing found, look for "Exemplu:"
      if (!cases.length) {
        const ex = text.match(/[Ee]xemplu\s*:?\s*([\s\S]{0,400}?)(?:\n\n|Subprogramul|Scrieți|$)/);
        if (ex) cases.push({ input: 'Exemplu din enunț:', output: ex[1].trim() });
      }
      return cases.slice(0,4);
    }

    /* ── Global helpers ─────────────────────────────────────── */
    window._saveAns = (key, val) => { answers[key] = val; };

    window._copyCode = function(id) {
      const el = document.getElementById(id);
      if (!el) return;
      navigator.clipboard.writeText(el.value).then(() => {
        const btns = document.querySelectorAll(`[onclick*="_copyCode('${id}')"]`);
        btns.forEach(b => { const o=b.textContent; b.textContent='✅ Copiat!'; setTimeout(()=>b.textContent=o, 1500); });
      }).catch(() => alert('Nu s-a putut copia automat. Selectează codul manual (Ctrl+A) și copiază-l.'));
    };

    window._openCompiler = function(id) {
      const el   = document.getElementById(id);
      const code = el ? el.value : '';
      if (code) {
        navigator.clipboard.writeText(code).catch(()=>{});
        window.open('https://www.onlinegdb.com/online_c++_compiler', '_blank');
        setTimeout(() => alert('Codul a fost copiat în clipboard.\nÎn OnlineGDB: selectează tot (Ctrl+A) și lipește (Ctrl+V), apoi apasă Run.'), 300);
      } else {
        window.open('https://www.onlinegdb.com/online_c++_compiler', '_blank');
      }
    };

    window._markTest = function(key, ti, result) {
      const div = document.getElementById(`tc-${key}-${ti}`);
      if (div) div.style.borderColor = result==='ok' ? 'rgba(34,197,94,.5)' : 'rgba(239,68,68,.5)';
      // Recount
      let passed=0, total=0;
      document.querySelectorAll(`[id^="tc-${key}-"]`).forEach(tc => {
        total++;
        const ok = tc.querySelector(`input[value="ok"]:checked`);
        if (ok) passed++;
      });
      selfScores[key] = { passed, total };
    };

    /* ── Submit ─────────────────────────────────────────────── */
    document.getElementById('btnSubmit').addEventListener('click', () => submitExam(false));
    document.getElementById('btnAbort').addEventListener('click', () => {
      clearInterval(timerInterval);
      currentExam = null;
      examInterface.style.display  = 'none';
      selectorOverlay.style.display= 'flex';
    });

    function submitExam(timeout) {
      if (!timeout && !confirm('Predai examenul? Nu poți reveni.')) return;
      clearInterval(timerInterval);

      const exam = currentExam;
      if (!exam) return;

      // Auto-grade Subject I
      const qs = exam.subiectI?.questions || [];
      let s1Correct = 0;
      qs.forEach((q, idx) => {
        const userAns = answers['s1q'+idx];
        const div = document.getElementById(`q-I-${idx}`);
        const fb  = div?.querySelector('.ea-q__feedback');
        if (q.correctAnswer) {
          const ok = userAns === q.correctAnswer;
          if (ok) s1Correct++;
          div?.classList.add(ok ? 'correct' : 'wrong');
          if (fb) {
            fb.className = 'ea-q__feedback ' + (ok ? 'correct' : 'wrong');
            fb.textContent = ok ? '✅ Corect! (+4 puncte)' : `❌ Greșit. Răspuns corect: ${q.correctAnswer.toUpperCase()})`;
          }
          div?.querySelectorAll('.ea-option').forEach(lbl => {
            const inp = lbl.querySelector('input');
            if (inp?.value===q.correctAnswer) lbl.classList.add('correct');
            else if (inp?.value===userAns && !ok) lbl.classList.add('wrong');
            inp && (inp.disabled = true);
          });
        }
      });

      const s1Score = s1Correct * 4;
      const passedTests  = Object.values(selfScores).reduce((a,s)=>a+(s.passed||0), 0);
      const totalTests   = Object.values(selfScores).reduce((a,s)=>a+(s.total||0), 0);

      examContent.style.display  = 'none';
      submitBar.style.display    = 'none';
      resultsSection.style.display = 'flex';

      document.getElementById('resultsBody').innerHTML = `
        <div class="ea-result-subject" style="text-align:center;padding:16px 0 24px">
          <div class="ea-score-big ${s1Score>=16?'ea-score-ok':s1Score>=8?'ea-score-mid':'ea-score-bad'}">${s1Correct}/5</div>
          <div style="color:var(--color-text-muted,#64748b)">Răspunsuri corecte Subiectul I</div>
          <div style="margin-top:6px;font-size:13px">Punctaj: <strong>${10+s1Score}/100</strong> (doar Subiectul I + oficiu)</div>
        </div>

        <div class="ea-result-subject">
          <h4>📋 Subiectul I — Grilă (${s1Score}/20p)</h4>
          <div class="ea-result-bar-bg"><div class="ea-result-bar-fill" style="width:${(s1Score/20)*100}%"></div></div>
          <p style="font-size:12px;color:var(--color-text-muted,#64748b);margin-top:6px">${s1Correct} corecte × 4p = ${s1Score}p + 10p din oficiu</p>
        </div>

        <div class="ea-result-subject">
          <h4>✍️ Subiectul al II-lea — Auto-evaluare (0–40p)</h4>
          <div class="ea-self-note">Verifică răspunsurile tale cu baremul oficial și acordă-ți punctajul manual.</div>
        </div>

        <div class="ea-result-subject">
          <h4>💻 Subiectul al III-lea — Teste${totalTests>0?` (${passedTests}/${totalTests} teste)`:''}  (0–30p)</h4>
          ${totalTests>0
            ? `<div class="ea-result-bar-bg"><div class="ea-result-bar-fill" style="width:${(passedTests/totalTests)*100}%;background:linear-gradient(90deg,#10b981,#059669)"></div></div>
               <p style="font-size:12px;color:var(--color-text-muted,#64748b);margin-top:6px">${passedTests}/${totalTests} teste marcate corect</p>`
            : '<div class="ea-self-note">Compilează codul și verifică rezultatele cu exemplele din enunț.</div>'}
        </div>

        ${exam.baremUrl ? `
        <div style="margin-top:20px;padding:14px 18px;border-radius:10px;background:rgba(168,85,247,.08);border:1px solid rgba(168,85,247,.2)">
          <p style="margin:0 0 10px;font-size:13px;font-weight:700;color:#c084fc">📋 Verifică răspunsurile complete cu baremul</p>
          <a href="${prefix()+exam.baremUrl}" target="_blank" rel="noopener" class="ea-btn ea-btn--ghost ea-btn--sm">Deschide Baremul PDF</a>
        </div>` : ''}`;

      try {
        const hist = JSON.parse(localStorage.getItem('infoExamAlbHistory')||'[]');
        hist.unshift({ date:new Date().toLocaleDateString('ro-RO'), examId:exam.id, year:exam.year, session:exam.session, s1Correct, s1Score, testsPass:passedTests, testsTotal:totalTests });
        localStorage.setItem('infoExamAlbHistory', JSON.stringify(hist.slice(0,20)));
        const today = new Date().toISOString().slice(0,10);
        const days = JSON.parse(localStorage.getItem('infoStudyDays')||'[]');
        if (!days.includes(today)) { days.push(today); localStorage.setItem('infoStudyDays', JSON.stringify(days)); }
      } catch(e) {}
    }

    document.getElementById('btnRetry').addEventListener('click', () => {
      if (!currentExam) return;
      const id = currentExam.id;
      resultsSection.style.display = 'none';
      startExam(id);
    });
    document.getElementById('btnNewExam').addEventListener('click', () => {
      currentExam = null;
      resultsSection.style.display = 'none';
      examInterface.style.display  = 'none';
      selectorOverlay.style.display= 'flex';
    });

    /* ── Init ───────────────────────────────────────────────── */
    loadIndex().catch(err => {
      examList.innerHTML = `<p style="color:#ef4444;padding:16px">Eroare: ${err.message}</p>`;
    });

  })();
  </script>
</BaseLayout>
