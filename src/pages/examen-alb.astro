---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// All available chapter sources for questions
const allChapters = [
  'introducere', 'complexitate', 'recursivitate', 'backtracking',
  'vectori', 'matrici', 'siruri', 'fisiere',
  'programare-dinamica', 'structuri', 'pointeri'
];
---
<BaseLayout title="Examen Alb — InfoLiceu">
  <Header />

  <main class="exam-page" id="main-content">
    <!-- Hero -->
    <div class="exam-hero">
      <div class="exam-hero__inner">
        <div class="exam-hero__badge">🎓 Simulare BAC Informatică</div>
        <h1>Examen Alb</h1>
        <p>Simulează condițiile reale de bacalaureat. Alege între examen complet (3h) sau practică rapidă (30 min). Rezultatele sunt salvate local.</p>
      </div>
    </div>

    <!-- Mode selection overlay -->
    <div id="preStartOverlay" class="exam-overlay">
      <div class="exam-mode-selection">
        <h2>Alege modul de examen</h2>
        <div class="exam-mode-grid">
          <div class="exam-mode-card" id="modeFullCard">
            <div class="exam-mode-icon">📋</div>
            <h3>Examen complet</h3>
            <p>3 ore · 15 întrebări · 3 subiecte</p>
            <ul class="exam-mode-details">
              <li>⏱️ Durata: <strong>3 ore</strong> (180 min)</li>
              <li>📝 Subiectul I — 5 grilă (diverse)</li>
              <li>📝 Subiectul II — 5 grilă (recursivitate)</li>
              <li>📝 Subiectul III — 5 grilă (backtracking)</li>
              <li>💾 Rezultate salvate automat</li>
            </ul>
            <button id="btnStartFull" class="exam-btn exam-btn--start">▶ Începe Examen Complet</button>
          </div>
          <div class="exam-mode-card exam-mode-card--practice" id="modePracticeCard">
            <div class="exam-mode-icon">⚡</div>
            <h3>Practică rapidă</h3>
            <p>30 min · 5 întrebări · capitole mixte</p>
            <ul class="exam-mode-details">
              <li>⏱️ Durata: <strong>30 minute</strong></li>
              <li>📝 5 întrebări din capitole aleatorii</li>
              <li>💡 Explicații după fiecare răspuns</li>
              <li>🎯 Ideal pentru studiu zilnic</li>
              <li>📊 Fără presiune, mod de învățare</li>
            </ul>
            <button id="btnStartPractice" class="exam-btn exam-btn--practice">⚡ Practică Rapidă</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Exam interface -->
    <div id="examInterface" class="exam-interface" style="display:none;">
      <!-- Timer sticky -->
      <div class="exam-timer-bar" id="timerBar">
        <div class="exam-timer-left">
          <div class="exam-timer-label" id="examModeLabel">⏱️ Examen complet</div>
          <div class="exam-timer-display" id="timerDisplay">3:00:00</div>
        </div>
        <!-- Progress sidebar -->
        <div class="exam-progress-dots" id="progressDots"></div>
        <div class="exam-timer-progress">
          <div id="timerProgressFill" class="exam-timer-progress-fill"></div>
        </div>
      </div>

      <div id="loadingMsg" class="exam-loading">
        <div class="exam-loading__spinner"></div>
        <p>Se încarcă întrebările...</p>
      </div>

      <div id="examContent" class="exam-content" style="display:none;">
        <!-- Questions rendered dynamically -->
      </div>

      <div class="exam-submit-bar">
        <button id="btnSubmit" class="exam-btn exam-btn--submit">✅ Predă Examenul</button>
        <span class="exam-submit-note">Poți preda oricând. Necompletate = greșite.</span>
      </div>
    </div>

    <!-- Results -->
    <div id="resultsSection" class="exam-results" style="display:none;">
      <div class="exam-results__card">
        <h2>📊 Rezultate Examen</h2>
        <div id="resultsBody"></div>
        <div class="exam-results__actions">
          <button id="btnRetry" class="exam-btn exam-btn--start">🔄 Reia Examenul</button>
          <a href={`${base}/exercitii`} class="exam-btn exam-btn--outline">📝 Exerciții</a>
          <a href={`${base}/streak`} class="exam-btn exam-btn--outline">📅 Calendar Studiu</a>
        </div>
      </div>
      <div id="examHistory" class="exam-history"></div>
    </div>
  </main>

  <style>
    .exam-page { min-height: 100vh; padding-bottom: 48px; }

    .exam-hero {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 30%, #0f3460 60%, #533483 100%);
      padding: 48px 24px 40px;
      text-align: center;
      color: #fff;
      position: relative;
      overflow: hidden;
    }
    .exam-hero::before {
      content: '';
      position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(99,102,241,0.12) 0%, transparent 60%);
    }
    .exam-hero__inner { position: relative; }
    .exam-hero__badge {
      display: inline-block; background: rgba(255,255,255,.12); backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,.2); border-radius: 20px;
      padding: 4px 16px; font-size: .82rem; font-weight: 600; margin-bottom: 16px;
    }
    .exam-hero h1 { font-size: clamp(1.8rem,5vw,2.8rem); margin: 0 0 12px; font-weight: 800; }
    .exam-hero p { opacity: .85; max-width: 640px; margin: 0 auto; font-size: 1rem; line-height: 1.6; }

    /* Mode selection */
    .exam-overlay {
      display: flex; justify-content: center; padding: 32px 16px;
    }
    .exam-mode-selection { max-width: 800px; width: 100%; }
    .exam-mode-selection h2 { text-align: center; margin-bottom: 24px; font-size: 1.3rem; }
    .exam-mode-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    }
    .exam-mode-card {
      background: var(--color-surface, #1e293b);
      border: 2px solid var(--color-border, #334155);
      border-radius: 16px; padding: 28px; text-align: center;
      transition: border-color .2s, transform .2s;
    }
    .exam-mode-card:hover { border-color: #3b82f6; transform: translateY(-2px); }
    .exam-mode-card--practice { border-color: rgba(168,85,247,0.3); }
    .exam-mode-card--practice:hover { border-color: #a855f7; }
    .exam-mode-icon { font-size: 2.5rem; margin-bottom: 12px; }
    .exam-mode-card h3 { margin: 0 0 6px; font-size: 1.2rem; }
    .exam-mode-card > p { color: var(--color-text-muted, #94a3b8); font-size: 14px; margin: 0 0 16px; }
    .exam-mode-details {
      list-style: none; padding: 0; margin: 0 0 20px;
      display: flex; flex-direction: column; gap: 8px; text-align: left;
    }
    .exam-mode-details li {
      background: var(--color-background, #0f172a); padding: 8px 12px;
      border-radius: 8px; font-size: 13px;
    }

    /* Timer */
    .exam-timer-bar {
      position: sticky; top: 0; z-index: 100;
      background: var(--color-surface, #1e293b);
      border-bottom: 2px solid var(--color-border, #334155);
      display: flex; align-items: center; gap: 16px;
      padding: 10px 24px; box-shadow: 0 2px 12px rgba(0,0,0,.3);
      flex-wrap: wrap;
    }
    .exam-timer-left { display: flex; align-items: center; gap: 12px; }
    .exam-timer-label { font-weight: 600; font-size: 13px; color: var(--color-text-muted, #94a3b8); }
    .exam-timer-display { font-size: 1.6rem; font-weight: 700; font-variant-numeric: tabular-nums; color: #22c55e; min-width: 90px; }
    .exam-timer-display.warning { color: #f59e0b; }
    .exam-timer-display.danger  { color: #ef4444; }
    .exam-progress-dots { display: flex; gap: 6px; align-items: center; }
    .exam-progress-dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--color-border, #334155); transition: background .3s;
    }
    .exam-progress-dot.answered { background: #22c55e; }
    .exam-progress-dot.current { background: #3b82f6; box-shadow: 0 0 6px rgba(59,130,246,0.5); }
    .exam-timer-progress { flex: 1; height: 6px; background: #1e293b; border-radius: 99px; overflow: hidden; border: 1px solid #334155; min-width: 100px; }
    .exam-timer-progress-fill { height: 100%; width: 100%; background: linear-gradient(90deg, #22c55e, #16a34a); transition: width 1s linear, background .5s; border-radius: 99px; }

    /* Content */
    .exam-loading { display: flex; flex-direction: column; align-items: center; padding: 48px; gap: 16px; color: var(--color-text-muted, #64748b); }
    .exam-loading__spinner { width: 40px; height: 40px; border: 4px solid #334155; border-top-color: #3b82f6; border-radius: 50%; animation: spin .8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .exam-content { max-width: 900px; margin: 32px auto 0; padding: 0 20px; display: flex; flex-direction: column; gap: 36px; }

    .exam-subject-section { background: var(--color-surface, #1e293b); border: 1.5px solid var(--color-border, #334155); border-radius: 14px; overflow: hidden; }
    .exam-subject-header { background: linear-gradient(90deg, #1d4ed8, #7c3aed); padding: 16px 22px; color: #fff; display: flex; justify-content: space-between; align-items: center; }
    .exam-subject-header h3 { margin: 0; font-size: 1.1rem; }
    .exam-subject-header .exam-subject-points { font-size: 13px; opacity: 0.85; }
    .exam-subject-body { padding: 20px; display: flex; flex-direction: column; gap: 20px; }

    .exam-question { border: 1px solid var(--color-border, #334155); border-radius: 10px; padding: 16px 18px; transition: border-color .2s; }
    .exam-question.answered { border-color: rgba(34,197,94,0.3); }
    .exam-question__text { font-weight: 600; margin-bottom: 12px; font-size: 15px; }
    .exam-question__num { color: #60a5fa; margin-right: 8px; }
    .exam-question__diff { font-size: 11px; padding: 2px 8px; border-radius: 6px; margin-left: 8px; font-weight: 600; }
    .exam-options { display: flex; flex-direction: column; gap: 8px; }
    .exam-option { display: flex; align-items: flex-start; gap: 10px; cursor: pointer; padding: 8px 10px; border-radius: 8px; transition: background .15s; }
    .exam-option:hover { background: rgba(59,130,246,.08); }
    .exam-option input[type="radio"] { margin-top: 2px; accent-color: #3b82f6; width: 16px; height: 16px; flex-shrink: 0; }
    .exam-option span { font-size: 14px; line-height: 1.4; }

    /* Practice mode - explanation shown after answer */
    .exam-explanation {
      margin-top: 12px; padding: 12px 16px;
      border-radius: 8px; font-size: 13px; line-height: 1.5;
      display: none;
    }
    .exam-explanation.correct { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); color: #4ade80; }
    .exam-explanation.wrong { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #f87171; }

    /* Submit */
    .exam-submit-bar { display: flex; align-items: center; gap: 16px; justify-content: center; padding: 24px; flex-wrap: wrap; }
    .exam-submit-note { font-size: 12px; color: var(--color-text-muted, #64748b); }

    /* Buttons */
    .exam-btn {
      padding: 12px 28px; border-radius: 10px; border: none;
      font-size: 15px; font-weight: 700; cursor: pointer;
      text-decoration: none; display: inline-block; text-align: center;
      transition: opacity .2s, transform .1s;
    }
    .exam-btn:active { transform: scale(.97); }
    .exam-btn--start { background: linear-gradient(90deg,#22c55e,#16a34a); color: #fff; width: 100%; margin-top: 8px; font-size: 16px; }
    .exam-btn--practice { background: linear-gradient(90deg,#8b5cf6,#7c3aed); color: #fff; width: 100%; margin-top: 8px; font-size: 16px; }
    .exam-btn--submit { background: linear-gradient(90deg,#f59e0b,#d97706); color: #fff; }
    .exam-btn--outline { background: transparent; border: 2px solid var(--color-border, #334155); color: var(--color-text, #f1f5f9); }

    /* Results */
    .exam-results { max-width: 700px; margin: 32px auto 0; padding: 0 20px; }
    .exam-results__card { background: var(--color-surface, #1e293b); border: 1.5px solid var(--color-border, #334155); border-radius: 16px; padding: 32px; }
    .exam-results__card h2 { margin: 0 0 24px; }
    .exam-results__actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 24px; }

    .exam-history { margin-top: 28px; }
    .exam-history h3 { margin-bottom: 12px; font-size: 1rem; }
    .history-item { background: var(--color-surface, #1e293b); border: 1px solid var(--color-border, #334155); border-radius: 10px; padding: 14px 18px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; font-size: 14px; }
    .history-score { font-weight: 700; color: #22c55e; font-size: 1.1rem; }

    .result-subject { padding: 16px 0; border-bottom: 1px solid var(--color-border, #334155); }
    .result-subject:last-child { border-bottom: none; }
    .result-subject h4 { margin: 0 0 10px; font-size: 1rem; }
    .result-bar-bg { background: #1e293b; border-radius: 99px; height: 10px; overflow: hidden; margin-top: 6px; }
    .result-bar-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg,#22c55e,#16a34a); transition: width .5s; }
    .result-score { font-size: 1.2rem; font-weight: 700; }
    .score-ok { color: #22c55e; }
    .score-mid { color: #f59e0b; }
    .score-bad { color: #ef4444; }

    /* Responsive */
    @media (max-width: 768px) {
      .exam-mode-grid { grid-template-columns: 1fr; }
      .exam-timer-bar { padding: 8px 16px; gap: 10px; }
      .exam-timer-display { font-size: 1.3rem; }
      .exam-progress-dots { order: 3; width: 100%; justify-content: center; }
    }
    @media (max-width: 480px) {
      .exam-hero { padding: 36px 16px 28px; }
      .exam-timer-left { flex-wrap: wrap; gap: 6px; }
    }
  </style>

  <script is:inline>
  (function() {
    var MODE_FULL = 'full';
    var MODE_PRACTICE = 'practice';
    var currentMode = MODE_FULL;
    var TOTAL_SECONDS = 3 * 60 * 60;
    var timerInterval = null;
    var secondsLeft = TOTAL_SECONDS;
    var examStarted = false;
    var allQuestions = [];
    var answers = {};

    var allChapterIds = [
      'introducere','complexitate','recursivitate','backtracking',
      'vectori','matrici','siruri','fisiere',
      'programare-dinamica','structuri','pointeri'
    ];

    var fullSubjects = [
      { id: 'vectori',       label: 'Subiectul I — Grilă (diverse)', chapters: ['vectori','introducere','complexitate','matrici','siruri'], count: 5 },
      { id: 'recursivitate', label: 'Subiectul II — Recursivitate',   chapters: ['recursivitate'], count: 5 },
      { id: 'backtracking',  label: 'Subiectul III — Backtracking',   chapters: ['backtracking'], count: 5 }
    ];

    var baseUrl = (document.querySelector('meta[name="base-url"]') || {}).content || '';

    var preStartOverlay = document.getElementById('preStartOverlay');
    var examInterface   = document.getElementById('examInterface');
    var loadingMsg      = document.getElementById('loadingMsg');
    var examContent     = document.getElementById('examContent');
    var resultsSection  = document.getElementById('resultsSection');
    var timerDisplay    = document.getElementById('timerDisplay');
    var timerFill       = document.getElementById('timerProgressFill');
    var progressDots    = document.getElementById('progressDots');
    var examModeLabel   = document.getElementById('examModeLabel');
    var btnSubmit       = document.getElementById('btnSubmit');
    var btnRetry        = document.getElementById('btnRetry');

    function formatTime(secs) {
      var h = Math.floor(secs / 3600);
      var m = Math.floor((secs % 3600) / 60);
      var s = secs % 60;
      return (h < 10 ? '0' : '') + h + ':' + (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
    }

    function updateTimer() {
      timerDisplay.textContent = formatTime(secondsLeft);
      var pct = (secondsLeft / TOTAL_SECONDS) * 100;
      timerFill.style.width = pct + '%';
      timerDisplay.classList.remove('warning', 'danger');
      if (secondsLeft <= 600) {
        timerDisplay.classList.add('danger');
        timerFill.style.background = '#ef4444';
      } else if (secondsLeft <= 1800) {
        timerDisplay.classList.add('warning');
        timerFill.style.background = '#f59e0b';
      }
      if (secondsLeft <= 0) {
        clearInterval(timerInterval);
        submitExam(true);
      } else {
        secondsLeft--;
      }
    }

    window.addEventListener('beforeunload', function(e) {
      if (examStarted && resultsSection.style.display === 'none') {
        e.preventDefault(); e.returnValue = '';
      }
    });

    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
      }
      return a;
    }

    function exercisePath(id) {
      var pathname = window.location.pathname;
      var parts = pathname.split('/').filter(Boolean);
      var repoBase = parts.length > 0 ? '/' + parts[0] : '';
      return repoBase + '/data/exercises/' + id + '.json';
    }

    async function loadChapterQuestions(chapterId) {
      var url = exercisePath(chapterId);
      var res = await fetch(url);
      if (!res.ok) return [];
      var data = await res.json();
      return (data.quiz || []).map(function(q) { return Object.assign({}, q, { _chapter: chapterId }); });
    }

    async function loadQuestionsForMode(mode) {
      if (mode === MODE_PRACTICE) {
        var allPool = [];
        var chaptersToLoad = shuffle(allChapterIds).slice(0, 5);
        for (var i = 0; i < chaptersToLoad.length; i++) {
          var qs = await loadChapterQuestions(chaptersToLoad[i]);
          allPool = allPool.concat(qs);
        }
        var selected = shuffle(allPool).slice(0, 5);
        return [{ id: 'practice', label: 'Practică Rapidă — Capitole mixte', questions: selected }];
      } else {
        var results = [];
        for (var s = 0; s < fullSubjects.length; s++) {
          var subj = fullSubjects[s];
          var pool = [];
          for (var c = 0; c < subj.chapters.length; c++) {
            var cqs = await loadChapterQuestions(subj.chapters[c]);
            pool = pool.concat(cqs);
          }
          results.push({ id: subj.id, label: subj.label, questions: shuffle(pool).slice(0, subj.count) });
        }
        return results;
      }
    }

    function buildProgressDots(totalQuestions) {
      progressDots.innerHTML = '';
      for (var i = 0; i < totalQuestions; i++) {
        var dot = document.createElement('span');
        dot.className = 'exam-progress-dot';
        dot.dataset.idx = i;
        progressDots.appendChild(dot);
      }
    }

    function updateProgressDot(idx) {
      var dot = progressDots.querySelector('[data-idx="' + idx + '"]');
      if (dot) dot.classList.add('answered');
    }

    function buildExamUI(subjectData) {
      examContent.innerHTML = '';
      var globalIdx = 0;
      subjectData.forEach(function(subj, si) {
        var section = document.createElement('div');
        section.className = 'exam-subject-section';
        var header = document.createElement('div');
        header.className = 'exam-subject-header';
        header.innerHTML = '<h3>' + subj.label + '</h3><span class="exam-subject-points">' + subj.questions.length + ' întrebări</span>';
        section.appendChild(header);

        var body = document.createElement('div');
        body.className = 'exam-subject-body';
        subj.questions.forEach(function(q, qi) {
          var qDiv = document.createElement('div');
          qDiv.className = 'exam-question';
          qDiv.id = 'q-' + si + '-' + qi;
          var qText = document.createElement('div');
          qText.className = 'exam-question__text';
          qText.innerHTML = '<span class="exam-question__num">' + (qi + 1) + '.</span>' + q.q;
          qDiv.appendChild(qText);

          var optsDiv = document.createElement('div');
          optsDiv.className = 'exam-options';
          var letters = ['A', 'B', 'C', 'D'];
          var currentGlobalIdx = globalIdx;

          q.opts.forEach(function(opt, oi) {
            var label = document.createElement('label');
            label.className = 'exam-option';
            var key = 's' + si + 'q' + qi;
            label.innerHTML =
              '<input type="radio" name="' + key + '" value="' + oi + '">' +
              '<span><strong>' + letters[oi] + ')</strong> ' + opt + '</span>';
            label.querySelector('input').addEventListener('change', function(e) {
              answers[key] = parseInt(e.target.value, 10);
              qDiv.classList.add('answered');
              updateProgressDot(currentGlobalIdx);

              // In practice mode, show explanation immediately
              if (currentMode === MODE_PRACTICE) {
                var expDiv = qDiv.querySelector('.exam-explanation');
                if (expDiv) {
                  var isCorrect = answers[key] === q.ans;
                  expDiv.className = 'exam-explanation ' + (isCorrect ? 'correct' : 'wrong');
                  expDiv.innerHTML = (isCorrect ? '✅ Corect! ' : '❌ Greșit. Răspunsul corect: <strong>' + letters[q.ans] + '</strong>. ') + (q.exp || '');
                  expDiv.style.display = 'block';
                  // Disable further changes
                  qDiv.querySelectorAll('input[type=radio]').forEach(function(r) { r.disabled = true; });
                }
              }
            });
            optsDiv.appendChild(label);
          });
          qDiv.appendChild(optsDiv);

          // Add explanation placeholder (hidden)
          var expDiv = document.createElement('div');
          expDiv.className = 'exam-explanation';
          qDiv.appendChild(expDiv);

          body.appendChild(qDiv);
          globalIdx++;
        });
        section.appendChild(body);
        examContent.appendChild(section);
      });
    }

    function submitExam(timeout) {
      clearInterval(timerInterval);
      examStarted = false;
      if (!timeout && !confirm('Ești sigur că vrei să predai examenul? Nu poți reveni.')) return;

      var totalCorrect = 0;
      var subjectResults = allQuestions.map(function(subj, si) {
        var correct = 0;
        subj.questions.forEach(function(q, qi) {
          var key = 's' + si + 'q' + qi;
          if (answers[key] === q.ans) correct++;
        });
        totalCorrect += correct;
        return { label: subj.label, correct: correct, total: subj.questions.length };
      });

      showResults(subjectResults, totalCorrect, timeout);
      var totalQ = allQuestions.reduce(function(s, sub) { return s + sub.questions.length; }, 0);
      saveHistory(totalCorrect, totalQ, currentMode);

      var today = new Date().toISOString().slice(0, 10);
      try {
        var days = JSON.parse(localStorage.getItem('infoStudyDays') || '[]');
        if (!days.includes(today)) { days.push(today); localStorage.setItem('infoStudyDays', JSON.stringify(days)); }
      } catch(e) {}
    }

    function showResults(subjectResults, totalCorrect, timeout) {
      examInterface.style.display = 'none';
      resultsSection.style.display = 'block';
      var totalQ = subjectResults.reduce(function(s, r) { return s + r.total; }, 0);
      var pct = Math.round((totalCorrect / totalQ) * 100);
      var scoreClass = pct >= 70 ? 'score-ok' : (pct >= 50 ? 'score-mid' : 'score-bad');

      var html = '';
      if (timeout) html += '<div class="result-subject"><strong>⏰ Timpul a expirat!</strong></div>';
      html += '<div class="result-subject" style="text-align:center;padding:20px 0;">' +
        '<div style="font-size:3rem;font-weight:800;" class="' + scoreClass + '">' + totalCorrect + '/' + totalQ + '</div>' +
        '<div style="font-size:1.1rem;color:var(--color-text-muted);">' + pct + '% corect</div></div>';

      subjectResults.forEach(function(r) {
        var sp = Math.round((r.correct / r.total) * 100);
        var sc = sp >= 70 ? 'score-ok' : (sp >= 50 ? 'score-mid' : 'score-bad');
        html += '<div class="result-subject"><h4>' + r.label + '</h4>' +
          '<div style="display:flex;justify-content:space-between;align-items:center;">' +
          '<div class="result-bar-bg" style="flex:1;margin-right:16px;"><div class="result-bar-fill" style="width:' + sp + '%"></div></div>' +
          '<div class="result-score ' + sc + '">' + r.correct + '/' + r.total + '</div></div></div>';
      });
      document.getElementById('resultsBody').innerHTML = html;
      renderHistory();
    }

    function saveHistory(score, total, mode) {
      try {
        var history = JSON.parse(localStorage.getItem('infoExamHistory') || '[]');
        history.unshift({ date: new Date().toLocaleDateString('ro-RO'), score: score, total: total, mode: mode || 'full' });
        if (history.length > 20) history = history.slice(0, 20);
        localStorage.setItem('infoExamHistory', JSON.stringify(history));
      } catch(e) {}
    }

    function renderHistory() {
      try {
        var history = JSON.parse(localStorage.getItem('infoExamHistory') || '[]');
        if (history.length === 0) return;
        var html = '<h3>📋 Ultimele examene</h3>';
        history.forEach(function(h) {
          var pct = Math.round((h.score / h.total) * 100);
          var modeTag = h.mode === 'practice' ? ' ⚡' : ' 📋';
          html += '<div class="history-item"><span>' + h.date + modeTag + '</span><span class="history-score">' + h.score + '/' + h.total + ' (' + pct + '%)</span></div>';
        });
        document.getElementById('examHistory').innerHTML = html;
      } catch(e) {}
    }

    function startExam(mode) {
      currentMode = mode;
      preStartOverlay.style.display = 'none';
      examInterface.style.display = 'block';
      examStarted = true;
      answers = {};

      if (mode === MODE_PRACTICE) {
        TOTAL_SECONDS = 30 * 60;
        secondsLeft = TOTAL_SECONDS;
        examModeLabel.textContent = '⚡ Practică rapidă';
        timerDisplay.textContent = '00:30:00';
      } else {
        TOTAL_SECONDS = 3 * 60 * 60;
        secondsLeft = TOTAL_SECONDS;
        examModeLabel.textContent = '⏱️ Examen complet';
        timerDisplay.textContent = '03:00:00';
      }

      loadQuestionsForMode(mode).then(function(data) {
        allQuestions = data;
        var totalQ = data.reduce(function(s, sub) { return s + sub.questions.length; }, 0);
        buildProgressDots(totalQ);
        loadingMsg.style.display = 'none';
        examContent.style.display = 'flex';
        buildExamUI(data);
        timerInterval = setInterval(updateTimer, 1000);
        updateTimer();
      }).catch(function(err) {
        loadingMsg.innerHTML = '<p style="color:#ef4444;">❌ Eroare la încărcarea întrebărilor: ' + err.message + '</p>';
      });
    }

    document.getElementById('btnStartFull').addEventListener('click', function() { startExam(MODE_FULL); });
    document.getElementById('btnStartPractice').addEventListener('click', function() { startExam(MODE_PRACTICE); });
    btnSubmit.addEventListener('click', function() { submitExam(false); });
    btnRetry.addEventListener('click', function() { window.location.reload(); });
  })();
  </script>
</BaseLayout>
