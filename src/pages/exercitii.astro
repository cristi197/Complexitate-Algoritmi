---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapters = [
  { id: 'introducere',   label: 'Introducere',    color: 'blue'   },
  { id: 'functii',       label: 'Funcții',        color: 'blue'   },
  { id: 'complexitate',  label: 'Complexitate',   color: 'teal'   },
  { id: 'recursivitate', label: 'Recursivitate',  color: 'green'  },
  { id: 'backtracking',  label: 'Backtracking',   color: 'purple' },
  { id: 'vectori',       label: 'Vectori',        color: 'orange' },
  { id: 'matrici',       label: 'Matrici',        color: 'teal'   },
  { id: 'siruri',        label: 'Șiruri',         color: 'red'    },
  { id: 'fisiere',       label: 'Fișiere',        color: 'pink'   },
  { id: 'programare-dinamica', label: 'Prog. Dinamică', color: 'teal' },
  { id: 'structuri',     label: 'Structuri',      color: 'purple' },
  { id: 'pointeri',      label: 'Pointeri',       color: 'green'  },
  { id: 'grafuri',       label: 'Grafuri',        color: 'purple',
    subcategories: [
      { id: 'neorientate', label: 'Neorientate', cat: 0 },
      { id: 'orientate',   label: 'Orientate',   cat: 1 },
      { id: 'arbori',      label: 'Arbori',      cat: 2 },
    ]
  },
];
---
<BaseLayout
  title="Exerciții — Informatică Liceu"
  description="Exersează cu filtrare după capitol, dificultate și număr de întrebări. Exportă ca PDF."
  bodyClass="has-sidebar"
>
  <Header />
  <Sidebar />

  <div class="app-shell">
    <div class="app-content" id="main-content">
      <!-- Hero -->
      <div class="chapter-hero" style="--hero-gradient: linear-gradient(135deg,#1e3a5f 0%,#1d4ed8 50%,#7c3aed 100%);">
        <a href={`${base}/`} class="chapter-hero-back">← Înapoi acasă</a>
        <h1>📝 Exerciții Interactive</h1>
        <p>Selectează capitolele, dificultatea și numărul de întrebări. Exersează sau exportă ca PDF.</p>
        <div class="chapter-hero-tags">
          <span class="chapter-hero-tag">1200 întrebări</span>
          <span class="chapter-hero-tag">12 capitole</span>
          <span class="chapter-hero-tag">3 niveluri</span>
          <span class="chapter-hero-tag">Export PDF</span>
        </div>
      </div>

      <div class="wrapper">

        <!-- ── Filters ─────────────────────────────────────── -->
        <section class="ex-filters-card" id="filtreSection">
          <div class="exf-header">
            <span class="exf-icon">⚙️</span>
            <h2>Configurează setul de exerciții</h2>
          </div>
          <div class="exf-body">

            <!-- Exercise type selector -->
            <div class="filter-group">
              <div class="filter-label">📋 Tip exercițiu</div>
              <div class="type-chips" id="typeChips">
                <button class="chip chip-type active" data-type="grila">Grilă (Subiect I)</button>
                <button class="chip chip-type" data-type="trasare" disabled title="În curând">Trasare cod (Subiect II) — în curând</button>
                <button class="chip chip-type" data-type="scriere" disabled title="În curând">Scriere program (Subiect III) — în curând</button>
              </div>
            </div>

            <!-- Chapter selector -->
            <div class="filter-group">
              <div class="filter-label">📚 Capitole</div>
              <div class="chapter-chips" id="chapterChips">
                <button class="chip chip-all active" data-all="true">Toate</button>
                {chapters.map(ch => (
                  <button class={`chip chip-${ch.color}`} data-chapter={ch.id}>{ch.label}</button>
                ))}
              </div>
            </div>

            <!-- Subcategory selector (for grafuri) -->
            <div class="filter-group" id="subcategoryGroup" style="display:none">
              <div class="filter-label">🔀 Subcategorii Grafuri</div>
              <div class="subcat-chips" id="subcatChips">
                <button class="chip chip-subcat active" data-subcat="all">Toate (mix)</button>
                <button class="chip chip-subcat chip-neorientate" data-subcat="0">Neorientate</button>
                <button class="chip chip-subcat chip-orientate" data-subcat="1">Orientate</button>
                <button class="chip chip-subcat chip-arbori" data-subcat="2">Arbori</button>
              </div>
              <div class="subcat-mix-hint" id="subcatMixHint">
                <small>💡 Selectează mai multe subcategorii pentru a le mixa</small>
              </div>
            </div>

            <!-- Difficulty selector -->
            <div class="filter-group">
              <div class="filter-label">🎯 Dificultate</div>
              <div class="diff-chips" id="diffChips">
                <button class="chip chip-diff active" data-diff="all">Toate</button>
                <button class="chip chip-diff chip-facil" data-diff="1">Facil</button>
                <button class="chip chip-diff chip-mediu" data-diff="2">Mediu</button>
                <button class="chip chip-diff chip-dificil" data-diff="3">Dificil</button>
              </div>
            </div>

            <!-- Count selector -->
            <div class="filter-group">
              <div class="filter-label">🔢 Număr de întrebări</div>
              <div class="count-chips" id="countChips">
                <button class="chip chip-count active" data-count="10">10</button>
                <button class="chip chip-count" data-count="20">20</button>
                <button class="chip chip-count" data-count="50">50</button>
                <button class="chip chip-count" data-count="100">100</button>
                <button class="chip chip-count" data-count="all">Toate</button>
              </div>
            </div>

            <!-- Timer selector -->
            <div class="filter-group">
              <div class="filter-label">⏱️ Timp alocat (opțional)</div>
              <div class="timer-chips" id="timerChips">
                <button class="chip chip-timer active" data-timer="0">Fără timp</button>
                <button class="chip chip-timer" data-timer="5">5 min</button>
                <button class="chip chip-timer" data-timer="10">10 min</button>
                <button class="chip chip-timer" data-timer="15">15 min</button>
                <button class="chip chip-timer" data-timer="20">20 min</button>
                <button class="chip chip-timer" data-timer="30">30 min</button>
                <button class="chip chip-timer" data-timer="45">45 min</button>
              </div>
            </div>

            <div class="filter-actions">
              <button id="btnGenerate" class="btn-generate">
                ▶ Generează exerciții
              </button>
              <a id="btnTestLink" href={`${base}/test-exercitii`} class="btn-test">
                🎯 Mod Examen
              </a>
              <button id="btnPDF" class="btn-pdf" style="display:none">
                ⬇ Descarcă PDF
              </button>
              <label id="answersToggleWrap" class="answers-toggle" style="display:none">
                <input type="checkbox" id="showAnswers" />
                <span>Arată toate răspunsurile</span>
              </label>
              <span id="loadingSpinner" style="display:none;opacity:.6;font-size:13px">Se încarcă…</span>
            </div>
          </div>
        </section>

        <!-- ── Print-only header ─────────────────────────────── -->
        <div id="printHeader" aria-hidden="true">
          <div class="ph-logo">📝 InfoLiceu — Exerciții Informatică</div>
          <div id="phMeta" class="ph-meta"></div>
          <div id="phDate" class="ph-date"></div>
          <hr class="ph-divider" />
        </div>

        <!-- ── Timer bar ─────────────────────────────────── -->
        <div id="timerBar" class="timer-bar" style="display:none">
          <div class="timer-inner">
            <span class="timer-icon">⏱️</span>
            <span id="timerDisplay" class="timer-display">00:00</span>
            <div class="timer-progress-wrap">
              <div id="timerProgress" class="timer-progress"></div>
            </div>
            <button id="timerPause" class="timer-btn" title="Pauză/Continuă">⏸</button>
            <button id="timerReset" class="timer-btn" title="Oprește cronometru">⏹</button>
          </div>
        </div>

        <!-- ── Results ─────────────────────────────────────── -->
        <section id="exResults" style="display:none">
          <div class="ex-results-header">
            <span id="exCount" class="ex-count-badge"></span>
            <span id="exSubtitle" class="ex-subtitle"></span>
          </div>
          <div id="exList" class="ex-list"></div>
        </section>

      </div><!-- /wrapper -->
    </div>
  </div>

  <!-- ── Inline styles for this page ── -->
  <style is:inline>
    /* Filter card — standalone, no dependency on animations.js */
    .ex-filters-card {
      background: var(--surface, #1e293b);
      border-radius: 16px;
      border: 1px solid var(--border, rgba(255,255,255,.1));
      margin-top: 28px;
      overflow: hidden;
    }
    .exf-header {
      display: flex; align-items: center; gap: 12px;
      padding: 18px 24px 0;
    }
    .exf-icon { font-size: 20px; }
    .exf-header h2 { font-size: 17px; font-weight: 800; color: var(--text, #e2e8f0); margin: 0; }
    .exf-body { padding: 20px 24px 24px; }
    .filter-group { margin-bottom: 20px; }
    .filter-label { font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }
    .chapter-chips, .diff-chips, .count-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .chip {
      padding: 6px 14px; border-radius: 999px; border: 1.5px solid rgba(255,255,255,.15);
      background: rgba(255,255,255,.06); color: #94a3b8; cursor: pointer;
      font-size: 13px; font-weight: 600; transition: all .18s; white-space: nowrap;
    }
    .chip:hover { background: rgba(255,255,255,.12); }
    .chip.active { border-color: transparent; color: #fff; }
    .chip-all.active    { background: linear-gradient(135deg,#1d4ed8,#7c3aed); }
    .chip-blue.active   { background: #1d4ed8; }
    .chip-teal.active   { background: #0d9488; }
    .chip-green.active  { background: #16a34a; }
    .chip-purple.active { background: #7c3aed; }
    .chip-orange.active { background: #c2410c; }
    .chip-red.active    { background: #dc2626; }
    .chip-pink.active   { background: #db2777; }
    .chip-facil.active  { background: #16a34a; }
    .chip-mediu.active  { background: #d97706; }
    .chip-dificil.active{ background: #dc2626; }
    .chip-count.active  { background: linear-gradient(135deg,#1d4ed8,#7c3aed); }
    .chip-diff.active   { background: #1d4ed8; }
    .chip-type.active   { background: linear-gradient(135deg,#0d9488,#14b8a6); }
    .chip-type:disabled { opacity: 0.4; cursor: not-allowed; }
    .type-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .subcat-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .timer-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .chip-subcat.active { background: linear-gradient(135deg,#7c3aed,#a855f7); }
    .chip-neorientate.active { background: #2563eb; }
    .chip-orientate.active { background: #dc2626; }
    .chip-arbori.active { background: #16a34a; }
    .chip-timer.active { background: linear-gradient(135deg,#d97706,#f59e0b); }
    .subcat-mix-hint { margin-top: 8px; color: #64748b; font-size: 12px; }

    /* Action buttons */
    .filter-actions { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-top: 24px; }
    .btn-generate {
      padding: 11px 28px; border-radius: 12px; border: none; cursor: pointer;
      background: linear-gradient(135deg,#1d4ed8,#7c3aed); color: #fff;
      font-size: 14px; font-weight: 700; transition: opacity .2s;
    }
    .btn-generate:hover { opacity: .88; }
    .btn-test {
      padding: 11px 28px; border-radius: 12px; border: none; cursor: pointer;
      background: linear-gradient(135deg,#16a34a,#22c55e); color: #fff;
      font-size: 14px; font-weight: 700; transition: opacity .2s; text-decoration: none;
      display: inline-flex; align-items: center;
    }
    .btn-test:hover { opacity: .88; }
    .btn-pdf {
      padding: 11px 22px; border-radius: 12px; border: 1.5px solid rgba(255,255,255,.2);
      background: rgba(255,255,255,.07); color: #e2e8f0; cursor: pointer;
      font-size: 13px; font-weight: 600; transition: background .2s;
    }
    .btn-pdf:hover { background: rgba(255,255,255,.14); }

    /* Answers toggle */
    .answers-toggle {
      display: flex; align-items: center; gap: 7px;
      cursor: pointer; font-size: 13px; font-weight: 600; color: #94a3b8;
      user-select: none;
    }
    .answers-toggle input[type=checkbox] {
      width: 16px; height: 16px; cursor: pointer; accent-color: #7c3aed;
    }

    /* Timer bar */
    .timer-bar {
      background: var(--surface, #1e293b); border-radius: 14px;
      border: 1.5px solid rgba(251,191,36,.3); margin-top: 20px;
      padding: 14px 20px; position: sticky; top: 70px; z-index: 90;
    }
    .timer-inner { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .timer-icon { font-size: 20px; }
    .timer-display { font-size: 22px; font-weight: 800; color: #fbbf24; font-family: monospace; min-width: 60px; }
    .timer-progress-wrap {
      flex: 1; min-width: 100px; height: 6px; border-radius: 3px;
      background: rgba(255,255,255,.1); overflow: hidden;
    }
    .timer-progress { height: 100%; background: linear-gradient(90deg,#16a34a,#fbbf24,#dc2626); border-radius: 3px; transition: width .5s linear; width: 100%; }
    .timer-btn {
      width: 32px; height: 32px; border-radius: 8px; border: 1px solid rgba(255,255,255,.15);
      background: rgba(255,255,255,.07); color: #e2e8f0; cursor: pointer;
      font-size: 14px; display: flex; align-items: center; justify-content: center;
    }
    .timer-btn:hover { background: rgba(255,255,255,.15); }
    .timer-bar.timer-expired { border-color: rgba(220,38,38,.5); animation: timer-pulse 1s ease-in-out 3; }
    @keyframes timer-pulse { 0%,100% { box-shadow: none; } 50% { box-shadow: 0 0 20px rgba(220,38,38,.4); } }

    /* Per-problem answer toggle */
    .ex-answer-toggle {
      margin-top: 10px; padding: 4px 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.05); color: #94a3b8; cursor: pointer;
      font-size: 12px; font-weight: 600; transition: all .2s;
    }
    .ex-answer-toggle:hover { background: rgba(124,58,237,.15); color: #a78bfa; border-color: rgba(124,58,237,.3); }
    .ex-answer-section {
      margin-top: 12px; padding: 12px 14px; border-radius: 10px;
      background: rgba(22,163,74,.08); border: 1px solid rgba(22,163,74,.2);
      display: none;
    }
    .ex-answer-section.visible { display: block; }
    .ex-answer-label { font-size: 11px; font-weight: 700; text-transform: uppercase; color: #16a34a; margin-bottom: 4px; }
    .ex-answer-text { font-size: 13px; color: #e2e8f0; line-height: 1.5; }
    .ex-answer-correct { font-weight: 700; color: #4ade80; }

    /* Print-only header (hidden on screen) */
    #printHeader { display: none; }

    /* Results header */
    .ex-results-header { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; flex-wrap: wrap; }
    .ex-count-badge {
      padding: 5px 16px; border-radius: 999px; font-size: 13px; font-weight: 800;
      background: linear-gradient(135deg,#1d4ed8,#7c3aed); color: #fff;
    }
    .ex-subtitle { font-size: 13px; color: #94a3b8; }

    /* Exercise cards */
    .ex-list { display: flex; flex-direction: column; gap: 16px; }
    .ex-card {
      background: var(--gray5, #1e293b); border-radius: 14px; padding: 18px 20px;
      border: 1.5px solid rgba(255,255,255,.08);
    }
    .ex-card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
    .ex-num { font-size: 11px; font-weight: 800; color: #64748b; min-width: 28px; }
    .ex-chapter-badge {
      font-size: 10px; font-weight: 700; padding: 2px 9px; border-radius: 6px;
      text-transform: uppercase; letter-spacing: .04em;
    }
    .ex-q { font-size: 15px; color: #e2e8f0; line-height: 1.5; margin-bottom: 14px; font-weight: 600; }
    .ex-opts { display: flex; flex-direction: column; gap: 7px; }
    .ex-opt {
      display: flex; align-items: flex-start; gap: 10px; padding: 8px 12px;
      border-radius: 10px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
      font-size: 13px; color: #94a3b8;
    }
    .ex-opt-letter {
      font-size: 11px; font-weight: 800; min-width: 20px; height: 20px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,.1); color: #e2e8f0; flex-shrink: 0; margin-top: 1px;
    }

    /* Difficulty badges inside cards */
    .ex-diff { display: inline-flex; align-items: center; padding: 2px 9px; border-radius: 6px; font-size: 10px; font-weight: 700; }
    .ex-diff-facil   { background: rgba(74,222,128,.15); color: #4ade80; }
    .ex-diff-mediu   { background: rgba(251,191,36,.15);  color: #fbbf24; }
    .ex-diff-dificil { background: rgba(248,113,113,.15); color: #f87171; }

    /* Correct answer marker (hidden on screen, shown in print when toggled) */
    .ex-correct-mark {
      margin-left: auto; flex-shrink: 0;
      display: none;
      align-items: center; justify-content: center;
      width: 20px; height: 20px; border-radius: 50%;
      background: #16a34a; color: #fff; font-size: 11px; font-weight: 800;
    }

    /* Chapter badge colors */
    .cb-introducere   { background: rgba(59,130,246,.15); color: #60a5fa; }
    .cb-complexitate  { background: rgba(13,148,136,.15); color: #2dd4bf; }
    .cb-recursivitate { background: rgba(22,163,74,.15);  color: #4ade80; }
    .cb-backtracking  { background: rgba(124,58,237,.15); color: #a78bfa; }
    .cb-vectori       { background: rgba(194,65,12,.15);  color: #fb923c; }
    .cb-matrici       { background: rgba(13,148,136,.15); color: #2dd4bf; }
    .cb-siruri        { background: rgba(220,38,38,.15);  color: #f87171; }
    .cb-fisiere       { background: rgba(219,39,119,.15); color: #f472b6; }

    /* Print / PDF styles */
    @media print {
      @page { margin: 18mm 16mm; }
      .sidebar, .header, .site-header, #filtreSection,
      .ex-results-header, .chapter-hero, .chapter-hero-back,
      #scroll-progress, #page-overlay, .timer-bar, .ex-answer-toggle { display: none !important; }
      .app-shell { padding: 0 !important; display: block !important; }
      .app-content { padding: 0 !important; margin: 0 !important; }
      .wrapper { padding: 0 !important; margin: 0 !important; max-width: 100% !important; }
      body, html { background: #fff !important; color: #111 !important; font-size: 11pt; }

      /* Print header */
      #printHeader { display: block !important; margin-bottom: 18px; }
      .ph-logo { font-size: 17pt; font-weight: 900; color: #1d4ed8; margin-bottom: 4px; }
      .ph-meta { font-size: 10pt; color: #475569; margin-bottom: 2px; }
      .ph-date { font-size: 9pt; color: #94a3b8; margin-bottom: 10px; }
      .ph-divider { border: none; border-top: 2px solid #e2e8f0; margin-bottom: 16px; }

      /* Results */
      #exResults { display: block !important; }
      .ex-list { gap: 12px !important; }

      /* Cards */
      .ex-card {
        background: #fff !important; border: 1.5px solid #d1d5db !important;
        border-radius: 8px !important; padding: 14px 16px !important;
        break-inside: avoid; page-break-inside: avoid; margin-bottom: 14px;
        box-shadow: none !important;
      }
      .ex-card-header { margin-bottom: 8px !important; }
      .ex-q { color: #111 !important; font-size: 11pt !important; font-weight: 700; }
      .ex-opts { gap: 5px !important; }
      .ex-opt {
        color: #374151 !important; background: #f9fafb !important;
        border-color: #e5e7eb !important; font-size: 10pt !important;
        padding: 6px 10px !important; border-radius: 6px !important;
      }
      .ex-opt-letter {
        background: #e5e7eb !important; color: #1f2937 !important;
        font-size: 9pt !important; border-radius: 4px !important;
      }
      .ex-chapter-badge, .ex-diff {
        print-color-adjust: exact; -webkit-print-color-adjust: exact;
      }
      .ex-num { color: #9ca3af !important; }

      /* Correct answers (visible when "Cu răspunsuri" is checked) */
      body.print-answers .ex-opt-correct {
        background: #dcfce7 !important; border-color: #86efac !important;
        print-color-adjust: exact; -webkit-print-color-adjust: exact;
      }
      body.print-answers .ex-opt-correct .ex-opt-letter {
        background: #16a34a !important; color: #fff !important;
        print-color-adjust: exact; -webkit-print-color-adjust: exact;
      }
      body.print-answers .ex-correct-mark { display: flex !important; }
      body.print-answers .ex-answer-section { display: block !important; background: #f0fdf4 !important; border-color: #86efac !important; }
      body.print-answers .ex-answer-label { color: #16a34a !important; }
      body.print-answers .ex-answer-text { color: #1f2937 !important; }
      body.print-answers .ex-answer-correct { color: #16a34a !important; }
    }
  </style>

  <!-- ── JavaScript ── -->
  <script is:inline>
  (function() {
    var BASE = document.querySelector('base') ? document.querySelector('base').href : '/';

    var CHAPTERS = [
      { id: 'introducere',   label: 'Introducere'   },
      { id: 'functii',       label: 'Funcții'       },
      { id: 'complexitate',  label: 'Complexitate'  },
      { id: 'recursivitate', label: 'Recursivitate' },
      { id: 'backtracking',  label: 'Backtracking'  },
      { id: 'vectori',       label: 'Vectori'       },
      { id: 'matrici',       label: 'Matrici'       },
      { id: 'siruri',        label: 'Șiruri'        },
      { id: 'fisiere',       label: 'Fișiere'       },
      { id: 'programare-dinamica', label: 'Prog. Dinamică' },
      { id: 'structuri',     label: 'Structuri'     },
      { id: 'pointeri',      label: 'Pointeri'      },
      { id: 'grafuri',       label: 'Grafuri'       },
    ];

    var DIFF_LABELS = ['','Facil','Mediu','Dificil'];
    var DIFF_CLS    = ['','ex-diff-facil','ex-diff-mediu','ex-diff-dificil'];
    var SUBCAT_LABELS = ['Neorientate','Orientate','Arbori'];

    // State
    var selectedChapters = []; // empty = all
    var selectedSubcats  = []; // empty = all subcats for grafuri
    var selectedDiff     = 'all';
    var selectedCount    = 10;
    var selectedTimer    = 0; // minutes, 0 = no timer
    var loadedData       = {}; // { chapterId: [{q,opts,ans,diff,category}, ...] }

    // Timer state
    var timerInterval = null;
    var timerRemaining = 0;
    var timerTotal = 0;
    var timerPaused = false;

    /* ── Chip logic ── */
    function setupChips() {
      // Chapter chips
      document.querySelectorAll('#chapterChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.dataset.all) {
            selectedChapters = [];
            document.querySelectorAll('#chapterChips .chip').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
          } else {
            var ch = btn.dataset.chapter;
            document.querySelector('#chapterChips .chip-all').classList.remove('active');
            btn.classList.toggle('active');
            if (btn.classList.contains('active')) {
              selectedChapters.push(ch);
            } else {
              selectedChapters = selectedChapters.filter(function(x) { return x !== ch; });
            }
            if (selectedChapters.length === 0) {
              document.querySelector('#chapterChips .chip-all').classList.add('active');
            }
          }
          updateSubcatVisibility();
        });
      });

      // Subcategory chips (multi-select for mixing)
      document.querySelectorAll('#subcatChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var val = btn.dataset.subcat;
          if (val === 'all') {
            selectedSubcats = [];
            document.querySelectorAll('#subcatChips .chip').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
          } else {
            document.querySelector('#subcatChips [data-subcat="all"]').classList.remove('active');
            btn.classList.toggle('active');
            var catNum = parseInt(val, 10);
            if (btn.classList.contains('active')) {
              selectedSubcats.push(catNum);
            } else {
              selectedSubcats = selectedSubcats.filter(function(x) { return x !== catNum; });
            }
            if (selectedSubcats.length === 0) {
              document.querySelector('#subcatChips [data-subcat="all"]').classList.add('active');
            }
          }
        });
      });

      // Diff chips
      document.querySelectorAll('#diffChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#diffChips .chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          selectedDiff = btn.dataset.diff;
        });
      });

      // Count chips
      document.querySelectorAll('#countChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#countChips .chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          selectedCount = btn.dataset.count === 'all' ? 'all' : parseInt(btn.dataset.count, 10);
        });
      });

      // Timer chips
      document.querySelectorAll('#timerChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#timerChips .chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          selectedTimer = parseInt(btn.dataset.timer, 10);
        });
      });
    }

    function updateSubcatVisibility() {
      var show = selectedChapters.indexOf('grafuri') !== -1;
      document.getElementById('subcategoryGroup').style.display = show ? '' : 'none';
      if (!show) {
        selectedSubcats = [];
        document.querySelectorAll('#subcatChips .chip').forEach(function(b) { b.classList.remove('active'); });
        document.querySelector('#subcatChips [data-subcat="all"]').classList.add('active');
      }
    }

    /* ── Determine base URL for data fetching ── */
    function getDataBase() {
      var canonical = document.querySelector('link[rel="canonical"]');
      if (canonical) {
        var url = new URL(canonical.href);
        var parts = url.pathname.split('/').filter(Boolean);
        if (parts.length > 0) {
          return url.origin + '/' + parts[0] + '/';
        }
        return url.origin + '/';
      }
      var loc = window.location;
      var path = loc.pathname;
      var pathBase = path.substring(0, path.lastIndexOf('/') + 1);
      return loc.origin + pathBase;
    }

    /* ── Load JSON data ── */
    function loadAllChapters(chapterIds) {
      var needed = chapterIds.filter(function(id) { return !loadedData[id]; });
      if (needed.length === 0) return Promise.resolve();
      var loc = window.location;
      var pathParts = loc.pathname.split('/').filter(Boolean);
      pathParts.pop();
      var dataPrefix = loc.origin + '/' + pathParts.join('/') + '/data/exercises/';

      var promises = needed.map(function(id) {
        return fetch(dataPrefix + id + '.json')
          .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status + ' for ' + id);
            return r.json();
          })
          .then(function(json) {
            var arr = Array.isArray(json) ? json : (json.quiz || []);
            arr = arr.map(function(q) { return Object.assign({}, q, { _chapter: id }); });
            loadedData[id] = arr;
          })
          .catch(function(err) {
            console.warn('Could not load', id, err);
            loadedData[id] = [];
          });
      });
      return Promise.all(promises);
    }

    /* ── Shuffle array (Fisher-Yates) ── */
    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = a[i]; a[i] = a[j]; a[j] = t;
      }
      return a;
    }

    /* ── Render cards ── */
    function renderCards(questions) {
      var list = document.getElementById('exList');
      list.innerHTML = '';

      questions.forEach(function(q, idx) {
        var diffCls   = DIFF_CLS[q.diff] || '';
        var diffLabel = DIFF_LABELS[q.diff] || '';
        var chLabel   = q._chapter || '';
        var subcatLabel = '';
        if (chLabel === 'grafuri' && typeof q.category !== 'undefined') {
          subcatLabel = SUBCAT_LABELS[q.category] || '';
        }

        var optsHtml = q.opts.map(function(opt, i) {
          var isCorrect = (typeof q.ans !== 'undefined') && i === q.ans;
          return '<div class="ex-opt' + (isCorrect ? ' ex-opt-correct' : '') + '">' +
            '<span class="ex-opt-letter">' + String.fromCharCode(65 + i) + '</span>' +
            '<span>' + opt + '</span>' +
            (isCorrect ? '<span class="ex-correct-mark" aria-label="Răspuns corect">✓</span>' : '') +
            '</div>';
        }).join('');

        // Per-problem answer section
        var answerHtml = '';
        if (typeof q.ans !== 'undefined') {
          var correctLetter = String.fromCharCode(65 + q.ans);
          var explanation = q.exp || '';
          answerHtml = '<button class="ex-answer-toggle" data-idx="' + idx + '">👁 Arată răspunsul</button>' +
            '<div class="ex-answer-section" id="ans-' + idx + '">' +
              '<div class="ex-answer-label">Răspuns corect</div>' +
              '<div class="ex-answer-text"><span class="ex-answer-correct">' + correctLetter + '. ' + q.opts[q.ans] + '</span></div>' +
              (explanation ? '<div class="ex-answer-text" style="margin-top:6px;color:#94a3b8;font-size:12px">💡 ' + explanation + '</div>' : '') +
            '</div>';
        }

        var card = document.createElement('div');
        card.className = 'ex-card';
        card.innerHTML =
          '<div class="ex-card-header">' +
            '<span class="ex-num">' + (idx + 1) + '.</span>' +
            '<span class="ex-chapter-badge cb-' + chLabel + '">' + chLabel + '</span>' +
            (subcatLabel ? '<span class="ex-chapter-badge" style="background:rgba(124,58,237,.12);color:#a78bfa">' + subcatLabel + '</span>' : '') +
            (diffLabel ? '<span class="ex-diff ' + diffCls + '">' + diffLabel + '</span>' : '') +
          '</div>' +
          '<div class="ex-q">' + q.q + '</div>' +
          '<div class="ex-opts">' + optsHtml + '</div>' +
          answerHtml;

        list.appendChild(card);
      });

      // Setup per-problem answer toggles
      list.querySelectorAll('.ex-answer-toggle').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var idx = btn.dataset.idx;
          var section = document.getElementById('ans-' + idx);
          if (section.classList.contains('visible')) {
            section.classList.remove('visible');
            btn.textContent = '👁 Arată răspunsul';
          } else {
            section.classList.add('visible');
            btn.textContent = '🙈 Ascunde răspunsul';
          }
        });
      });
    }

    /* ── Timer functions ── */
    function startTimer(minutes) {
      stopTimer();
      timerTotal = minutes * 60;
      timerRemaining = timerTotal;
      timerPaused = false;
      var bar = document.getElementById('timerBar');
      bar.style.display = '';
      bar.classList.remove('timer-expired');
      document.getElementById('timerPause').textContent = '⏸';
      updateTimerDisplay();

      timerInterval = setInterval(function() {
        if (!timerPaused) {
          timerRemaining--;
          updateTimerDisplay();
          if (timerRemaining <= 0) {
            stopTimer();
            bar.classList.add('timer-expired');
            document.getElementById('timerDisplay').textContent = '00:00 ⏰';
          }
        }
      }, 1000);
    }

    function updateTimerDisplay() {
      var mins = Math.floor(timerRemaining / 60);
      var secs = timerRemaining % 60;
      document.getElementById('timerDisplay').textContent =
        (mins < 10 ? '0' : '') + mins + ':' + (secs < 10 ? '0' : '') + secs;
      var pct = timerTotal > 0 ? (timerRemaining / timerTotal) * 100 : 100;
      document.getElementById('timerProgress').style.width = pct + '%';
    }

    function stopTimer() {
      if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
      }
    }

    /* ── Global show/hide answers ── */
    function setupGlobalAnswers() {
      document.getElementById('showAnswers').addEventListener('change', function() {
        var checked = this.checked;
        document.querySelectorAll('.ex-answer-section').forEach(function(s) {
          if (checked) {
            s.classList.add('visible');
          } else {
            s.classList.remove('visible');
          }
        });
        document.querySelectorAll('.ex-answer-toggle').forEach(function(btn) {
          btn.textContent = checked ? '🙈 Ascunde răspunsul' : '👁 Arată răspunsul';
        });
        // Also toggle correct mark highlights
        if (checked) {
          document.body.classList.add('print-answers');
        } else {
          document.body.classList.remove('print-answers');
        }
      });
    }

    /* ── Generate ── */
    function onGenerate() {
      var spinner = document.getElementById('loadingSpinner');
      var btn     = document.getElementById('btnGenerate');
      spinner.style.display = 'inline';
      btn.disabled = true;

      var chapterIds = selectedChapters.length > 0
        ? selectedChapters
        : CHAPTERS.map(function(c) { return c.id; });

      loadAllChapters(chapterIds).then(function() {
        var pool = [];
        chapterIds.forEach(function(id) {
          var qs = (loadedData[id] || []).filter(function(q) {
            // Difficulty filter
            if (selectedDiff !== 'all' && q.diff !== parseInt(selectedDiff, 10)) return false;
            // Subcategory filter (only for grafuri)
            if (id === 'grafuri' && selectedSubcats.length > 0) {
              if (selectedSubcats.indexOf(q.category) === -1) return false;
            }
            return true;
          });
          pool = pool.concat(qs);
        });

        pool = shuffle(pool);
        var count = selectedCount === 'all' ? pool.length : Math.min(selectedCount, pool.length);
        pool = pool.slice(0, count);

        renderCards(pool);

        // Show results section
        var resultsEl = document.getElementById('exResults');
        resultsEl.style.display = '';
        document.getElementById('exCount').textContent = pool.length + ' întrebări';

        var chStr = selectedChapters.length === 0 ? 'Toate capitolele'
          : selectedChapters.join(', ');
        var diffStr = selectedDiff === 'all' ? 'Orice dificultate'
          : (DIFF_LABELS[parseInt(selectedDiff,10)] || '');
        var subcatStr = '';
        if (selectedChapters.indexOf('grafuri') !== -1 && selectedSubcats.length > 0) {
          subcatStr = ' · ' + selectedSubcats.map(function(c) { return SUBCAT_LABELS[c]; }).join('+');
        }
        var timerStr = selectedTimer > 0 ? ' · ' + selectedTimer + ' min' : '';

        document.getElementById('exSubtitle').textContent = chStr + ' · ' + diffStr + subcatStr + timerStr;
        document.getElementById('phMeta').textContent =
          pool.length + ' întrebări · ' + chStr + ' · ' + diffStr + subcatStr;
        document.getElementById('phDate').textContent =
          'Generat pe ' + new Date().toLocaleDateString('ro-RO', { day: '2-digit', month: 'long', year: 'numeric' });

        // Show PDF button + answers toggle
        document.getElementById('btnPDF').style.display = '';
        document.getElementById('answersToggleWrap').style.display = 'flex';

        // Start timer if set
        if (selectedTimer > 0) {
          startTimer(selectedTimer);
        } else {
          document.getElementById('timerBar').style.display = 'none';
          stopTimer();
        }

        // Reset global answers toggle
        document.getElementById('showAnswers').checked = false;
        document.body.classList.remove('print-answers');

        resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        spinner.style.display = 'none';
        btn.disabled = false;
      });
    }

    function onPDF() {
      var withAnswers = document.getElementById('showAnswers').checked;
      if (withAnswers) {
        document.body.classList.add('print-answers');
      } else {
        document.body.classList.remove('print-answers');
      }
      window.print();
      setTimeout(function() {
        if (!withAnswers) document.body.classList.remove('print-answers');
      }, 1000);
    }

    document.addEventListener('DOMContentLoaded', function() {
      setupChips();
      setupGlobalAnswers();
      document.getElementById('btnGenerate').addEventListener('click', onGenerate);
      document.getElementById('btnPDF').addEventListener('click', onPDF);

      // Timer controls (for browse mode)
      document.getElementById('timerPause').addEventListener('click', function() {
        timerPaused = !timerPaused;
        this.textContent = timerPaused ? '▶' : '⏸';
      });
      document.getElementById('timerReset').addEventListener('click', function() {
        stopTimer();
        document.getElementById('timerBar').style.display = 'none';
      });

      // Dynamic link to exam mode with current filters
      document.getElementById('btnTestLink').addEventListener('click', function(e) {
        e.preventDefault();
        var params = [];
        if (selectedChapters.length > 0) params.push('ch=' + selectedChapters.join(','));
        if (selectedSubcats.length > 0) params.push('sub=' + selectedSubcats.join(','));
        if (selectedDiff !== 'all') params.push('diff=' + selectedDiff);
        if (selectedCount !== 10) params.push('count=' + selectedCount);
        if (selectedTimer > 0) params.push('timer=' + selectedTimer);
        var base = this.getAttribute('href').split('?')[0];
        window.location.href = base + (params.length ? '?' + params.join('&') : '');
      });
    });
  })();
  </script>

  <script is:inline src={`${import.meta.env.BASE_URL}js/platform.js`}></script>
</BaseLayout>
