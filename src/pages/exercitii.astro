  </style>

  <!-- ── JavaScript ── -->
  <script is:inline>
  (function() {
    var BASE = document.querySelector('base') ? document.querySelector('base').href : '/';

    var CHAPTERS = [
      { id: 'introducere',   label: 'Introducere'   },
      { id: 'functii',       label: 'Funcții'       },
      { id: 'complexitate',  label: 'Complexitate'  },
      { id: 'recursivitate', label: 'Recursivitate' },
      { id: 'backtracking',  label: 'Backtracking'  },
      { id: 'vectori',       label: 'Vectori'       },
      { id: 'matrici',       label: 'Matrici'       },
      { id: 'siruri',        label: 'Șiruri'        },
      { id: 'fisiere',       label: 'Fișiere'       },
      { id: 'programare-dinamica', label: 'Prog. Dinamică' },
      { id: 'structuri',     label: 'Structuri'     },
      { id: 'pointeri',      label: 'Pointeri'      },
      { id: 'grafuri',       label: 'Grafuri'       },
    ];

    var DIFF_LABELS = ['','Facil','Mediu','Dificil'];
    var DIFF_CLS    = ['','ex-diff-facil','ex-diff-mediu','ex-diff-dificil'];
    var SUBCAT_LABELS = ['Neorientate','Orientate','Arbori'];

    // State
    var selectedChapters = []; // empty = all
    var selectedSubcats  = []; // empty = all subcats for grafuri
    var selectedDiff     = 'all';
    var selectedCount    = 10;
    var selectedTimer    = 0; // minutes, 0 = no timer
    var loadedData       = {}; // { chapterId: [{q,opts,ans,diff,category}, ...] }

    // Timer state
    var timerInterval = null;
    var timerRemaining = 0;
    var timerTotal = 0;
    var timerPaused = false;

    /* ── Chip logic ── */
    function setupChips() {
      // Chapter chips
      document.querySelectorAll('#chapterChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.dataset.all) {
            selectedChapters = [];
            document.querySelectorAll('#chapterChips .chip').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
          } else {
            var ch = btn.dataset.chapter;
            document.querySelector('#chapterChips .chip-all').classList.remove('active');
            btn.classList.toggle('active');
            if (btn.classList.contains('active')) {
              selectedChapters.push(ch);
            } else {
              selectedChapters = selectedChapters.filter(function(x) { return x !== ch; });
            }
            if (selectedChapters.length === 0) {
              document.querySelector('#chapterChips .chip-all').classList.add('active');
            }
          }
          updateSubcatVisibility();
        });
      });

      // Subcategory chips (multi-select for mixing)
      document.querySelectorAll('#subcatChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var val = btn.dataset.subcat;
          if (val === 'all') {
            selectedSubcats = [];
            document.querySelectorAll('#subcatChips .chip').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
          } else {
            document.querySelector('#subcatChips [data-subcat="all"]').classList.remove('active');
            btn.classList.toggle('active');
            var catNum = parseInt(val, 10);
            if (btn.classList.contains('active')) {
              selectedSubcats.push(catNum);
            } else {
              selectedSubcats = selectedSubcats.filter(function(x) { return x !== catNum; });
            }
            if (selectedSubcats.length === 0) {
              document.querySelector('#subcatChips [data-subcat="all"]').classList.add('active');
            }
          }
        });
      });

      // Diff chips
      document.querySelectorAll('#diffChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#diffChips .chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          selectedDiff = btn.dataset.diff;
        });
      });

      // Count chips
      document.querySelectorAll('#countChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#countChips .chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          selectedCount = btn.dataset.count === 'all' ? 'all' : parseInt(btn.dataset.count, 10);
        });
      });

      // Timer chips
      document.querySelectorAll('#timerChips .chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#timerChips .chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          selectedTimer = parseInt(btn.dataset.timer, 10);
        });
      });
    }

    function updateSubcatVisibility() {
      var show = selectedChapters.indexOf('grafuri') !== -1;
      document.getElementById('subcategoryGroup').style.display = show ? '' : 'none';
      if (!show) {
        selectedSubcats = [];
        document.querySelectorAll('#subcatChips .chip').forEach(function(b) { b.classList.remove('active'); });
        document.querySelector('#subcatChips [data-subcat="all"]').classList.add('active');
      }
    }

    /* ── Determine base URL for data fetching ── */
    function getDataBase() {
      var canonical = document.querySelector('link[rel="canonical"]');
      if (canonical) {
        var url = new URL(canonical.href);
        var parts = url.pathname.split('/').filter(Boolean);
        if (parts.length > 0) {
          return url.origin + '/' + parts[0] + '/';
        }
        return url.origin + '/';
      }
      var loc = window.location;
      var path = loc.pathname;
      var pathBase = path.substring(0, path.lastIndexOf('/') + 1);
      return loc.origin + pathBase;
    }

    /* ── Load JSON data ── */
    function loadAllChapters(chapterIds) {
      var needed = chapterIds.filter(function(id) { return !loadedData[id]; });
      if (needed.length === 0) return Promise.resolve();
      var loc = window.location;
      var pathParts = loc.pathname.split('/').filter(Boolean);
      pathParts.pop();
      var dataPrefix = loc.origin + '/' + pathParts.join('/') + '/data/exercises/';

      var promises = needed.map(function(id) {
        return fetch(dataPrefix + id + '.json')
          .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status + ' for ' + id);
            return r.json();
          })
          .then(function(json) {
            var arr = Array.isArray(json) ? json : (json.quiz || []);
            arr = arr.map(function(q) { return Object.assign({}, q, { _chapter: id }); });
            loadedData[id] = arr;
          })
          .catch(function(err) {
            console.warn('Could not load', id, err);
            loadedData[id] = [];
          });
      });
      return Promise.all(promises);
    }

    /* ── Shuffle array (Fisher-Yates) ── */
    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = a[i]; a[i] = a[j]; a[j] = t;
      }
      return a;
    }

    /* ── Render cards ── */
    function renderCards(questions) {
      var list = document.getElementById('exList');
      list.innerHTML = '';

      questions.forEach(function(q, idx) {
        var diffCls   = DIFF_CLS[q.diff] || '';
        var diffLabel = DIFF_LABELS[q.diff] || '';
        var chLabel   = q._chapter || '';
        var subcatLabel = '';
        if (chLabel === 'grafuri' && typeof q.category !== 'undefined') {
          subcatLabel = SUBCAT_LABELS[q.category] || '';
        }

        var optsHtml = q.opts.map(function(opt, i) {
          var isCorrect = (typeof q.ans !== 'undefined') && i === q.ans;
          return '<div class="ex-opt' + (isCorrect ? ' ex-opt-correct' : '') + '">' +
            '<span class="ex-opt-letter">' + String.fromCharCode(65 + i) + '</span>' +
            '<span>' + opt + '</span>' +
            (isCorrect ? '<span class="ex-correct-mark" aria-label="Răspuns corect">✓</span>' : '') +
            '</div>';
        }).join('');

        // Per-problem answer section
        var answerHtml = '';
        if (typeof q.ans !== 'undefined') {
          var correctLetter = String.fromCharCode(65 + q.ans);
          var explanation = q.exp || '';
          answerHtml = '<button class="ex-answer-toggle" data-idx="' + idx + '">👁 Arată răspunsul</button>' +
            '<div class="ex-answer-section" id="ans-' + idx + '">' +
              '<div class="ex-answer-label">Răspuns corect</div>' +
              '<div class="ex-answer-text"><span class="ex-answer-correct">' + correctLetter + '. ' + q.opts[q.ans] + '</span></div>' +
              (explanation ? '<div class="ex-answer-text" style="margin-top:6px;color:#94a3b8;font-size:12px">💡 ' + explanation + '</div>' : '') +
            '</div>';
        }

        var card = document.createElement('div');
        card.className = 'ex-card';
        card.innerHTML =
          '<div class="ex-card-header">' +
            '<span class="ex-num">' + (idx + 1) + '.</span>' +
            '<span class="ex-chapter-badge cb-' + chLabel + '">' + chLabel + '</span>' +
            (subcatLabel ? '<span class="ex-chapter-badge" style="background:rgba(124,58,237,.12);color:#a78bfa">' + subcatLabel + '</span>' : '') +
            (diffLabel ? '<span class="ex-diff ' + diffCls + '">' + diffLabel + '</span>' : '') +
          '</div>' +
          '<div class="ex-q">' + q.q + '</div>' +
          '<div class="ex-opts">' + optsHtml + '</div>' +
          answerHtml;

        list.appendChild(card);
      });

      // Setup per-problem answer toggles
      list.querySelectorAll('.ex-answer-toggle').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var idx = btn.dataset.idx;
          var section = document.getElementById('ans-' + idx);
          if (section.classList.contains('visible')) {
            section.classList.remove('visible');
            btn.textContent = '👁 Arată răspunsul';
          } else {
            section.classList.add('visible');
            btn.textContent = '🙈 Ascunde răspunsul';
          }
        });
      });
    }

    /* ── Timer functions ── */
    function startTimer(minutes) {
      stopTimer();
      timerTotal = minutes * 60;
      timerRemaining = timerTotal;
      timerPaused = false;
      var bar = document.getElementById('timerBar');
      bar.style.display = '';
      bar.classList.remove('timer-expired');
      document.getElementById('timerPause').textContent = '⏸';
      updateTimerDisplay();

      timerInterval = setInterval(function() {
        if (!timerPaused) {
          timerRemaining--;
          updateTimerDisplay();
          if (timerRemaining <= 0) {
            stopTimer();
            bar.classList.add('timer-expired');
            document.getElementById('timerDisplay').textContent = '00:00 ⏰';
          }
        }
      }, 1000);
    }

    function updateTimerDisplay() {
      var mins = Math.floor(timerRemaining / 60);
      var secs = timerRemaining % 60;
      document.getElementById('timerDisplay').textContent =
        (mins < 10 ? '0' : '') + mins + ':' + (secs < 10 ? '0' : '') + secs;
      var pct = timerTotal > 0 ? (timerRemaining / timerTotal) * 100 : 100;
      document.getElementById('timerProgress').style.width = pct + '%';
    }

    function stopTimer() {
      if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
      }
    }

    /* ── Global show/hide answers ── */
    function setupGlobalAnswers() {
      document.getElementById('showAnswers').addEventListener('change', function() {
        var checked = this.checked;
        document.querySelectorAll('.ex-answer-section').forEach(function(s) {
          if (checked) {
            s.classList.add('visible');
          } else {
            s.classList.remove('visible');
          }
        });
        document.querySelectorAll('.ex-answer-toggle').forEach(function(btn) {
          btn.textContent = checked ? '🙈 Ascunde răspunsul' : '👁 Arată răspunsul';
        });
        // Also toggle correct mark highlights
        if (checked) {
          document.body.classList.add('print-answers');
        } else {
          document.body.classList.remove('print-answers');
        }
      });
    }

    /* ── Generate ── */
    function onGenerate() {
      var spinner = document.getElementById('loadingSpinner');
      var btn     = document.getElementById('btnGenerate');
      spinner.style.display = 'inline';
      btn.disabled = true;

      var chapterIds = selectedChapters.length > 0
        ? selectedChapters
        : CHAPTERS.map(function(c) { return c.id; });

      loadAllChapters(chapterIds).then(function() {
        var pool = [];
        chapterIds.forEach(function(id) {
          var qs = (loadedData[id] || []).filter(function(q) {
            // Difficulty filter
            if (selectedDiff !== 'all' && q.diff !== parseInt(selectedDiff, 10)) return false;
            // Subcategory filter (only for grafuri)
            if (id === 'grafuri' && selectedSubcats.length > 0) {
              if (selectedSubcats.indexOf(q.category) === -1) return false;
            }
            return true;
          });
          pool = pool.concat(qs);
        });

        pool = shuffle(pool);
        var count = selectedCount === 'all' ? pool.length : Math.min(selectedCount, pool.length);
        pool = pool.slice(0, count);

        renderCards(pool);

        // Show results section
        var resultsEl = document.getElementById('exResults');
        resultsEl.style.display = '';
        document.getElementById('exCount').textContent = pool.length + ' întrebări';

        var chStr = selectedChapters.length === 0 ? 'Toate capitolele'
          : selectedChapters.join(', ');
        var diffStr = selectedDiff === 'all' ? 'Orice dificultate'
          : (DIFF_LABELS[parseInt(selectedDiff,10)] || '');
        var subcatStr = '';
        if (selectedChapters.indexOf('grafuri') !== -1 && selectedSubcats.length > 0) {
          subcatStr = ' · ' + selectedSubcats.map(function(c) { return SUBCAT_LABELS[c]; }).join('+');
        }
        var timerStr = selectedTimer > 0 ? ' · ' + selectedTimer + ' min' : '';

        document.getElementById('exSubtitle').textContent = chStr + ' · ' + diffStr + subcatStr + timerStr;
        document.getElementById('phMeta').textContent =
          pool.length + ' întrebări · ' + chStr + ' · ' + diffStr + subcatStr;
        document.getElementById('phDate').textContent =
          'Generat pe ' + new Date().toLocaleDateString('ro-RO', { day: '2-digit', month: 'long', year: 'numeric' });

        // Show PDF button + answers toggle
        document.getElementById('btnPDF').style.display = '';
        document.getElementById('answersToggleWrap').style.display = 'flex';

        // Start timer if set
        if (selectedTimer > 0) {
          startTimer(selectedTimer);
        } else {
          document.getElementById('timerBar').style.display = 'none';
          stopTimer();
        }

        // Reset global answers toggle
        document.getElementById('showAnswers').checked = false;
        document.body.classList.remove('print-answers');

        resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        spinner.style.display = 'none';
        btn.disabled = false;
      });
    }

    function onPDF() {
      var withAnswers = document.getElementById('showAnswers').checked;
      if (withAnswers) {
        document.body.classList.add('print-answers');
      } else {
        document.body.classList.remove('print-answers');
      }
      window.print();
      setTimeout(function() {
        if (!withAnswers) document.body.classList.remove('print-answers');
      }, 1000);
    }

    /* ═══════════════════════════════════════════════════════
       TEST MODE — Exam-like interface
    ═══════════════════════════════════════════════════════ */
    var testState = {
      questions: [],
      answers: [],    // null = not answered, number = chosen index
      skipped: [],    // boolean array
      current: 0,
      score: 0,
      timerInterval: null,
      timerRemaining: 0,
      timerTotal: 0,
      paused: false,
      finished: false,
      reviewMode: false
    };

    function onStartTest() {
      var spinner = document.getElementById('loadingSpinner');
      spinner.style.display = 'inline';

      var chapterIds = selectedChapters.length > 0
        ? selectedChapters
        : CHAPTERS.map(function(c) { return c.id; });

      loadAllChapters(chapterIds).then(function() {
        var pool = [];
        chapterIds.forEach(function(id) {
          var qs = (loadedData[id] || []).filter(function(q) {
            if (selectedDiff !== 'all' && q.diff !== parseInt(selectedDiff, 10)) return false;
            if (id === 'grafuri' && selectedSubcats.length > 0) {
              if (selectedSubcats.indexOf(q.category) === -1) return false;
            }
            return true;
          });
          pool = pool.concat(qs);
        });

        pool = shuffle(pool);
        var count = selectedCount === 'all' ? pool.length : Math.min(selectedCount, pool.length);
        pool = pool.slice(0, count);

        if (pool.length === 0) {
          spinner.style.display = 'none';
          alert('Nu s-au găsit exerciții cu filtrele selectate.');
          return;
        }

        // Initialize test state
        testState.questions = pool;
        testState.answers = new Array(pool.length).fill(null);
        testState.skipped = new Array(pool.length).fill(false);
        testState.current = 0;
        testState.score = 0;
        testState.finished = false;
        testState.reviewMode = false;
        testState.paused = false;

        // Timer
        var minutes = selectedTimer > 0 ? selectedTimer : 15; // default 15 min if none set
        testState.timerTotal = minutes * 60;
        testState.timerRemaining = testState.timerTotal;

        // Hide other sections, show test mode
        document.getElementById('exResults').style.display = 'none';
        document.getElementById('timerBar').style.display = 'none';
        document.getElementById('testMode').style.display = '';
        document.getElementById('testResults').style.display = 'none';
        document.getElementById('testQuestionArea').style.display = '';
        document.getElementById('testBottomNav').style.display = '';
        document.getElementById('testHeader').style.display = '';
        document.getElementById('testNavDots').style.display = '';

        // Set timer label
        document.getElementById('testTimerLabel').textContent = pool.length + ' probleme · ' + minutes + ' min';

        // Render dots
        renderTestDots();
        renderTestQuestion();
        startTestTimer();

        spinner.style.display = 'none';

        document.getElementById('testMode').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    function renderTestDots() {
      var dots = document.getElementById('testNavDots');
      dots.innerHTML = '';
      testState.questions.forEach(function(_, i) {
        var dot = document.createElement('button');
        dot.className = 'test-dot';
        if (i === testState.current) dot.className += ' current';
        if (testState.answers[i] !== null) dot.className += ' answered';
        else if (testState.skipped[i]) dot.className += ' skipped';
        dot.textContent = i + 1;
        dot.addEventListener('click', function() {
          if (!testState.finished) {
            testState.current = i;
            renderTestDots();
            renderTestQuestion();
          }
        });
        dots.appendChild(dot);
      });
    }

    function renderTestQuestion() {
      var area = document.getElementById('testQuestionArea');
      var q = testState.questions[testState.current];
      var idx = testState.current;
      var chosen = testState.answers[idx];
      var isReview = testState.reviewMode;

      var diffLabel = DIFF_LABELS[q.diff] || '';
      var diffCls = DIFF_CLS[q.diff] || '';
      var chLabel = q._chapter || '';
      var subcatLabel = '';
      if (chLabel === 'grafuri' && typeof q.category !== 'undefined') {
        subcatLabel = SUBCAT_LABELS[q.category] || '';
      }

      var optsHtml = q.opts.map(function(opt, i) {
        var cls = 'test-q-option';
        if (chosen === i) cls += ' selected';
        if (isReview) {
          if (i === q.ans) cls += ' correct';
          else if (chosen === i && i !== q.ans) cls += ' wrong';
        }
        return '<div class="' + cls + '" data-opt="' + i + '">' +
          '<span class="test-q-option-letter">' + String.fromCharCode(65 + i) + '</span>' +
          '<span class="test-q-option-text">' + opt + '</span>' +
          '</div>';
      }).join('');

      var reviewHtml = '';
      if (isReview && q.exp) {
        var isCorrect = chosen === q.ans;
        reviewHtml = '<div style="margin-top:14px;padding:12px 14px;border-radius:10px;' +
          'background:' + (isCorrect ? 'rgba(34,197,94,.08)' : 'rgba(239,68,68,.08)') + ';' +
          'border:1px solid ' + (isCorrect ? 'rgba(34,197,94,.25)' : 'rgba(239,68,68,.25)') + ';' +
          'font-size:13px;color:' + (isCorrect ? '#4ade80' : '#f87171') + ';line-height:1.5">' +
          (isCorrect ? '✅ Corect! ' : '❌ Greșit. Răspuns: <strong>' + String.fromCharCode(65 + q.ans) + '</strong>. ') +
          q.exp + '</div>';
      }

      area.innerHTML =
        '<div class="test-q-header">' +
          '<span class="test-q-num">Întrebarea ' + (idx + 1) + ' / ' + testState.questions.length + '</span>' +
          '<span class="test-q-badge cb-' + chLabel + '">' + chLabel + '</span>' +
          (subcatLabel ? '<span class="test-q-badge" style="background:rgba(124,58,237,.12);color:#a78bfa">' + subcatLabel + '</span>' : '') +
          (diffLabel ? '<span class="ex-diff ' + diffCls + '">' + diffLabel + '</span>' : '') +
        '</div>' +
        '<div class="test-q-text">' + q.q + '</div>' +
        '<div class="test-q-options">' + optsHtml + '</div>' +
        reviewHtml;

      // Bind option clicks (only if not finished)
      if (!testState.finished) {
        area.querySelectorAll('.test-q-option').forEach(function(opt) {
          opt.addEventListener('click', function() {
            var i = parseInt(opt.dataset.opt, 10);
            testState.answers[idx] = i;
            testState.skipped[idx] = false;
            renderTestDots();
            renderTestQuestion();
            updateTestProgress();
          });
        });
      }

      // Update nav buttons
      document.getElementById('testPrevBtn').disabled = idx === 0;
      var hasUnanswered = testState.answers.some(function(a, i) { return a === null && i !== idx; });
      document.getElementById('testSkipBtn').style.display = (testState.finished || chosen !== null) ? 'none' : '';
      document.getElementById('testNextBtn').style.display = idx < testState.questions.length - 1 ? '' : 'none';
    }

    function updateTestProgress() {
      var answered = testState.answers.filter(function(a) { return a !== null; }).length;
      var total = testState.questions.length;
      document.getElementById('testProgressText').textContent = answered + ' / ' + total + ' răspunse';
      var pct = total > 0 ? (answered / total) * 100 : 0;
      document.getElementById('testProgressBar').style.width = pct + '%';
    }

    function startTestTimer() {
      stopTestTimer();
      testState.paused = false;
      updateTestTimerDisplay();

      testState.timerInterval = setInterval(function() {
        if (!testState.paused && !testState.finished) {
          testState.timerRemaining--;
          updateTestTimerDisplay();
          if (testState.timerRemaining <= 0) {
            finishTest(true);
          }
        }
      }, 1000);
    }

    function stopTestTimer() {
      if (testState.timerInterval) {
        clearInterval(testState.timerInterval);
        testState.timerInterval = null;
      }
    }

    function updateTestTimerDisplay() {
      var mins = Math.floor(testState.timerRemaining / 60);
      var secs = testState.timerRemaining % 60;
      var display = document.getElementById('testTimerDisplay');
      display.textContent = (mins < 10 ? '0' : '') + mins + ':' + (secs < 10 ? '0' : '') + secs;

      // Color coding
      var pct = testState.timerTotal > 0 ? testState.timerRemaining / testState.timerTotal : 1;
      display.className = 'test-timer-display';
      if (pct <= 0.1) display.className += ' danger';
      else if (pct <= 0.25) display.className += ' warning';
    }

    function finishTest(timeExpired) {
      testState.finished = true;
      stopTestTimer();

      // Calculate score
      var correct = 0;
      var answered = 0;
      var skippedCount = 0;
      testState.questions.forEach(function(q, i) {
        if (testState.answers[i] !== null) {
          answered++;
          if (testState.answers[i] === q.ans) correct++;
        } else {
          skippedCount++;
        }
      });
      testState.score = correct;

      var total = testState.questions.length;
      var pct = total > 0 ? Math.round((correct / total) * 100) : 0;
      var emoji = pct >= 90 ? '🏆' : pct >= 70 ? '🎉' : pct >= 50 ? '😊' : '📚';
      var msg = pct >= 90 ? 'Excelent! Ești pregătit/ă!'
        : pct >= 70 ? 'Foarte bine! Recapitulează ce ai greșit.'
        : pct >= 50 ? 'Bine! Exersează mai mult pe temele dificile.'
        : 'Nu te descuraja! Revizuiește teoria și încearcă din nou.';

      var timeUsed = testState.timerTotal - testState.timerRemaining;
      var timeMin = Math.floor(timeUsed / 60);
      var timeSec = timeUsed % 60;

      document.getElementById('testResults').style.display = '';
      document.getElementById('testResults').innerHTML =
        '<div class="test-results-emoji">' + emoji + '</div>' +
        '<div class="test-results-score">' + correct + ' / ' + total + '</div>' +
        '<div class="test-results-pct">' + pct + '%</div>' +
        (timeExpired ? '<div style="color:#f87171;font-size:13px;margin-top:6px">⏰ Timpul a expirat!</div>' : '') +
        '<div class="test-results-msg">' + msg + '</div>' +
        '<div class="test-results-stats">' +
          '<div class="test-results-stat"><div class="test-results-stat-val" style="color:#4ade80">' + correct + '</div><div class="test-results-stat-label">Corecte</div></div>' +
          '<div class="test-results-stat"><div class="test-results-stat-val" style="color:#f87171">' + (answered - correct) + '</div><div class="test-results-stat-label">Greșite</div></div>' +
          '<div class="test-results-stat"><div class="test-results-stat-val" style="color:#fbbf24">' + skippedCount + '</div><div class="test-results-stat-label">Nerezolvate</div></div>' +
          '<div class="test-results-stat"><div class="test-results-stat-val">' + timeMin + ':' + (timeSec < 10 ? '0' : '') + timeSec + '</div><div class="test-results-stat-label">Timp folosit</div></div>' +
        '</div>' +
        '<div class="test-results-actions">' +
          '<button class="test-results-btn test-results-btn-review" id="testReviewBtn">🔍 Revizuiește</button>' +
          '<button class="test-results-btn test-results-btn-retry" id="testRetryBtn">🔄 Reia testul</button>' +
          '<button class="test-results-btn test-results-btn-back" id="testBackBtn">← Înapoi la filtre</button>' +
        '</div>';

      // Hide question area during results
      document.getElementById('testQuestionArea').style.display = 'none';
      document.getElementById('testBottomNav').style.display = 'none';

      // Bind result buttons
      document.getElementById('testReviewBtn').addEventListener('click', function() {
        testState.reviewMode = true;
        testState.current = 0;
        document.getElementById('testResults').style.display = 'none';
        document.getElementById('testQuestionArea').style.display = '';
        document.getElementById('testBottomNav').style.display = '';
        document.getElementById('testSkipBtn').style.display = 'none';
        renderTestDots();
        renderTestQuestion();
      });

      document.getElementById('testRetryBtn').addEventListener('click', function() {
        // Restart with same questions, reshuffled
        testState.questions = shuffle(testState.questions);
        testState.answers = new Array(testState.questions.length).fill(null);
        testState.skipped = new Array(testState.questions.length).fill(false);
        testState.current = 0;
        testState.score = 0;
        testState.finished = false;
        testState.reviewMode = false;
        testState.timerRemaining = testState.timerTotal;
        document.getElementById('testResults').style.display = 'none';
        document.getElementById('testQuestionArea').style.display = '';
        document.getElementById('testBottomNav').style.display = '';
        renderTestDots();
        renderTestQuestion();
        updateTestProgress();
        startTestTimer();
      });

      document.getElementById('testBackBtn').addEventListener('click', function() {
        document.getElementById('testMode').style.display = 'none';
        stopTestTimer();
      });

      renderTestDots();
      updateTestProgress();
    }

    document.addEventListener('DOMContentLoaded', function() {
      setupChips();
      setupGlobalAnswers();
      document.getElementById('btnGenerate').addEventListener('click', onGenerate);
      document.getElementById('btnStartTest').addEventListener('click', onStartTest);
      document.getElementById('btnPDF').addEventListener('click', onPDF);

      // Timer controls (for browse mode)
      document.getElementById('timerPause').addEventListener('click', function() {
        timerPaused = !timerPaused;
        this.textContent = timerPaused ? '▶' : '⏸';
      });
      document.getElementById('timerReset').addEventListener('click', function() {
        stopTimer();
        document.getElementById('timerBar').style.display = 'none';
      });

      // Test mode navigation
      document.getElementById('testPrevBtn').addEventListener('click', function() {
        if (testState.current > 0) {
          testState.current--;
          renderTestDots();
          renderTestQuestion();
        }
      });
      document.getElementById('testNextBtn').addEventListener('click', function() {
        if (testState.current < testState.questions.length - 1) {
          testState.current++;
          renderTestDots();
          renderTestQuestion();
        }
      });
      document.getElementById('testSkipBtn').addEventListener('click', function() {
        testState.skipped[testState.current] = true;
        // Go to next unanswered
        var next = -1;
        for (var i = testState.current + 1; i < testState.questions.length; i++) {
          if (testState.answers[i] === null) { next = i; break; }
        }
        if (next === -1) {
          // Wrap around
          for (var j = 0; j < testState.current; j++) {
            if (testState.answers[j] === null) { next = j; break; }
          }
        }
        if (next !== -1) {
          testState.current = next;
        } else {
          // All answered or skipped, go to next
          if (testState.current < testState.questions.length - 1) testState.current++;
        }
        renderTestDots();
        renderTestQuestion();
      });
      document.getElementById('testSubmitBtn').addEventListener('click', function() {
        var unanswered = testState.answers.filter(function(a) { return a === null; }).length;
        var msg = unanswered > 0
          ? 'Ai ' + unanswered + ' întrebări nerezolvate. Predai testul?'
          : 'Predai testul?';
        if (confirm(msg)) finishTest(false);
      });
    });
  })();
  </script>

  <script is:inline src={`${import.meta.env.BASE_URL}/js/platform.js`}></script>
</BaseLayout>
