---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const chapters = [
  {
    num: 0, file: 'introducere', color: 'ch-blue', icon: '🖥️', difficulty: 'easy',
    title: 'Introducere în Informatică', subtitle: 'Bazele absolute, program C++, programa BAC 2026',
    topics: ['Ce este informatica și algoritmul','Structura unui program C++','Tipuri de date: int, double, char, bool','Operatori și structuri de control','Programa completă BAC 2026'],
    time: '~25 min'
  },
  {
    num: 8, file: 'functii', color: 'ch-blue', icon: '⚙️', difficulty: 'easy',
    title: 'Funcții și Subprograme', subtitle: 'Parametri, referințe, variabile locale/globale',
    topics: ['Declarare, definire, apel de funcție','Parametri prin valoare vs. referință (&)','Variabile locale vs. globale','Funcții void și cu return','Overloading și funcții inline'],
    time: '~30 min'
  },
  {
    num: 1, file: 'complexitate', color: 'ch-blue', icon: '📊', difficulty: 'medium',
    title: 'Eficiența Algoritmilor', subtitle: 'Complexitate timp & spațiu, notații Big-O',
    topics: ['Notația Big-O, Ω, Θ','Clase de complexitate comparate','Algoritmi de sortare analizați','Animație Bubble Sort interactivă','Probleme tip BAC rezolvate'],
    time: '~45 min'
  },
  {
    num: 2, file: 'recursivitate', color: 'ch-green', icon: '🔄', difficulty: 'medium',
    title: 'Recursivitate', subtitle: 'Funcții recursive și stiva de apeluri',
    topics: ['Cum funcționează recursivitatea','Stiva de apeluri vizualizată','Factorial, Fibonacci, putere','Recursiv vs. iterativ — comparație','Memoizare și introducere DP'],
    time: '~35 min'
  },
  {
    num: 3, file: 'backtracking', color: 'ch-purple', icon: '🌳', difficulty: 'hard',
    title: 'Backtracking', subtitle: 'Căutare exhaustivă cu revenire',
    topics: ['Șablonul general backtracking','Animație N-Regine pas cu pas','Permutări și combinări','Labirint — căutarea ieșirii','Probleme BAC complete'],
    time: '~40 min'
  },
  {
    num: 4, file: 'vectori', color: 'ch-orange', icon: '📦', difficulty: 'easy',
    title: 'Vectori (Tablouri 1D)', subtitle: 'Operații, algoritmi, aplicații clasice',
    topics: ['Declarare, inițializare, citire','Parcurgere, căutare, sortare','Interclasare, ștergere, inserare','Ciurul lui Eratostene','Probleme clasice BAC cu vectori'],
    time: '~35 min'
  },
  {
    num: 5, file: 'matrici', color: 'ch-teal', icon: '🔲', difficulty: 'medium',
    title: 'Matrici (Tablouri 2D)', subtitle: 'Operații pe tablouri bidimensionale',
    topics: ['Declarare și parcurgere completă','Diagonale, triunghi sup/inf','Transpusa și rotirea matricei','Matrice pătratice speciale','Spirală, borduri, probleme BAC'],
    time: '~35 min'
  },
  {
    num: 6, file: 'siruri', color: 'ch-red', icon: '🔤', difficulty: 'medium',
    title: 'Șiruri de Caractere', subtitle: 'Prelucrarea textelor în C++',
    topics: ['char[] vs. string în C++','Funcții standard strlen, strcpy, strcat','Palindrom, anagramă, cifru Caesar','Numărare caractere și cuvinte','Probleme BAC cu șiruri'],
    time: '~35 min'
  },
  {
    num: 7, file: 'fisiere', color: 'ch-pink', icon: '📁', difficulty: 'easy',
    title: 'Fișiere', subtitle: 'Citire și scriere din/în fișiere C++',
    topics: ['Deschidere, citire, scriere, închidere','fstream, ifstream, ofstream','Citire până la EOF','Procesare date din fișiere','Probleme BAC cu fișiere'],
    time: '~30 min'
  },
  {
    num: 9, file: 'programare-dinamica', color: 'ch-teal', icon: '🧮', difficulty: 'hard',
    title: 'Programare Dinamică', subtitle: 'De la memoizare la DP tabelar',
    topics: ['Fibonacci: naiv → memoizare → DP','DP tabelar bottom-up','Cel mai lung subșir crescător (LIS)','Triunghi de numere — sum maximă','Probleme BAC M-I intensiv'],
    time: '~40 min'
  },
  {
    num: 10, file: 'structuri', color: 'ch-purple', icon: '🗂️', difficulty: 'medium',
    title: 'Structuri (struct)', subtitle: 'Tipuri de date definite de utilizator',
    topics: ['Declararea și inițializarea struct','Accesarea câmpurilor cu . și ->','Array de structuri','Sortare după un câmp','Structuri ca parametri de funcție'],
    time: '~30 min'
  },
  {
    num: 11, file: 'pointeri', color: 'ch-green', icon: '🔗', difficulty: 'hard',
    title: 'Pointeri & Alocare Dinamică', subtitle: 'Referințe, new/delete, liste',
    topics: ['Ce este un pointer — *, &, ->','Aritmetica pointerilor','Alocare dinamică: new și delete','Pointeri și funcții','Introducere în liste simplu înlănțuite'],
    time: '~35 min'
  },
];
---
<BaseLayout
  title="Informatică Liceu — Algoritmi & Structuri de Date"
  description="Ghid complet de informatică pentru liceu și bacalaureat: algoritmi, complexitate, recursivitate, backtracking, vectori, matrici, șiruri, fișiere."
>
  <Header />
  <Sidebar />

      <!-- Hero -->
  <section class="hero" id="hero">
    <div class="hero-bg-radial" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="hero-eyebrow">
        <span class="hero-eyebrow-dot"></span>
        🎓 BAC Informatică · România · C++
      </span>
      <h1>Informatică Liceu<br /><span>Algoritmi &amp; Structuri de Date</span></h1>
      <p class="hero-desc">
        Ghid complet pas cu pas pentru bacalaureat. De la noțiuni fundamentale
        la probleme rezolvate, cu animații interactive și exemple din practică.
      </p>
      <div class="hero-badges">
        <span class="hero-badge">📊 12 capitole</span>
        <span class="hero-badge">🎬 Animații interactive</span>
        <span class="hero-badge">⏱ Complexitate timp &amp; spațiu</span>
        <span class="hero-badge">📝 Probleme rezolvate</span>
        <span class="hero-badge">🔊 Audio lecții</span>
      </div>
      <div class="hero-actions">
        <a href="#capitole"     class="btn-hero-primary">Începe să înveți →</a>
        <a href="#complexitate" class="btn-hero-secondary">Big-O Referință</a>
        <a href={`${base}/analiza-bac`} class="btn-hero-secondary btn-hero-ghost">
          🤖 Analizează-ți varianta BAC
        </a>
      </div>
      <!-- Onboarding hint for first-time visitors -->
      <p class="hero-onboarding">
        <strong>Ești la început?</strong> Urmează capitolele în ordine:
        <a href={`${base}/capitole/introducere`}>Introducere</a> →
        <a href={`${base}/capitole/functii`}>Funcții</a> →
        <a href={`${base}/capitole/recursivitate`}>Recursivitate</a> → ...
      </p>

      <!-- Decorative code preview -->
      <div class="hero-graphic" aria-hidden="true">
        <div class="hero-code-preview">
          <div class="hcp-bar">
            <span class="hcp-dot r"></span>
            <span class="hcp-dot y"></span>
            <span class="hcp-dot g"></span>
            <span class="hcp-title">cautare_binara.cpp</span>
          </div>
          <pre class="hcp-code"><span class="kw">int</span> cautareBinara(<span class="kw">int</span> v[], <span class="kw">int</span> n, <span class="kw">int</span> x) {"{"}
  <span class="kw">int</span> st = <span class="nu">0</span>, dr = n - <span class="nu">1</span>;
  <span class="kw">while</span> (st &lt;= dr) {"{"}
    <span class="kw">int</span> mij = (st + dr) / <span class="nu">2</span>;
    <span class="kw">if</span> (v[mij] == x) <span class="kw">return</span> mij;
    <span class="kw">if</span> (v[mij] &lt; x) st = mij + <span class="nu">1</span>;
    <span class="kw">else</span>            dr = mij - <span class="nu">1</span>;
  {"}"}
  <span class="kw">return</span> -<span class="nu">1</span>; <span class="cm">// O(log n) ✓</span>
{"}"}

<span class="cm">// Complexitate: O(log n) timp · O(1) spațiu</span>
<span class="cm">// vs. căutare liniară: O(n) — de 1000x mai rapid</span></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <div class="stats-strip">
    <div class="stat-item">
      <span class="stat-num">12</span>
      <span class="stat-lbl">Capitole</span>
    </div>
    <div class="stat-sep" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num">800+</span>
      <span class="stat-lbl">Quiz-uri BAC</span>
    </div>
    <div class="stat-sep" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num">5+</span>
      <span class="stat-lbl">Animații</span>
    </div>
    <div class="stat-sep" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-num">~8h</span>
      <span class="stat-lbl">Conținut total</span>
    </div>
  </div>

  <!-- Chapters grid -->
  <div id="capitole" role="main" aria-label="Conținut principal">
    <div class="section-heading">
      <h2 class="section-title">📚 Capitolele cursului</h2>
      <p class="section-subtitle">Parcurge lecțiile în ordine sau sari direct la capitolul care te interesează.</p>
    </div>

    <div class="chapters-grid">
      {chapters.map(ch => (
        <a href={`${base}/capitole/${ch.file}`} class={`chapter-card ${ch.color} slide`} data-chapter={ch.file}>
          <div class="chapter-card-stripe"></div>
          <div class="chapter-card-header">
            <div class="chapter-num-icon">
              <span class="card-icon" aria-hidden="true">{ch.icon}</span>
            </div>
            <div style="flex:1">
              <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:2px;">
                <h2>{ch.title}</h2>
                <span class={`difficulty-badge ${ch.difficulty === 'easy' ? 'easy' : ch.difficulty === 'medium' ? 'medium' : 'hard'}`}>
                  {ch.difficulty === 'easy' ? 'Ușor' : ch.difficulty === 'medium' ? 'Mediu' : 'Dificil'}
                </span>
              </div>
              <p>{ch.subtitle}</p>
            </div>
          </div>
          <div class="chapter-card-body">
            <ul class="chapter-topics">
              {ch.topics.map(t => <li>{t}</li>)}
            </ul>
          </div>
          <div class="chapter-card-footer">
            <span>⏱ {ch.time} lectură</span>
            <span class="go">Deschide →</span>
          </div>
          <div class="card-progress">
            <div class="card-progress-fill" data-chapter-file={ch.file}></div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- BAC AI CTA -->
  <div class="bac-cta">
    <div class="bac-cta-inner">
      <div class="bac-cta-text">
        <h2>🤖 Analiză BAC cu AI</h2>
        <p>
          Încarcă subiectul tău de BAC în format PDF și primește o analiză completă,
          cu teorie, pași de rezolvare și link-uri directe la capitolele relevante.
        </p>
      </div>
      <a href={`${base}/analiza-bac`} class="bac-cta-btn">
        Încearcă gratuit →
      </a>
    </div>
  </div>

  <!-- Big-O reference section -->
  <div id="complexitate" class="wrapper">
    <div class="section-heading">
      <h2 class="section-title">📊 Referință Big-O</h2>
      <p class="section-subtitle">Complexitățile cele mai întâlnite la examen.</p>
    </div>
    <div class="table-scroll">
      <table class="o-table">
        <thead>
          <tr><th>Notație</th><th>Nume</th><th>Exemplu</th><th>n=1000</th></tr>
        </thead>
        <tbody>
          <tr class="row-green"><td>O(1)</td><td>Constant</td><td>Accesare element array</td><td>1 op</td></tr>
          <tr class="row-green"><td>O(log n)</td><td>Logaritmic</td><td>Căutare binară</td><td>10 op</td></tr>
          <tr class="row-yellow"><td>O(n)</td><td>Liniar</td><td>Parcurgere array</td><td>1 000 op</td></tr>
          <tr class="row-yellow"><td>O(n log n)</td><td>Liniar-log</td><td>Merge sort, Quick sort</td><td>10 000 op</td></tr>
          <tr class="row-red"><td>O(n²)</td><td>Pătratic</td><td>Bubble sort, selecție</td><td>1 000 000 op</td></tr>
          <tr class="row-red"><td>O(2ⁿ)</td><td>Exponențial</td><td>Backtracking naiv</td><td>~ ∞</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <Footer />

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // Scroll reveal for chapter cards
      if (typeof initScrollReveal === 'function') initScrollReveal();
      if (typeof initCopyButtons === 'function') initCopyButtons();
      // Animate card progress bars based on visited localStorage
      document.querySelectorAll('.card-progress-fill').forEach(function(bar) {
        var chFile = bar.getAttribute('data-chapter-file');
        var visited = localStorage.getItem('visited_' + chFile) === '1';
        var quizDone = parseInt(localStorage.getItem('quiz_score_' + chFile) || '0', 10);
        var pct = visited ? (quizDone > 0 ? Math.min(100, quizDone) : 30) : 0;
        if (pct > 0) {
          setTimeout(function() { bar.style.width = pct + '%'; }, 400);
        }
      });
    });
  </script>
  <script is:inline src={`${import.meta.env.BASE_URL}/js/animations.js`}></script>

  <style>
    .hero-bg-radial {
      position: absolute; inset: 0; pointer-events: none; z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99,102,241,0.18) 0%, transparent 70%),
        radial-gradient(ellipse 60% 50% at 80% 80%, rgba(168,85,247,0.1) 0%, transparent 60%);
    }
    .hero { position: relative; overflow: hidden; }
    .hero-inner { position: relative; z-index: 1; }
    .chapter-num-icon {
      width: 48px; height: 48px; flex-shrink: 0;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 24px;
      background: var(--surface2);
      border: 1px solid var(--border);
    }
    .chapter-card-header { display: flex; align-items: flex-start; gap: 14px; }
    .chapter-card-header h2 { font-size: 15px; font-weight: 700; margin: 0; }
    .chapter-card-header p  { font-size: 12.5px; color: var(--text-muted); margin: 0; }
  </style>
</BaseLayout>
