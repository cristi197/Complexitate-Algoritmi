---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapterLinks = [
  { href: `${base}/capitole/introducere`, label: 'Introducere în C++' },
  { href: `${base}/capitole/vectori`, label: 'Vectori' },
  { href: `${base}/capitole/recursivitate`, label: 'Recursivitate' },
  { href: `${base}/capitole/backtracking`, label: 'Backtracking' },
  { href: `${base}/capitole/complexitate`, label: 'Complexitate' },
  { href: `${base}/capitole/matrici`, label: 'Matrice' },
  { href: `${base}/capitole/siruri`, label: 'Șiruri de caractere' },
  { href: `${base}/capitole/fisiere`, label: 'Fișiere' },
  { href: `${base}/capitole/programare-dinamica`, label: 'Programare Dinamică' },
  { href: `${base}/capitole/structuri`, label: 'Structuri (struct)' },
];
---
<BaseLayout title="Calendar Studiu — InfoLiceu">
  <Header />

  <main class="streak-page">
    <!-- Hero -->
    <div class="streak-hero">
      <div class="streak-hero__inner">
        <h1>📅 Calendar Studiu</h1>
        <p>Vizualizează progresul tău zilnic. Fiecare capitol vizitat contează ca o zi de studiu!</p>
      </div>
    </div>

    <div class="streak-layout">
      <!-- Stats cards -->
      <div class="streak-stats">
        <div class="streak-stat-card streak-stat-card--main">
          <div class="streak-stat-value" id="currentStreak">—</div>
          <div class="streak-stat-label">🔥 Streak curent</div>
          <div class="streak-stat-unit">zile consecutive</div>
        </div>
        <div class="streak-stat-card">
          <div class="streak-stat-value" id="totalDays">—</div>
          <div class="streak-stat-label">📚 Total zile studiate</div>
        </div>
        <div class="streak-stat-card">
          <div class="streak-stat-value" id="longestStreak">—</div>
          <div class="streak-stat-label">🏆 Cel mai lung streak</div>
        </div>
        <div class="streak-stat-card">
          <div class="streak-stat-value" id="thisMonth">—</div>
          <div class="streak-stat-label">📆 Zile luna aceasta</div>
        </div>
      </div>

      <!-- Calendar -->
      <div class="streak-calendar-section">
        <div class="streak-calendar-header">
          <button id="btnPrevMonth" class="streak-nav-btn">‹</button>
          <h2 id="calendarTitle" class="streak-calendar-title"></h2>
          <button id="btnNextMonth" class="streak-nav-btn">›</button>
        </div>
        <div class="streak-calendar-weekdays">
          <span>Lun</span><span>Mar</span><span>Mie</span>
          <span>Joi</span><span>Vin</span><span>Sâm</span><span>Dum</span>
        </div>
        <div id="calendarGrid" class="streak-calendar-grid"></div>
        <div class="streak-calendar-legend">
          <span class="legend-item"><span class="legend-dot legend-dot--studied"></span> Zi studiată</span>
          <span class="legend-item"><span class="legend-dot legend-dot--today"></span> Azi</span>
          <span class="legend-item"><span class="legend-dot legend-dot--empty"></span> Nestudiat</span>
        </div>
      </div>

      <!-- Study goals -->
      <div class="streak-goals-section">
        <h3>🎯 Obiective zilnice</h3>
        <p class="streak-goals-intro">Setează-ți obiective pentru a-ți organiza studiul:</p>
        <div class="streak-goals-grid">
          <label class="streak-goal-item">
            <input type="checkbox" id="goal1" class="streak-goal-check" data-goal="exercises" />
            <span class="streak-goal-text">Rezolvă 10 exerciții</span>
          </label>
          <label class="streak-goal-item">
            <input type="checkbox" id="goal2" class="streak-goal-check" data-goal="chapter" />
            <span class="streak-goal-text">Studiază 1 capitol</span>
          </label>
          <label class="streak-goal-item">
            <input type="checkbox" id="goal3" class="streak-goal-check" data-goal="exam" />
            <span class="streak-goal-text">Fă un examen alb</span>
          </label>
          <label class="streak-goal-item">
            <input type="checkbox" id="goal4" class="streak-goal-check" data-goal="review" />
            <span class="streak-goal-text">Recapitulează cheat sheet</span>
          </label>
        </div>
        <div class="streak-goals-progress" id="goalsProgress">
          <span id="goalsCount">0/4 completate azi</span>
        </div>
      </div>

      <!-- Studiază azi -->
      <div class="streak-study-section">
        <h3>📖 Studiază astăzi</h3>
        <p class="streak-study-intro">Alege un capitol pentru a adăuga ziua de azi la streak-ul tău:</p>
        <div class="streak-chapter-grid">
          {chapterLinks.map(ch => (
            <a href={ch.href} class="streak-chapter-link">
              {ch.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Mark today button -->
      <div class="streak-mark-section">
        <button id="btnMarkToday" class="streak-btn streak-btn--mark">
          ✅ Marchează azi ca zi de studiu
        </button>
        <p class="streak-mark-note" id="markNote"></p>
      </div>

      <!-- Reset -->
      <div class="streak-danger-section">
        <button id="btnReset" class="streak-btn streak-btn--danger">🗑️ Resetează tot istoricul</button>
      </div>
    </div>
  </main>

  <style>
    .streak-page { min-height: 100vh; padding-bottom: 56px; }

    .streak-hero {
      background: linear-gradient(135deg, #0c4a6e 0%, #0369a1 40%, #0ea5e9 70%, #38bdf8 100%);
      padding: 40px 24px 36px;
      text-align: center;
      color: #fff;
    }
    .streak-hero h1 { font-size: clamp(1.6rem,4vw,2.4rem); margin: 0 0 10px; }
    .streak-hero p { opacity: .85; max-width: 560px; margin: 0 auto; font-size: 1rem; }

    .streak-layout { max-width: 860px; margin: 32px auto 0; padding: 0 20px; display: flex; flex-direction: column; gap: 28px; }

    /* Stats */
    .streak-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 14px;
    }
    .streak-stat-card {
      background: var(--color-surface, #1e293b);
      border: 1.5px solid var(--color-border, #334155);
      border-radius: 14px;
      padding: 20px;
      text-align: center;
    }
    .streak-stat-card--main {
      background: linear-gradient(135deg, #0c4a6e, #0369a1);
      border-color: #0ea5e9;
    }
    .streak-stat-value { font-size: 2.4rem; font-weight: 800; line-height: 1; margin-bottom: 6px; }
    .streak-stat-label { font-size: 13px; font-weight: 600; color: var(--color-text-muted, #94a3b8); }
    .streak-stat-unit { font-size: 11px; color: var(--color-text-muted, #64748b); margin-top: 4px; }
    .streak-stat-card--main .streak-stat-value { color: #fbbf24; }
    .streak-stat-card--main .streak-stat-label { color: #bae6fd; }

    /* Calendar */
    .streak-calendar-section {
      background: var(--color-surface, #1e293b);
      border: 1.5px solid var(--color-border, #334155);
      border-radius: 16px;
      padding: 24px;
    }
    .streak-calendar-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .streak-calendar-title { font-size: 1.15rem; font-weight: 700; margin: 0; }
    .streak-nav-btn {
      background: var(--color-background, #0f172a);
      border: 1.5px solid var(--color-border, #334155);
      color: var(--color-text, #f1f5f9);
      width: 36px; height: 36px;
      border-radius: 8px;
      font-size: 1.2rem;
      cursor: pointer;
      transition: background .15s;
    }
    .streak-nav-btn:hover { background: #1d4ed8; border-color: #3b82f6; }

    .streak-calendar-weekdays {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
      margin-bottom: 8px;
    }
    .streak-calendar-weekdays span { text-align: center; font-size: 12px; font-weight: 600; color: var(--color-text-muted, #64748b); padding: 4px 0; }

    .streak-calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; }

    .cal-day {
      aspect-ratio: 1;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 500;
      cursor: default;
      transition: transform .15s;
      background: var(--color-background, #0f172a);
      color: var(--color-text-muted, #64748b);
      border: 1px solid transparent;
    }
    .cal-day--empty { background: transparent; }
    .cal-day--studied { background: linear-gradient(135deg,#0369a1,#0ea5e9); color: #fff; font-weight: 700; box-shadow: 0 2px 8px rgba(14,165,233,0.3); }
    .cal-day--today { border: 3px solid #f59e0b; color: #fbbf24; font-weight: 800; background: rgba(245,158,11,0.15); box-shadow: 0 0 8px rgba(245,158,11,0.4); position: relative; }
    .cal-day--today::after { content: ''; position: absolute; bottom: 3px; left: 50%; transform: translateX(-50%); width: 5px; height: 5px; background: #f59e0b; border-radius: 50%; }
    .cal-day--today.cal-day--studied { border-color: #f59e0b; color: #fff; background: linear-gradient(135deg,#0369a1,#0ea5e9); box-shadow: 0 0 0 3px rgba(245,158,11,0.4), 0 2px 8px rgba(14,165,233,0.3); }
    .cal-day--today.cal-day--studied::after { background: #fbbf24; }
    .cal-day--future { opacity: .3; }
    .cal-day:not(.cal-day--empty):hover { transform: scale(1.1); z-index: 1; }

    .streak-calendar-legend { display: flex; gap: 20px; margin-top: 14px; flex-wrap: wrap; }
    .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--color-text-muted, #94a3b8); }
    .legend-dot { width: 14px; height: 14px; border-radius: 4px; display: inline-block; }
    .legend-dot--studied { background: linear-gradient(135deg,#0369a1,#0ea5e9); }
    .legend-dot--today { background: transparent; border: 2px solid #f59e0b; }
    .legend-dot--empty { background: var(--color-background, #0f172a); border: 1px solid var(--color-border, #334155); }

    /* Study links */
    .streak-study-section {
      background: var(--color-surface, #1e293b);
      border: 1.5px solid var(--color-border, #334155);
      border-radius: 14px;
      padding: 22px;
    }
    .streak-study-section h3 { margin: 0 0 8px; }
    .streak-study-intro { color: var(--color-text-muted, #94a3b8); font-size: 14px; margin: 0 0 16px; }
    .streak-chapter-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 10px;
    }
    .streak-chapter-link {
      background: var(--color-background, #0f172a);
      border: 1.5px solid var(--color-border, #334155);
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 500;
      color: var(--color-text, #f1f5f9);
      text-decoration: none;
      transition: border-color .2s, background .2s;
    }
    .streak-chapter-link:hover { border-color: #3b82f6; background: rgba(59,130,246,.08); }

    /* Buttons */
    .streak-mark-section { text-align: center; }
    .streak-btn {
      padding: 12px 28px;
      border-radius: 10px;
      border: none;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity .2s, transform .1s;
    }
    .streak-btn:active { transform: scale(.97); }
    .streak-btn--mark { background: linear-gradient(90deg,#22c55e,#16a34a); color: #fff; width: 100%; max-width: 360px; }
    .streak-btn--danger { background: transparent; border: 1.5px solid #ef4444; color: #ef4444; font-size: 13px; }
    .streak-btn--danger:hover { background: rgba(239,68,68,.08); }
    .streak-mark-note { font-size: 13px; color: var(--color-text-muted, #64748b); margin-top: 10px; min-height: 20px; }

    .streak-danger-section { text-align: center; }

    /* Goals */
    .streak-goals-section {
      background: var(--color-surface, #1e293b);
      border: 1.5px solid var(--color-border, #334155);
      border-radius: 14px; padding: 22px;
    }
    .streak-goals-section h3 { margin: 0 0 8px; }
    .streak-goals-intro { color: var(--color-text-muted, #94a3b8); font-size: 14px; margin: 0 0 16px; }
    .streak-goals-grid { display: flex; flex-direction: column; gap: 10px; }
    .streak-goal-item {
      display: flex; align-items: center; gap: 12px;
      background: var(--color-background, #0f172a);
      border: 1.5px solid var(--color-border, #334155);
      border-radius: 10px; padding: 12px 16px;
      cursor: pointer; transition: border-color .2s, background .2s;
    }
    .streak-goal-item:hover { border-color: #3b82f6; }
    .streak-goal-check { width: 18px; height: 18px; accent-color: #22c55e; cursor: pointer; }
    .streak-goal-check:checked + .streak-goal-text { text-decoration: line-through; color: var(--color-text-muted, #64748b); }
    .streak-goal-text { font-size: 14px; font-weight: 500; }
    .streak-goals-progress {
      margin-top: 14px; text-align: center;
      font-size: 13px; font-weight: 600; color: var(--color-text-muted, #94a3b8);
    }
  </style>

  <script is:inline>
  (function() {
    var STORAGE_KEY = 'infoStudyDays';
    // Use local date (not UTC) to match calendar rendering
    var now = new Date();
    var today = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0') + '-' + String(now.getDate()).padStart(2,'0');

    var currentViewDate = new Date();
    currentViewDate.setDate(1);

    function getDays() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { return []; }
    }
    function saveDays(days) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(days));
    }

    // Mark today as studied (called when visiting this page)
    function markToday() {
      var days = getDays();
      if (!days.includes(today)) {
        days.push(today);
        saveDays(days);
        return true;
      }
      return false;
    }

    function computeStreak(days) {
      if (!days.length) return 0;
      var sorted = days.slice().sort();
      var streak = 0;
      var d = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      while (true) {
        var ds = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
        if (sorted.includes(ds)) {
          streak++;
          d.setDate(d.getDate() - 1);
        } else {
          break;
        }
      }
      return streak;
    }

    function computeLongestStreak(days) {
      if (!days.length) return 0;
      var sorted = days.slice().sort();
      var best = 1, cur = 1;
      for (var i = 1; i < sorted.length; i++) {
        var prevParts = sorted[i-1].split('-');
        var currParts = sorted[i].split('-');
        var prev = new Date(parseInt(prevParts[0]), parseInt(prevParts[1])-1, parseInt(prevParts[2]));
        var curr = new Date(parseInt(currParts[0]), parseInt(currParts[1])-1, parseInt(currParts[2]));
        var diff = (curr - prev) / 86400000;
        if (diff === 1) { cur++; if (cur > best) best = cur; }
        else if (diff > 1) cur = 1;
      }
      return best;
    }

    function countThisMonth(days) {
      var prefix = today.slice(0, 7); // "YYYY-MM"
      return days.filter(function(d) { return d.startsWith(prefix); }).length;
    }

    function renderStats() {
      var days = getDays();
      var streak = computeStreak(days);
      var longest = computeLongestStreak(days);
      document.getElementById('currentStreak').textContent = streak;
      document.getElementById('totalDays').textContent = days.length;
      document.getElementById('longestStreak').textContent = longest;
      document.getElementById('thisMonth').textContent = countThisMonth(days);
    }

    function renderCalendar() {
      var days = getDays();
      var year = currentViewDate.getFullYear();
      var month = currentViewDate.getMonth();
      var monthNames = ['Ianuarie','Februarie','Martie','Aprilie','Mai','Iunie','Iulie','August','Septembrie','Octombrie','Noiembrie','Decembrie'];
      document.getElementById('calendarTitle').textContent = monthNames[month] + ' ' + year;

      var firstDay = new Date(year, month, 1);
      var lastDay  = new Date(year, month + 1, 0);

      // Monday = 0 for grid alignment (JS: 0=Sun, 1=Mon...)
      var startDow = (firstDay.getDay() + 6) % 7; // shift so Mon=0
      var grid = document.getElementById('calendarGrid');
      grid.innerHTML = '';

      // Empty cells before first day
      for (var e = 0; e < startDow; e++) {
        var empty = document.createElement('div');
        empty.className = 'cal-day cal-day--empty';
        grid.appendChild(empty);
      }

      for (var d = 1; d <= lastDay.getDate(); d++) {
        var dateStr = year + '-' + String(month+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
        var cell = document.createElement('div');
        var classes = ['cal-day'];
        if (dateStr === today) classes.push('cal-day--today');
        if (days.includes(dateStr)) classes.push('cal-day--studied');
        if (dateStr > today) classes.push('cal-day--future');
        cell.className = classes.join(' ');
        cell.textContent = d;
        cell.title = dateStr + (days.includes(dateStr) ? ' ✅ Studiat' : '');
        grid.appendChild(cell);
      }
    }

    // Nav
    document.getElementById('btnPrevMonth').addEventListener('click', function() {
      currentViewDate.setMonth(currentViewDate.getMonth() - 1);
      renderCalendar();
    });
    document.getElementById('btnNextMonth').addEventListener('click', function() {
      var next = new Date(currentViewDate);
      next.setMonth(next.getMonth() + 1);
      var now = new Date();
      if (next.getFullYear() > now.getFullYear() || (next.getFullYear() === now.getFullYear() && next.getMonth() > now.getMonth())) return;
      currentViewDate.setMonth(currentViewDate.getMonth() + 1);
      renderCalendar();
    });

    // Mark today button
    document.getElementById('btnMarkToday').addEventListener('click', function() {
      var added = markToday();
      var note = document.getElementById('markNote');
      if (added) {
        note.textContent = '✅ Ziua de azi a fost adăugată la streak-ul tău!';
        note.style.color = '#22c55e';
      } else {
        note.textContent = 'ℹ️ Ziua de azi era deja marcată ca studiată.';
        note.style.color = '#f59e0b';
      }
      renderStats();
      renderCalendar();
    });

    // Reset
    document.getElementById('btnReset').addEventListener('click', function() {
      if (confirm('Ești sigur? Vei pierde tot istoricul de studiu!')) {
        localStorage.removeItem(STORAGE_KEY);
        renderStats();
        renderCalendar();
        document.getElementById('markNote').textContent = 'Istoricul a fost resetat.';
      }
    });

    // Auto-mark today when page loads
    markToday();
    renderStats();
    renderCalendar();

    // Goals system
    var GOALS_KEY = 'infoStudyGoals';
    function getTodayGoals() {
      try {
        var data = JSON.parse(localStorage.getItem(GOALS_KEY) || '{}');
        if (data.date !== today) return {};
        return data.goals || {};
      } catch(e) { return {}; }
    }
    function saveTodayGoals(goals) {
      localStorage.setItem(GOALS_KEY, JSON.stringify({ date: today, goals: goals }));
    }
    function updateGoalsUI() {
      var goals = getTodayGoals();
      var checks = document.querySelectorAll('.streak-goal-check');
      var done = 0;
      checks.forEach(function(ch) {
        var key = ch.dataset.goal;
        if (goals[key]) { ch.checked = true; done++; }
        else ch.checked = false;
      });
      document.getElementById('goalsCount').textContent = done + '/' + checks.length + ' completate azi';
    }
    document.querySelectorAll('.streak-goal-check').forEach(function(ch) {
      ch.addEventListener('change', function() {
        var goals = getTodayGoals();
        goals[ch.dataset.goal] = ch.checked;
        saveTodayGoals(goals);
        updateGoalsUI();
      });
    });
    updateGoalsUI();
  })();
  </script>
</BaseLayout>
