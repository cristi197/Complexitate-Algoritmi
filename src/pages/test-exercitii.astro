    /* All questions scroll view */
    .rw-all-view { max-width: 800px; margin: 0 auto; width: 100%; padding: 20px; }
    .rw-all-card {
      background: var(--surface, #1e293b); border-radius: 16px;
      border: 2px solid rgba(255,255,255,.08); padding: 24px; margin-bottom: 16px;
      scroll-margin-top: 120px;
    }
    .rw-all-card.card-correct { border-color: rgba(34,197,94,.25); }
    .rw-all-card.card-wrong { border-color: rgba(239,68,68,.25); }
    .rw-all-card.card-unanswered { border-color: rgba(100,116,139,.25); }

    /* Visual diagram in explanation */
    .ev-visual-diagram {
      margin-top: 12px; padding: 12px 16px; border-radius: 10px;
      background: rgba(30,41,59,.8); border: 1px solid rgba(255,255,255,.08);
      font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 12px;
      line-height: 1.6; color: #94a3b8; white-space: pre; overflow-x: auto;
    }

    /* Matrix display */
    .ev-matrix { display: inline-block; margin: 8px 4px; vertical-align: middle; }
    .ev-matrix-table {
      border-collapse: collapse; border-left: 2px solid #60a5fa; border-right: 2px solid #60a5fa;
      border-radius: 4px; display: inline-table;
    }
    .ev-matrix-table td {
      padding: 4px 10px; text-align: center; font-family: 'JetBrains Mono', monospace;
      font-size: 13px; color: #e2e8f0; font-weight: 600;
    }
    .ev-matrix-table tr:not(:last-child) td { border-bottom: 1px solid rgba(255,255,255,.06); }

    /* ═══ CUSTOM MODAL ═══ */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(0,0,0,.7); backdrop-filter: blur(6px);
      display: flex; align-items: center; justify-content: center; padding: 20px;
    }
    .modal-card {
      background: var(--surface, #1e293b); border-radius: 20px;
      border: 1.5px solid rgba(255,255,255,.1); padding: 36px;
      max-width: 440px; width: 100%; text-align: center;
      box-shadow: 0 20px 60px rgba(0,0,0,.5); animation: modal-in .25s ease-out;
    }
    @keyframes modal-in { from { opacity: 0; transform: scale(.92) translateY(10px); } to { opacity: 1; transform: none; } }
    .modal-icon { font-size: 40px; margin-bottom: 12px; }
    .modal-title { font-size: 20px; font-weight: 800; color: #e2e8f0; margin: 0 0 8px; }
    .modal-desc { font-size: 14px; color: #94a3b8; margin: 0 0 18px; line-height: 1.5; }
    .modal-stats {
      display: flex; justify-content: center; gap: 20px; margin-bottom: 24px;
      padding: 14px; background: rgba(255,255,255,.03); border-radius: 12px;
      border: 1px solid rgba(255,255,255,.06);
    }
    .modal-stat { text-align: center; }
    .modal-stat-val { font-size: 20px; font-weight: 800; }
    .modal-stat-label { font-size: 10px; color: #64748b; text-transform: uppercase; font-weight: 600; }
    .modal-actions { display: flex; gap: 12px; justify-content: center; }
    .modal-btn {
      padding: 12px 24px; border-radius: 12px; border: none; cursor: pointer;
      font-size: 14px; font-weight: 700; transition: all .2s;
    }
    .modal-btn-cancel { background: rgba(255,255,255,.08); color: #e2e8f0; border: 1.5px solid rgba(255,255,255,.15); }
    .modal-btn-cancel:hover { background: rgba(255,255,255,.12); }
    .modal-btn-confirm { background: linear-gradient(135deg,#f59e0b,#d97706); color: #fff; box-shadow: 0 4px 16px rgba(245,158,11,.3); }
    .modal-btn-confirm:hover { opacity: .88; }

    /* Responsive */
    @media (max-width: 600px) {
      .ev-topbar { padding: 10px 12px; gap: 10px; }
      .ev-timer { font-size: 20px; }
      .ev-main { padding: 16px 12px; }
      .ev-question-card { padding: 20px 16px; }
      .ev-nav-strip { gap: 4px; padding: 8px 12px; }
      .ev-dot { width: 28px; height: 28px; font-size: 10px; }
      .ev-btn { padding: 12px 18px; font-size: 13px; }
      .ev-bottombar { padding: 12px; gap: 8px; }
      .ev-submit-below-btn { padding: 12px 24px; font-size: 13px; }
      .setup-card { border-radius: 14px; }
      .rv-card { padding: 28px 20px; }
      .rw-topbar { flex-wrap: wrap; gap: 8px; }
      .rw-mode-toggle { margin-left: 0; }
    }
  </style>

  <script is:inline>
  (function() {
    /* ── Constants ── */
    var CHAPTERS = [
      { id: 'introducere', label: 'Introducere' },
      { id: 'functii', label: 'Funcții' },
      { id: 'complexitate', label: 'Complexitate' },
      { id: 'recursivitate', label: 'Recursivitate' },
      { id: 'backtracking', label: 'Backtracking' },
      { id: 'vectori', label: 'Vectori' },
      { id: 'matrici', label: 'Matrici' },
      { id: 'siruri', label: 'Șiruri' },
      { id: 'fisiere', label: 'Fișiere' },
      { id: 'programare-dinamica', label: 'Prog. Dinamică' },
      { id: 'structuri', label: 'Structuri' },
      { id: 'pointeri', label: 'Pointeri' },
      { id: 'grafuri', label: 'Grafuri' }
    ];
    var DIFF_LABELS = ['','Facil','Mediu','Dificil'];
    var SUBCAT_LABELS = ['Neorientate','Orientate','Arbori'];

    /* ── State ── */
    var cfg = { chapters: [], subcats: [], diff: 'all', count: 10, timer: 10 };
    var exam = { questions: [], answers: [], current: 0, finished: false, timerInterval: null, timerRemaining: 0, timerTotal: 0 };
    var reviewCurrent = 0;
    var reviewMode = 'single'; // 'single' or 'all'
    var loadedData = {};

    /* ── Setup chips ── */
    function initSetup() {
      // Chapter chips
      document.querySelectorAll('#chapterChips .s-chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.dataset.all) {
            cfg.chapters = [];
            document.querySelectorAll('#chapterChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
          } else {
            document.querySelector('#chapterChips .s-chip-all').classList.remove('active');
            btn.classList.toggle('active');
            var ch = btn.dataset.chapter;
            if (btn.classList.contains('active')) cfg.chapters.push(ch);
            else cfg.chapters = cfg.chapters.filter(function(x) { return x !== ch; });
            if (cfg.chapters.length === 0) document.querySelector('#chapterChips .s-chip-all').classList.add('active');
          }
          document.getElementById('subcatGroup').style.display = cfg.chapters.indexOf('grafuri') !== -1 ? '' : 'none';
        });
      });

      // Subcategory chips (multi-select)
      document.querySelectorAll('#subcatChips .s-chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.dataset.subcat === 'all') {
            cfg.subcats = [];
            document.querySelectorAll('#subcatChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
          } else {
            document.querySelector('#subcatChips [data-subcat="all"]').classList.remove('active');
            btn.classList.toggle('active');
            var val = parseInt(btn.dataset.subcat, 10);
            if (btn.classList.contains('active')) cfg.subcats.push(val);
            else cfg.subcats = cfg.subcats.filter(function(x) { return x !== val; });
            if (cfg.subcats.length === 0) document.querySelector('#subcatChips [data-subcat="all"]').classList.add('active');
          }
        });
      });

      // Difficulty
      document.querySelectorAll('#diffChips .s-chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#diffChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          cfg.diff = btn.dataset.diff;
        });
      });

      // Count
      document.querySelectorAll('#countChips .s-chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#countChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          cfg.count = parseInt(btn.dataset.count, 10);
        });
      });

      // Timer
      document.querySelectorAll('#timerChips .s-chip').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#timerChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          cfg.timer = parseInt(btn.dataset.timer, 10);
        });
      });

      // Apply URL params (from exercitii page)
      applyUrlParams();
    }

    /* ── Read URL params and pre-select chips ── */
    function applyUrlParams() {
      var params = new URLSearchParams(window.location.search);

      // Chapters
      if (params.has('ch')) {
        var chapters = params.get('ch').split(',');
        document.querySelectorAll('#chapterChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
        chapters.forEach(function(ch) {
          var btn = document.querySelector('#chapterChips [data-chapter="' + ch + '"]');
          if (btn) { btn.classList.add('active'); cfg.chapters.push(ch); }
        });
        if (cfg.chapters.length === 0) document.querySelector('#chapterChips .s-chip-all').classList.add('active');
        document.getElementById('subcatGroup').style.display = cfg.chapters.indexOf('grafuri') !== -1 ? '' : 'none';
      }

      // Subcategories
      if (params.has('sub')) {
        var subs = params.get('sub').split(',').map(Number);
        document.querySelectorAll('#subcatChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
        subs.forEach(function(val) {
          var btn = document.querySelector('#subcatChips [data-subcat="' + val + '"]');
          if (btn) { btn.classList.add('active'); cfg.subcats.push(val); }
        });
        if (cfg.subcats.length === 0) document.querySelector('#subcatChips [data-subcat="all"]').classList.add('active');
      }

      // Difficulty
      if (params.has('diff')) {
        var diff = params.get('diff');
        document.querySelectorAll('#diffChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
        var btn = document.querySelector('#diffChips [data-diff="' + diff + '"]');
        if (btn) { btn.classList.add('active'); cfg.diff = diff; }
      }

      // Count
      if (params.has('count')) {
        var count = parseInt(params.get('count'), 10);
        document.querySelectorAll('#countChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
        var btn = document.querySelector('#countChips [data-count="' + count + '"]');
        if (btn) { btn.classList.add('active'); cfg.count = count; }
      }

      // Timer
      if (params.has('timer')) {
        var timer = parseInt(params.get('timer'), 10);
        document.querySelectorAll('#timerChips .s-chip').forEach(function(b) { b.classList.remove('active'); });
        var btn = document.querySelector('#timerChips [data-timer="' + timer + '"]');
        if (btn) { btn.classList.add('active'); cfg.timer = timer; }
      }
    }

    /* ── Data loading ── */
    function loadChapters(ids) {
      var needed = ids.filter(function(id) { return !loadedData[id]; });
      if (!needed.length) return Promise.resolve();
      var loc = window.location;
      var parts = loc.pathname.split('/').filter(Boolean);
      parts.pop();
      var prefix = loc.origin + '/' + parts.join('/') + '/data/exercises/';
      return Promise.all(needed.map(function(id) {
        return fetch(prefix + id + '.json').then(function(r) { return r.json(); }).then(function(json) {
          var arr = Array.isArray(json) ? json : (json.quiz || []);
          loadedData[id] = arr.map(function(q) { return Object.assign({}, q, { _chapter: id }); });
        }).catch(function() { loadedData[id] = []; });
      }));
    }

    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = a[i]; a[i] = a[j]; a[j] = t;
      }
      return a;
    }

    /* ── Start exam ── */
    function startExam() {
      var ids = cfg.chapters.length > 0 ? cfg.chapters : CHAPTERS.map(function(c) { return c.id; });
      document.getElementById('btnStart').disabled = true;
      document.getElementById('btnStart').textContent = 'Se încarcă…';

      loadChapters(ids).then(function() {
        var pool = [];
        ids.forEach(function(id) {
          (loadedData[id] || []).forEach(function(q) {
            if (cfg.diff !== 'all' && q.diff !== parseInt(cfg.diff, 10)) return;
            if (id === 'grafuri' && cfg.subcats.length > 0 && cfg.subcats.indexOf(q.category) === -1) return;
            pool.push(q);
          });
        });
        pool = shuffle(pool).slice(0, Math.min(cfg.count, pool.length));

        if (!pool.length) {
          alert('Nu s-au găsit exerciții cu aceste filtre.');
          document.getElementById('btnStart').disabled = false;
          document.getElementById('btnStart').innerHTML = '<span class="start-icon">▶</span> Începe Testul';
          return;
        }

        exam.questions = pool;
        exam.answers = new Array(pool.length).fill(null);
        exam.current = 0;
        exam.finished = false;
        exam.timerTotal = cfg.timer * 60;
        exam.timerRemaining = exam.timerTotal;

        showView('exam');
        renderDots();
        renderQuestion();
        updateProgress();
        startTimer();
      });
    }

    /* ── View management ── */
    function showView(name) {
      document.getElementById('setupScreen').style.display = name === 'setup' ? '' : 'none';
      document.getElementById('examView').style.display = name === 'exam' ? '' : 'none';
      document.getElementById('resultsView').style.display = name === 'results' ? '' : 'none';
      document.getElementById('reviewView').style.display = name === 'review' ? '' : 'none';
      window.scrollTo(0, 0);
    }

    /* ── Timer ── */
    function startTimer() {
      stopTimer();
      updateTimerDisplay();
      exam.timerInterval = setInterval(function() {
        if (exam.finished) return;
        exam.timerRemaining--;
        updateTimerDisplay();
        if (exam.timerRemaining <= 0) finishExam(true);
      }, 1000);
    }

    function stopTimer() {
      if (exam.timerInterval) { clearInterval(exam.timerInterval); exam.timerInterval = null; }
    }

    function updateTimerDisplay() {
      var m = Math.max(0, Math.floor(exam.timerRemaining / 60));
      var s = Math.max(0, exam.timerRemaining % 60);
      var txt = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
      var el = document.getElementById('evTimer');
      el.textContent = txt;
      var pct = exam.timerTotal > 0 ? exam.timerRemaining / exam.timerTotal : 1;
      el.className = 'ev-timer' + (pct <= 0.1 ? ' danger' : pct <= 0.25 ? ' warning' : '');
    }

    /* ── Dots ── */
    function renderDots() {
      var strip = document.getElementById('evNavStrip');
      strip.innerHTML = '';
      exam.questions.forEach(function(_, i) {
        var d = document.createElement('button');
        d.className = 'ev-dot' + dotClass(i);
        d.textContent = i + 1;
        d.addEventListener('click', function() { exam.current = i; renderDots(); renderQuestion(); });
        strip.appendChild(d);
      });
    }

    function dotClass(i) {
      var cls = '';
      if (i === exam.current) cls += ' current';
      if (exam.answers[i] !== null) cls += ' answered';
      else if (exam.answers[i] === null && i !== exam.current) {
        // Check if it was visited and skipped (we use a separate flag)
      }
      return cls;
    }

    /* ── Text formatting: matrix notation → visual grid ── */
    function formatText(text) {
      if (!text) return text;
      // Detect matrix notation like {{1,2,3},{4,5,6},{7,8,9}} or [[1,2],[3,4]]
      text = text.replace(/\{\{([^}]+(?:\},\{[^}]+)*)\}\}/g, function(match, inner) {
        var rows = inner.split('},{');
        var html = '<div class="ev-matrix"><table class="ev-matrix-table">';
        rows.forEach(function(row) {
          html += '<tr>';
          row.split(',').forEach(function(cell) {
            html += '<td>' + cell.trim() + '</td>';
          });
          html += '</tr>';
        });
        html += '</table></div>';
        return html;
      });
      text = text.replace(/\[\[([^\]]+(?:\],\[[^\]]+)*)\]\]/g, function(match, inner) {
        var rows = inner.split('],[');
        var html = '<div class="ev-matrix"><table class="ev-matrix-table">';
        rows.forEach(function(row) {
          html += '<tr>';
          row.split(',').forEach(function(cell) {
            html += '<td>' + cell.trim() + '</td>';
          });
          html += '</tr>';
        });
        html += '</table></div>';
        return html;
      });
      return text;
    }

    /* ── Question rendering ── */
    function renderQuestion() {
      var q = exam.questions[exam.current];
      var idx = exam.current;
      var chosen = exam.answers[idx];

      var chLabel = q._chapter || '';
      var subcatLabel = (chLabel === 'grafuri' && typeof q.category !== 'undefined') ? SUBCAT_LABELS[q.category] || '' : '';
      var diffLabel = DIFF_LABELS[q.diff] || '';

      var optsHtml = q.opts.map(function(opt, i) {
        var cls = 'ev-option' + (chosen === i ? ' selected' : '');
        return '<div class="' + cls + '" data-i="' + i + '">' +
          '<span class="ev-option-letter">' + String.fromCharCode(65 + i) + '</span>' +
          '<span class="ev-option-text">' + opt + '</span>' +
          '</div>';
      }).join('');

      document.getElementById('evQuestionCard').innerHTML =
        '<div class="ev-q-header">' +
          '<span class="ev-q-num">Întrebarea ' + (idx + 1) + ' / ' + exam.questions.length + '</span>' +
          '<span class="ev-q-badge" style="background:rgba(124,58,237,.12);color:#a78bfa">' + chLabel + '</span>' +
          (subcatLabel ? '<span class="ev-q-badge" style="background:rgba(59,130,246,.12);color:#60a5fa">' + subcatLabel + '</span>' : '') +
          (diffLabel ? '<span class="ev-q-badge" style="background:rgba(251,191,36,.12);color:#fbbf24">' + diffLabel + '</span>' : '') +
        '</div>' +
        '<div class="ev-q-text">' + formatText(q.q) + '</div>' +
        '<div class="ev-q-options">' + optsHtml + '</div>';

      // Bind option clicks
      document.querySelectorAll('#evQuestionCard .ev-option').forEach(function(opt) {
        opt.addEventListener('click', function() {
          exam.answers[idx] = parseInt(opt.dataset.i, 10);
          renderDots();
          renderQuestion();
          updateProgress();
        });
      });

      // Nav buttons
      document.getElementById('evPrev').disabled = idx === 0;
      document.getElementById('evNext').disabled = idx === exam.questions.length - 1;
      document.getElementById('evSkip').style.display = chosen !== null ? 'none' : '';
    }

    function updateProgress() {
      var answered = exam.answers.filter(function(a) { return a !== null; }).length;
      var total = exam.questions.length;
      document.getElementById('evProgress').textContent = answered + ' / ' + total;
      document.getElementById('evProgressFill').style.width = (total > 0 ? (answered / total) * 100 : 0) + '%';

      // Show/hide submit below grid
      var belowEl = document.getElementById('evSubmitBelow');
      if (answered === total && total > 0) {
        belowEl.style.display = '';
      } else {
        belowEl.style.display = 'none';
      }
    }

    /* ── Submit modal ── */
    function showSubmitModal() {
      var answered = exam.answers.filter(function(a) { return a !== null; }).length;
      var total = exam.questions.length;
      var unanswered = total - answered;

      document.getElementById('modalDesc').textContent =
        unanswered > 0
          ? 'Ai răspuns la ' + answered + ' din ' + total + ' întrebări. ' + unanswered + ' rămân nerezolvate.'
          : 'Ai răspuns la toate cele ' + total + ' întrebări.';

      document.getElementById('modalStats').innerHTML =
        '<div class="modal-stat"><div class="modal-stat-val" style="color:#4ade80">' + answered + '</div><div class="modal-stat-label">Rezolvate</div></div>' +
        '<div class="modal-stat"><div class="modal-stat-val" style="color:#fbbf24">' + unanswered + '</div><div class="modal-stat-label">Nerezolvate</div></div>' +
        '<div class="modal-stat"><div class="modal-stat-val" style="color:#e2e8f0">' + formatTime(exam.timerTotal - exam.timerRemaining) + '</div><div class="modal-stat-label">Timp folosit</div></div>';

      document.getElementById('submitModal').style.display = '';
    }

    function hideSubmitModal() {
      document.getElementById('submitModal').style.display = 'none';
    }

    function formatTime(seconds) {
      var m = Math.floor(seconds / 60);
      var s = seconds % 60;
      return m + ':' + (s < 10 ? '0' : '') + s;
    }

    /* ── Finish exam ── */
    function finishExam(timeExpired) {
      exam.finished = true;
      stopTimer();
      hideSubmitModal();

      var correct = 0, answered = 0;
      exam.questions.forEach(function(q, i) {
        if (exam.answers[i] !== null) {
          answered++;
          if (exam.answers[i] === q.ans) correct++;
        }
      });

      var total = exam.questions.length;
      var pct = total > 0 ? Math.round((correct / total) * 100) : 0;
      var emoji = pct >= 90 ? '🏆' : pct >= 70 ? '🎉' : pct >= 50 ? '😊' : '📚';
      var msg = pct >= 90 ? 'Excelent! Ești pregătit/ă pentru orice!'
        : pct >= 70 ? 'Foarte bine! Recapitulează temele unde ai greșit.'
        : pct >= 50 ? 'Bine! Exersează mai mult pe capitolele dificile.'
        : 'Nu te descuraja! Revizuiește teoria și încearcă din nou.';
      var pctClass = pct >= 70 ? 'good' : pct >= 50 ? 'ok' : 'bad';
      var timeUsed = exam.timerTotal - exam.timerRemaining;

      document.getElementById('rvCard').innerHTML =
        '<div class="rv-emoji">' + emoji + '</div>' +
        '<div class="rv-score">' + correct + ' / ' + total + '</div>' +
        '<div class="rv-pct ' + pctClass + '">' + pct + '%</div>' +
        (timeExpired ? '<div class="rv-time-expired">⏰ Timpul a expirat!</div>' : '') +
        '<div class="rv-msg">' + msg + '</div>' +
        '<div class="rv-stats">' +
          '<div class="rv-stat"><div class="rv-stat-val" style="color:#4ade80">' + correct + '</div><div class="rv-stat-label">Corecte</div></div>' +
          '<div class="rv-stat"><div class="rv-stat-val" style="color:#f87171">' + (answered - correct) + '</div><div class="rv-stat-label">Greșite</div></div>' +
          '<div class="rv-stat"><div class="rv-stat-val" style="color:#fbbf24">' + (total - answered) + '</div><div class="rv-stat-label">Nerezolvate</div></div>' +
          '<div class="rv-stat"><div class="rv-stat-val" style="color:#60a5fa">' + formatTime(timeUsed) + '</div><div class="rv-stat-label">Timp</div></div>' +
        '</div>' +
        '<div class="rv-actions">' +
          '<button class="rv-btn rv-btn-review" id="rvReviewBtn">🔍 Revizuiește răspunsurile</button>' +
          '<button class="rv-btn rv-btn-retry" id="rvRetryBtn">🔄 Reia testul</button>' +
          '<button class="rv-btn rv-btn-back" id="rvBackBtn">← Test nou</button>' +
        '</div>';

      showView('results');

      document.getElementById('rvReviewBtn').addEventListener('click', function() { startReview(); });
      document.getElementById('rvRetryBtn').addEventListener('click', function() {
        exam.questions = shuffle(exam.questions);
        exam.answers = new Array(exam.questions.length).fill(null);
        exam.current = 0;
        exam.finished = false;
        exam.timerRemaining = exam.timerTotal;
        showView('exam');
        renderDots();
        renderQuestion();
        updateProgress();
        startTimer();
      });
      document.getElementById('rvBackBtn').addEventListener('click', function() {
        showView('setup');
        document.getElementById('btnStart').disabled = false;
        document.getElementById('btnStart').innerHTML = '<span class="start-icon">▶</span> Începe Testul';
      });
    }

    /* ── Review mode ── */
    function startReview() {
      reviewCurrent = 0;
      reviewMode = 'single';
      showView('review');
      var correct = 0;
      exam.questions.forEach(function(q, i) { if (exam.answers[i] === q.ans) correct++; });
      document.getElementById('rwScore').textContent = correct + ' / ' + exam.questions.length + ' corecte';
      document.getElementById('rwModeSingle').classList.add('active');
      document.getElementById('rwModeAll').classList.remove('active');
      showReviewMode('single');
      renderReviewDots();
      renderReviewQuestion();
    }

    function showReviewMode(mode) {
      reviewMode = mode;
      var singleView = document.getElementById('rwSingleView');
      var singleFooter = document.getElementById('rwSingleFooter');
      var allView = document.getElementById('rwAllView');
      var navStrip = document.getElementById('rwNavStrip');

      if (mode === 'single') {
        singleView.style.display = '';
        singleFooter.style.display = '';
        allView.style.display = 'none';
        navStrip.style.display = '';
        renderReviewDots();
        renderReviewQuestion();
      } else {
        singleView.style.display = 'none';
        singleFooter.style.display = 'none';
        allView.style.display = '';
        navStrip.style.display = '';
        renderReviewAll();
        renderReviewDots();
      }
    }

    function renderReviewAll() {
      var container = document.getElementById('rwAllView');
      var html = '';
      exam.questions.forEach(function(q, i) {
        var chosen = exam.answers[i];
        var isCorrect = chosen === q.ans;
        var wasAnswered = chosen !== null;
        var cardCls = 'rw-all-card' + (!wasAnswered ? ' card-unanswered' : isCorrect ? ' card-correct' : ' card-wrong');

        var chLabel = q._chapter || '';
        var subcatLabel = (chLabel === 'grafuri' && typeof q.category !== 'undefined') ? SUBCAT_LABELS[q.category] || '' : '';
        var diffLabel = DIFF_LABELS[q.diff] || '';

        var optsHtml = q.opts.map(function(opt, oi) {
          var cls = 'ev-option';
          if (oi === q.ans) cls += ' review-correct';
          else if (oi === chosen && chosen !== q.ans) cls += ' review-wrong';
          else cls += ' review-neutral';
          return '<div class="' + cls + '">' +
            '<span class="ev-option-letter">' + String.fromCharCode(65 + oi) + '</span>' +
            '<span class="ev-option-text">' + opt + '</span></div>';
        }).join('');

        var expClass = (!wasAnswered || !isCorrect) ? 'wrong-exp' : 'correct-exp';
        var expIcon = isCorrect ? '✅ Corect!' : (wasAnswered ? '❌ Greșit.' : '⚠️ Nerezolvată.');
        var expText = '';
        if (!isCorrect && wasAnswered) {
          expText = ' Ai ales <strong>' + String.fromCharCode(65 + chosen) + '</strong>, răspunsul corect era <strong>' + String.fromCharCode(65 + q.ans) + '</strong>.';
        } else if (!wasAnswered) {
          expText = ' Răspunsul corect era <strong>' + String.fromCharCode(65 + q.ans) + '</strong>.';
        }

        html += '<div class="' + cardCls + '" id="rw-q-' + i + '">' +
          '<div class="ev-q-header">' +
            '<span class="ev-q-num">Întrebarea ' + (i + 1) + '</span>' +
            '<span class="ev-q-badge" style="background:rgba(124,58,237,.12);color:#a78bfa">' + chLabel + '</span>' +
            (subcatLabel ? '<span class="ev-q-badge" style="background:rgba(59,130,246,.12);color:#60a5fa">' + subcatLabel + '</span>' : '') +
            (diffLabel ? '<span class="ev-q-badge" style="background:rgba(251,191,36,.12);color:#fbbf24">' + diffLabel + '</span>' : '') +
          '</div>' +
          '<div class="ev-q-text">' + formatText(q.q) + '</div>' +
          '<div class="ev-q-options">' + optsHtml + '</div>' +
          '<div class="ev-explanation ' + expClass + '">' + expIcon + expText + (q.exp ? '<br><br>💡 ' + q.exp : '') + '</div>' +
          (!isCorrect ? buildVisualDiagram(q) : '') +
        '</div>';
      });
      container.innerHTML = html;
    }

    function renderReviewDots() {
      var strip = document.getElementById('rwNavStrip');
      strip.innerHTML = '';
      exam.questions.forEach(function(q, i) {
        var d = document.createElement('button');
        var cls = 'ev-dot';
        if (reviewMode === 'single' && i === reviewCurrent) cls += ' current';
        if (exam.answers[i] === null) cls += ' review-unanswered';
        else if (exam.answers[i] === q.ans) cls += ' review-correct';
        else cls += ' review-wrong';
        d.className = cls;
        d.textContent = i + 1;
        d.addEventListener('click', function() {
          if (reviewMode === 'single') {
            reviewCurrent = i; renderReviewDots(); renderReviewQuestion();
          } else {
            var el = document.getElementById('rw-q-' + i);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
        strip.appendChild(d);
      });
    }

    function renderReviewQuestion() {
      var q = exam.questions[reviewCurrent];
      var chosen = exam.answers[reviewCurrent];
      var isCorrect = chosen === q.ans;
      var wasAnswered = chosen !== null;

      var chLabel = q._chapter || '';
      var subcatLabel = (chLabel === 'grafuri' && typeof q.category !== 'undefined') ? SUBCAT_LABELS[q.category] || '' : '';
      var diffLabel = DIFF_LABELS[q.diff] || '';

      var optsHtml = q.opts.map(function(opt, i) {
        var cls = 'ev-option';
        if (i === q.ans) cls += ' review-correct';
        else if (i === chosen && chosen !== q.ans) cls += ' review-wrong';
        else cls += ' review-neutral';
        return '<div class="' + cls + '">' +
          '<span class="ev-option-letter">' + String.fromCharCode(65 + i) + '</span>' +
          '<span class="ev-option-text">' + opt + '</span>' +
          '</div>';
      }).join('');

      var expClass = (!wasAnswered || !isCorrect) ? 'wrong-exp' : 'correct-exp';
      var expIcon = isCorrect ? '✅ Corect!' : (wasAnswered ? '❌ Greșit.' : '⚠️ Nerezolvată.');
      var expText = '';
      if (!isCorrect && wasAnswered) {
        expText = ' Ai ales <strong>' + String.fromCharCode(65 + chosen) + '</strong>, răspunsul corect era <strong>' + String.fromCharCode(65 + q.ans) + '</strong>.';
      } else if (!wasAnswered) {
        expText = ' Răspunsul corect era <strong>' + String.fromCharCode(65 + q.ans) + '</strong>.';
      }

      // Visual diagram for wrong/unanswered answers
      var visualHtml = '';
      if (!isCorrect) {
        visualHtml = buildVisualDiagram(q);
      }

      document.getElementById('rwQuestionCard').innerHTML =
        '<div class="ev-q-header">' +
          '<span class="ev-q-num">Întrebarea ' + (reviewCurrent + 1) + ' / ' + exam.questions.length + '</span>' +
          '<span class="ev-q-badge" style="background:rgba(124,58,237,.12);color:#a78bfa">' + chLabel + '</span>' +
          (subcatLabel ? '<span class="ev-q-badge" style="background:rgba(59,130,246,.12);color:#60a5fa">' + subcatLabel + '</span>' : '') +
          (diffLabel ? '<span class="ev-q-badge" style="background:rgba(251,191,36,.12);color:#fbbf24">' + diffLabel + '</span>' : '') +
        '</div>' +
        '<div class="ev-q-text">' + formatText(q.q) + '</div>' +
        '<div class="ev-q-options">' + optsHtml + '</div>' +
        '<div class="ev-explanation ' + expClass + '">' + expIcon + expText + (q.exp ? '<br><br>💡 ' + q.exp : '') + '</div>' +
        visualHtml;

      document.getElementById('rwPrev').disabled = reviewCurrent === 0;
      document.getElementById('rwNext').disabled = reviewCurrent === exam.questions.length - 1;
    }

    /* ── Visual diagram generator for graph questions ── */
    function buildVisualDiagram(q) {
      var text = (q.q + ' ' + (q.exp || '')).toLowerCase();
      var chapter = q._chapter || '';
      var diagram = '';

      // ═══ GRAFURI ═══
      if (chapter === 'grafuri') {
        if (text.indexOf('matrice') !== -1 && text.indexOf('adiacen') !== -1) {
          diagram = '📊 Matricea de adiacență:\n' +
            '   Graf neorientat → matrice simetrică\n' +
            '        1  2  3  4\n' +
            '   1  [ 0  1  1  0 ]\n' +
            '   2  [ 1  0  0  1 ]   a[i][j] = a[j][i]\n' +
            '   3  [ 1  0  0  1 ]\n' +
            '   4  [ 0  1  1  0 ]\n' +
            '   Spațiu: O(n²) | Grad nod v = Σ linie v';
        } else if (text.indexOf('liste') !== -1 && text.indexOf('adiacen') !== -1) {
          diagram = '📊 Calculul gradelor din liste de adiacență:\n' +
            '   1: {2,3,4,6} → d(1) = 4 (par)\n' +
            '   2: {1,3,5}   → d(2) = 3 (impar)\n' +
            '   ...\n' +
            '   d(v) = |lista[v]| = nr. elemente din listă\n' +
            '   ⚠️ Numără elementele fiecărei liste!';
        } else if (text.indexOf('bfs') !== -1 || text.indexOf('breadth') !== -1) {
          diagram = '📊 BFS (Breadth-First Search):\n' +
            '   Structură: Coadă (FIFO)\n' +
            '   ┌───────────────────────┐\n' +
            '   │  Start → [1]         │\n' +
            '   │  Nivel 1 → [2,3]     │  vizităm nivel cu nivel\n' +
            '   │  Nivel 2 → [4,5,6]   │\n' +
            '   └───────────────────────┘\n' +
            '   Garanție: drum minim (nr. muchii)';
        } else if (text.indexOf('dfs') !== -1 || text.indexOf('depth') !== -1) {
          diagram = '📊 DFS (Depth-First Search):\n' +
            '   Structură: Stivă / Recursie\n' +
            '   1 → 2 → 4 → (backtrack) → 5 → (backtrack)\n' +
            '     → 3 → 6 → ...\n' +
            '   Merge cât mai adânc, apoi revine';
        } else if (text.indexOf('eulerian') !== -1 || text.indexOf('euler') !== -1) {
          diagram = '📊 Condiții Euler (graf conex):\n' +
            '   ┌─────────────────────────────────┐\n' +
            '   │ Ciclu eulerian ⟺ ∀v: d(v) par  │\n' +
            '   │ Lanț eulerian ⟺ exact 2 impare │\n' +
            '   └─────────────────────────────────┘\n' +
            '   Lema: Σd(v) = 2m (nr. noduri impare = par)';
        } else if (text.indexOf('vector') !== -1 && text.indexOf('tați') !== -1) {
          diagram = '📊 Vector de tați - Exemplu:\n' +
            '   nod:    1  2  3  4  5  6  7\n' +
            '   tată:  [4  3  7  6  7  0  6]\n' +
            '   ─────────────────────────────\n' +
            '   Rădăcină: tată[i]=0 → nodul 6\n' +
            '   Frunze: noduri care NU apar ca tată\n' +
            '   Fii[x] = {i | tată[i] = x}';
        } else if (text.indexOf('hamiltonian') !== -1) {
          diagram = '📊 Cicluri/Drumuri:\n' +
            '   Hamiltonian: trece prin FIECARE NOD exact o dată\n' +
            '   Eulerian:    trece prin FIECARE MUCHIE exact o dată\n' +
            '   ⚠️ Ciclu hamiltonian cu n noduri = lungime n';
        } else if (text.indexOf('arbore') !== -1 && (text.indexOf('muchii') !== -1 || text.indexOf('n-1') !== -1 || text.indexOf('n−1') !== -1)) {
          diagram = '📊 Proprietăți arbore:\n' +
            '   • n noduri → exact n-1 muchii\n' +
            '   • Conex + Aciclic\n' +
            '   • Între oricare 2 noduri: unic drum\n' +
            '   • Eliminarea unei muchii → deconectare';
        } else if (text.indexOf('complet') !== -1) {
          diagram = '📊 Graf complet Kₙ:\n' +
            '   Muchii = n(n-1)/2\n' +
            '   K₅: ●───●     5×4/2 = 10 muchii\n' +
            '        |\\×/|    Fiecare nod: grad n-1 = 4\n' +
            '        ●─●─●';
        } else if (text.indexOf('tare conex') !== -1) {
          diagram = '📊 Componente Tare Conexe (SCC):\n' +
            '   Tare conex: ∀u,v ∃ drum u→v ȘI v→u\n' +
            '   ┌───┐     ┌───┐\n' +
            '   │A→B│ ──→ │C↔D│   {A,B,E} și {C,D}\n' +
            '   │↑ ↓│     └───┘   sunt SCC-uri\n' +
            '   │E←─│\n' +
            '   └───┘';
        } else if (text.indexOf('bipartit') !== -1) {
          diagram = '📊 Graf bipartit:\n' +
            '   Set A: ● ● ●     Muchii doar A↔B\n' +
            '           ╲|╱|╲\n' +
            '   Set B:  ● ● ●\n' +
            '   ⟺ Nu conține cicluri de lungime impară';
        } else if (text.indexOf('conex') !== -1 && text.indexOf('component') !== -1) {
          diagram = '📊 Componente conexe:\n' +
            '   Graf fără cicluri cu k componente:\n' +
            '   • Fiecare componentă = arbore\n' +
            '   • Total muchii = n - k\n' +
            '   • n=25, k=5 → muchii = 20';
        } else if (text.indexOf('grad') !== -1 && (text.indexOf('impar') !== -1 || text.indexOf('par') !== -1)) {
          diagram = '📊 Reguli grade:\n' +
            '   • Σd(v) = 2m (lema mânii de mână)\n' +
            '   • Nr. noduri cu grad impar = MEREU PAR\n' +
            '   • Graf complet: d(v) = n-1 pentru ∀v';
        }
      }

      // ═══ MATRICI ═══
      if (chapter === 'matrici') {
        if (text.indexOf('diagonala principal') !== -1) {
          diagram = '📊 Diagonala principală (i == j):\n' +
            '   ┌             ┐\n' +
            '   │ [■] .   .   │  i=0,j=0\n' +
            '   │  .  [■] .   │  i=1,j=1\n' +
            '   │  .   .  [■] │  i=2,j=2\n' +
            '   └             ┘\n' +
            '   n elemente pe diagonala principală';
        } else if (text.indexOf('diagonala secundar') !== -1 || text.indexOf('anti-diagonal') !== -1) {
          diagram = '📊 Diagonala secundară (i + j = n-1):\n' +
            '   ┌             ┐\n' +
            '   │  .   .  [■] │  i=0,j=n-1\n' +
            '   │  .  [■]  .  │  i=1,j=n-2\n' +
            '   │ [■]  .   .  │  i=2,j=0\n' +
            '   └             ┘\n' +
            '   Element: a[i][n-1-i]';
        } else if (text.indexOf('triunghiular') !== -1) {
          diagram = '📊 Matrice triunghiulară superioară:\n' +
            '   ┌             ┐\n' +
            '   │  ■  ■  ■  ■ │  a[i][j] poate fi ≠0 pt i≤j\n' +
            '   │  0  ■  ■  ■ │\n' +
            '   │  0  0  ■  ■ │  a[i][j] = 0 pentru i > j\n' +
            '   │  0  0  0  ■ │\n' +
            '   └             ┘\n' +
            '   Elemente nenule: n(n+1)/2';
        } else if (text.indexOf('transpus') !== -1) {
          diagram = '📊 Transpusa matricei:\n' +
            '   A =  [1 2 3]     Aᵀ = [1 4]\n' +
            '        [4 5 6]          [2 5]\n' +
            '                         [3 6]\n' +
            '   Regulă: Aᵀ[i][j] = A[j][i]\n' +
            '   Liniile devin coloane și invers';
        } else if (text.indexOf('spirală') !== -1 || text.indexOf('spiral') !== -1) {
          diagram = '📊 Parcurgere spirală:\n' +
            '   ┌──────────────→\n' +
            '   │  1   2   3   4  │\n' +
            '   │ 12  13  14   5  ↓\n' +
            '   ↑ 11  16  15   6  │\n' +
            '   │ 10   9   8   7  │\n' +
            '   ←──────────────┘\n' +
            '   Straturi: ⌈n/2⌉';
        } else if (text.indexOf('prefix') !== -1 && text.indexOf('2d') !== -1) {
          diagram = '📊 Prefix Sum 2D:\n' +
            '   prefix[i][j] = a[i][j]\n' +
            '     + prefix[i-1][j]\n' +
            '     + prefix[i][j-1]\n' +
            '     - prefix[i-1][j-1]  (incluzie-excludere)\n' +
            '   \n' +
            '   Suma submatrice (r1,c1)→(r2,c2) în O(1)';
        } else if (text.indexOf('rotir') !== -1 && text.indexOf('90') !== -1) {
          diagram = '📊 Rotire 90° sens orar:\n' +
            '   [1 2 3]      [7 4 1]\n' +
            '   [4 5 6]  →   [8 5 2]\n' +
            '   [7 8 9]      [9 6 3]\n' +
            '   Formula: new[i][j] = old[n-1-j][i]';
        } else if (text.indexOf('simetr') !== -1) {
          diagram = '📊 Matrice simetrică:\n' +
            '   a[i][j] = a[j][i]\n' +
            '   ┌         ┐\n' +
            '   │ 1  2  3 │  A = Aᵀ\n' +
            '   │ 2  5  4 │\n' +
            '   │ 3  4  9 │\n' +
            '   └         ┘';
        } else if (text.indexOf('înmulți') !== -1 && text.indexOf('matric') !== -1) {
          diagram = '📊 Înmulțirea matricelor:\n' +
            '   A(m×n) × B(n×p) = C(m×p)\n' +
            '   C[i][j] = Σ A[i][k]*B[k][j], k=0..n-1\n' +
            '   Complexitate naivă: O(m*n*p)\n' +
            '   Pătrate n×n: O(n³)';
        }
      }

      // ═══ SIRURI ═══
      if (chapter === 'siruri') {
        if (text.indexOf('strcpy') !== -1 || text.indexOf('strcat') !== -1) {
          diagram = '📊 Operații pe șiruri C-style:\n' +
            '   strcpy(d,s):  d ← s (tot, cu \\0)\n' +
            '   strcat(d,s):  d ← d + s (concatenare)\n' +
            '   strncpy(d,s,n): d ← primele n din s\n' +
            '   ⚠️ Indexare: s+2 → pointer de la poz. 2';
        } else if (text.indexOf('strlen') !== -1 && text.indexOf('palindrom') !== -1) {
          diagram = '📊 Verificare palindrom:\n' +
            '   s = "a b c b a"\n' +
            '        ↑       ↑   s[0]==s[4] ✓\n' +
            '          ↑   ↑     s[1]==s[3] ✓\n' +
            '            ↑       mijloc - OK\n' +
            '   Condiție: s[i] == s[n-1-i], ∀i < n/2';
        } else if (text.indexOf('ascii') !== -1 || text.indexOf('majuscul') !== -1 || text.indexOf('minuscul') !== -1) {
          diagram = '📊 Coduri ASCII importante:\n' +
            '   \'0\' = 48   \'9\' = 57\n' +
            '   \'A\' = 65   \'Z\' = 90\n' +
            '   \'a\' = 97   \'z\' = 122\n' +
            '   Conversie: majusculă + 32 = minusculă';
        } else if (text.indexOf('strcmp') !== -1) {
          diagram = '📊 strcmp(s1, s2):\n' +
            '   Returnează: <0 dacă s1 < s2\n' +
            '                0 dacă s1 == s2\n' +
            '               >0 dacă s1 > s2\n' +
            '   Comparare caracter cu caracter (ASCII)';
        } else if (text.indexOf('strtok') !== -1 || text.indexOf('cuvinte') !== -1) {
          diagram = '📊 Tokenizare șir:\n' +
            '   "ana are mere" + delim=" "\n' +
            '   → token1: "ana"\n' +
            '   → token2: "are"\n' +
            '   → token3: "mere"\n' +
            '   Nr. cuvinte ≈ nr. spații + 1';
        }
      }

      if (!diagram) return '';
      return '<div class="ev-visual-diagram">' + diagram + '</div>';
    }

    /* ── Init ── */
    document.addEventListener('DOMContentLoaded', function() {
      initSetup();

      // Start button
      document.getElementById('btnStart').addEventListener('click', startExam);

      // Back button in exam view
      document.getElementById('evBackBtn').addEventListener('click', function() {
        if (confirm('Ești sigur? Vei pierde progresul testului curent.')) {
          stopTimer();
          showView('setup');
          document.getElementById('btnStart').disabled = false;
          document.getElementById('btnStart').innerHTML = '<span class="start-icon">▶</span> Începe Testul';
        }
      });

      // Exam navigation
      document.getElementById('evPrev').addEventListener('click', function() {
        if (exam.current > 0) { exam.current--; renderDots(); renderQuestion(); }
      });
      document.getElementById('evNext').addEventListener('click', function() {
        if (exam.current < exam.questions.length - 1) { exam.current++; renderDots(); renderQuestion(); }
      });
      document.getElementById('evSkip').addEventListener('click', function() {
        // Find next unanswered
        var next = -1;
        for (var i = exam.current + 1; i < exam.questions.length; i++) { if (exam.answers[i] === null) { next = i; break; } }
        if (next === -1) { for (var j = 0; j < exam.current; j++) { if (exam.answers[j] === null) { next = j; break; } } }
        if (next === -1 && exam.current < exam.questions.length - 1) next = exam.current + 1;
        if (next !== -1) { exam.current = next; renderDots(); renderQuestion(); }
      });

      // Submit buttons → custom modal
      document.getElementById('evSubmitTopBtn').addEventListener('click', showSubmitModal);
      document.getElementById('evSubmitBelowBtn').addEventListener('click', showSubmitModal);
      document.getElementById('modalCancel').addEventListener('click', hideSubmitModal);
      document.getElementById('modalConfirm').addEventListener('click', function() { finishExam(false); });

      // Close modal on overlay click
      document.getElementById('submitModal').addEventListener('click', function(e) {
        if (e.target === this) hideSubmitModal();
      });

      // Review navigation
      document.getElementById('rwPrev').addEventListener('click', function() {
        if (reviewCurrent > 0) { reviewCurrent--; renderReviewDots(); renderReviewQuestion(); }
      });
      document.getElementById('rwNext').addEventListener('click', function() {
        if (reviewCurrent < exam.questions.length - 1) { reviewCurrent++; renderReviewDots(); renderReviewQuestion(); }
      });
      document.getElementById('rwBackBtn').addEventListener('click', function() { showView('results'); });

      // Review mode toggle
      document.getElementById('rwModeSingle').addEventListener('click', function() {
        document.getElementById('rwModeSingle').classList.add('active');
        document.getElementById('rwModeAll').classList.remove('active');
        showReviewMode('single');
      });
      document.getElementById('rwModeAll').addEventListener('click', function() {
        document.getElementById('rwModeAll').classList.add('active');
        document.getElementById('rwModeSingle').classList.remove('active');
        showReviewMode('all');
      });

      // Keyboard shortcuts
      document.addEventListener('keydown', function(e) {
        if (document.getElementById('submitModal').style.display !== 'none') {
          if (e.key === 'Escape') hideSubmitModal();
          return;
        }
        var examVisible = document.getElementById('examView').style.display !== 'none';
        var reviewVisible = document.getElementById('reviewView').style.display !== 'none';
        if (examVisible) {
          if (e.key === 'ArrowLeft') { document.getElementById('evPrev').click(); }
          else if (e.key === 'ArrowRight') { document.getElementById('evNext').click(); }
          else if (e.key >= '1' && e.key <= '4') {
            var optIdx = parseInt(e.key, 10) - 1;
            if (optIdx < exam.questions[exam.current].opts.length) {
              exam.answers[exam.current] = optIdx;
              renderDots(); renderQuestion(); updateProgress();
            }
          }
        }
        if (reviewVisible) {
          if (e.key === 'ArrowLeft') { document.getElementById('rwPrev').click(); }
          else if (e.key === 'ArrowRight') { document.getElementById('rwNext').click(); }
        }
      });
    });
  })();
  </script>
</BaseLayout>
