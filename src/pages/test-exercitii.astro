---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const chapters = [
  { id: 'introducere',   label: 'Introducere',    color: 'blue'   },
  { id: 'functii',       label: 'Funcții',        color: 'blue'   },
  { id: 'complexitate',  label: 'Complexitate',   color: 'teal'   },
  { id: 'recursivitate', label: 'Recursivitate',  color: 'green'  },
  { id: 'backtracking',  label: 'Backtracking',   color: 'purple' },
  { id: 'vectori',       label: 'Vectori',        color: 'orange' },
  { id: 'matrici',       label: 'Matrici',        color: 'teal'   },
  { id: 'siruri',        label: 'Șiruri',         color: 'red'    },
  { id: 'fisiere',       label: 'Fișiere',        color: 'pink'   },
  { id: 'programare-dinamica', label: 'Prog. Dinamică', color: 'teal' },
  { id: 'structuri',     label: 'Structuri',      color: 'purple' },
  { id: 'pointeri',      label: 'Pointeri',       color: 'green'  },
  { id: 'grafuri',       label: 'Grafuri',        color: 'purple' },
];
---
<BaseLayout title="Test Exerciții — Mod Examen" description="Simulare test cronometrat cu exerciții de informatică." bodyClass="test-page-body">

  <div class="test-page">

    <!-- ═══════════ SETUP SCREEN ═══════════ -->
    <div id="setupScreen" class="setup-screen">
      <div class="setup-card">
        <div class="setup-header">
          <a href={`${base}/exercitii`} class="setup-back">← Înapoi la exerciții</a>
          <div class="setup-icon">🎯</div>
          <h1>Test — Mod Examen</h1>
          <p>Configurează testul, apoi rezolvă-l exact ca la un examen real. Timp limitat, navigare liberă, predare la final.</p>
        </div>

        <div class="setup-body">
          <!-- Chapters -->
          <div class="setup-group">
            <label class="setup-label">📚 Capitole</label>
            <div class="setup-chips" id="chapterChips">
              <button class="s-chip s-chip-all active" data-all="true">Toate</button>
              {chapters.map(ch => (
                <button class={`s-chip s-chip-${ch.color}`} data-chapter={ch.id}>{ch.label}</button>
              ))}
            </div>
          </div>

          <!-- Subcategories (grafuri) -->
          <div class="setup-group" id="subcatGroup" style="display:none">
            <label class="setup-label">🔀 Subcategorii Grafuri</label>
            <div class="setup-chips" id="subcatChips">
              <button class="s-chip s-chip-subcat active" data-subcat="all">Toate (mix)</button>
              <button class="s-chip s-chip-subcat" data-subcat="0">Neorientate</button>
              <button class="s-chip s-chip-subcat" data-subcat="1">Orientate</button>
              <button class="s-chip s-chip-subcat" data-subcat="2">Arbori</button>
            </div>
          </div>

          <!-- Difficulty -->
          <div class="setup-group">
            <label class="setup-label">🎯 Dificultate</label>
            <div class="setup-chips" id="diffChips">
              <button class="s-chip active" data-diff="all">Toate</button>
              <button class="s-chip s-chip-facil" data-diff="1">Facil</button>
              <button class="s-chip s-chip-mediu" data-diff="2">Mediu</button>
              <button class="s-chip s-chip-dificil" data-diff="3">Dificil</button>
            </div>
          </div>

          <!-- Count -->
          <div class="setup-group">
            <label class="setup-label">🔢 Număr întrebări</label>
            <div class="setup-chips" id="countChips">
              <button class="s-chip" data-count="5">5</button>
              <button class="s-chip active" data-count="10">10</button>
              <button class="s-chip" data-count="15">15</button>
              <button class="s-chip" data-count="20">20</button>
              <button class="s-chip" data-count="30">30</button>
              <button class="s-chip" data-count="50">50</button>
            </div>
          </div>

          <!-- Timer -->
          <div class="setup-group">
            <label class="setup-label">⏱️ Timp</label>
            <div class="setup-chips" id="timerChips">
              <button class="s-chip" data-timer="5">5 min</button>
              <button class="s-chip active" data-timer="10">10 min</button>
              <button class="s-chip" data-timer="15">15 min</button>
              <button class="s-chip" data-timer="20">20 min</button>
              <button class="s-chip" data-timer="30">30 min</button>
              <button class="s-chip" data-timer="45">45 min</button>
              <button class="s-chip" data-timer="60">60 min</button>
            </div>
          </div>

          <button id="btnStart" class="setup-start-btn">
            <span class="start-icon">▶</span> Începe Testul
          </button>
        </div>
      </div>
    </div>

    <!-- ═══════════ EXAM INTERFACE ═══════════ -->
    <div id="examView" class="exam-view" style="display:none">

      <!-- Sticky top bar -->
      <header class="ev-topbar">
        <button id="evBackBtn" class="ev-back-btn" title="Înapoi la meniu">✕</button>
        <div class="ev-topbar-left">
          <span class="ev-timer-icon">⏱️</span>
          <span id="evTimer" class="ev-timer">00:00</span>
        </div>
        <div class="ev-topbar-center">
          <span id="evProgress" class="ev-progress-label">0 / 0</span>
          <div class="ev-progress-bar"><div id="evProgressFill" class="ev-progress-fill"></div></div>
        </div>
        <div class="ev-topbar-right">
          <button id="evSubmitTopBtn" class="ev-submit-btn">✅ Predă</button>
        </div>
      </header>

      <!-- Question navigator (dots) -->
      <nav class="ev-nav-strip" id="evNavStrip"></nav>

      <!-- Submit button below grid (appears when all answered) -->
      <div id="evSubmitBelow" class="ev-submit-below" style="display:none">
        <button id="evSubmitBelowBtn" class="ev-submit-below-btn">✅ Predă testul — Toate întrebările completate!</button>
      </div>

      <!-- Question display -->
      <main class="ev-main">
        <div class="ev-question-card" id="evQuestionCard"></div>
      </main>

      <!-- Bottom navigation -->
      <footer class="ev-bottombar">
        <button id="evPrev" class="ev-btn ev-btn-prev">⬅ Precedenta</button>
        <button id="evSkip" class="ev-btn ev-btn-skip">⏭ Sari peste</button>
        <button id="evNext" class="ev-btn ev-btn-next">Următoarea ➡</button>
      </footer>
    </div>

    <!-- ═══════════ RESULTS SCREEN ═══════════ -->
    <div id="resultsView" class="results-view" style="display:none">
      <div class="rv-card" id="rvCard"></div>
    </div>

    <!-- ═══════════ REVIEW MODE ═══════════ -->
    <div id="reviewView" class="review-view" style="display:none">
      <header class="rw-topbar">
        <button id="rwBackBtn" class="ev-back-btn" title="Înapoi la rezultate">✕</button>
        <span class="rw-title">🔍 Revizuire Test</span>
        <span id="rwScore" class="rw-score"></span>
        <div class="rw-mode-toggle">
          <button id="rwModeSingle" class="rw-mode-btn active">Câte una</button>
          <button id="rwModeAll" class="rw-mode-btn">Toate</button>
        </div>
      </header>
      <nav class="ev-nav-strip" id="rwNavStrip"></nav>
      <!-- Single question mode -->
      <main class="ev-main" id="rwSingleView">
        <div class="ev-question-card" id="rwQuestionCard"></div>
      </main>
      <footer class="ev-bottombar" id="rwSingleFooter">
        <button id="rwPrev" class="ev-btn ev-btn-prev">⬅ Precedenta</button>
        <button id="rwNext" class="ev-btn ev-btn-next">Următoarea ➡</button>
      </footer>
      <!-- All questions scroll mode -->
      <main class="ev-main rw-all-view" id="rwAllView" style="display:none"></main>
    </div>

    <!-- ═══════════ CUSTOM MODAL ═══════════ -->
    <div id="submitModal" class="modal-overlay" style="display:none">
      <div class="modal-card">
        <div class="modal-icon">📋</div>
        <h2 class="modal-title">Predai testul?</h2>
        <p class="modal-desc" id="modalDesc">Ai răspuns la X din Y întrebări.</p>
        <div class="modal-stats" id="modalStats"></div>
        <div class="modal-actions">
          <button id="modalCancel" class="modal-btn modal-btn-cancel">← Continuă testul</button>
          <button id="modalConfirm" class="modal-btn modal-btn-confirm">✅ Predă definitiv</button>
        </div>
      </div>
    </div>

  </div><!-- /test-page -->

  <style is:inline>
    .test-page-body { overflow-x: hidden; }
    .test-page { min-height: 100vh; }

    /* ═══ SETUP SCREEN ═══ */
    .setup-screen {
      display: flex; justify-content: center; align-items: flex-start;
      padding: 40px 20px; min-height: 100vh;
    }
    .setup-card {
      width: 100%; max-width: 720px;
      background: var(--surface, #1e293b); border-radius: 20px;
      border: 1.5px solid rgba(255,255,255,.08);
      overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,.3);
    }
    .setup-header {
      text-align: center; padding: 36px 28px 24px;
      background: linear-gradient(135deg, #1e3a5f 0%, #1d4ed8 50%, #7c3aed 100%);
      color: #fff;
    }
    .setup-back {
      position: absolute; top: 16px; left: 20px;
      color: rgba(255,255,255,.7); text-decoration: none; font-size: 13px; font-weight: 600;
    }
    .setup-header { position: relative; }
    .setup-icon { font-size: 40px; margin-bottom: 10px; }
    .setup-header h1 { margin: 0 0 8px; font-size: 1.6rem; font-weight: 800; }
    .setup-header p { margin: 0; opacity: .85; font-size: 14px; max-width: 500px; margin: 0 auto; line-height: 1.5; }
    .setup-body { padding: 28px; }
    .setup-group { margin-bottom: 22px; }
    .setup-label { display: block; font-size: 12px; font-weight: 700; color: var(--text-muted, #94a3b8); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 10px; }
    .setup-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .s-chip {
      padding: 7px 16px; border-radius: 999px; border: 1.5px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.05); color: #94a3b8; cursor: pointer;
      font-size: 13px; font-weight: 600; transition: all .18s; white-space: nowrap;
    }
    .s-chip:hover { background: rgba(255,255,255,.1); }
    .s-chip.active { border-color: transparent; color: #fff; background: linear-gradient(135deg,#1d4ed8,#7c3aed); }
    .s-chip-all.active { background: linear-gradient(135deg,#1d4ed8,#7c3aed); }
    .s-chip-blue.active { background: #1d4ed8; }
    .s-chip-teal.active { background: #0d9488; }
    .s-chip-green.active { background: #16a34a; }
    .s-chip-purple.active { background: #7c3aed; }
    .s-chip-orange.active { background: #c2410c; }
    .s-chip-red.active { background: #dc2626; }
    .s-chip-pink.active { background: #db2777; }
    .s-chip-facil.active { background: #16a34a; }
    .s-chip-mediu.active { background: #d97706; }
    .s-chip-dificil.active { background: #dc2626; }
    .s-chip-subcat.active { background: linear-gradient(135deg,#7c3aed,#a855f7); }

    .setup-start-btn {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      width: 100%; padding: 16px; margin-top: 28px; border: none; border-radius: 14px;
      background: linear-gradient(135deg,#16a34a,#22c55e); color: #fff;
      font-size: 17px; font-weight: 800; cursor: pointer; transition: opacity .2s;
      box-shadow: 0 4px 20px rgba(34,197,94,.3);
    }
    .setup-start-btn:hover { opacity: .9; }
    .start-icon { font-size: 20px; }

    /* ═══ EXAM VIEW ═══ */
    .exam-view { display: flex; flex-direction: column; min-height: 100vh; }

    .ev-topbar {
      position: sticky; top: 0; z-index: 100;
      background: var(--surface, #1e293b); border-bottom: 2px solid rgba(255,255,255,.06);
      display: flex; align-items: center; gap: 16px; padding: 12px 20px;
      box-shadow: 0 4px 24px rgba(0,0,0,.4); backdrop-filter: blur(12px);
    }
    .ev-back-btn {
      width: 36px; height: 36px; border-radius: 10px; border: 2px solid rgba(239,68,68,.4);
      background: rgba(239,68,68,.08); color: #f87171; cursor: pointer;
      font-size: 18px; font-weight: 800; display: flex; align-items: center; justify-content: center;
      transition: all .2s; flex-shrink: 0;
    }
    .ev-back-btn:hover { background: rgba(239,68,68,.2); border-color: #ef4444; transform: scale(1.05); }
    .ev-topbar-left { display: flex; align-items: center; gap: 8px; }
    .ev-timer-icon { font-size: 18px; }
    .ev-timer {
      font-size: 26px; font-weight: 800; font-family: 'JetBrains Mono', monospace;
      color: #22c55e; min-width: 75px; letter-spacing: 1px;
    }
    .ev-timer.warning { color: #f59e0b; }
    .ev-timer.danger { color: #ef4444; animation: ev-pulse 1s infinite; }
    @keyframes ev-pulse { 0%,100% { opacity:1; } 50% { opacity:.5; } }

    .ev-topbar-center { flex: 1; display: flex; align-items: center; gap: 12px; min-width: 0; }
    .ev-progress-label { font-size: 13px; font-weight: 700; color: #e2e8f0; white-space: nowrap; }
    .ev-progress-bar { flex: 1; height: 8px; border-radius: 4px; background: rgba(255,255,255,.08); overflow: hidden; }
    .ev-progress-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg,#22c55e,#16a34a); transition: width .3s; width: 0; }

    .ev-topbar-right { display: flex; }
    .ev-submit-btn {
      padding: 9px 22px; border-radius: 10px; border: none; cursor: pointer;
      background: linear-gradient(135deg,#f59e0b,#d97706); color: #fff;
      font-size: 13px; font-weight: 700; transition: opacity .2s;
    }
    .ev-submit-btn:hover { opacity: .85; }

    /* Submit below grid */
    .ev-submit-below {
      padding: 10px 20px; display: flex; justify-content: center;
      background: rgba(34,197,94,.04); border-bottom: 1px solid rgba(34,197,94,.15);
      animation: submit-glow .6s ease-out;
    }
    @keyframes submit-glow { from { background: rgba(34,197,94,.15); } to { background: rgba(34,197,94,.04); } }
    .ev-submit-below-btn {
      padding: 14px 36px; border-radius: 12px; border: 2px solid rgba(34,197,94,.4);
      background: linear-gradient(135deg,#16a34a,#22c55e); color: #fff;
      font-size: 15px; font-weight: 800; cursor: pointer; transition: all .2s;
      box-shadow: 0 4px 20px rgba(34,197,94,.3); letter-spacing: .02em;
    }
    .ev-submit-below-btn:hover { opacity: .9; transform: translateY(-1px); box-shadow: 0 6px 28px rgba(34,197,94,.4); }

    /* Nav strip */
    .ev-nav-strip {
      display: flex; flex-wrap: wrap; gap: 5px; padding: 12px 20px;
      background: var(--surface, #1e293b); border-bottom: 1px solid rgba(255,255,255,.04);
      justify-content: center;
    }
    .ev-dot {
      width: 34px; height: 34px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,.1);
      background: rgba(255,255,255,.03); color: #64748b; cursor: pointer;
      font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center;
      transition: all .15s; position: relative;
    }
    .ev-dot:hover { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.2); }
    .ev-dot.current { background: #1d4ed8; border-color: #3b82f6; color: #fff; box-shadow: 0 0 12px rgba(59,130,246,.5); transform: scale(1.1); }
    .ev-dot.answered { background: rgba(34,197,94,.12); border-color: rgba(34,197,94,.4); color: #4ade80; }
    .ev-dot.skipped { background: rgba(251,191,36,.08); border-color: rgba(251,191,36,.3); color: #fbbf24; }
    /* Review colors */
    .ev-dot.review-correct { background: rgba(34,197,94,.2); border-color: #22c55e; color: #fff; }
    .ev-dot.review-wrong { background: rgba(239,68,68,.2); border-color: #ef4444; color: #fff; }
    .ev-dot.review-unanswered { background: rgba(100,116,139,.15); border-color: #475569; color: #94a3b8; }

    /* Main */
    .ev-main { flex: 1; padding: 24px 20px; max-width: 800px; margin: 0 auto; width: 100%; }
    .ev-question-card {
      background: var(--surface, #1e293b); border-radius: 18px;
      border: 1.5px solid rgba(255,255,255,.08); padding: 28px; min-height: 250px;
      box-shadow: 0 4px 24px rgba(0,0,0,.15);
    }

    .ev-q-header { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }
    .ev-q-num { font-size: 14px; font-weight: 800; color: #3b82f6; }
    .ev-q-badge { font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 6px; text-transform: uppercase; letter-spacing: .03em; }
    .ev-q-text { font-size: 16px; font-weight: 600; color: #e2e8f0; line-height: 1.65; margin-bottom: 22px; }

    .ev-q-options { display: flex; flex-direction: column; gap: 10px; }
    .ev-option {
      display: flex; align-items: flex-start; gap: 14px; padding: 14px 18px;
      border-radius: 12px; border: 2px solid rgba(255,255,255,.08);
      background: rgba(255,255,255,.02); cursor: pointer; transition: all .2s;
    }
    .ev-option:hover { background: rgba(59,130,246,.05); border-color: rgba(59,130,246,.2); }
    .ev-option.selected { background: rgba(59,130,246,.1); border-color: #3b82f6; }
    .ev-option.review-correct { background: rgba(34,197,94,.1); border-color: #22c55e; cursor: default; }
    .ev-option.review-wrong { background: rgba(239,68,68,.08); border-color: #ef4444; cursor: default; }
    .ev-option.review-neutral { opacity: .5; cursor: default; }

    .ev-option-letter {
      width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center;
      background: rgba(255,255,255,.07); color: #e2e8f0; font-size: 13px; font-weight: 800; flex-shrink: 0;
    }
    .ev-option.selected .ev-option-letter { background: #1d4ed8; color: #fff; }
    .ev-option.review-correct .ev-option-letter { background: #16a34a; color: #fff; }
    .ev-option.review-wrong .ev-option-letter { background: #dc2626; color: #fff; }
    .ev-option-text { font-size: 14px; color: #cbd5e1; line-height: 1.55; padding-top: 4px; }

    /* Explanation in review */
    .ev-explanation {
      margin-top: 18px; padding: 14px 18px; border-radius: 12px; font-size: 13px; line-height: 1.6;
    }
    .ev-explanation.correct-exp {
      background: rgba(34,197,94,.06); border: 1.5px solid rgba(34,197,94,.2); color: #4ade80;
    }
    .ev-explanation.wrong-exp {
      background: rgba(239,68,68,.06); border: 1.5px solid rgba(239,68,68,.2); color: #f87171;
    }

    /* Bottom bar */
    .ev-bottombar {
      position: sticky; bottom: 0;
      display: flex; justify-content: space-between; align-items: center; gap: 12px;
      padding: 16px 20px; background: var(--surface, #1e293b);
      border-top: 2px solid rgba(255,255,255,.08);
      box-shadow: 0 -4px 24px rgba(0,0,0,.3);
    }
    .ev-btn {
      padding: 14px 28px; border-radius: 12px; border: 2px solid rgba(255,255,255,.15);
      background: rgba(255,255,255,.06); color: #e2e8f0; cursor: pointer;
      font-size: 15px; font-weight: 700; transition: all .2s;
    }
    .ev-btn:hover { background: rgba(255,255,255,.12); transform: translateY(-1px); }
    .ev-btn:disabled { opacity: .25; cursor: not-allowed; transform: none; }
    .ev-btn-prev { border-color: rgba(148,163,184,.3); color: #cbd5e1; }
    .ev-btn-prev:hover { background: rgba(148,163,184,.1); border-color: rgba(148,163,184,.5); }
    .ev-btn-skip { border-color: rgba(251,191,36,.4); color: #fbbf24; background: rgba(251,191,36,.06); }
    .ev-btn-skip:hover { background: rgba(251,191,36,.15); border-color: rgba(251,191,36,.6); }
    .ev-btn-next { border-color: rgba(59,130,246,.4); color: #60a5fa; background: rgba(59,130,246,.06); }
    .ev-btn-next:hover { background: rgba(59,130,246,.15); border-color: rgba(59,130,246,.6); }

    /* ═══ RESULTS VIEW ═══ */
    .results-view { display: flex; justify-content: center; padding: 48px 20px; min-height: 100vh; align-items: flex-start; }
    .rv-card {
      max-width: 600px; width: 100%; background: var(--surface, #1e293b);
      border-radius: 20px; border: 1.5px solid rgba(255,255,255,.08);
      padding: 40px 36px; text-align: center; box-shadow: 0 8px 40px rgba(0,0,0,.3);
    }
    .rv-emoji { font-size: 56px; margin-bottom: 12px; }
    .rv-score { font-size: 42px; font-weight: 800; color: #e2e8f0; }
    .rv-pct { font-size: 22px; font-weight: 700; margin-top: 4px; }
    .rv-pct.good { color: #22c55e; }
    .rv-pct.ok { color: #f59e0b; }
    .rv-pct.bad { color: #ef4444; }
    .rv-msg { font-size: 15px; color: #94a3b8; margin-top: 14px; line-height: 1.6; }
    .rv-time-expired { color: #ef4444; font-size: 14px; font-weight: 600; margin-top: 8px; }
    .rv-stats { display: flex; justify-content: center; gap: 28px; margin-top: 24px; flex-wrap: wrap; }
    .rv-stat { text-align: center; }
    .rv-stat-val { font-size: 24px; font-weight: 800; }
    .rv-stat-label { font-size: 11px; color: #64748b; text-transform: uppercase; font-weight: 600; margin-top: 2px; }
    .rv-actions { display: flex; gap: 12px; justify-content: center; margin-top: 32px; flex-wrap: wrap; }
    .rv-btn {
      padding: 12px 28px; border-radius: 12px; border: none; cursor: pointer;
      font-size: 14px; font-weight: 700; transition: opacity .2s;
    }
    .rv-btn:hover { opacity: .85; }
    .rv-btn-review { background: linear-gradient(135deg,#1d4ed8,#7c3aed); color: #fff; }
    .rv-btn-retry { background: linear-gradient(135deg,#16a34a,#22c55e); color: #fff; }
    .rv-btn-back { background: rgba(255,255,255,.08); color: #e2e8f0; border: 1.5px solid rgba(255,255,255,.15); }

    /* ═══ REVIEW VIEW ═══ */
    .review-view { display: flex; flex-direction: column; min-height: 100vh; }
    .rw-topbar {
      position: sticky; top: 0; z-index: 100;
      background: var(--surface, #1e293b); border-bottom: 2px solid rgba(255,255,255,.06);
      display: flex; align-items: center; gap: 16px; padding: 12px 20px;
