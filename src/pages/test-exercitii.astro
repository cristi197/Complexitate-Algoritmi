    .rw-mode-btn {
      padding: 6px 14px; border-radius: 6px; border: none; cursor: pointer;
      font-size: 12px; font-weight: 700; color: #94a3b8; background: transparent; transition: all .2s;
    }
    .rw-mode-btn.active { background: #1d4ed8; color: #fff; }
