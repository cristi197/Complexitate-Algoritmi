---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const algorithms = [
  {
    id: 'bubble-sort',
    name: 'Bubble Sort',
    description: 'Sortare prin interschimbare repetată de elemente adiacente. O(n²).',
    category: 'Sortare',
    vars: ['v', 'n', 'i', 'j', 'aux', 'ok'],
    steps: [] // generated by JS
  },
  {
    id: 'cautare-liniara',
    name: 'Căutare liniară',
    description: 'Caută un element x în vector. O(n).',
    category: 'Căutare',
    vars: ['v', 'n', 'x', 'i', 'gasit'],
    steps: []
  },
  {
    id: 'cautare-binara',
    name: 'Căutare binară',
    description: 'Caută un element x în vector sortat. O(log n).',
    category: 'Căutare',
    vars: ['v', 'n', 'x', 'st', 'dr', 'mij'],
    steps: []
  },
  {
    id: 'factorial',
    name: 'Factorial iterativ',
    description: 'Calculează n! iterativ. O(n).',
    category: 'Matematic',
    vars: ['n', 'i', 'rez'],
    steps: []
  },
  {
    id: 'max-vector',
    name: 'Maxim din vector',
    description: 'Găsește valoarea maximă dintr-un vector. O(n).',
    category: 'Vectori',
    vars: ['v', 'n', 'i', 'maxim'],
    steps: []
  },
  {
    id: 'suma-cifre',
    name: 'Suma cifrelor',
    description: 'Calculează suma cifrelor unui număr. O(log n).',
    category: 'Matematic',
    vars: ['n', 'suma', 'cifra'],
    steps: []
  },
];
---
<BaseLayout
  title="Simulator Trasare Algoritm | InfoLiceu"
  description="Vizualizează execuția algoritmilor pas cu pas — exact ca la Subiectul I BAC. Urmărește valorile variabilelor la fiecare iterație."
  bodyClass="has-sidebar"
>
  <Header />
  <Sidebar />

  <div class="app-shell">
    <div class="app-content" id="main-content">

      <!-- Hero -->
      <div class="chapter-hero" style="--hero-gradient: linear-gradient(135deg,#1e40af 0%,#7c3aed 100%);">
        <a href={`${base}/`} class="chapter-hero-back">← Înapoi acasă</a>
        <h1><span aria-hidden="true">🔍</span> Simulator Trasare Algoritm</h1>
        <p>Urmărește execuția algoritmilor <strong>pas cu pas</strong> — exact ca la Subiectul I BAC Informatică. Selectează un algoritm, introdu datele și apasă „Pas următor".</p>
        <div class="hero-badges" style="margin-top:1rem">
          <span class="hero-badge">📋 6 algoritmi</span>
          <span class="hero-badge">🎯 Antrenament BAC</span>
          <span class="hero-badge">📊 Variabile vizuale</span>
        </div>
      </div>

      <div class="wrapper" style="max-width:960px;">

        <!-- Algorithm selector -->
        <div class="tracer-card">
          <h2 class="tracer-section-title">① Alege algoritmul</h2>
          <div class="algo-grid" id="algo-grid">
            <!-- filled by JS -->
          </div>
        </div>

        <!-- Input -->
        <div class="tracer-card" id="input-card" style="display:none">
          <h2 class="tracer-section-title">② Introdu datele de intrare</h2>
          <div id="input-area"></div>
          <button class="tracer-btn tracer-btn--primary" id="start-btn">▶ Pornește simularea</button>
        </div>

        <!-- Code + State viewer -->
        <div class="tracer-card" id="tracer-card" style="display:none">
          <h2 class="tracer-section-title">③ Execuție pas cu pas</h2>
          <div class="tracer-layout">
            <!-- Code panel -->
            <div class="tracer-code-panel">
              <div class="tracer-code-title">Cod C++ (linia curentă evidențiată)</div>
              <pre class="tracer-code" id="tracer-code"></pre>
            </div>
            <!-- Variables panel -->
            <div class="tracer-vars-panel">
              <div class="tracer-code-title">Variabile</div>
              <div class="tracer-vars" id="tracer-vars"></div>
              <div class="tracer-explanation" id="tracer-exp"></div>
            </div>
          </div>
          <!-- Array visualizer -->
          <div id="array-viz-wrap" style="display:none">
            <div class="tracer-code-title" style="margin-top:1rem">Vector v</div>
            <div class="array-viz" id="array-viz"></div>
          </div>
          <!-- Controls -->
          <div class="tracer-controls">
            <button class="tracer-btn tracer-btn--secondary" id="prev-btn" disabled>← Anterior</button>
            <span class="tracer-step-info" id="step-info">Pas 0 / 0</span>
            <button class="tracer-btn tracer-btn--primary" id="next-btn">Următor →</button>
            <button class="tracer-btn tracer-btn--ghost" id="restart-btn">↺ Reia</button>
          </div>
        </div>

        <!-- Done panel -->
        <div class="tracer-card tracer-done" id="done-card" style="display:none">
          <div style="font-size:2.5rem;margin-bottom:0.5rem" aria-hidden="true">✅</div>
          <h3>Algoritm finalizat!</h3>
          <p id="done-msg"></p>
          <button class="tracer-btn tracer-btn--primary" id="new-algo-btn">Alege alt algoritm</button>
        </div>

      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script id="tracer-algos-data" type="application/json" set:html={JSON.stringify(algorithms)}></script>

<script is:inline>
(function() {
  /* ── Algorithm definitions ── */
  var ALGOS = {
    'bubble-sort': {
      name: 'Bubble Sort',
      codeLines: [
        'void bubbleSort(int v[], int n) {',
        '  bool ok;',
        '  do {',
        '    ok = true;',
        '    for (int i = 0; i < n-1; i++) {',
        '      if (v[i] > v[i+1]) {',
        '        int aux = v[i];',
        '        v[i] = v[i+1];',
        '        v[i+1] = aux;',
        '        ok = false;',
        '      }',
        '    }',
        '  } while (!ok);',
        '}',
      ],
      inputHTML: '<label>Vector (numere separate prin spații):<br><input id="inp-v" type="text" placeholder="ex: 5 3 8 1 4" class="tracer-input" value="5 3 8 1 4"></label>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var steps = [];
        var ok;
        steps.push({ line: 0, vars: { v: v.slice(), n: n }, exp: 'Se apelează bubbleSort cu vectorul inițial.', arr: v.slice() });
        do {
          ok = true;
          steps.push({ line: 3, vars: { v: v.slice(), n: n, ok: true }, exp: 'Resetăm ok = true. Dacă nu se face nicio interschimbare, vectorul e sortat.', arr: v.slice() });
          for (var i = 0; i < n - 1; i++) {
            steps.push({ line: 4, vars: { v: v.slice(), n: n, ok: ok, i: i }, exp: 'Parcurgem elementele de la 0 la n-2. i = ' + i, arr: v.slice(), highlight: [i, i+1] });
            steps.push({ line: 5, vars: { v: v.slice(), n: n, ok: ok, i: i }, exp: 'Comparăm v[' + i + ']=' + v[i] + ' cu v[' + (i+1) + ']=' + v[i+1] + '. Condiție: ' + v[i] + ' > ' + v[i+1] + ' = ' + (v[i] > v[i+1]), arr: v.slice(), highlight: [i, i+1] });
            if (v[i] > v[i+1]) {
              var aux = v[i];
              steps.push({ line: 6, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'aux = v[' + i + '] = ' + aux + '. Salvăm valoarea pentru interschimbare.', arr: v.slice(), highlight: [i, i+1] });
              v[i] = v[i+1];
              steps.push({ line: 7, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'v[' + i + '] = v[' + (i+1) + '] = ' + v[i] + '. Prima parte a interschimbării.', arr: v.slice(), highlight: [i, i+1] });
              v[i+1] = aux;
              steps.push({ line: 8, vars: { v: v.slice(), n: n, ok: ok, i: i, aux: aux }, exp: 'v[' + (i+1) + '] = aux = ' + aux + '. Interschimbare completă!', arr: v.slice(), highlight: [i, i+1] });
              ok = false;
              steps.push({ line: 9, vars: { v: v.slice(), n: n, ok: false, i: i, aux: aux }, exp: 'ok = false — s-a făcut o interschimbare, deci mai trebuie o trecere.', arr: v.slice() });
            }
          }
          steps.push({ line: 12, vars: { v: v.slice(), n: n, ok: ok }, exp: 'Trecere completă. ok = ' + ok + '. ' + (ok ? 'Vectorul este sortat!' : 'Mai trebuie o trecere.'), arr: v.slice() });
        } while (!ok);
        steps.push({ line: 13, vars: { v: v.slice(), n: n }, exp: '✅ Algoritm finalizat! Vector sortat: [' + v.join(', ') + ']', arr: v.slice(), done: true });
        return { steps: steps, result: 'Vector sortat: [' + v.join(', ') + ']' };
      }
    },
    'cautare-liniara': {
      name: 'Căutare liniară',
      codeLines: [
        'int cautareLiniara(int v[], int n, int x) {',
        '  for (int i = 0; i < n; i++) {',
        '    if (v[i] == x) {',
        '      return i;  // găsit la poziția i',
        '    }',
        '  }',
        '  return -1;  // negăsit',
        '}',
      ],
      inputHTML: '<label>Vector:<br><input id="inp-v" type="text" placeholder="ex: 5 3 8 1 4" class="tracer-input" value="5 3 8 1 4"></label><br><label style="margin-top:0.5rem;display:block">Caută x:<br><input id="inp-x" type="number" class="tracer-input" value="8"></label>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var x = parseInt(inputs['inp-x']);
        var steps = [];
        steps.push({ line: 0, vars: { v: v.slice(), n: n, x: x }, exp: 'Se apelează căutarea pentru x=' + x, arr: v.slice() });
        for (var i = 0; i < n; i++) {
          steps.push({ line: 1, vars: { v: v.slice(), n: n, x: x, i: i }, exp: 'Parcurgere: i=' + i, arr: v.slice(), highlight: [i] });
          steps.push({ line: 2, vars: { v: v.slice(), n: n, x: x, i: i }, exp: 'v[' + i + ']=' + v[i] + ' == x=' + x + '? ' + (v[i] === x), arr: v.slice(), highlight: [i] });
          if (v[i] === x) {
            steps.push({ line: 3, vars: { v: v.slice(), n: n, x: x, i: i }, exp: '✅ Element găsit la poziția ' + i + '!', arr: v.slice(), highlight: [i], done: true });
            return { steps: steps, result: 'Elementul ' + x + ' a fost găsit la poziția ' + i };
          }
        }
        steps.push({ line: 6, vars: { v: v.slice(), n: n, x: x, i: n }, exp: '❌ Elementul ' + x + ' nu există în vector. Se returnează -1.', arr: v.slice(), done: true });
        return { steps: steps, result: 'Elementul ' + x + ' NU a fost găsit (return -1)' };
      }
    },
    'cautare-binara': {
      name: 'Căutare binară',
      codeLines: [
        'int cautareBinara(int v[], int n, int x) {',
        '  int st = 0, dr = n - 1;',
        '  while (st <= dr) {',
        '    int mij = (st + dr) / 2;',
        '    if (v[mij] == x) return mij;',
        '    if (v[mij] < x) st = mij + 1;',
        '    else             dr = mij - 1;',
        '  }',
        '  return -1;',
        '}',
      ],
      inputHTML: '<label>Vector SORTAT:<br><input id="inp-v" type="text" placeholder="ex: 1 3 5 8 12 17" class="tracer-input" value="1 3 5 8 12 17"></label><br><label style="margin-top:0.5rem;display:block">Caută x:<br><input id="inp-x" type="number" class="tracer-input" value="8"></label>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var x = parseInt(inputs['inp-x']);
        var steps = [];
        var st = 0, dr = n - 1;
        steps.push({ line: 1, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr }, exp: 'Inițializăm st=0, dr=' + dr, arr: v.slice(), highlight: [st, dr] });
        while (st <= dr) {
          steps.push({ line: 2, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr }, exp: 'st=' + st + ' <= dr=' + dr + '? ' + (st <= dr), arr: v.slice(), highlight: [st, dr] });
          var mij = Math.floor((st + dr) / 2);
          steps.push({ line: 3, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: mij }, exp: 'mij = (' + st + ' + ' + dr + ') / 2 = ' + mij + '. v[mij] = ' + v[mij], arr: v.slice(), highlight: [mij] });
          if (v[mij] === x) {
            steps.push({ line: 4, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: mij }, exp: '✅ v[' + mij + ']=' + v[mij] + ' == x=' + x + '. Găsit la poziția ' + mij + '!', arr: v.slice(), highlight: [mij], done: true });
            return { steps: steps, result: 'Elementul ' + x + ' găsit la poziția ' + mij };
          }
          if (v[mij] < x) {
            steps.push({ line: 5, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: mij }, exp: 'v[' + mij + ']=' + v[mij] + ' < x=' + x + '. Căutăm în dreapta: st=' + (mij+1), arr: v.slice() });
            st = mij + 1;
          } else {
            steps.push({ line: 6, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr, mij: mij }, exp: 'v[' + mij + ']=' + v[mij] + ' > x=' + x + '. Căutăm în stânga: dr=' + (mij-1), arr: v.slice() });
            dr = mij - 1;
          }
        }
        steps.push({ line: 8, vars: { v: v.slice(), n: n, x: x, st: st, dr: dr }, exp: '❌ st=' + st + ' > dr=' + dr + '. Elementul ' + x + ' nu există.', arr: v.slice(), done: true });
        return { steps: steps, result: 'Elementul ' + x + ' NU a fost găsit (return -1)' };
      }
    },
    'factorial': {
      name: 'Factorial iterativ',
      codeLines: [
        'long long factorial(int n) {',
        '  long long rez = 1;',
        '  for (int i = 2; i <= n; i++) {',
        '    rez = rez * i;',
        '  }',
        '  return rez;',
        '}',
      ],
      inputHTML: '<label>n (max 12 pentru int):<br><input id="inp-n" type="number" class="tracer-input" value="5" min="0" max="12"></label>',
      run: function(inputs) {
        var n = parseInt(inputs['inp-n']);
        var rez = 1;
        var steps = [];
        steps.push({ line: 1, vars: { n: n, rez: 1 }, exp: 'Inițializăm rez = 1.' });
        for (var i = 2; i <= n; i++) {
          steps.push({ line: 2, vars: { n: n, rez: rez, i: i }, exp: 'i=' + i + ' <= n=' + n + '? ' + (i <= n) });
          var prev = rez;
          rez = rez * i;
          steps.push({ line: 3, vars: { n: n, rez: rez, i: i }, exp: 'rez = ' + prev + ' × ' + i + ' = ' + rez });
        }
        steps.push({ line: 5, vars: { n: n, rez: rez }, exp: '✅ ' + n + '! = ' + rez, done: true });
        return { steps: steps, result: n + '! = ' + rez };
      }
    },
    'max-vector': {
      name: 'Maxim din vector',
      codeLines: [
        'int maxim(int v[], int n) {',
        '  int maxim = v[0];',
        '  for (int i = 1; i < n; i++) {',
        '    if (v[i] > maxim) {',
        '      maxim = v[i];',
        '    }',
        '  }',
        '  return maxim;',
        '}',
      ],
      inputHTML: '<label>Vector:<br><input id="inp-v" type="text" placeholder="ex: 5 3 8 1 4" class="tracer-input" value="5 3 8 1 4"></label>',
      run: function(inputs) {
        var v = inputs['inp-v'].trim().split(/\s+/).map(Number);
        var n = v.length;
        var mx = v[0];
        var steps = [];
        steps.push({ line: 1, vars: { v: v.slice(), n: n, maxim: mx }, exp: 'Inițializăm maxim = v[0] = ' + mx, arr: v.slice(), highlight: [0] });
        for (var i = 1; i < n; i++) {
          steps.push({ line: 2, vars: { v: v.slice(), n: n, maxim: mx, i: i }, exp: 'i=' + i, arr: v.slice(), highlight: [i] });
          steps.push({ line: 3, vars: { v: v.slice(), n: n, maxim: mx, i: i }, exp: 'v[' + i + ']=' + v[i] + ' > maxim=' + mx + '? ' + (v[i] > mx), arr: v.slice(), highlight: [i] });
          if (v[i] > mx) {
            mx = v[i];
            steps.push({ line: 4, vars: { v: v.slice(), n: n, maxim: mx, i: i }, exp: 'Nou maxim: maxim = ' + mx, arr: v.slice(), highlight: [i] });
          }
        }
        steps.push({ line: 7, vars: { v: v.slice(), n: n, maxim: mx }, exp: '✅ Maximul este ' + mx, arr: v.slice(), done: true });
        return { steps: steps, result: 'Maximul din vector este ' + mx };
      }
    },
    'suma-cifre': {
      name: 'Suma cifrelor',
      codeLines: [
        'int sumaCifre(int n) {',
        '  int suma = 0, cifra;',
        '  while (n > 0) {',
        '    cifra = n % 10;',
        '    suma = suma + cifra;',
        '    n = n / 10;',
        '  }',
        '  return suma;',
        '}',
      ],
      inputHTML: '<label>n (număr întreg pozitiv):<br><input id="inp-n" type="number" class="tracer-input" value="1234" min="1"></label>',
      run: function(inputs) {
        var n = parseInt(inputs['inp-n']);
        var orig = n;
        var suma = 0;
        var steps = [];
        steps.push({ line: 1, vars: { n: n, suma: 0 }, exp: 'Inițializăm suma = 0.' });
        while (n > 0) {
          steps.push({ line: 2, vars: { n: n, suma: suma }, exp: 'n=' + n + ' > 0? Da. Continuăm.' });
          var cifra = n % 10;
          steps.push({ line: 3, vars: { n: n, suma: suma, cifra: cifra }, exp: 'cifra = n % 10 = ' + n + ' % 10 = ' + cifra });
          suma += cifra;
          steps.push({ line: 4, vars: { n: n, suma: suma, cifra: cifra }, exp: 'suma = ' + (suma - cifra) + ' + ' + cifra + ' = ' + suma });
          n = Math.floor(n / 10);
          steps.push({ line: 5, vars: { n: n, suma: suma, cifra: cifra }, exp: 'n = n / 10 = ' + n + ' (eliminăm ultima cifră)' });
        }
        steps.push({ line: 7, vars: { n: n, suma: suma }, exp: '✅ Suma cifrelor lui ' + orig + ' = ' + suma, done: true });
        return { steps: steps, result: 'Suma cifrelor lui ' + orig + ' = ' + suma };
      }
    }
  };

  /* ── State ── */
  var currentAlgo = null;
  var currentSteps = [];
  var currentStep = -1;

  /* ── Elements ── */
  function el(id) { return document.getElementById(id); }
  var algoGrid   = el('algo-grid');
  var inputCard  = el('input-card');
  var inputArea  = el('input-area');
  var tracerCard = el('tracer-card');
  var doneCard   = el('done-card');
  var codeEl     = el('tracer-code');
  var varsEl     = el('tracer-vars');
  var expEl      = el('tracer-exp');
  var stepInfo   = el('step-info');
  var prevBtn    = el('prev-btn');
  var nextBtn    = el('next-btn');
  var arrayViz   = el('array-viz');
  var arrayWrap  = el('array-viz-wrap');

  /* ── Build algo grid ── */
  var algosData = JSON.parse(el('tracer-algos-data').textContent);
  algosData.forEach(function(algo) {
    var def = ALGOS[algo.id];
    if (!def) return;
    var btn = document.createElement('button');
    btn.className = 'algo-btn';
    btn.innerHTML =
      '<strong>' + def.name + '</strong>' +
      '<span class="algo-cat">' + algo.category + '</span>' +
      '<small>' + algo.description + '</small>';
    btn.addEventListener('click', function() {
      selectAlgo(algo.id);
    });
    algoGrid.appendChild(btn);
  });

  function selectAlgo(id) {
    currentAlgo = id;
    var def = ALGOS[id];
    // Highlight selected
    algoGrid.querySelectorAll('.algo-btn').forEach(function(b) { b.classList.remove('selected'); });
    algoGrid.querySelectorAll('.algo-btn').forEach(function(b) {
      if (b.querySelector('strong').textContent === def.name) b.classList.add('selected');
    });
    // Show input
    inputArea.innerHTML = def.inputHTML;
    inputCard.style.display = '';
    tracerCard.style.display = 'none';
    doneCard.style.display = 'none';
  }

  el('start-btn').addEventListener('click', function() {
    var def = ALGOS[currentAlgo];
    // Collect inputs
    var inputs = {};
    inputArea.querySelectorAll('input').forEach(function(inp) {
      inputs[inp.id] = inp.value;
    });
    var result = def.run(inputs);
    currentSteps = result.steps;
    currentStep = 0;
    tracerCard.style.display = '';
    doneCard.style.display = 'none';
    // Render code
    codeEl.innerHTML = def.codeLines.map(function(line, i) {
      return '<span class="code-line" id="cl-' + i + '">' + escapeHtml(line) + '</span>';
    }).join('\n');
    renderStep();
  });

  el('next-btn').addEventListener('click', function() {
    if (currentStep < currentSteps.length - 1) {
      currentStep++;
      renderStep();
    }
  });

  el('prev-btn').addEventListener('click', function() {
    if (currentStep > 0) {
      currentStep--;
      renderStep();
    }
  });

  el('restart-btn').addEventListener('click', function() {
    currentStep = 0;
    renderStep();
    tracerCard.style.display = '';
    doneCard.style.display = 'none';
  });

  el('new-algo-btn').addEventListener('click', function() {
    doneCard.style.display = 'none';
    tracerCard.style.display = 'none';
    inputCard.style.display = 'none';
    algoGrid.querySelectorAll('.algo-btn').forEach(function(b) { b.classList.remove('selected'); });
    currentAlgo = null;
  });

  function renderStep() {
    var step = currentSteps[currentStep];
    // Highlight current code line
    var lines = codeEl.querySelectorAll('.code-line');
    lines.forEach(function(l) { l.classList.remove('active-line'); });
    if (step.line !== undefined && lines[step.line]) {
      lines[step.line].classList.add('active-line');
      lines[step.line].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
    // Render vars
    varsEl.innerHTML = '';
    Object.keys(step.vars).forEach(function(key) {
      var val = step.vars[key];
      if (Array.isArray(val)) return; // skip array, shown visually
      var div = document.createElement('div');
      div.className = 'var-row';
      div.innerHTML = '<span class="var-name">' + key + '</span><span class="var-val">' + val + '</span>';
      varsEl.appendChild(div);
    });
    // Explanation
    expEl.textContent = step.exp || '';
    // Array visualizer
    if (step.arr) {
      arrayWrap.style.display = '';
      arrayViz.innerHTML = step.arr.map(function(v, i) {
        var cls = 'arr-cell';
        if (step.highlight && step.highlight.indexOf(i) !== -1) cls += ' arr-cell--active';
        return '<div class="' + cls + '"><span class="arr-val">' + v + '</span><span class="arr-idx">[' + i + ']</span></div>';
      }).join('');
    } else {
      arrayWrap.style.display = 'none';
    }
    // Step info
    stepInfo.textContent = 'Pas ' + (currentStep + 1) + ' / ' + currentSteps.length;
    prevBtn.disabled = currentStep === 0;
    nextBtn.disabled = currentStep === currentSteps.length - 1;
    // Done?
    if (step.done) {
      el('done-msg').textContent = currentSteps[currentSteps.length - 1].exp;
      // Show done after last step
      if (currentStep === currentSteps.length - 1) {
        doneCard.style.display = '';
      }
    }
  }

  function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
})();
</script>

