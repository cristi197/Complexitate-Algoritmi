            </div>
          </div>
        </div>
      `;
    }

    // ── Pseudocode problem ────────────────────────────────────────
    function renderPseudocodeProblem(p, varNr) {
      var subQ = (p.subQuestions || []).map(function(q) {
        return '<div class="v09-sub-q">' +
          '<span class="v09-sub-lbl">' + q.id + ')<\/span>' +
          '<span>' + escHtml(q.text || '') + '<\/span>' +
          (q.points ? '<span class="v09-sub-pts">' + q.points + 'p.<\/span>' : '') +
        '<\/div>';
      }).join('');
      var pcHl = highlightPseudocode(p.pseudocode || '');
      return '<div class="v09-problem">' +
        '<div class="v09-prob-hdr">' +
          '<span class="v09-prob-nr">Nr. ' + p.nr + '<\/span>' +
          '<span class="v09-prob-type v09-prob-type--pseudo">Pseudocod<\/span>' +
          '<span class="v09-prob-pts">' + (p.points || 26) + 'p.<\/span>' +
        '<\/div>' +
        (p.intro ? '<div class="v09-prob-intro">' + escHtml(p.intro) + '<\/div>' : '') +
        (pcHl ?
          '<div class="v09-pseudo-wrap">' +
            '<div class="v09-pseudo-hdr">' +
              '<span>PSEUDOCOD<\/span>' +
              '<span style="color:#60a5fa;font-size:.7rem">\u00C5\u00A0=\u00A0\u2190 (atribuire) \u00B7 \u250C\u2502\u2514 = blocuri<\/span>' +
            '<\/div>' +
            '<code class="v09-pseudo-code">' + pcHl + '<\/code>' +
          '<\/div>'
        : '') +
        (subQ ? '<div class="v09-sub-qs">' + subQ + '<\/div>' : '') +
        renderSandboxEvaluator(varNr, p.nr, 'pseudocode') +
      '<\/div>';
    }

    // ── Recursiv problem ──────────────────────────────────────────
    function renderRecursivProblem(p, varNr) {
      var code = p.code || '';
      var parts = code.split(/\/\/C\+\+/i);
      var cCode   = parts[0].replace(/^\/\/C\s*/i, '').trim();
      var cppCode = (parts[1] || '').trim();
      var uid = 'rp' + p.nr;
      var codeHtml = '';
      if (cCode && cppCode) {
        codeHtml = '<div class="v09-code-wrap">' +
          '<div class="v09-code-tabs">' +
            '<button class="v09-code-tab active" data-pane="c-' + uid + '">C<\/button>' +
            '<button class="v09-code-tab" data-pane="cpp-' + uid + '">C++<\/button>' +
          '<\/div>' +
          '<div class="v09-code-pane active" id="c-' + uid + '">' + escHtml(cCode) + '<\/div>' +
          '<div class="v09-code-pane" id="cpp-' + uid + '">' + escHtml(cppCode) + '<\/div>' +
        '<\/div>';
      } else if (cCode) {
        codeHtml = '<div class="v09-code-wrap"><div class="v09-code-pane active">' + escHtml(cCode) + '<\/div><\/div>';
      }
      return '<div class="v09-problem">' +
        '<div class="v09-prob-hdr">' +
          '<span class="v09-prob-nr">Nr. ' + p.nr + '<\/span>' +
          '<span class="v09-prob-type v09-prob-type--recurs">Recursivitate<\/span>' +
          '<span class="v09-prob-pts">' + (p.points || 6) + 'p.<\/span>' +
        '<\/div>' +
        (p.intro ? '<div class="v09-prob-intro">' + escHtml(p.intro) + '<\/div>' : '') +
        codeHtml +
        renderSandboxEvaluator(varNr, p.nr, 'recursivitate') +
      '<\/div>';
    }

    // ── Generic problem ───────────────────────────────────────────
    function renderProblem(p, varNr) {
      var TYPES = {
        fisier:  ['Fi\u015Fiere', 'v09-prob-type--fisier'],
        program: ['Program C/C++', 'v09-prob-type--prog'],
        written: ['Problem\u0103', 'v09-prob-type--written']
      };
      var t = TYPES[p.type] || ['Problem\u0103', 'v09-prob-type--written'];
      return '<div class="v09-problem">' +
        '<div class="v09-prob-hdr">' +
          '<span class="v09-prob-nr">Nr. ' + p.nr + '<\/span>' +
          '<span class="v09-prob-type ' + t[1] + '">' + t[0] + '<\/span>' +
          '<span class="v09-prob-pts">' + (p.points || 10) + 'p.<\/span>' +
        '<\/div>' +
        '<div class="v09-prob-text">' + escHtml(p.text || '') + '<\/div>' +
        renderSandboxEvaluator(varNr, p.nr, p.type) +
      '<\/div>';
    }

    // ── Subprogram problem ────────────────────────────────────────
    function renderSubprogramProblem(p, varNr) {
      var subQ = (p.subQuestions || []).map(function(q) {
        return '<div class="v09-sub-q">' +
          '<span class="v09-sub-lbl">' + q.id + ')<\/span>' +
          '<span>' + escHtml(q.text || '') + '<\/span>' +
          (q.points ? '<span class="v09-sub-pts">' + q.points + 'p.<\/span>' : '') +
        '<\/div>';
      }).join('');
      return '<div class="v09-problem">' +
        '<div class="v09-prob-hdr">' +
          '<span class="v09-prob-nr">Nr. ' + p.nr + '<\/span>' +
          '<span class="v09-prob-type v09-prob-type--subprog">Subprogram<\/span>' +
          '<span class="v09-prob-pts">' + (p.points || 10) + 'p.<\/span>' +
        '<\/div>' +
        (p.intro ? '<div class="v09-prob-intro">' + escHtml(p.intro) + '<\/div>' : '') +
        (subQ ? '<div class="v09-sub-qs">' + subQ + '<\/div>' : '') +
        renderSandboxEvaluator(varNr, p.nr, 'subprog') +
      '<\/div>';
    }

    // ── Grile interaction ─────────────────────────────────────────
    function bindGrileInteraction(container) {
      container.querySelectorAll('.v09-grila').forEach(function(gEl) {
        var gId = gEl.id;
        var opts = gEl.querySelectorAll('.v09-option');
        var footer = document.getElementById(gId + '-footer').firstElementChild;
        opts.forEach(function(opt) {
          opt.addEventListener('click', function() {
            opts.forEach(function(o) { o.classList.remove('v09-sel'); });
            opt.classList.add('v09-sel');
            selectedAnswers[gId] = opt.dataset.opt;
            if (footer) footer.textContent = 'R\u0103spuns selectat: ' + opt.dataset.opt.toUpperCase() + '.';
            updateSubjectScore(gEl);
          });
        });
      });
    }

    function updateSubjectScore(gEl) {
      var body = gEl.closest('.v09-subject-body');
      if (!body) return;
      var grile = body.querySelectorAll('.v09-grila');
      var sel = body.querySelectorAll('.v09-option.v09-sel').length;
      var scoreEl = document.getElementById('score-' + body.id);
      if (scoreEl && sel > 0) {
        scoreEl.style.display = 'inline-block';
        scoreEl.textContent = sel + '/' + grile.length + ' selectate';
      }
    }

    // ── Code tabs ─────────────────────────────────────────────────
    function bindCodeTabs(container) {
      container.querySelectorAll('.v09-code-tabs').forEach(function(tabsEl) {
        var wrap = tabsEl.parentElement;
        tabsEl.querySelectorAll('.v09-code-tab').forEach(function(tab) {
          tab.addEventListener('click', function() {
            tabsEl.querySelectorAll('.v09-code-tab').forEach(function(t) { t.classList.remove('active'); });
            tab.classList.add('active');
            var paneId = tab.dataset.pane;
            wrap.querySelectorAll('.v09-code-pane').forEach(function(pane) {
              pane.classList.toggle('active', pane.id === paneId);
            });
          });
        });
      });
    }

    // ── Toggle subject body ───────────────────────────────────────
    window.v09Toggle = function(hdr) {
      var body = hdr.nextElementSibling;
      var icon = hdr.querySelector('.v09-toggle-icon');
      if (body) body.classList.toggle('v09-body-collapsed');
      if (icon) icon.classList.toggle('rotated');
    };

    // ── Navigation ────────────────────────────────────────────────
    document.getElementById('btnBackGrid').addEventListener('click', function() {
      document.getElementById('variantView').style.display = 'none';
      document.getElementById('gridView').style.display = '';
      buildGrid();
    });
    document.getElementById('btnPrev').addEventListener('click', function() {
      if (currentVariant > 1) openVariant(currentVariant - 1);
    });
    document.getElementById('btnNext').addEventListener('click', function() {
      if (currentVariant < 100) openVariant(currentVariant + 1);
    });
    document.addEventListener('keydown', function(e) {
      if (document.getElementById('variantView').style.display === 'none') return;
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
      if (e.key === 'ArrowLeft') { if (currentVariant > 1) openVariant(currentVariant - 1); }
      else if (e.key === 'ArrowRight') { if (currentVariant < 100) openVariant(currentVariant + 1); }
      else if (e.key === 'Escape') { document.getElementById('btnBackGrid').click(); }
    });
    document.getElementById('btnGoVar').addEventListener('click', function() {
      var v = parseInt(document.getElementById('varSearch').value);
      if (v >= 1 && v <= 100) openVariant(v);
    });
    document.getElementById('varSearch').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') document.getElementById('btnGoVar').click();
    });

    // ── Format pseudocode ────────────────────────────────────────
    function formatPseudocode(raw) {
      if (!raw) return '';
      let s = raw.replace(/\u00C5/g, '\u2190'); // Å → ←
      s = s.replace(/\s+/g, ' ');
      s = s.replace(/\s*([\u250C\u2502\u2514\u25A0])/g, '\n$1');
      s = s.replace(/\n+/g, '\n');
      return s.trim();
    }

    var PC_KW = ['cat timp','c\u00e2t timp','executa','execut\u0103','daca','dac\u0103',
      'atunci','altfel','pentru','repeta','repet\u0103','pana c\u00e2nd','p\u00e2n\u0103 c\u00e2nd','pana cand'];
    var PC_CMD = ['citeste','cite\u015fte','cite\u0219te','scrie'];

    function highlightPseudocode(raw) {
      var s = escHtml(formatPseudocode(raw));
      s = s.replace(/\u2190/g, '<span class="v09-pc-op">\u2190<\/span>');
      s = s.replace(/([\u250C\u2502\u2514\u25A0])/g, '<span class="v09-pc-box">$1<\/span>');
      PC_KW.forEach(function(kw) {
        var re = new RegExp('\\b' + kw.replace(/\s+/, '\\s+') + '\\b', 'gi');
        s = s.replace(re, function(m) { return '<span class="v09-pc-kw">' + m + '<\/span>'; });
      });
      PC_CMD.forEach(function(cmd) {
        var re = new RegExp('\\b' + cmd + '\\b', 'gi');
        s = s.replace(re, function(m) { return '<span class="v09-pc-str">' + m + '<\/span>'; });
      });
      return s;
    }

    // ── Helpers ───────────────────────────────────────────────────
    function escHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }
  </script>
</BaseLayout>
