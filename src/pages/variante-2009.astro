        </button>
        <div class="v09-sandbox-pane">
          <div class="v09-sandbox-layout">
            <!-- Left panel: Code edit -->
            <div>
              <div class="v09-editor-header">
                <span class="v09-editor-title">💻 C++ Sandbox Compiler (Offline)</span>
              </div>
              <textarea class="v09-editor-textarea" placeholder="// Scrie codul tău C++ aici..." spellcheck="false"></textarea>
              <div class="v09-score-bar-wrap">
                <span style="font-size:.75rem;font-weight:700;color:#cbd5e1;">Evaluare:</span>
                <span class="v09-score-lbl" style="font-size:0.75rem;font-weight:700;color:#10b981;">0 / 100 puncte</span>
              </div>
              <div class="v09-score-bar-bg">
